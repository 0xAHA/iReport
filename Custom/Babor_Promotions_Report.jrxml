<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Babor_Promotions_Report" pageWidth="792" pageHeight="612" columnWidth="555" leftMargin="36" rightMargin="36" topMargin="36" bottomMargin="36" uuid="220cb077-82d6-42bb-beee-07b72495fbfe">
	<property name="ireport.zoom" value="1.7715610000000013"/>
	<property name="ireport.x" value="295"/>
	<property name="ireport.y" value="0"/>
	<parameter name="dateRange1" class="java.util.Date" isForPrompting="false">
		<parameterDescription><![CDATA[All]]></parameterDescription>
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRange2" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
  base.soNum,
  base.customerName,
  base.productNum,
  base.productDescription,
  base.listPrice,
  base.qty,
  base.totalPrice,
  base.discAmt,
  base.nettPrice,
  base.discountPercent,
  base.promoCode
FROM (
  SELECT
    so.num AS soNum,
    c.name AS customerName,
    prod.num AS productNum,
    COALESCE(prod.description, pt.description) AS productDescription,
    prod.price AS listPrice,
    psi.qty AS qty,
    prod.price * psi.qty AS totalPrice,
    prod.price * psi.qty - psi.totalPrice AS discAmt,
    psi.totalPrice AS nettPrice,
    CASE WHEN prod.price > 0 AND psi.qty != 0
      THEN (prod.price * psi.qty - psi.totalPrice) / (prod.price * psi.qty) * 100
      ELSE 0
    END AS discountPercent,
    CustomFieldByName(si.customfields, 'Promo Code') AS promoCode
  FROM postsoitem psi
  JOIN postso ps ON ps.id = psi.postSoId
  JOIN so ON so.id = ps.soId
  JOIN soitem si ON si.id = psi.soItemId
  JOIN customer c ON c.id = so.customerId
  JOIN product prod ON prod.id = si.productId
  JOIN part pt ON pt.id = prod.partId
  WHERE ($P{dateRange1} IS NULL OR psi.dateCreated >= $P{dateRange1})
    AND ($P{dateRange2} IS NULL OR psi.dateCreated < DATE_ADD($P{dateRange2}, INTERVAL 1 DAY))
) base
WHERE base.promoCode IS NOT NULL
  AND base.promoCode != ''
ORDER BY base.promoCode, base.productNum]]>
	</queryString>
