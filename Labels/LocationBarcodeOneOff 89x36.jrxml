<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="LocationBarcodeOneOff 89x36" pageWidth="252" pageHeight="102" orientation="Landscape" whenNoDataType="AllSectionsNoDetail" columnWidth="246" leftMargin="3" rightMargin="3" topMargin="3" bottomMargin="3" uuid="920355eb-1779-4ae0-84aa-8481a2c71a7f">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="0"/>
