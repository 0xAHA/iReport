	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<style name="default" isDefault="true" fontName="SansSerif" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false" pdfFontName="Helvetica" pdfEncoding="Cp1252" isPdfEmbedded="false"/>
	<style name="barcode" hAlign="Center" vAlign="Middle"/>
	<parameter name="locationGroupID" class="java.lang.String">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="locationID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT location.Name AS Name, location.description AS Description, tag.num AS Tag,
    locationGroup.Name AS LG
FROM Tag, Location, locationGroup
WHERE tag.typeID = 10
  AND location.ID = tag.locationID
  AND location.locationGroupID = locationGroup.ID
  AND Location.ID LIKE $P{locationID}
  AND locationgroup.id IN ($P!{locationGroupID})
  AND location.activeflag = 1
ORDER BY locationGroup.Name, location.Name]]>
	</queryString>
	<field name="NAME" class="java.lang.String"/>
	<field name="DESCRIPTION" class="java.lang.String"/>
	<field name="TAG" class="java.lang.Integer"/>
	<field name="LG" class="java.lang.String"/>
	<background>
		<band/>
	</background>
