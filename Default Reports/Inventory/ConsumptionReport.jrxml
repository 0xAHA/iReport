		<queryString>
			<![CDATA[SELECT	part.num as part, part.description, SUM(il.changeqty * -1) AS qtyconsumed, uom.code AS uom,
	SUM(il.cost * (il.changeqty * -1)) AS totalcost

FROM 	inventorylog il
	LEFT OUTER JOIN part ON il.partid = part.id
	LEFT OUTER JOIN location ON il.beglocationid = location.id
	LEFT OUTER JOIN sysuser ON il.userid = sysuser.id
	LEFT OUTER JOIN locationgroup lg ON location.locationgroupid = lg.id
	LEFT OUTER JOIN uom on part.uomid = uom.id
	LEFT OUTER JOIN post ON il.recordid = post.id AND il.tableid = -1407594912

WHERE	il.typeid = 67 /*Type 67 is Adjust Scrap*/
AND 	$P!{cbApplyDateFilter} BETWEEN $P{dateRange1} AND DATE_SUB($P{dateRange2}, INTERVAL 1 SECOND)
AND 	part.activeflag IN ($P{ckShowActive}, $P{ckShowInactive})
AND 	sysuser.username LIKE $P{salesPersonUser}
AND 	part.num LIKE $P{partNum}
AND 	lg.id IN ($P!{locationGroupID})
AND 	location.id LIKE $P{locationID}
AND	COALESCE(post.customerid,0) LIKE $P{customerIDCustomer/Job}

GROUP BY	part.num, part.description, uom.code

ORDER BY 	part.num]]>
		</queryString>
