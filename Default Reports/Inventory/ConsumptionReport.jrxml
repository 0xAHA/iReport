		<field name="unitcost" class="java.math.BigDecimal"/>
		<field name="customer" class="java.lang.String"/>
		<field name="note" class="java.lang.String"/>
		<variable name="GroupTotalQty" class="java.math.BigDecimal" resetType="Group" resetGroup="GroupBy" calculation="Sum">
			<variableExpression><![CDATA[$F{qtyconsumed}]]></variableExpression>
		</variable>
		<variable name="DateFormat" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[(System.getProperty("REPORT_DATE_FORMAT"))]]></variableExpression>
		</variable>
		<variable name="QtyDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_QTY")]]></variableExpression>
		</variable>
		<variable name="CostDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_COST")]]></variableExpression>
		</variable>
		<variable name="GroupTotalCost" class="java.math.BigDecimal" resetType="Group" resetGroup="GroupBy" calculation="Sum">
			<variableExpression><![CDATA[$F{unitcost}.multiply($F{qtyconsumed})]]></variableExpression>
		</variable>
		<variable name="ReportTotalQty" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{qtyconsumed}]]></variableExpression>
		</variable>
		<variable name="ReportTotalCost" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{unitcost}.multiply($F{qtyconsumed})]]></variableExpression>
		</variable>
		<group name="GroupBy" keepTogether="true">
			<groupExpression><![CDATA[$F{groupby}]]></groupExpression>
		</group>
