		<queryString>
			<![CDATA[SELECT	COALESCE($P!{cbGroupBy},"") AS groupby,
	part.num as part,
	part.description,
	$P!{cbApplyDateFilter} AS date,
	il.changeqty * -1 AS qtyconsumed,
	location.name AS location,
	sysuser.username,
	lg.name AS lg,
	uom.code AS uom,
	il.cost AS unitcost,
	customer.name AS customer,
	il.info AS note

FROM 	inventorylog il
	LEFT OUTER JOIN part ON il.partid = part.id
	LEFT OUTER JOIN location ON il.beglocationid = location.id
	LEFT OUTER JOIN sysuser ON il.userid = sysuser.id
	LEFT OUTER JOIN locationgroup lg ON location.locationgroupid = lg.id
	LEFT OUTER JOIN uom on part.uomid = uom.id
	LEFT OUTER JOIN post ON il.recordid = post.id AND il.tableid = -1407594912 /*<----Post Table ID*/
	LEFT OUTER JOIN customer ON post.customerid = customer.id

WHERE	il.typeid = 67 /*Type 67 is Adjust Scrap*/
AND 	$P!{cbApplyDateFilter} BETWEEN $P{dateRange1} AND DATE_SUB($P{dateRange2}, INTERVAL 1 SECOND)
AND 	part.activeflag IN ($P{ckShowActive}, $P{ckShowInactive})
AND 	sysuser.username LIKE $P{salesPersonUser}
AND 	part.num LIKE $P{partNum}
AND 	lg.id IN ($P!{locationGroupID})
AND 	location.id LIKE $P{locationID}
AND	COALESCE(post.customerid,0) LIKE $P{customerIDCustomer/Job}

ORDER BY 	groupby, part, date, lg, location]]>
		</queryString>
		<field name="groupby" class="java.lang.String"/>
		<field name="part" class="java.lang.String"/>
		<field name="description" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="date" class="java.sql.Timestamp"/>
		<field name="qtyconsumed" class="java.math.BigDecimal"/>
		<field name="location" class="java.lang.String"/>
