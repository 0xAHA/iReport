<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ReverseLotHistory" pageWidth="792" pageHeight="612" orientation="Landscape" whenNoDataType="AllSectionsNoDetail" columnWidth="752" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="f349ddf1-4879-46c5-bcaa-9aaa4b87b234">
	<property name="ireport.zoom" value="1.4641000000000008"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<subDataset name="SubReport" uuid="f7df1452-9014-46a0-8924-a275bb9e39db">
		<parameter name="woItemIDs" class="java.lang.String" isForPrompting="false">
			<defaultValueExpression><![CDATA[0]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT PART.NUM AS PARTNUM,
       PART.DESCRIPTION,
       ABS(IL.CHANGEQTY) AS CHANGEQTY,
       TIL.INFO AS LOT,
       IL.INFO AS EVENT,
       ILT.DESCRIPTION AS TYPE,
       IL.EVENTDATE,
       IL.ID AS ILID,
       IL.QTYONHAND,
       IL.TYPEID,
       IL.INFO,
       CASE WHEN SUBSTRING(IL.INFO FROM 1 FOR 13) = 'FINISHED GOOD' THEN SUBSTRING(IL.INFO FROM 15 FOR 10) ELSE '' END AS WONUMBER,
       IL.TYPEID AS ILTYPE,
       COMPANY.NAME AS COMPANY,
       COALESCE(TAG.QTY,0) AS TAGQTY,
       COALESCE(TAGEND.QTY,0) AS TAGENDQTY,
       WOITEMS.WOITEMIDS,
       VENDOR.NAME AS VENDOR,
       PHONE.DATUS AS PHONE,
       EMAIL.DATUS AS EMAIL

FROM INVENTORYLOG IL
     LEFT OUTER JOIN TIINVENTORYLOG TIL ON IL.ID = TIL.INVENTORYLOGID AND TIL.PARTTRACKINGID = 1
     INNER JOIN PART ON IL.PARTID = PART.ID
     INNER JOIN INVENTORYLOGTYPE ILT ON IL.TYPEID = ILT.ID
     LEFT OUTER JOIN COMPANY ON COMPANY.ID=1
     LEFT OUTER JOIN WOITEM ON IL.RECORDID = WOITEM.ID AND IL.TABLEID = -355941248 AND IL.TYPEID IN (10, 50)
     LEFT OUTER JOIN (SELECT GROUP_CONCAT(ID) AS WOITEMIDS, WOID AS WOID
                      FROM WOITEM
                      WHERE TYPEID = 20
                      GROUP BY WOID) AS WOITEMS ON WOITEMS.WOID = WOITEM.WOID
     LEFT OUTER JOIN TAG ON IL.BEGTAGNUM = TAG.NUM
     LEFT OUTER JOIN TAG TAGEND ON IL.ENDTAGNUM = TAGEND.NUM
     LEFT OUTER JOIN (SELECT PARTRACKINFO.INVLOGID AS INVLOGID, GROUP_CONCAT(PARTRACKINFO.TRACKVALUE, ', ') AS TRACKVALUE
                      FROM (SELECT TIINVENTORYLOG.INVENTORYLOGID AS INVLOGID,
                                   CONCAT(PARTTRACKING.ABBR, ': ',
                                      GROUP_CONCAT((CASE WHEN PARTTRACKING.TYPEID = 10 THEN TIINVENTORYLOG.INFO
                                                         WHEN PARTTRACKING.TYPEID = 20 THEN SUBSTRING(TIINVENTORYLOG.INFODATE FROM 1 FOR 11)
                                                         WHEN PARTTRACKING.TYPEID = 30 THEN SUBSTRING(TIINVENTORYLOG.INFODATE FROM 1 FOR 11)
                                                         WHEN PARTTRACKING.TYPEID = 40 THEN TIINVENTORYLOGSN.SERIALNUM
                                                         WHEN PARTTRACKING.TYPEID = 50 THEN CAST(TIINVENTORYLOG.INFODOUBLE AS DECIMAL(18,2))
                                                         WHEN PARTTRACKING.TYPEID = 60 THEN CAST(TIINVENTORYLOG.INFODOUBLE AS DECIMAL(18,5))
                                                         WHEN PARTTRACKING.TYPEID = 70 THEN TIINVENTORYLOG.INFOINTEGER
                                                         WHEN PARTTRACKING.TYPEID = 80 THEN TIINVENTORYLOG.INFOINTEGER
                                                         ELSE TIINVENTORYLOG.INFO END))) AS TRACKVALUE
                            FROM TIINVENTORYLOG
                                 INNER JOIN PARTTRACKING ON TIINVENTORYLOG.PARTTRACKINGID = PARTTRACKING.ID AND PARTTRACKING.ID = 1
                                 LEFT OUTER JOIN TIINVENTORYLOGSN ON TIINVENTORYLOG.ID = TIINVENTORYLOGSN.TIINVENTORYLOGID
                            GROUP BY TIINVENTORYLOG.INVENTORYLOGID, PARTTRACKING.ABBR, PARTTRACKING.SORTORDER
                            ORDER BY PARTTRACKING.SORTORDER) AS PARTRACKINFO
                      GROUP BY PARTRACKINFO.INVLOGID) TRACKINFO ON IL.ID = TRACKINFO.INVLOGID
     LEFT OUTER JOIN RECEIPTITEM ON IL.RECORDID = RECEIPTITEM.ID AND IL.TYPEID = 10 AND IL.TABLEID = 1259138490
     LEFT OUTER JOIN POITEM ON RECEIPTITEM.POITEMID = POITEM.ID
     LEFT OUTER JOIN PO ON POITEM.POID = PO.ID
     LEFT OUTER JOIN VENDOR ON PO.VENDORID = VENDOR.ID
     LEFT OUTER JOIN CONTACT PHONE ON VENDOR.ACCOUNTID = PHONE.ACCOUNTID AND PHONE.TYPEID = 50 AND PHONE.DEFAULTFLAG = 1
     LEFT OUTER JOIN CONTACT EMAIL ON VENDOR.ACCOUNTID = EMAIL.ACCOUNTID AND EMAIL.TYPEID = 20 AND EMAIL.DEFAULTFLAG = 1

WHERE WOITEM.ID IN ($P!{woItemIDs})

ORDER BY PART.NUM, IL.EVENTDATE DESC]]>
		</queryString>
		<field name="PARTNUM" class="java.lang.String"/>
		<field name="DESCRIPTION" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="CHANGEQTY" class="java.math.BigDecimal">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="LOT" class="java.lang.String"/>
		<field name="EVENT" class="java.lang.String"/>
		<field name="EVENTDATE" class="java.sql.Timestamp">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="ILID" class="java.lang.Long"/>
		<variable name="QtyDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_QTY")]]></variableExpression>
		</variable>
		<variable name="SUM_CHANGEQTY" class="java.lang.Double" incrementType="Group" incrementGroup="Log" calculation="Sum">
			<variableExpression><![CDATA[$F{CHANGEQTY}]]></variableExpression>
		</variable>
		<group name="Log">
			<groupExpression><![CDATA[$F{ILID}]]></groupExpression>
		</group>
	</subDataset>
	<parameter name="partNum" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="Lot" class="java.lang.String"/>
	<parameter name="path" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[]]></parameterDescription>
		<defaultValueExpression><![CDATA["../Other/"]]></defaultValueExpression>
	</parameter>
	<parameter name="REPORTDESCRIPTION" class="java.lang.String">
		<defaultValueExpression><![CDATA["Shows the history for the specified lot number."]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT PART.NUM AS PARTNUM,
       PART.DESCRIPTION,
       IL.CHANGEQTY,
       TIL.INFO AS LOT,
       IL.INFO AS EVENT,
       ILT.DESCRIPTION AS TYPE,
       IL.EVENTDATE,
       IL.ID AS ILID,
       IL.QTYONHAND,
       IL.TYPEID,
       IL.INFO,
       CASE WHEN SUBSTRING(IL.INFO FROM 1 FOR 13) = 'FINISHED GOOD' THEN SUBSTRING(IL.INFO FROM (POSITION('#' IN IL.INFO)+1) FOR 20) ELSE '' END AS WONUMBER,
       IL.TYPEID AS ILTYPE,
       COMPANY.NAME AS COMPANY,
       COALESCE(TAG.QTY,0) AS TAGQTY,
       COALESCE(TAGEND.QTY,0) AS TAGENDQTY,
       WOITEMS.WOITEMIDS,
       CUSTOMER.NAME AS CUSTOMER,
       PHONE.DATUS AS PHONE,
       EMAIL.DATUS AS EMAIL

FROM INVENTORYLOG IL
     INNER JOIN TIINVENTORYLOG TIL ON IL.ID = TIL.INVENTORYLOGID AND TIL.PARTTRACKINGID = 1
     INNER JOIN PART ON IL.PARTID = PART.ID
     INNER JOIN INVENTORYLOGTYPE ILT ON IL.TYPEID = ILT.ID
     LEFT OUTER JOIN COMPANY ON COMPANY.ID=1
     LEFT OUTER JOIN WOITEM ON IL.RECORDID = WOITEM.ID AND IL.TABLEID = -355941248 AND IL.TYPEID IN (10, 50)
     LEFT OUTER JOIN (SELECT GROUP_CONCAT(ID) AS WOITEMIDS, WOID AS WOID
                      FROM WOITEM
                      WHERE TYPEID = 20
                      GROUP BY WOID) AS WOITEMS ON WOITEMS.WOID = WOITEM.WOID
     LEFT OUTER JOIN TAG ON IL.BEGTAGNUM = TAG.NUM
     LEFT OUTER JOIN TAG TAGEND ON IL.ENDTAGNUM = TAGEND.NUM
     LEFT OUTER JOIN (SELECT PARTRACKINFO.INVLOGID AS INVLOGID, GROUP_CONCAT(PARTRACKINFO.TRACKVALUE, ', ') AS TRACKVALUE
                      FROM (SELECT TIINVENTORYLOG.INVENTORYLOGID AS INVLOGID,
                                   CONCAT(PARTTRACKING.ABBR,': ',
                                     GROUP_CONCAT((CASE WHEN PARTTRACKING.TYPEID = 10 THEN TIINVENTORYLOG.INFO
                                                        WHEN PARTTRACKING.TYPEID = 20 THEN SUBSTRING(TIINVENTORYLOG.INFODATE FROM 1 FOR 11)
                                                        WHEN PARTTRACKING.TYPEID = 30 THEN SUBSTRING(TIINVENTORYLOG.INFODATE FROM 1 FOR 11)
                                                        WHEN PARTTRACKING.TYPEID = 40 THEN TIINVENTORYLOGSN.SERIALNUM
                                                        WHEN PARTTRACKING.TYPEID = 50 THEN CAST(TIINVENTORYLOG.INFODOUBLE AS DECIMAL(18,2))
                                                        WHEN PARTTRACKING.TYPEID = 60 THEN CAST(TIINVENTORYLOG.INFODOUBLE AS DECIMAL(18,5))
                                                        WHEN PARTTRACKING.TYPEID = 70 THEN TIINVENTORYLOG.INFOINTEGER
                                                        WHEN PARTTRACKING.TYPEID = 80 THEN TIINVENTORYLOG.INFOINTEGER
                                                   ELSE TIINVENTORYLOG.INFO END ))) AS TRACKVALUE
                            FROM TIINVENTORYLOG
                                 INNER JOIN PARTTRACKING ON TIINVENTORYLOG.PARTTRACKINGID = PARTTRACKING.ID
                                 LEFT OUTER JOIN TIINVENTORYLOGSN ON TIINVENTORYLOG.ID = TIINVENTORYLOGSN.TIINVENTORYLOGID
                            GROUP BY TIINVENTORYLOG.INVENTORYLOGID, PARTTRACKING.ABBR, PARTTRACKING.SORTORDER
                            ORDER BY PARTTRACKING.SORTORDER) AS PARTRACKINFO
                      GROUP BY PARTRACKINFO.INVLOGID) TRACKINFO ON IL.ID = TRACKINFO.INVLOGID
     LEFT OUTER JOIN SHIPITEM ON IL.RECORDID = SHIPITEM.ID AND IL.TYPEID = 20 AND IL.TABLEID = 1555030112
     LEFT OUTER JOIN SOITEM ON SHIPITEM.SOITEMID = SOITEM.ID
     LEFT OUTER JOIN SO ON SOITEM.SOID = SO.ID
     LEFT OUTER JOIN CUSTOMER ON CUSTOMER.ID = SO.CUSTOMERID
     LEFT OUTER JOIN CONTACT PHONE ON CUSTOMER.ACCOUNTID = PHONE.ACCOUNTID AND PHONE.TYPEID = 50 AND PHONE.DEFAULTFLAG = 1
     LEFT OUTER JOIN CONTACT EMAIL ON CUSTOMER.ACCOUNTID = EMAIL.ACCOUNTID AND EMAIL.TYPEID = 60 AND EMAIL.DEFAULTFLAG = 1

WHERE PART.NUM LIKE $P{partNum}
  AND IL.TYPEID != 40
  AND COALESCE(UPPER(TRACKINFO.TRACKVALUE),'') LIKE UPPER(CONCAT('%',$P{Lot},'%'))

ORDER BY PART.NUM, IL.EVENTDATE DESC]]>
	</queryString>
