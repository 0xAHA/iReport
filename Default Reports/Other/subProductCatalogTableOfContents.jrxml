				<textElement textAlignment="Center" verticalAlignment="Middle" markup="none">
					<font fontName="Open Sans" size="16" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{AlternateReportTitle}.equals("%") ? "Product Catalog" : $P{AlternateReportTitle}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="22" width="572" height="20" uuid="51261ef9-448e-48d6-a1b0-5854198ff39a"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Open Sans" size="12" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{company}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="472" y="57" width="100" height="20" uuid="c8394d87-f5b7-4316-baef-b9d5e41ac233"/>
				<box rightPadding="5"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font fontName="Open Sans" isBold="true"/>
