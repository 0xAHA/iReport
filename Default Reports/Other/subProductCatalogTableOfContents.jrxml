<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="subProductCatalogTableOfContents" pageWidth="572" pageHeight="752" columnWidth="555" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="bb5c2d1a-fa9b-46cf-ad91-cec91995ae4e">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<style name="Zebra" fontName="Open Sans">
		<conditionalStyle>
			<conditionExpression><![CDATA[$V{PAGE_COUNT}.intValue() % 2 == 0]]></conditionExpression>
			<style mode="Opaque" backcolor="#EAEAEA" pattern="" fontName="Open Sans"/>
		</conditionalStyle>
	</style>
	<parameter name="productTree1" class="java.lang.String" isForPrompting="false"/>
	<parameter name="productTree2" class="java.lang.String" isForPrompting="false"/>
	<parameter name="ShowCoverPage" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
	</parameter>
	<parameter name="ExcludeCoverFromPageNumbering" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
	</parameter>
	<parameter name="countStart" class="java.lang.Integer" isForPrompting="false">
		<defaultValueExpression><![CDATA[$P{ShowCoverPage} == false || $P{ExcludeCoverFromPageNumbering} == true
    ? 1
    : 2]]></defaultValueExpression>
	</parameter>
	<parameter name="tocIncrement" class="java.lang.Integer" isForPrompting="false"/>
	<parameter name="AlternateReportTitle" class="java.lang.String" isForPrompting="false"/>
	<parameter name="ShowInactiveProducts" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
	</parameter>
	<parameter name="ckIncludeServiceItems" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[20,0]]></parameterDescription>
		<defaultValueExpression><![CDATA["20"]]></defaultValueExpression>
	</parameter>
	<parameter name="ckIncludeNonInventoryItems" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[30,0]]></parameterDescription>
		<defaultValueExpression><![CDATA["30"]]></defaultValueExpression>
	</parameter>
	<parameter name="cbUncategorizedProducts" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[1,Include,2,Exclude,3,Show Only]]></parameterDescription>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    producttree.name AS productTree,
    (SELECT name FROM company) AS company,
    (SELECT datus FROM contact WHERE accountid = 1 AND typeid = 50 and defaultflag = 1 LIMIT 1) AS phone,
    (SELECT datus FROM contact WHERE accountid = 1 AND typeid = 60 and defaultflag = 1 LIMIT 1) AS email,
    floor(((SELECT count(product.id)
        FROM product
        join producttotree on producttotree.productid = product.id
        left join part on product.partid = part.id
        WHERE producttreeid = producttree.id
        and if($P!{ShowInactiveProducts},1=1,product.activeflag = 1)
        and (part.typeid IN (10,$P!{ckIncludeServiceItems},$P!{ckIncludeNonInventoryItems}) OR part.id is null)) - 0.01) / 12) AS productTreeCounter,
    @counter:=@counter + 1 + floor(((SELECT count(product.id)
        FROM product
        join producttotree on producttotree.productid = product.id
        left join part on product.partid = part.id
        WHERE producttreeid = producttree.id
        and if($P!{ShowInactiveProducts},1=1,product.activeflag = 1)) - 0.01) / 12) AS pageHelper

FROM producttree
    CROSS JOIN (SELECT @counter:=$P!{countStart}) c

WHERE producttree.id != 1
    and (
        COALESCE(producttree.id,0) IN ($P!{productTree1})
        OR COALESCE(producttree.id,0) LIKE $P{productTree2}
    )

HAVING (SELECT count(product.id) FROM product
        join producttotree on producttotree.productid = product.id
        left join part on product.partid = part.id
        WHERE producttreeid = producttree.id
        and if($P!{ShowInactiveProducts},1=1,product.activeflag = 1)
        and (part.typeid IN (10,$P!{ckIncludeServiceItems},$P!{ckIncludeNonInventoryItems}) OR part.id is null)) > 0]]>
	</queryString>
	<field name="productTree" class="java.lang.String"/>
	<field name="company" class="java.lang.String"/>
	<field name="phone" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="email" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="pageHelper" class="java.lang.Integer"/>
	<field name="productTreeCounter" class="java.lang.Integer"/>
