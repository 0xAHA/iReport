		</band>
	</pageHeader>
	<detail>
		<band height="20" splitType="Stretch">
			<textField>
				<reportElement style="Zebra" x="0" y="0" width="472" height="20" uuid="e652452e-84d3-4e06-b74a-ae4db68eb37a"/>
				<box leftPadding="3" rightPadding="5"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Open Sans" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{productTree}.replaceAll("zz - ","")]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement style="Zebra" x="472" y="0" width="100" height="20" uuid="8de4cc19-0e32-4bad-8201-9ad40a032f7c"/>
				<box rightPadding="5"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font fontName="Open Sans" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[($F{pageHelper} - $F{productTreeCounter} - ($P{ShowCoverPage} ? 0 : 1)) + $P{tocIncrement}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
	<summary>
		<band height="20">
			<printWhenExpression><![CDATA[$P{cbUncategorizedProducts}.equals("1") && $P{productTree2}.equals("%")]]></printWhenExpression>
			<textField evaluationTime="Report">
				<reportElement mode="Opaque" x="0" y="0" width="572" height="20" backcolor="#EAEAEA" uuid="4ac4d979-aabb-484b-8e43-e0b5c8ef4213">
					<printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 != 0]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Center" markup="none"/>
				<textFieldExpression><![CDATA[""]]></textFieldExpression>
			</textField>
			<textField evaluationTime="Report">
				<reportElement mode="Transparent" x="0" y="0" width="472" height="20" uuid="d122044b-1fbc-477c-aa6e-3cc1a570f07b"/>
				<box leftPadding="3" rightPadding="5"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Open Sans" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["Uncategorized"]]></textFieldExpression>
			</textField>
			<textField evaluationTime="Report">
				<reportElement mode="Transparent" x="472" y="0" width="100" height="20" uuid="946f74b7-92eb-4d98-b77f-de50ae118a4e"/>
				<box rightPadding="5"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font fontName="Open Sans" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{pageHelper} + 1]]></textFieldExpression>
			</textField>
		</band>
	</summary>
</jasperReport>
