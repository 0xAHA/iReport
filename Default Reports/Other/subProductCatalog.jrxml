<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="subProductCatalog" columnCount="4" printOrder="Horizontal" pageWidth="572" pageHeight="752" columnWidth="137" columnSpacing="7" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="4d0c25d7-80ef-402d-bbb8-f797d6d2fec6">
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<style name="barcode" hAlign="Center" vAlign="Top"/>
	<parameter name="productNum" class="java.lang.String" isForPrompting="false"/>
	<parameter name="productTree1" class="java.lang.String" isForPrompting="false"/>
	<parameter name="productTree2" class="java.lang.String" isForPrompting="false"/>
	<parameter name="module" class="java.lang.Object" isForPrompting="false">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="ShowBarcode" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
	</parameter>
	<parameter name="ShowProductPrice" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
	</parameter>
	<parameter name="cbBarcode" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[product.num,Product Number,product.upc,Product UPC,product.sku,Product SKU]]></parameterDescription>
		<defaultValueExpression><![CDATA["product.num"]]></defaultValueExpression>
	</parameter>
	<parameter name="ShowInactiveProducts" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
	</parameter>
	<parameter name="ckIncludeServiceItems" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[20,0]]></parameterDescription>
		<defaultValueExpression><![CDATA["20"]]></defaultValueExpression>
	</parameter>
	<parameter name="ckIncludeNonInventoryItems" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[30,0]]></parameterDescription>
		<defaultValueExpression><![CDATA["30"]]></defaultValueExpression>
	</parameter>
	<parameter name="cbUncategorizedProducts" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[1,Include,2,Exclude,3,Show Only]]></parameterDescription>
	</parameter>
	<queryString>
		<![CDATA[select
    product.id as productID,
    product.description as productDescription,
    product.num as productNum,
    coalesce(left(product.upc,11),left(part.upc,11),'') as partUPC,
    uom.name as uom,
    coalesce(producttree.name,'zz - Uncategorized') as productTree,
    coalesce($P!{cbBarcode},'') as barcode,
    product.price,
    currency.symbol

from product

    LEFT OUTER JOIN part on product.id = part.defaultproductid
    LEFT OUTER JOIN uom on product.uomid = uom.id
    LEFT OUTER JOIN producttotree on producttotree.productid = product.id
    LEFT OUTER JOIN producttree on producttotree.producttreeid = producttree.id
    LEFT OUTER JOIN currency ON currency.homeCurrency = 1

where if($P!{ShowInactiveProducts},1=1,product.activeflag = 1)
    and product.num LIKE '$P!{productNum}'
    and (part.typeid IN (10,$P!{ckIncludeServiceItems},$P!{ckIncludeNonInventoryItems}) OR part.id is null)

    and (CASE '$P!{cbUncategorizedProducts}'
        WHEN '1' THEN (COALESCE(producttree.id,0) IN ($P!{productTree1}) OR COALESCE(producttree.id,0) LIKE $P{productTree2})
        WHEN '2' THEN (producttree.id is not null AND (COALESCE(producttree.id,0) IN ($P!{productTree1}) OR COALESCE(producttree.id,0) LIKE $P{productTree2}))
        WHEN '3' THEN producttree.id is null
        END)

order by productTree, product.num]]>
	</queryString>
	<field name="productID" class="java.lang.Integer"/>
	<field name="productDescription" class="java.lang.String"/>
	<field name="productNum" class="java.lang.String"/>
	<field name="partUPC" class="java.lang.String"/>
	<field name="uom" class="java.lang.String"/>
	<field name="productTree" class="java.lang.String"/>
	<field name="barcode" class="java.lang.String"/>
	<field name="price" class="java.lang.Double"/>
	<field name="symbol" class="java.lang.Integer"/>
	<variable name="isMultiCurrency" class="java.lang.Boolean">
		<variableExpression><![CDATA[com.evnt.eve.modules.CurrencyModule.isMultiCurrency()]]></variableExpression>
	</variable>
	<variable name="PriceDecimal" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_PRICE")]]></variableExpression>
	</variable>
	<group name="Product Tree" isStartNewPage="true">
		<groupExpression><![CDATA[$F{productTree}]]></groupExpression>
	</group>
	<pageHeader>
		<band height="34">
			<textField>
				<reportElement x="0" y="0" width="570" height="29" forecolor="#000000" uuid="efff44ac-c0cb-4d04-a04e-9b32a4310654"/>
				<box>
					<pen lineColor="#000000"/>
					<topPen lineColor="#000000"/>
					<leftPen lineColor="#000000"/>
					<bottomPen lineWidth="1.0" lineColor="#000000"/>
					<rightPen lineColor="#000000"/>
				</box>
				<textElement textAlignment="Right" verticalAlignment="Bottom">
					<font fontName="Open Sans" size="14" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{cbUncategorizedProducts}.equals("3")
    ? ""
    : $F{productTree}.replaceAll("zz - ","")]]></textFieldExpression>
			</textField>
		</band>
	</pageHeader>
	<detail>
		<band height="233" splitType="Stretch">
			<rectangle>
				<reportElement x="0" y="0" width="137" height="226" uuid="0823a816-c8e0-4535-b0a1-328d554b370f"/>
				<graphicElement>
					<pen lineWidth="0.5"/>
				</graphicElement>
			</rectangle>
			<image hAlign="Center" vAlign="Middle">
				<reportElement x="5" y="4" width="125" height="125" uuid="0779bd96-05a1-4f86-ad9f-dc5be400e7f3"/>
				<imageExpression><![CDATA[com.evnt.util.ImageUtil.decodeImage(((com.evnt.eve.modules.ReportHelperModule) $P{module}).getImageData("Product", $F{productID}, true))]]></imageExpression>
			</image>
			<textField>
				<reportElement x="2" y="147" width="132" height="24" uuid="3f2c145b-8633-46a7-8147-6b25f48bbebf"/>
				<box topPadding="2" leftPadding="2" rightPadding="2"/>
				<textElement textAlignment="Center">
					<font fontName="Open Sans" size="8" isBold="false"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{productDescription}]]></textFieldExpression>
			</textField>
			<textField hyperlinkType="Reference">
				<reportElement x="2" y="134" width="132" height="13" forecolor="#000000" uuid="11c0f716-e9b7-49b8-afc6-5b6edecb531f"/>
				<box topPadding="2" leftPadding="2" rightPadding="2"/>
				<textElement textAlignment="Center">
					<font fontName="Open Sans" size="8" isBold="false"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{productNum}]]></textFieldExpression>
				<anchorNameExpression><![CDATA["ProductNum"]]></anchorNameExpression>
				<hyperlinkReferenceExpression><![CDATA[$F{productNum}]]></hyperlinkReferenceExpression>
			</textField>
			<componentElement>
				<reportElement style="barcode" x="3" y="181" width="131" height="45" uuid="de519091-129e-4e9e-ba05-0a7829ad10ee">
					<printWhenExpression><![CDATA[($P{cbBarcode}.equals("product.num") || $P{cbBarcode}.equals("product.sku")) && $P{ShowBarcode} && !$F{barcode}.equals("")]]></printWhenExpression>
				</reportElement>
				<jr:barbecue xmlns:jr="http://jasperreports.sourceforge.net/jasperreports/components" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports/components http://jasperreports.sourceforge.net/xsd/components.xsd" type="Code128" drawText="false" checksumRequired="false" barWidth="3" barHeight="100">
					<jr:codeExpression><![CDATA[$F{barcode}]]></jr:codeExpression>
				</jr:barbecue>
			</componentElement>
			<componentElement>
				<reportElement x="3" y="181" width="131" height="45" uuid="70d4a993-4b84-423f-97c3-1cfdeff8478d">
					<printWhenExpression><![CDATA[($P{cbBarcode}.equals("product.upc") && !$F{partUPC}.equals("")) && $P{ShowBarcode} && $F{partUPC}.length() > 10]]></printWhenExpression>
				</reportElement>
				<jr:barbecue xmlns:jr="http://jasperreports.sourceforge.net/jasperreports/components" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports/components http://jasperreports.sourceforge.net/xsd/components.xsd" type="UPCA" drawText="true" checksumRequired="false" barWidth="2" barHeight="0">
					<jr:codeExpression><![CDATA[$F{partUPC}]]></jr:codeExpression>
				</jr:barbecue>
			</componentElement>
			<textField>
				<reportElement x="2" y="171" width="132" height="10" uuid="25d2e588-0ec4-40bf-95b6-892423742357">
					<printWhenExpression><![CDATA[$P{ShowProductPrice}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Center">
					<font fontName="Open Sans" size="7"/>
				</textElement>
				<textFieldExpression><![CDATA[$V{isMultiCurrency} ? com.fbi.sdk.constants.setup.CurrencySymbolConst.getFormattedCurrency($F{symbol}, $F{price}, $V{PriceDecimal}) : $F{price}]]></textFieldExpression>
				<patternExpression><![CDATA[$V{PriceDecimal}]]></patternExpression>
			</textField>
		</band>
	</detail>
</jasperReport>
