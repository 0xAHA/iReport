<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="subOrderSheet" columnCount="2" pageWidth="572" pageHeight="752" whenNoDataType="NoDataSection" columnWidth="283" columnSpacing="6" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="44af956a-d3c0-4855-ba7b-245825539dd5">
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<style name="ColumnHeader" mode="Opaque" forecolor="#000000" backcolor="#EAEAEA" hAlign="Center" vAlign="Bottom" fontName="Open Sans" fontSize="10">
		<box>
			<leftPen lineWidth="1.0" lineColor="#FFFFFF"/>
			<bottomPen lineWidth="0.5"/>
			<rightPen lineWidth="1.0" lineColor="#FFFFFF"/>
		</box>
	</style>
	<style name="Zebra" fontName="Open Sans">
		<box leftPadding="3" rightPadding="3">
			<leftPen lineWidth="1.0" lineColor="#FFFFFF"/>
			<rightPen lineWidth="1.0" lineColor="#FFFFFF"/>
		</box>
		<conditionalStyle>
			<conditionExpression><![CDATA[$V{COLUMN_COUNT} % 2 == 0]]></conditionExpression>
			<style mode="Opaque" backcolor="#EAEAEA"/>
		</conditionalStyle>
	</style>
	<style name="CenterBarcode" hAlign="Center" vAlign="Middle"/>
	<style name="TopBarcode" hAlign="Center" vAlign="Top"/>
	<style name="BottomBarcode" hAlign="Center" vAlign="Bottom"/>
	<parameter name="poNum" class="java.lang.String" isForPrompting="false"/>
	<parameter name="productNum" class="java.lang.String" isForPrompting="false"/>
	<parameter name="productTree1" class="java.lang.String" isForPrompting="false"/>
	<parameter name="productTree2" class="java.lang.String" isForPrompting="false"/>
	<parameter name="AlternateReportTitle" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="REPORTDESCRIPTION" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["Created by Daniel L"]]></defaultValueExpression>
	</parameter>
	<parameter name="ShowItemsWithZeroOnHand" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
	</parameter>
	<parameter name="LastPageFooterNote" class="java.lang.String" isForPrompting="false"/>
	<parameter name="ShowOnlyUncategorizedProducts" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
	</parameter>
	<parameter name="ShowInactiveProducts" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
	</parameter>
	<parameter name="ckIncludeServiceItems" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[20,0]]></parameterDescription>
		<defaultValueExpression><![CDATA["20"]]></defaultValueExpression>
	</parameter>
	<parameter name="ckIncludeNonInventoryItems" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[30,0]]></parameterDescription>
		<defaultValueExpression><![CDATA["30"]]></defaultValueExpression>
	</parameter>
	<parameter name="cbUncategorizedProducts" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[1,Include,2,Exclude,3,Show Only]]></parameterDescription>
	</parameter>
	<queryString>
		<![CDATA[select
    product.id as productID,
    product.description as productDescription,
    product.num as productNum,
    coalesce(part.upc,'') as partUPC,
    uom.code as uom,
    coalesce(producttree.name,'zz - Uncategorized') as productTree

from product

    left outer join part on product.id = part.defaultproductid
    left outer join uom on product.uomid = uom.id
    left outer join producttotree on producttotree.productid = product.id
    left outer join producttree on producttotree.producttreeid = producttree.id

where if($P!{ShowInactiveProducts},1=1,product.activeflag = 1)
    and product.num LIKE '$P!{productNum}'
    and (part.typeid IN (10,$P!{ckIncludeServiceItems},$P!{ckIncludeNonInventoryItems}) OR part.id is null)

    and (CASE '$P!{cbUncategorizedProducts}'
        WHEN '1' THEN (COALESCE(producttree.id,0) IN ($P!{productTree1}) OR COALESCE(producttree.id,0) LIKE $P{productTree2})
        WHEN '2' THEN (producttree.id is not null AND (COALESCE(producttree.id,0) IN ($P!{productTree1}) OR COALESCE(producttree.id,0) LIKE $P{productTree2}))
        WHEN '3' THEN producttree.id is null
        END)

order by productTree, product.num]]>
	</queryString>
	<field name="productID" class="java.lang.Integer"/>
	<field name="productDescription" class="java.lang.String"/>
	<field name="productNum" class="java.lang.String"/>
	<field name="partUPC" class="java.lang.String"/>
	<field name="uom" class="java.lang.String"/>
	<field name="productTree" class="java.lang.String"/>
	<variable name="DateFormat" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[(System.getProperty("REPORT_DATE_FORMAT"))]]></variableExpression>
	</variable>
	<variable name="CostDecimal" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_COST")]]></variableExpression>
	</variable>
	<variable name="TotalsDecimal" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_TOTAL")]]></variableExpression>
	</variable>
	<variable name="PriceDecimal" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_PRICE")]]></variableExpression>
	</variable>
	<variable name="isMultiCurrency" class="java.lang.Boolean">
		<variableExpression><![CDATA[com.evnt.eve.modules.CurrencyModule.isMultiCurrency()]]></variableExpression>
	</variable>
	<variable name="QtyDecimal" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_QTY")]]></variableExpression>
	</variable>
	<group name="TREE">
		<groupExpression><![CDATA[$F{productTree}]]></groupExpression>
		<groupHeader>
			<band height="13">
				<printWhenExpression><![CDATA[$P{ShowOnlyUncategorizedProducts} == false]]></printWhenExpression>
				<textField isStretchWithOverflow="true" isBlankWhenNull="true">
					<reportElement style="Zebra" stretchType="RelativeToBandHeight" mode="Opaque" x="0" y="0" width="282" height="13" isPrintWhenDetailOverflows="true" forecolor="#FFFFFF" backcolor="#000000" uuid="3aa5b8d9-2c6f-4493-aaa5-afbe45b9ad21"/>
					<box leftPadding="3" rightPadding="3"/>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font fontName="Open Sans" size="9" isBold="true"/>
					</textElement>
					<textFieldExpression><![CDATA[$P{cbUncategorizedProducts}.equals("3")
    ? ""
    : $F{productTree}.replaceAll("zz - ","")]]></textFieldExpression>
				</textField>
			</band>
		</groupHeader>
	</group>
	<pageHeader>
		<band height="24" splitType="Stretch">
			<textField>
				<reportElement key="" mode="Transparent" x="0" y="0" width="200" height="17" forecolor="#000000" backcolor="#FFFFFF" uuid="aeefaa7a-8363-4a65-aa13-507ffdfaadec"/>
				<textElement verticalAlignment="Middle" rotation="None" markup="none">
					<font fontName="Open Sans" size="12" isBold="true" isItalic="false" isUnderline="false" isStrikeThrough="false" pdfEncoding="Cp1252" isPdfEmbedded="false"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<textFieldExpression><![CDATA["Order Sheet"]]></textFieldExpression>
			</textField>
		</band>
	</pageHeader>
	<detail>
		<band height="13" splitType="Prevent">
			<textField isStretchWithOverflow="true" isBlankWhenNull="true">
				<reportElement style="Zebra" stretchType="RelativeToBandHeight" x="0" y="0" width="60" height="13" isPrintWhenDetailOverflows="true" uuid="552aa331-a655-4186-add7-031f5ecbe14c"/>
				<box leftPadding="3" rightPadding="3"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Open Sans" size="7"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{productNum}]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true" isBlankWhenNull="true">
