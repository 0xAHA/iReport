				</subreport>
			</band>
		</groupHeader>
	</group>
	<pageFooter>
		<band height="18">
			<printWhenExpression><![CDATA[$P{CoverPageImageURL}.equals("%")]]></printWhenExpression>
			<textField>
				<reportElement x="0" y="0" width="572" height="18" uuid="96963cea-34a6-4c5b-9e02-a963f74b0e76">
					<printWhenExpression><![CDATA[$P{HideFooterInformation} == false && $P{CoverPageImageURL}.equals("%")]]></printWhenExpression>
				</reportElement>
				<box leftPadding="3" rightPadding="3"/>
				<textElement textAlignment="Center" verticalAlignment="Bottom">
					<font fontName="Open Sans" size="10" isBold="false"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{company} +
($F{phone} == null ? "" : "  •  " + $F{phone}) +
($F{email} == null ? "" : "  •  " + $F{email})]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="543" y="0" width="29" height="18" uuid="29c4f355-a3d5-4c65-994e-a3fa6eda3260">
					<printWhenExpression><![CDATA[$V{PAGE_NUMBER} - 1 > 0]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Right" verticalAlignment="Bottom">
					<font fontName="Open Sans" isBold="false"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{ExcludeCoverFromPageNumbering}
    ? $V{PAGE_NUMBER} - 1
    : $V{PAGE_NUMBER}]]></textFieldExpression>
			</textField>
		</band>
	</pageFooter>
</jasperReport>
