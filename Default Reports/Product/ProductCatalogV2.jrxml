					<parametersMapExpression><![CDATA[$P{REPORT_PARAMETERS_MAP}]]></parametersMapExpression>
					<connectionExpression><![CDATA[$P{REPORT_CONNECTION}]]></connectionExpression>
					<subreportExpression><![CDATA["../Other/subProductCatalog.jasper"]]></subreportExpression>
				</subreport>
			</band>
		</groupHeader>
	</group>
	<group name="Order Sheet" isStartNewPage="true">
		<groupHeader>
			<band height="24">
				<printWhenExpression><![CDATA[$P{ShowOrderSheet}]]></printWhenExpression>
				<subreport runToBottom="true">
					<reportElement x="0" y="0" width="572" height="24" uuid="0bca69b4-d377-4b6c-8f87-c1a7a6069e9c"/>
					<parametersMapExpression><![CDATA[$P{REPORT_PARAMETERS_MAP}]]></parametersMapExpression>
					<connectionExpression><![CDATA[$P{REPORT_CONNECTION}]]></connectionExpression>
