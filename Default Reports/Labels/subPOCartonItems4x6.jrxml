	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="ShipID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["21"]]></defaultValueExpression>
	</parameter>
	<parameter name="POID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["17"]]></defaultValueExpression>
	</parameter>
	<parameter name="module" class="java.lang.Object" isForPrompting="false"/>
	<parameter name="ShipStatus" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["10"]]></defaultValueExpression>
	</parameter>
	<parameter name="path" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:Program Files/Fishbowl/server/reports/ship/"]]></defaultValueExpression>
	</parameter>
	<parameter name="ISSUBREPORTONLY" class="java.lang.String" isForPrompting="false"/>
	<parameter name="ShowTracking" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT shipitem.id AS ShipItemID, poitem.polineitem AS POLineItem, part.num AS PartNum, poitem.vendorpartnum AS VendorPartNum,
    part.description AS PartDescription, poitem.note AS Note, COALESCE(poitem.qtytofulfill,0) AS QtyToFulfill,
    COALESCE(poitem.qtyfulfilled,0) AS QtyFulfilled, COALESCE(poitem.qtypicked,0) AS QtyPicked, uom.code AS UOMCode,
    company.name AS CompanyName, shipcarton.id AS shipCartonID, shipcarton.trackingnum AS TrackingNumber,
    shipcarton.cartonnum as CartonNumber, shipcarton.freightweight AS Weight, shipcarton.id as cartonID,
    COALESCE((SELECT SUM(shipitem.qtyshipped)
       FROM shipitem
      WHERE shipitem.shipid = $P{ShipID}
        AND shipitem.poItemId = poitem.id),0) AS QtyShipped, COALESCE(weightUom.code, 'lbs') AS weightUomCode, poitem.typeid

FROM shipcarton, poitem
    INNER JOIN uom ON (poitem.uomid = uom.id)
    INNER JOIN part ON (poitem.partid = part.id)
    LEFT OUTER JOIN shipitem ON ((shipitem.shipID = $P{ShipID}) AND (shipitem.poItemId = poitem.id))
    LEFT OUTER JOIN sysProperties ON sysProperties.sysKey = 'Default Weight UomId'
    LEFT OUTER JOIN uom weightUom ON sysProperties.sysValue = weightUom.id
    JOIN company ON company.id = 1

WHERE poitem.poid = $P{POID}
  AND shipcarton.shipid = $P{ShipID}
  AND shipitem.shipcartonid = shipcarton.id
  AND part.typeid IN (10,21,22,30,40,50)
  AND poitem.typeid IN (20,30)

ORDER BY shipcarton.id, poitem.polineitem]]>
	</queryString>
	<field name="SHIPITEMID" class="java.lang.Integer"/>
	<field name="POLINEITEM" class="java.lang.Integer"/>
	<field name="PARTNUM" class="java.lang.String"/>
	<field name="VENDORPARTNUM" class="java.lang.String"/>
