		<parameter name="colTotalPrice" class="java.lang.Boolean" isForPrompting="false">
			<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT shipitem.id AS shipitemid, soitem.solineitem AS SOLineItem, soitem.productnum AS ProductNum,
    soitem.customerpartnum AS CustPartNum, product.description AS ProductDescription, soitem.note AS Note,
    COALESCE(soitem.qtytofulfill, 0) AS QtyToFulfill, COALESCE(soitem.qtyfulfilled, 0) AS QtyFulfilled,
    COALESCE(soitem.qtypicked,0) AS QtyPicked, company.name AS CompanyName, shipcarton.id AS shipCartonID,
    shipcarton.trackingnum AS TrackingNumber, shipcarton.freightweight AS FreightWeight, shipcarton.id as cartonID,
    shipcarton.cartonnum AS CartonNumber, uom.code AS UOMCode, product.weight AS ProductWeight,
    COALESCE((SELECT SUM(shipitem.qtyshipped)
       FROM shipitem
      WHERE shipitem.shipid = $P{ShipID}
        AND shipitem.soItemId = soitem.id
        AND shipitem.shipcartonid = shipcarton.id), 0) AS QtyShipped, COALESCE(weightUom.code, 'lbs') AS weightUom,
    soItem.unitPrice AS unitPrice

FROM soitem
    LEFT JOIN uom ON (soitem.uomid = uom.id)
    LEFT JOIN product ON (soitem.productid = product.id)
    LEFT JOIN part ON (product.partid = part.id)
    LEFT OUTER JOIN shipitem ON ((shipitem.shipID = $P{ShipID}) AND (shipitem.soItemId = soitem.id))
    LEFT OUTER JOIN shipcarton ON  shipitem.shipcartonid = shipcarton.id
    LEFT OUTER JOIN sysProperties ON sysProperties.sysKey = 'Default Weight UomId'
    LEFT OUTER JOIN uom weightUom ON sysProperties.sysValue = weightUom.id

    INNER JOIN company ON company.id = 1

WHERE soitem.soid = $P{SOID}
  AND shipitem.shipID = $P{ShipID}
  AND soitem.typeid IN (10,30,50)

ORDER BY shipcarton.id, soitem.solineitem]]>
		</queryString>
