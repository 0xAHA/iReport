	<parameter name="shipID" class="java.lang.String">
		<defaultValueExpression><![CDATA["201"]]></defaultValueExpression>
	</parameter>
	<parameter name="path" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["../Labels/"]]></defaultValueExpression>
	</parameter>
	<parameter name="module" class="java.lang.Object" isForPrompting="false">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="ISSUBREPORTONLY" class="java.lang.String" isForPrompting="false"/>
	<parameter name="ckShowCountry" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[1,0]]></parameterDescription>
		<defaultValueExpression><![CDATA["1"]]></defaultValueExpression>
	</parameter>
	<parameter name="ShowUniqueShipNumbers" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
	</parameter>
	<parameter name="ShowBarcode" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
	</parameter>
	<parameter name="ShowTracking" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT po.id AS POID, po.locationgroupid AS LocationGroupID, ship.id AS ShipID, ship.statusid AS ShipStatus, ship.note AS Memo, po.vendorso AS SalesOrderNumber, ship.dateshipped AS ShipDate,
    po.shiptoname AS ShipToName, po.shiptoaddress AS ShipToAddress, po.shiptocity AS ShipToCity, shipState.code AS ShipToState, po.shiptozip AS ShipToZip,
    po.remittoname AS BillToName, po.remitaddress AS BillToAddress, po.remitcity AS BillToCity, billState.code AS BillToState, po.remitzip AS BillToZip,
    COALESCE(ship.cartoncount,0) AS CartonCount, po.datefirstship AS RegShipDate, fobpoint.name AS FobPoint, shipterms.name AS ShippingTerms, carrier.name AS CarrierName, po.num AS PONum,
    shipcountry.name AS shipcountry, billcountry.name AS billcountry, ship.num AS shipnum, company.name AS company,
    (SELECT s1.sysvalue
        FROM sysproperties s1
        WHERE s1.syskey = 'Barcodes have DI'
    ) AS BarcodesHaveDI

FROM ship
    INNER JOIN carrier ON (ship.carrierid = carrier.id)
    INNER JOIN po ON (ship.poId = po.id)
    INNER JOIN fobpoint ON (po.fobpointid = fobpoint.id)
    INNER JOIN shipterms ON (po.shiptermsid = shipterms.id)
    LEFT OUTER JOIN stateconst shipState ON (po.shiptostateid = shipState.id)
    LEFT OUTER JOIN stateconst billState ON (po.remitstateid = billState.id)
    LEFT OUTER JOIN countryconst shipCountry ON (po.shiptocountryid = shipCountry.id)
    LEFT OUTER JOIN countryconst billCountry ON (po.remitcountryid = billCountry.id)
    JOIN company ON company.id  = 1

WHERE ship.id = $P{shipID}
  AND ship.ordertypeid = 10]]>
	</queryString>
