	<parameter name="ckShowCountry" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[1,0]]></parameterDescription>
		<defaultValueExpression><![CDATA["1"]]></defaultValueExpression>
	</parameter>
	<parameter name="ShowUniqueShipNumbers" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
	</parameter>
	<parameter name="ShowBarcode" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
	</parameter>
	<parameter name="ShowTracking" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT xo.id AS XOID, xo.fromlgid AS FromLGID, xo.shiptolgid AS ShipToLGID, ship.id AS ShipID, ship.statusid AS ShipStatus, ship.note AS ShipNote, ship.dateshipped AS ShipDate,
    xo.shiptoname AS ShipToName, xo.shiptoaddress AS ShipToAddress, xo.shiptocity AS ShipToCity, shipState.code AS ShipToState, xo.shiptozip AS ShipToZip,
    xo.fromname AS FromName, xo.fromaddress AS FromAddress, xo.fromcity AS FromCity, fromState.code AS FromState, xo.fromzip AS FromZip,
    xo.dateconfirmed as DateConfirmed, xo.datescheduled as ScheduledDate, xo.ownerisfrom as OwnerIsFrom, xotype.name as Type,
    fromlg.name AS FromLGName, shiptolg.name AS ShipToLGName, company.name AS company,
    COALESCE(ship.cartoncount,0) AS CartonCount, carrier.name AS CarrierName, xo.num AS XONum,
    shipcountry.name AS shipcountry, fromcountry.name AS fromcountry, ship.num AS shipnum,
    (SELECT s1.sysvalue
        FROM sysproperties s1
        WHERE s1.syskey = 'Barcodes have DI'
    ) AS BarcodesHaveDI

FROM ship
    INNER JOIN carrier ON (ship.carrierid = carrier.id)
    INNER JOIN xo ON (ship.xoId = xo.id)
    INNER JOIN locationgroup fromLG ON (xo.fromlgid = fromLG.id)
    INNER JOIN locationgroup shipToLG ON (xo.shiptolgid = shipToLG.id)
    JOIN xotype ON (xo.typeid = xotype.id)
    LEFT OUTER JOIN stateconst shipState ON (xo.shiptostateid = shipState.id)
    LEFT OUTER JOIN stateconst fromState ON (xo.fromstateid = fromState.id)
    LEFT OUTER JOIN countryconst shipCountry ON (xo.shiptocountryid = shipCountry.id)
    LEFT OUTER JOIN countryconst fromCountry ON (xo.fromcountryid = fromCountry.id)
    JOIN company ON company.id = 1

WHERE ship.id = $P{shipID}
  AND ship.ordertypeid = 40]]>
	</queryString>
