	<variable name="ORDERNUMBER" class="java.lang.String">
		<variableExpression><![CDATA[$F{BARCODESHAVEDI} == null ? $V{PREORDERNUMBER} :
	$F{BARCODESHAVEDI}.equals("true") && !$P{ShowUniqueShipNumbers} ? "T" + $V{PREORDERNUMBER} : $V{PREORDERNUMBER}]]></variableExpression>
	</variable>
	<variable name="PREORDERNUMBER" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[$P{ShowUniqueShipNumbers} ?
    $F{SHIPNUM} :
    $F{XONUM}]]></variableExpression>
	</variable>
	<variable name="Owner" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[( $F{OWNERISFROM}.intValue() == 1 ? $F{FROMLGNAME} : $F{SHIPTOLGNAME} )]]></variableExpression>
	</variable>
	<variable name="OwnerLGID" class="java.lang.Integer" resetType="None">
