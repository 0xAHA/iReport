	<subDataset name="SingletonTracking" uuid="b3c5e7a9-4d2f-4e8b-9c1a-6f8d2e4b7a3c">
		<parameter name="receiptitemid" class="java.lang.String"/>
		<queryString>
			<![CDATA[Select
Batch.Info as BATCH
,DATE(ExpDate.InfoDate) as EXPIRATION
,PID.Info as PALLETID
From receipt
join receiptitem on receiptitem.receiptid = receipt.id
left join trackinginfo batch on batch.recordid = receiptitem.id and batch.tableid = 1259138490 and batch.parttrackingid = 5
left join trackinginfo ExpDate on ExpDate.recordid = receiptitem.id and ExpDate.tableid = 1259138490 and ExpDate.parttrackingid = 3
left join trackinginfo PID on PID.recordid = receiptitem.id and PID.tableid = 1259138490 and PID.parttrackingid = 8
where receiptitem.id = $P{receiptitemid}]]>
		</queryString>
		<field name="BATCH" class="java.lang.String"/>
		<field name="EXPIRATION" class="java.sql.Timestamp"/>
		<field name="PALLETID" class="java.lang.String"/>
		<variable name="DateFormat" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[(System.getProperty("REPORT_DATE_FORMAT"))]]></variableExpression>
		</variable>
	</subDataset>
	<subDataset name="SerialTracking" uuid="c4d6f8b1-3e5a-4c9d-b2e4-7a9f1c3d5e8b">
		<parameter name="receiptitemid" class="java.lang.String"/>
		<queryString>
			<![CDATA[SELECT TrackingInfoSN.SERIALNUM
FROM TrackingInfo
  INNER JOIN TrackingInfoSN ON TrackingInfoSN.trackingInfoID = TrackingInfo.id
  INNER JOIN PartTracking ON TrackingInfoSN.partTrackingID = PartTracking.id
WHERE tableID=1259138490 AND recordID=$P{receiptitemid}
  ORDER BY trackingInfoID]]>
		</queryString>
		<field name="SERIALNUM" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
	</subDataset>
	<parameter name="module" class="java.lang.Object" isForPrompting="false">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="REPORTDESCRIPTION" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["This label displays part information and tracking details (Batch, Expiration, Serial Numbers) for received items."]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRangeNone" class="java.lang.String" isForPrompting="false"/>
	<parameter name="IncludeReceivedItems" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Boolean(true)]]></defaultValueExpression>
	</parameter>
	<parameter name="receiptID" class="java.lang.String">
		<defaultValueExpression><![CDATA["0"]]></defaultValueExpression>
	</parameter>
	<parameter name="IncludeItemBarcode" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Boolean(true)]]></defaultValueExpression>
	</parameter>
	<parameter name="DefaultLocationBarcode" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
	</parameter>
	<parameter name="path" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["../Labels/"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT RECEIPT.ID AS RECEIPTID, RECEIPTTYPE.NAME AS RECEIPTTYPE, part.num as partnum,
    RECEIPTSTATUS.NAME AS RECEIPTSTATUS, RECEIPTLG.NAME AS RECEIPTLOCATIONGROUP,
    RECEIPTLG.ID AS RECEIPTLOCATIONGROUPID, ORDERTYPE.NAME AS ORDERTYPE, ORDERTYPE.ID AS ORDERTYPEID,
    RECEIPTITEM.ID AS RECEIPTITEMID, RECEIPTITEMSTATUS.NAME AS RECEIPTITEMSTATUS,
    RECEIPTITEMSTATUS.ID AS RECEIPTITEMSTATUSID, RECEIPTITEM.QTY AS RECEIPTITEMQTY,
    UOM.CODE AS RECEIPTITEMUOM, MAINLOCATION.NAME AS RECEIPTITEMLOCNAME,
    MAINLG.NAME AS RECEIPTITEMLOCGRPNAME, MAINTAG.NUM AS RECEIPTITEMTAGNUM,

VENDOR.NAME as VENDORNAME,
VENDOR.ACCOUNTNUM as VENDORNUM,

    (CASE
        WHEN receiptitemstatus.id = 10 THEN defaultTag.num
        WHEN receiptitemstatus.id IN (20, 30, 40) THEN Tag.num
    END) AS DEFAULTLOCATION,
    (CASE
        WHEN receiptitemstatus.id = 10 THEN defaultLg.name
        WHEN receiptitemstatus.id IN (20, 30, 40) THEN mainLg.name
    END) AS LOCATIONLGNAME,
    (CASE
        WHEN receiptitemstatus.id = 10 THEN defaultLoc.name
        WHEN receiptitemstatus.id IN (20, 30, 40) THEN mainLocation.name
    END) AS LOCATIONNAME,
    (CASE
        WHEN part.num IS NULL THEN poitem.partnum
        ELSE part.num
    END) AS RECEIPTITEMPARTNUM,
    (CASE
        WHEN PART.DESCRIPTION IS NULL THEN POITEM.DESCRIPTION
        ELSE PART.DESCRIPTION
    END) AS RECEIPTITEMPARTDESC,
    (CASE
	WHEN RECEIPT.ORDERTYPEID = 10 THEN PO.NUM
	WHEN RECEIPT.ORDERTYPEID = 20 THEN SO.NUM
	WHEN RECEIPT.ORDERTYPEID = 40 THEN XO.NUM
    END) AS ORDERNUMBER,
    (CASE
	WHEN RECEIPT.ORDERTYPEID = 10 THEN VENDOR.NAME
	WHEN RECEIPT.ORDERTYPEID = 20 THEN CUSTOMER.NAME
	WHEN RECEIPT.ORDERTYPEID = 40 THEN XOLG.NAME
    END) AS ORDERNAME,
    (CASE
	WHEN RECEIPT.ORDERTYPEID = 10 THEN POITEM.NOTE
	WHEN RECEIPT.ORDERTYPEID = 20 THEN SOITEM.NOTE
	WHEN RECEIPT.ORDERTYPEID = 40 THEN XOITEM.NOTE
    END) AS RECEIPTITEMNOTE,
    COMPANY.NAME AS COMPANYNAME,
    (SELECT s1.sysvalue
        FROM sysproperties s1
        WHERE s1.syskey = 'Barcodes have DI'
        ) AS BARCODESHAVEDI


FROM receipt
    INNER JOIN receipttype ON (receipt.typeid = receipttype.id)
    INNER JOIN receiptstatus ON (receipt.statusid = receiptstatus.id)
    INNER JOIN locationgroup receiptlg ON (receipt.locationgroupid = receiptlg.id)
    LEFT OUTER JOIN ordertype ON (receipt.ordertypeid = ordertype.id)
    LEFT OUTER JOIN receiptitem ON ((receipt.id = receiptitem.receiptid))
    LEFT OUTER JOIN tag maintag ON (receiptitem.tagid = maintag.id)
    LEFT OUTER JOIN tag ON receiptitem.locationid = tag.locationid AND tag.typeid = 10
    LEFT OUTER JOIN location mainlocation ON (maintag.locationid = mainlocation.id)
    LEFT OUTER JOIN locationgroup mainlg ON (mainlocation.locationgroupid = mainlg.id)
    LEFT OUTER JOIN receiptitemstatus ON (receiptitem.statusid = receiptitemstatus.id)
    LEFT OUTER JOIN part ON (receiptitem.partid = part.id)
    LEFT OUTER JOIN defaultlocation ON (part.id = defaultlocation.partid AND receipt.locationgroupid = defaultlocation.locationgroupid)
    LEFT OUTER JOIN location defaultLoc ON (defaultlocation.locationid = defaultLoc.id)
    LEFT OUTER JOIN locationGroup defaultLg ON defaultLG.id = defaultLoc.locationGroupId
    LEFT OUTER JOIN tag defaultTag ON defaultLoc.id = defaultTag.locationId AND defaultTag.partId = 0
    LEFT OUTER JOIN uom ON (receiptitem.uomid = uom.id)
    LEFT OUTER JOIN po ON ((receipt.poid = po.id) AND (receipt.ordertypeid = 10))
    LEFT OUTER JOIN so ON ((receipt.soid = so.id) AND (receipt.ordertypeid = 20))
    LEFT OUTER JOIN xo ON ((receipt.xoid = xo.id) AND (receipt.ordertypeid = 40))
    LEFT OUTER JOIN vendor ON ((receipt.poid = po.id) AND (receipt.ordertypeid = 10) AND (vendor.id = po.vendorid))
    LEFT OUTER JOIN customer ON ((receipt.soid = so.id) AND (receipt.ordertypeid = 20) AND (customer.id = so.customerid))
    LEFT OUTER JOIN LocationGroup xolg ON ((receipt.xoid = xo.id) AND (receipt.ordertypeid = 40) AND (xolg.id = xo.fromlgid))
    LEFT OUTER JOIN poitem ON ((receiptitem.poitemid = poitem.id) AND (receipt.ordertypeid = 10))
    LEFT OUTER JOIN soitem ON ((receiptitem.soitemid = soitem.id) AND (receipt.ordertypeid = 20))
    LEFT OUTER JOIN xoitem ON ((receiptitem.xoitemid = xoitem.id) AND (receipt.ordertypeid = 40))
    JOIN company ON company.id = 1

WHERE receipt.id = $P!{receiptID}]]>
	</queryString>
	<field name="RECEIPTID" class="java.lang.Integer"/>
	<field name="RECEIPTTYPE" class="java.lang.String"/>
	<field name="RECEIPTSTATUS" class="java.lang.String"/>
	<field name="RECEIPTLOCATIONGROUP" class="java.lang.String"/>
	<field name="RECEIPTLOCATIONGROUPID" class="java.lang.Integer"/>
	<field name="ORDERTYPE" class="java.lang.String"/>
