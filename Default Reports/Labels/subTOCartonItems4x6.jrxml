		<defaultValueExpression><![CDATA["10"]]></defaultValueExpression>
	</parameter>
	<parameter name="path" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:Program Files/Fishbowl/server/reports/ship/"]]></defaultValueExpression>
	</parameter>
	<parameter name="ISSUBREPORTONLY" class="java.lang.String" isForPrompting="false"/>
	<parameter name="ShowTracking" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT shipitem.id AS ShipItemID, xoitem.lineitem AS XOLineItem, part.num AS PartNum, part.description AS PartDescription, xoitem.note AS Note,
    COALESCE(xoitem.qtytofulfill,0) AS QtyToFulfill, COALESCE(xoitem.qtyfulfilled,0) AS QtyFulfilled, COALESCE(xoitem.qtypicked,0) AS QtyPicked,
    uom.code AS UOMCode, company.name AS CompanyName,shipcarton.id AS shipCartonID, shipcarton.trackingnum AS TrackingNumber,
    shipcarton.freightweight AS Weight, shipcarton.id as cartonID, shipcarton.cartonnum AS CartonNumber,
    COALESCE((SELECT SUM(shipitem.qtyshipped)
       FROM shipitem
      WHERE shipitem.shipid = $P{ShipID}
        AND shipitem.xoItemId = xoitem.id
        AND shipitem.shipcartonid = shipcarton.id), 0) AS QtyShipped, COALESCE(weightUom.code, 'lbs') AS weightUomCode

FROM shipcarton, xoitem
    INNER JOIN uom ON (xoitem.uomid = uom.id)
    INNER JOIN part ON (xoitem.partid = part.id)
    LEFT OUTER JOIN shipitem ON ((shipitem.shipID = $P{ShipID}) AND (shipitem.xoItemId = xoitem.id))
    LEFT OUTER JOIN sysProperties ON sysProperties.sysKey = 'Default Weight UomId'
    LEFT OUTER JOIN uom weightUom ON sysProperties.sysValue = weightUom.id
    INNER JOIN company ON company.id = 1

WHERE xoitem.xoid = $P{XOID}
  AND part.typeid IN (10,21,22,30,40,50)
  AND xoitem.typeid = 10
  AND shipcarton.shipid = $P{ShipID}
  AND shipitem.shipcartonid = shipcarton.id

ORDER BY shipcarton.id, xoitem.lineitem]]>
	</queryString>
