	<queryString>
		<![CDATA[SELECT ship.id AS shipid

FROM ship

WHERE ship.statusid IN ($P{ckEntered},$P{ckPacked},$P{ckShipped})
  AND $P!{cbApplyDateFilter} BETWEEN $P{dateRange1} AND DATE_SUB($P{dateRange2}, INTERVAL 1 SECOND)]]>
	</queryString>
