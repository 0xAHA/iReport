			<property name="Tab" value="Field Titles"/>
			<property name="Group" value="Payments"/>
			<property name="Sort" value="4"/>
			<parameterDescription><![CDATA[Payment Button]]></parameterDescription>
		</parameter>
		<queryString>
			<![CDATA[SELECT 	so.num,
	so.datelastmodified AS sodatelastmodified,
	so.dateissued as sodateissued,
	so.datecompleted as sodatecompleted,
    	so.datecreated as sodatecreated,
	so.datefirstship as sodatefirstship,
	so.daterevision as sodaterevision,
	so.statusid,
    	so.revisionnum,
	so.locationgroupid,
	so.salesman,
	so.datefirstship,
	sostatus.name AS sostatus,
    	paymentterms.name AS paymentterms,
	fobpoint.name AS fobpoint,
	shipterms.name AS shippingterms,
    	carrier.name AS carriername,
	sysuser.firstname,
	sysuser.lastname,
	company.name AS company,
    	carrierservice.name AS shipservice,
	currency.code AS currencyCode,
	so.currencyRate AS currencyRate,
    	homeCurrency.code AS homeCurrencyCode,
	So.estimatedTax,
	so.customerpo,
          $P!{CustomField:SO1} AS socf1,
          $P!{CustomField:SO2} AS socf2,
          $P!{CustomField:SO3} AS socf3,
          $P!{CustomField:SO4} AS socf4,
          $P!{CustomField:SO5} AS socf5,
          $P!{CustomField:SO6} AS socf6,
          IF(STR_TO_DATE($P!{CustomField:SO1}, '%Y-%m-%d %H:%i:%s') IS NULL, 0, 1) AS socf1DateBoolean,
          IF(STR_TO_DATE($P!{CustomField:SO2}, '%Y-%m-%d %H:%i:%s') IS NULL, 0, 1) AS socf2DateBoolean,
          IF(STR_TO_DATE($P!{CustomField:SO3}, '%Y-%m-%d %H:%i:%s') IS NULL, 0, 1) AS socf3DateBoolean,
          IF(STR_TO_DATE($P!{CustomField:SO4}, '%Y-%m-%d %H:%i:%s') IS NULL, 0, 1) AS socf4DateBoolean,
          IF(STR_TO_DATE($P!{CustomField:SO5}, '%Y-%m-%d %H:%i:%s') IS NULL, 0, 1) AS socf5DateBoolean,
          IF(STR_TO_DATE($P!{CustomField:SO6}, '%Y-%m-%d %H:%i:%s') IS NULL, 0, 1) AS socf6DateBoolean,
          IF(STR_TO_DATE($P!{CustomField:SO1}, '%Y-%m-%d %H:%i:%s') IS NULL, NULL, $P!{CustomField:SO1}) AS socf1Date,
          IF(STR_TO_DATE($P!{CustomField:SO2}, '%Y-%m-%d %H:%i:%s') IS NULL, NULL, $P!{CustomField:SO2}) AS socf2Date,
          IF(STR_TO_DATE($P!{CustomField:SO3}, '%Y-%m-%d %H:%i:%s') IS NULL, NULL, $P!{CustomField:SO3}) AS socf3Date,
          IF(STR_TO_DATE($P!{CustomField:SO4}, '%Y-%m-%d %H:%i:%s') IS NULL, NULL, $P!{CustomField:SO4}) AS socf4Date,
          IF(STR_TO_DATE($P!{CustomField:SO5}, '%Y-%m-%d %H:%i:%s') IS NULL, NULL, $P!{CustomField:SO5}) AS socf5Date,
          IF(STR_TO_DATE($P!{CustomField:SO6}, '%Y-%m-%d %H:%i:%s') IS NULL, NULL, $P!{CustomField:SO6}) AS socf6Date

FROM 	so
    	INNER JOIN company ON company.id = 1
    	INNER JOIN carrier ON so.carrierid = carrier.id
    	INNER JOIN fobpoint ON so.fobpointid = fobpoint.id
    	INNER JOIN paymentterms ON so.paymenttermsid = paymentterms.id
    	INNER JOIN shipterms ON so.shiptermsid = shipterms.id
    	INNER JOIN sostatus ON sostatus.id = so.statusid
    	INNER JOIN customer ON so.customerId = customer.id
    	LEFT OUTER JOIN sysuser ON so.salesman = sysuser.username
    	LEFT OUTER JOIN carrierservice ON so.carrierserviceid = carrierservice.id
   	LEFT OUTER JOIN currency ON customer.currencyId = currency.id
   	LEFT OUTER JOIN currency AS homeCurrency ON homeCurrency.homeCurrency = 1

WHERE 	so.id = $P{soId}]]>
		</queryString>
