	<queryString>
		<![CDATA[SELECT PICK.ID AS PICKID, PICK.NUM AS PICKNUMBER, PICKTYPE.NAME AS PICKTYPE, PICKSTATUS.NAME AS PICKSTATUS,
    PRIORITY.NAME AS PICKPRIORITY, PICKLG.NAME AS PICKLOCATIONGROUP, PICKLG.ID AS PICKLOCATIONGROUPID,
    PICK.DATECREATED AS PICKDATECREATED, PICK.DATESCHEDULED AS PICKDATESCHEDULED, PICK.DATEFINISHED AS PICKDATEFINISHED,
    PICK.DATELASTMODIFIED AS PICKDATELASTMODIFIED, PICK.DATESTARTED AS PICKDATESTARTED,
    PICKITEM.ID AS PICKITEMID, PICKITEMSTATUS.NAME AS PICKITEMSTATUS, PICKITEMSTATUS.ID AS PICKITEMSTATUSID,
    PART.NUM AS PICKITEMPARTNUM, PART.DESCRIPTION AS PICKITEMPARTDESC, PICKITEM.QTY AS PICKITEMQTY, UOM.CODE AS PICKITEMUOM,
    COALESCE(MAINLOCATION.NAME, '') AS PICKITEMLOCNAME, COALESCE(MAINLG.NAME, '') AS PICKITEMLOCGRPNAME, MAINTAG.NUM AS PICKITEMTAGNUM,
    COALESCE(DESTLOCATION.NAME, '') AS PICKITEMDESTLOCNAME, COALESCE(DESTLG.NAME, '') AS PICKITEMDESTLOCGRPNAME,
    PICKITEM.SLOTNUM AS PICKITEMSLOTNUM, COMPANY.NAME AS COMPANY,
    (CASE
	WHEN PICKITEM.ORDERTYPEID = 10 THEN POITEM.NOTE
	WHEN PICKITEM.ORDERTYPEID = 20 THEN SOITEM.NOTE
	WHEN PICKITEM.ORDERTYPEID = 40 THEN XOITEM.NOTE
    END) AS PICKITEMNOTE, COALESCE(SOITEM.DESCRIPTION,PART.DESCRIPTION) AS SOITEMDESCRIPTION, CARRIER.NAME AS CARRIER,
    kitHeader.productNum AS kitHeaderName, kitHeader.description AS kitHeaderDescription, kitHeader.id AS kitFlag, so.id AS RECORDID,
    COALESCE($P!{CustomField:Item1}, "") AS itemcf1,
    COALESCE($P!{CustomField:Item2}, "") AS itemcf2,
    COALESCE($P!{CustomField:Item3}, "") AS itemcf3

FROM pick
    INNER JOIN picktype ON pick.typeid = picktype.id
    INNER JOIN pickstatus ON pick.statusid = pickstatus.id
    INNER JOIN priority ON pick.priority = priority.id
    INNER JOIN locationgroup picklg ON pick.locationgroupid = picklg.id
    LEFT OUTER JOIN pickitem ON pick.id = pickitem.pickid
    LEFT OUTER JOIN tag maintag ON COALESCE(pickitem.srctagid,pickitem.tagid) = maintag.id
    LEFT OUTER JOIN location mainlocation ON pickitem.srclocationid = mainlocation.id
    LEFT OUTER JOIN locationgroup mainlg ON mainlocation.locationgroupid = mainlg.id
    LEFT OUTER JOIN pickitemstatus ON pickitem.statusid = pickitemstatus.id
    LEFT OUTER JOIN part ON pickitem.partid = part.id
    LEFT OUTER JOIN uom ON pickitem.uomid = uom.id
    LEFT OUTER JOIN tag desttag ON pickitem.desttagid = desttag.id
    LEFT OUTER JOIN location destlocation ON desttag.locationid = destlocation.id
    LEFT OUTER JOIN locationgroup destlg ON destlocation.locationgroupid = destlg.id
    LEFT OUTER JOIN poitem ON (pickitem.poitemid = poitem.id AND pickitem.ordertypeid = 10)
    LEFT OUTER JOIN soitem ON (pickitem.soitemid = soitem.id AND pickitem.ordertypeid = 20)
    LEFT OUTER JOIN woitem ON (pickitem.woitemid = woitem.id AND pickitem.ordertypeid = 30)
    LEFT OUTER JOIN xoitem ON (pickitem.xoitemid = xoitem.id AND pickitem.ordertypeid = 40)
    LEFT OUTER JOIN so ON soitem.soid = so.id
    LEFT OUTER JOIN carrier ON so.carrierid = carrier.id
    JOIN company ON company.id = 1
    LEFT OUTER JOIN objectToObject AS obo ON obo.recordid1 = soitem.id AND obo.typeid = 30
    LEFT OUTER JOIN soitem AS kitHeader ON kitHeader.id = obo.recordid2 AND kitheader.typeid = 80

WHERE (pick.num = $P{pickNum})

ORDER BY IF($P!{ShowKitHeaders},COALESCE(kitheader.id,"ZZ"), COALESCE($P!{cbPrimarySortBy},'ZZ')),
COALESCE($P!{cbPrimarySortBy},'ZZ'),
COALESCE($P!{cbSecondarySortBy}, 'ZZ')]]>
	</queryString>
	<field name="PICKID" class="java.lang.Integer"/>
	<field name="PICKNUMBER" class="java.lang.String"/>
	<field name="PICKTYPE" class="java.lang.String"/>
	<field name="PICKSTATUS" class="java.lang.String"/>
	<field name="PICKPRIORITY" class="java.lang.String"/>
	<field name="PICKLOCATIONGROUP" class="java.lang.String"/>
	<field name="PICKLOCATIONGROUPID" class="java.lang.Integer"/>
	<field name="PICKDATECREATED" class="java.sql.Timestamp"/>
	<field name="PICKDATESCHEDULED" class="java.sql.Timestamp"/>
	<field name="PICKDATEFINISHED" class="java.sql.Timestamp"/>
	<field name="PICKDATELASTMODIFIED" class="java.sql.Timestamp"/>
	<field name="PICKDATESTARTED" class="java.sql.Timestamp"/>
	<field name="PICKITEMID" class="java.lang.Integer"/>
	<field name="PICKITEMSTATUS" class="java.lang.String"/>
