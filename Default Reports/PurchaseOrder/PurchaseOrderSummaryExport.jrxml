			<property name="Sort" value="3"/>
			<parameterDescription><![CDATA[po.num $P!{cbOrder},PO #,vendor.name $P!{cbOrder},Vendor,po.vendorso $P!{cbOrder},Vendor SO,po.customerso $P!{cbOrder},Customer SO,po.buyer $P!{cbOrder},Buyer,qbclass.name $P!{cbOrder},PO Class,locationgroup.name $P!{cbOrder},Location Group,postatus.name $P!{cbOrder},PO Status,po.datecreated $P!{cbOrder},Order Date Created, po.dateissued $P!{cbOrder}, Order Date Issued, po.datecompleted $P!{cbOrder}, Order Date Completed, po.dateconfirmed $P!{cbOrder}, Order Date Confirmed, $P!{CustomField:PO1} $P!{cbOrder}, PO Custom Field 1,$P!{CustomField:PO2} $P!{cbOrder}, PO Custom Field 2,$P!{CustomField:PO3} $P!{cbOrder}, PO Custom Field 3,$P!{CustomField:PO4} $P!{cbOrder}, PO Custom Field 4,$P!{CustomField:PO5} $P!{cbOrder}, PO Custom Field 5,$P!{CustomField:PO6} $P!{cbOrder}, PO Custom Field 6,part.num $P!{cbOrder}, Part Number, part.description $P!{cbOrder}, Part Description,poitem.qtyfulfilled $P!{cbOrder}, Qty Received, (poitem.qtytofulfill - poitem.qtyfulfilled) $P!{cbOrder}, Qty Remaining, poitem.qtytofulfill $P!{cbOrder}, Total Qty, uom.code $P!{cbOrder}, UOM, poitem.unitcost $P!{cbOrder}, Unit Cost, poitem.totalcost $P!{cbOrder}, Total Cost, poitemtype.name $P!{cbOrder}, Type, customerjob.name $P!{cbOrder}, Customer Job, poitemstatus.name $P!{cbOrder}, Item Status, POITEM.DATESCHEDULEDFULFILLMENT $P!{cbOrder}, Item Date Scheduled, POITEM.DATELASTFULFILLMENT $P!{cbOrder}, Item Date Fulfilled,poitem.revlevel $P!{cbOrder}, Revision,poitemclass.name $P!{cbOrder}, Item Class,$P!{CustomField:Item1} $P!{cbOrder}, POItem Custom Field 1,$P!{CustomField:Item2} $P!{cbOrder}, POItem Custom Field 2,$P!{CustomField:Item3} $P!{cbOrder}, POItem Custom Field 3,$P!{CustomField:Item4} $P!{cbOrder}, POItem Custom Field 4,$P!{CustomField:Item5} $P!{cbOrder}, POItem Custom Field 5,$P!{CustomField:Item6} $P!{cbOrder}, POItem Custom Field 6]]></parameterDescription>
			<defaultValueExpression><![CDATA["po.num $P!{cbOrder}"]]></defaultValueExpression>
		</parameter>
