		<parameter name="salesPersonBuyer" class="java.lang.String" isForPrompting="false">
			<parameterDescription><![CDATA[Buyer]]></parameterDescription>
			<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT LOCATIONGROUP.NAME AS LG,
   POITEM.TOTALCOST AS POITEMTOTALCOST,
   POITEM.DATESCHEDULEDFULFILLMENT AS POITEMDATESCHEDULEDFULFILLMENT,
   POITEM.UNITCOST AS POITEMUNITCOST,
   POITEM.QTYTOFULFILL AS POITEMQTYTOFULFILL,
   POITEM.QTYFULFILLED AS POITEMQTYFULFILLED,
   POITEM.PARTNUM AS POITEMPARTNUM,
   POITEM.DATELASTFULFILLMENT AS POITEMDATELASTFULFILLMENT,
   POITEM.DESCRIPTION AS POITEMDESCRIPTION,
   POITEM.NOTE AS POITEMNOTE,
   POITEM.POLINEITEM AS POLINEITEM,
   POITEM.REVLEVEL AS POITEMREVLEVEL,
   PO.REMITTONAME AS POREMITTONAME,
   PO.NUM AS PONUM,
   PO.DATEISSUED AS PODATEISSUED,
   PO.REVISIONNUM AS POREVISIONNUM,
   PO.BUYER AS POBUYER,
   PO.DATECOMPLETED AS PODATECOMPLETED,
   PO.DATECONFIRMED AS PODATECONFIRMED,
   PO.DATECREATED AS PODATECREATED,
   PO.DATEFIRSTSHIP AS PODATEFIRSTSHIP,
   PO.DATELASTMODIFIED AS PODATELASTMODIFIED,
   PO.DATEREVISION AS PODATEREVISION,
   PO.DELIVERTO AS PODELIVERTO,
   PO.NOTE AS PONOTE,
   POITEM.VENDORPARTNUM AS POITEMVENDORPARTNUM,
   PO.SHIPTONAME AS POSHIPTONAME,
   PO.USERNAME AS POUSERNAME,
   PO.VENDORCONTACT AS POVENDORCONTACT,
   PO.VENDORSO AS POVENDORSO,
   COALESCE(PART.DESCRIPTION, POITEM.DESCRIPTION) AS PARTDESCRIPTION,
   COALESCE(PART.NUM, POITEM.PARTNUM) AS PARTNUM,
   UOM.ID AS UOMID,
   UOM.CODE,
   UOM.NAME AS UOMNAME,
   COMPANY.NAME AS COMPANY,
   VENDOR.NAME AS VENDORNAME,
   POITEMSTATUS.NAME AS ITEMSTATUS,
   POSTATUS.NAME AS POSTATUS,
   QBCLASS.NAME AS CLASS,
   PART.ID AS PARTID,
   POITEM.STATUSID AS POITEMSTATUS,
   CURRENCY.SYMBOL,
   PO.VENDORSO,
   PO.CUSTOMERSO,
   PO.BUYER,
   QBCLASS.NAME AS POCLASS,
   POITEM.QTYTOFULFILL AS TOTALQTY,
   (POITEM.QTYTOFULFILL - POITEM.QTYFULFILLED) AS REMAININGQTY,
   POITEM.QTYFULFILLED AS QTYRECEIVED,
   POITEMTYPE.NAME AS POITEMTYPE,
   CUSTOMERJOB.NAME AS CUSTOMERJOB,
   POITEMCLASS.NAME AS POITEMCLASS,
   $P!{CustomField:PO1} AS pocf1,
    $P!{CustomField:PO2} AS pocf2,
    $P!{CustomField:PO3} AS pocf3,
    $P!{CustomField:PO4} AS pocf4,
    $P!{CustomField:PO5} AS pocf5,
    $P!{CustomField:PO6} AS pocf6,
    $P!{CustomField:Item1} AS itemcf1,
    $P!{CustomField:Item2} AS itemcf2,
    $P!{CustomField:Item3} AS itemcf3,
    $P!{CustomField:Item4} AS itemcf4,
    $P!{CustomField:Item5} AS itemcf5,
    $P!{CustomField:Item6} AS itemcf6

FROM po
   LEFT JOIN poitem ON poitem.poid = po.id
   LEFT JOIN part ON poitem.partid = part.id
   LEFT JOIN uom ON poitem.uomid = uom.id
   LEFT JOIN vendor ON po.vendorid = vendor.id
   LEFT JOIN locationgroup ON po.locationgroupid = locationgroup.id
   LEFT JOIN poitemstatus ON poitem.statusid = poitemstatus.id
   LEFT JOIN postatus ON po.statusid = postatus.id
   LEFT JOIN poitemtype ON poitem.typeid = poitemtype.id
   LEFT JOIN qbclass ON po.qbclassid = qbclass.id
   LEFT JOIN qbclass poitemclass ON poitem.qbclassid = poitemclass.id
   JOIN company ON company.id = 1
   LEFT JOIN currency ON currency.homeCurrency = 1
   LEFT JOIN customer customerjob ON poitem.customerid = customerjob.id

WHERE locationgroup.id IN ($P!{locationGroupID})
   AND vendor.id LIKE '$P!{vendorID}'
   AND COALESCE(part.num, '') LIKE $P{partNum}
   AND $P!{cbApplyDateFilter} BETWEEN $P{dateRange1} AND DATE_SUB($P{dateRange2}, INTERVAL 1 SECOND)
   AND po.qbclassid LIKE '$P!{qbClassID}'
   AND PO.statusID IN ($P!{ckBidRequest}, $P!{ckPendingApproval}, $P!{ckIssued}, $P!{ckPartial}, $P!{ckFulfilled}, $P!{ckClosedShort}, $P!{ckVoided})
   AND poitem.statusID IN ($P!{ckItemEntered}, $P!{ckItemPartial}, $P!{ckItemFulfilled}, $P!{ckItemClosedShort}, $P!{ckItemVoided})
   AND poitem.typeid IN ($P!{ckPurchase}, $P!{ckMiscPurchase}, $P!{ckCreditReturn}, $P!{ckMiscCreditReturn}, $P!{ckOutsourced}, $P!{ckShipping})
   AND COALESCE(UPPER($P!{cfFilter}),'') LIKE UPPER($P{cfFilterData})
   AND COALESCE(UPPER($P!{cfItemFilter}),'') LIKE UPPER($P{cfItemFilterData})
   AND po.buyer LIKE $P{salesPersonBuyer}

ORDER BY $P!{cbSortBy}]]>
		</queryString>
		<field name="pocf1" class="java.lang.String"/>
		<field name="pocf2" class="java.lang.String"/>
		<field name="pocf3" class="java.lang.String"/>
		<field name="pocf4" class="java.lang.String"/>
		<field name="pocf5" class="java.lang.String"/>
		<field name="pocf6" class="java.lang.String"/>
		<field name="itemcf1" class="java.lang.String"/>
		<field name="itemcf2" class="java.lang.String"/>
		<field name="itemcf3" class="java.lang.String"/>
		<field name="itemcf4" class="java.lang.String"/>
		<field name="itemcf5" class="java.lang.String"/>
		<field name="itemcf6" class="java.lang.String"/>
		<field name="LG" class="java.lang.String"/>
		<field name="POITEMTOTALCOST" class="java.lang.Double"/>
		<field name="POITEMDATESCHEDULEDFULFILLMENT" class="java.sql.Timestamp"/>
		<field name="POITEMUNITCOST" class="java.lang.Double"/>
		<field name="POITEMQTYTOFULFILL" class="java.lang.Double"/>
		<field name="POITEMQTYFULFILLED" class="java.lang.Double"/>
		<field name="POITEMPARTNUM" class="java.lang.String"/>
		<field name="POITEMDATELASTFULFILLMENT" class="java.sql.Timestamp"/>
		<field name="POITEMDESCRIPTION" class="java.lang.String"/>
		<field name="POITEMNOTE" class="java.lang.String"/>
		<field name="POLINEITEM" class="java.lang.Integer"/>
		<field name="POITEMREVLEVEL" class="java.lang.String"/>
		<field name="POREMITTONAME" class="java.lang.String"/>
		<field name="PONUM" class="java.lang.String"/>
		<field name="PODATEISSUED" class="java.sql.Timestamp"/>
		<field name="POREVISIONNUM" class="java.lang.Integer"/>
		<field name="POBUYER" class="java.lang.String"/>
		<field name="PODATECOMPLETED" class="java.sql.Timestamp"/>
		<field name="PODATECONFIRMED" class="java.sql.Timestamp"/>
		<field name="PODATECREATED" class="java.sql.Timestamp"/>
		<field name="PODATEFIRSTSHIP" class="java.sql.Timestamp"/>
		<field name="PODATELASTMODIFIED" class="java.sql.Timestamp"/>
		<field name="PODATEREVISION" class="java.sql.Timestamp"/>
		<field name="PODELIVERTO" class="java.lang.String"/>
		<field name="PONOTE" class="java.lang.String"/>
		<field name="POITEMVENDORPARTNUM" class="java.lang.String"/>
		<field name="POSHIPTONAME" class="java.lang.String"/>
		<field name="POUSERNAME" class="java.lang.String"/>
		<field name="POVENDORCONTACT" class="java.lang.String"/>
		<field name="POVENDORSO" class="java.lang.String"/>
		<field name="PARTDESCRIPTION" class="java.lang.String"/>
		<field name="PARTNUM" class="java.lang.String"/>
		<field name="UOMID" class="java.lang.Integer"/>
