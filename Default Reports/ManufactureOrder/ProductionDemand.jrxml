	<subDataset name="Short Summary" uuid="78c6e0e3-c9c6-4706-ab23-a81655ba3323">
		<parameter name="dateRange1" class="java.util.Date" isForPrompting="false">
			<parameterDescription><![CDATA[This Month]]></parameterDescription>
			<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
		</parameter>
		<parameter name="dateRange2" class="java.util.Date" isForPrompting="false">
			<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
		</parameter>
		<parameter name="customerID" class="java.lang.String" isForPrompting="false">
			<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
		</parameter>
		<parameter name="partNum" class="java.lang.String" isForPrompting="false">
			<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
		</parameter>
		<parameter name="woNum" class="java.lang.String" isForPrompting="false">
			<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
		</parameter>
		<parameter name="locationGroupID" class="java.lang.String" isForPrompting="false">
			<defaultValueExpression><![CDATA["-1"]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT part.num AS "Part #",
    SUM(woitem.qtytarget) AS "Needed",
    COALESCE(tag.qty, 0) AS "On Hand",
    COALESCE(tag.qty, 0) - SUM(woitem.qtytarget) AS "Short"

FROM wo
JOIN company ON company.id = 1
JOIN woitem ON wo.id = woitem.woid AND woitem.typeid = 10
JOIN part ON woitem.partid = part.id
JOIN moitem ON woitem.moitemid = moitem.id
LEFT JOIN soitem ON moitem.soitemid = soitem.id
LEFT JOIN so ON soitem.soid = so.id
LEFT JOIN customer ON so.customerid = customer.id
JOIN locationgroup ON wo.locationgroupid = locationgroup.id
LEFT JOIN (SELECT SUM(tag.qty) AS QTY, tag.partid, locationgroup.id AS locationGroupId
                FROM tag
                JOIN location ON tag.locationid = location.id
                JOIN locationgroup ON location.locationgroupid = locationgroup.id
                GROUP BY 2,3) AS Tag ON part.id = tag.partid AND wo.locationgroupid = tag.locationgroupid

WHERE wo.statusid < 40
AND COALESCE(tag.qty,0) - woitem.qtytarget < 0
AND wo.datecreated BETWEEN $P{dateRange1} AND $P{dateRange2}
AND part.num LIKE $P{partNum}
AND wo.num LIKE $P{woNum}
AND locationgroup.id IN ($P!{locationGroupID})
AND COALESCE(customer.id,0) LIKE $P{customerID}

GROUP BY part.num, tag.qty

ORDER BY part.num]]>
		</queryString>
		<field name="Part #" class="java.lang.String"/>
		<field name="Needed" class="java.lang.Double"/>
		<field name="On Hand" class="java.lang.Double"/>
		<field name="Short" class="java.lang.Double"/>
		<variable name="QtyDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_QTY")]]></variableExpression>
		</variable>
		<variable name="CostDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_COST")]]></variableExpression>
		</variable>
		<variable name="DateFormat" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[(System.getProperty("REPORT_DATE_FORMAT"))]]></variableExpression>
		</variable>
	</subDataset>
	<subDataset name="Raw Goods" uuid="08f988d4-623b-4928-a21e-035cc68eb515">
		<parameter name="woID" class="java.lang.String">
			<defaultValueExpression><![CDATA["-1"]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[Select part.num as partnumber, part.description,
    (woitem.qtytarget * COALESCE(uomconversion.multiply,1)) / COALESCE(uomconversion.factor, 1) as needed,
    COALESCE(tag.qty,0) as onhand, uom.code as partuom

from woitem
JOIN wo on woitem.woid = wo.id
JOIN part on woitem.partid = part.id
JOIN uom on part.uomid = uom.id
LEFT JOIN uomconversion ON (uomconversion.touomid = part.uomid AND uomconversion.fromuomid = woitem.uomid)
LEFT JOIN (SELECT SUM(tag.qty) as qty, tag.partid, location.locationgroupid AS locationgroupid
               from tag
	     JOIN location ON tag.locationid = location.id
               group by 2,3) as tag on woitem.partid = tag.partid and tag.locationgroupid = wo.locationgroupid


where woitem.typeid not in (10,31)
AND wo.id = $P{woID}]]>
		</queryString>
		<field name="PARTNUMBER" class="java.lang.String"/>
		<field name="DESCRIPTION" class="java.lang.String"/>
		<field name="NEEDED" class="java.lang.Double"/>
		<field name="ONHAND" class="java.lang.Double"/>
		<field name="PARTUOM" class="java.lang.String"/>
		<variable name="QtyDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_QTY")]]></variableExpression>
		</variable>
	</subDataset>
	<subDataset name="RawGoodsShort" uuid="3d777595-400e-4336-9e84-50f96895a5a0">
		<parameter name="dateRange1" class="java.util.Date" isForPrompting="false">
			<parameterDescription><![CDATA[This Month]]></parameterDescription>
			<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
		</parameter>
		<parameter name="dateRange2" class="java.util.Date" isForPrompting="false">
			<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
		</parameter>
		<parameter name="customerID" class="java.lang.String" isForPrompting="false">
			<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
		</parameter>
		<parameter name="partNum" class="java.lang.String" isForPrompting="false">
			<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
		</parameter>
		<parameter name="woNum" class="java.lang.String" isForPrompting="false">
			<defaultValueExpression><![CDATA["-1"]]></defaultValueExpression>
		</parameter>
		<parameter name="locationGroupID" class="java.lang.String" isForPrompting="false">
			<defaultValueExpression><![CDATA["-1"]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT part.num AS "Part #",
    SUM(woitem.qtytarget) AS "Needed",
    SUM(COALESCE(tag.qty, 0)) / count(woitem.id) AS "On Hand",
    SUM(COALESCE(tag.qty, 0)) / count(woitem.id) - SUM(woitem.qtytarget) AS "Short"

FROM wo
JOIN company ON company.id = 1
JOIN woitem ON wo.id = woitem.woid AND woitem.typeid not in (10,31)
JOIN part ON woitem.partid = part.id
JOIN moitem ON woitem.moitemid = moitem.id
LEFT JOIN soitem ON moitem.soitemid = soitem.id
LEFT JOIN so ON soitem.soid = so.id
LEFT JOIN customer ON so.customerid = customer.id
JOIN locationgroup ON wo.locationgroupid = locationgroup.id
LEFT JOIN (SELECT SUM(tag.qty) AS QTY, tag.partid, locationgroup.id AS locationGroupId
                FROM tag
                JOIN location ON tag.locationid = location.id
                JOIN locationgroup ON location.locationgroupid = locationgroup.id
                GROUP BY 2,3) AS Tag ON part.id = tag.partid AND wo.locationgroupid = tag.locationgroupid

WHERE wo.statusid < 40
AND COALESCE(tag.qty,0) - woitem.qtytarget < 0
AND wo.datecreated BETWEEN $P{dateRange1} AND $P{dateRange2}
AND part.num LIKE $P{partNum}
AND (wo.num in ($P!{woNum}))
AND locationgroup.id IN ($P!{locationGroupID})
AND COALESCE(customer.id,0) LIKE $P{customerID}

GROUP BY part.num

ORDER BY part.num]]>
		</queryString>
		<field name="Part #" class="java.lang.String"/>
		<field name="Needed" class="java.lang.Double"/>
		<field name="On Hand" class="java.lang.Double"/>
		<field name="Short" class="java.lang.Double"/>
		<variable name="QtyDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_QTY")]]></variableExpression>
		</variable>
	</subDataset>
	<parameter name="dateRange1" class="java.util.Date" isForPrompting="false">
		<parameterDescription><![CDATA[This Month]]></parameterDescription>
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRange2" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="customerID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="partNum" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="woNum" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="locationGroupID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["-1"]]></defaultValueExpression>
	</parameter>
	<parameter name="ShowRawGoods" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
	</parameter>
	<parameter name="path" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:/Program Files/Fishbowl/Server/reports/WorkOrder/"]]></defaultValueExpression>
	</parameter>
	<parameter name="module" class="java.lang.Object" isForPrompting="false">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="REPORTDESCRIPTION" class="java.lang.String">
		<parameterDescription><![CDATA[]]></parameterDescription>
		<defaultValueExpression><![CDATA["Shows inventory demand for finished goods with shortages in unfulfilled work orders. It details order allocations, summarizes production needs by part number, and provides insights into work orders driven by customer demand or stock replenishment."]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT wo.num AS "WO #", customer.name AS "Customer", part.num AS "Part #", part.description AS "Description", wo.datescheduled AS "Schedule Date",
    woitem.qtytarget AS "Needed", COALESCE(tag.qty, 0) AS "On Hand", COALESCE(tag.qty,0) - woitem.qtytarget AS "Short", company.name AS company, locationgroup.name AS LocationGroup, customfieldview.info AS machine, bom.estimatedduration,
    wo.id as woid, uom.code as partuom, wo.qtyTarget AS woQtyTarget

FROM wo
JOIN company ON company.id = 1
JOIN woitem ON wo.id = woitem.woid AND woitem.typeid = 10
JOIN part ON woitem.partid = part.id
JOIN uom ON part.uomid = uom.id
JOIN moitem ON woitem.moitemid = moitem.id
LEFT JOIN soitem ON moitem.soitemid = soitem.id
LEFT JOIN so ON soitem.soid = so.id
LEFT JOIN customer ON so.customerid = customer.id
JOIN locationgroup ON wo.locationgroupid = locationgroup.id
LEFT JOIN bom ON moitem.bomid = bom.id
LEFT JOIN customfieldview ON bom.id = customfieldview.recordid AND customfieldview.cfname = 'Machine' AND customfieldview.cftableid ='1705436292'
LEFT JOIN (SELECT SUM(tag.qty) AS QTY, tag.partid, locationgroup.id AS locationGroupId
                FROM tag
                JOIN location ON tag.locationid = location.id
                JOIN locationgroup ON location.locationgroupid = locationgroup.id
                GROUP BY 2,3) AS Tag ON part.id = tag.partid AND wo.locationgroupid = tag.locationgroupid

WHERE wo.statusid < 40
AND COALESCE(tag.qty,0) - woitem.qtytarget < 0
AND wo.datecreated BETWEEN $P{dateRange1} AND $P{dateRange2}
AND part.num LIKE $P{partNum}
AND wo.num LIKE $P{woNum}
AND locationgroup.id IN ($P!{locationGroupID})
AND COALESCE(customer.id,0) LIKE $P{customerID}

ORDER BY locationgroup.name, COALESCE(customer.name, 'zzz'), wo.num]]>
	</queryString>
	<field name="WO #" class="java.lang.String"/>
	<field name="Customer" class="java.lang.String"/>
	<field name="Part #" class="java.lang.String"/>
	<field name="Description" class="java.lang.String"/>
	<field name="Schedule Date" class="java.sql.Timestamp"/>
	<field name="Needed" class="java.lang.Double"/>
	<field name="On Hand" class="java.lang.Double"/>
