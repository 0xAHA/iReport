	<property name="ireport.callouts" value="##Wed Mar 25 15:35:47 MDT 2015\ncallouts.3.pins=619,208;\ncallouts.3.text=table 2 Finished Goods summary\n\ncallouts.2.pins=266,203;\ncallouts.2.text=table 3 Raw Goods Summary.\ncallouts.1.text=Version 1 \n3/20/15\ncallouts.3.bounds=597,267,150,75\ncallouts.2.bounds=198,256,150,75\ncallouts.1.bounds=-7,352,150,75"/>
