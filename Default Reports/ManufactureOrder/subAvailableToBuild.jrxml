	<style name="RestrictingAtb">
		<conditionalStyle>
			<conditionExpression><![CDATA[$F{TYPEID}!= 10 && $F{parttype} == 10 && ((($F{stageflag} ? $V{StageAvailableToBuild} < 0 ? 0 : $V{StageAvailableToBuild} : $F{QTYAVAILABLE} < 0 ? 0 : $F{QTYAVAILABLE}) / $V{UomConversion}) == $F{AvailableToBuild} || $V{UomConversion} > ($F{stageflag} ? $V{StageAvailableToBuild} < 0 ? 0 : $V{StageAvailableToBuild} : $F{QTYAVAILABLE} < 0 ? 0 : $F{QTYAVAILABLE}) || ($F{stageflag} ? $V{StageAvailableToBuild} < 0 ? 0 : $V{StageAvailableToBuild} : $F{QTYAVAILABLE} < 0 ? 0 : $F{QTYAVAILABLE}) < 0)]]></conditionExpression>
			<style mode="Opaque" backcolor="#FFFF66"/>
		</conditionalStyle>
	</style>
