	</parameter>
	<parameter name="parentcount" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="colLineNumber" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT LOCATIONGROUP.NAME AS LOCATIONGROUP,
       CONCAT(BOM.NUM,' - ',BOM.DESCRIPTION) AS BOMNUM,
       BOMITEMTYPE.NAME AS TYPE,
       BOMITEM.TYPEID AS TYPEID,
       CONCAT(PART.NUM,' - ',PART.DESCRIPTION) AS PART,
       BOMITEM.QUANTITY AS BOMQTY,
       COALESCE(QTYONHAND.QTY,0) - COALESCE(QTYALLOCATED.QTY,0) - COALESCE(QTYNOTAVAILABLE.QTY,0) + COALESCE(QTYDROPSHIP.QTY,0) AS QTYAVAILABLE,
       UOM.CODE AS BOMITEMUOM,
       COALESCE(UOMCONVERSION.FACTOR,1) AS FACTOR,
       COALESCE(UOMCONVERSION.MULTIPLY,1) AS MULTIPLY,
       bomitem.id bomitemid,
       PARTUOM.CODE AS PARTUOM,
       bomitem.stage AS stageflag,
       bomitem.stagebomid,
       locationgroup.id AS locationgroupid,
       part.typeid AS parttype, part.num AS partnum,
availableToBuild.qty AS AvailableToBuild,
availableToBuildStage.qty AS AvailableToBuildStage

from bom
JOIN bomitem on bom.id = bomitem.bomid and bomitem.groupdefault = 1 AND bomitem.typeid !=10
JOIN bomitem AS fg ON fg.bomid = bom.id AND fg.typeid = 10
JOIN bomitemtype on bomitem.typeid = bomitemtype.id
JOIN part on bomitem.partid = part.id
JOIN uom partuom on part.uomid = partuom.id
JOIN uom ON bomitem.uomid = uom.id
LEFT JOIN uomconversion ON bomitem.uomid = uomconversion.fromUomid AND uomconversion.touomid = part.uomid
LEFT JOIN locationgroup ON locationgroup.id IN ($P!{locationGroupID})
LEFT JOIN (Select sum(COALESCE(qtyonhand.qty,0)) as qty, qtyonhand.partid, qtyonhand.locationgroupid
                from  qtyonhand
                group by 2,3) as qtyonhand on part.id = qtyonhand.partid and qtyonhand.locationgroupid = locationgroup.id
LEFT JOIN (Select sum(COALESCE(qtyallocated.qty,0)) as qty, qtyallocated.partid, qtyallocated.locationgroupid
                from  qtyallocated
                group by 2,3) as qtyallocated on part.id = qtyallocated.partid and qtyallocated.locationgroupid = locationgroup.id
LEFT JOIN (Select sum(COALESCE(qtynotavailable.qty,0)) as qty, qtynotavailable.partid, qtynotavailable.locationgroupid
                from  qtynotavailable
                group by 2,3) as qtynotavailable on part.id = qtynotavailable.partid and qtynotavailable.locationgroupid = locationgroup.id
LEFT JOIN (Select sum(COALESCE(qtyDropship.qty,0)) as qty, qtyDropship.partid, qtydropship.locationgroupid
                from  qtyDropship
                group by 2,3) as qtyDropship on part.id = qtyDropship.partid and qtydropship.locationgroupid = locationgroup.id
JOIN company on company.id = 1
LEFT JOIN (SELECT locationgroup.id AS lgID,
	bom.id AS bomID,
	MIN(FLOOR(COALESCE(QINVENTORY.QA,0)/bomitem.quantity)) AS qty
	FROM bom
	LEFT JOIN bomitem ON bomitem.bomid = bom.id AND bomitem.groupdefault = true AND bomitem.typeid != 10
	INNER JOIN PART ON PART.ID = BOMITEM.PARTID AND PART.TYPEID = 10
	LEFT JOIN locationgroup ON locationgroup.id IN ($P!{locationGroupID})
	LEFT JOIN (
    		SELECT PARTID ID, LOCATIONGROUPID,
    		IF(SUM(QTYONHAND - QTYALLOCATED - QTYNOTAVAILABLE + QTYDROPSHIP) > 0,
    		SUM(QTYONHAND - QTYALLOCATED - QTYNOTAVAILABLE + QTYDROPSHIP), 0) QA
    		FROM QTYINVENTORYTOTALS QTYINV
    		WHERE QTYINV.LOCATIONGROUPID IN ($P!{locationGroupID})
    		GROUP BY 1, 2
	) QINVENTORY ON QINVENTORY.ID = BOMITEM.PARTID AND QINVENTORY.LOCATIONGROUPID = locationgroup.ID
	where bom.id = $P{bomID}
	GROUP BY locationgroup.id, bom.id
	ORDER BY bom.num, locationgroup.name
) AS availableToBuild ON availableToBuild.bomID = bom.id AND availableToBuild.lgID = locationgroup.id
LEFT JOIN (SELECT locationgroup.id AS lgID,
	bom.id AS bomID,
	MIN(FLOOR(COALESCE(QINVENTORY.QA,0)/bomitem.quantity)) AS qty
	FROM bom
	LEFT JOIN bomitem ON bomitem.bomid = bom.id AND bomitem.groupdefault = true AND bomitem.typeid != 10
	INNER JOIN PART ON PART.ID = BOMITEM.PARTID AND PART.TYPEID = 10
	LEFT JOIN locationgroup ON locationgroup.id IN ($P!{locationGroupID})
	LEFT JOIN (
    		SELECT PARTID ID, LOCATIONGROUPID,
    		IF(SUM(QTYONHAND - QTYALLOCATED - QTYNOTAVAILABLE + QTYDROPSHIP) > 0,
    		SUM(QTYONHAND - QTYALLOCATED - QTYNOTAVAILABLE + QTYDROPSHIP), 0) QA
    		FROM QTYINVENTORYTOTALS QTYINV
    		WHERE QTYINV.LOCATIONGROUPID IN ($P!{locationGroupID})
    		GROUP BY 1, 2
	) QINVENTORY ON QINVENTORY.ID = BOMITEM.PARTID AND QINVENTORY.LOCATIONGROUPID = locationgroup.ID
	where bom.id = $P{bomID}
	GROUP BY locationgroup.id, bom.id
	ORDER BY bom.num, locationgroup.name
) AS availableToBuildStage ON availableToBuildStage.bomID = bomitem.stagebomid AND availableToBuildStage.lgID = locationgroup.id

where bom.id = $P{bomID}
AND bomitem.typeid != 10

order by 1,2,3, bomitem.stage DESC,bomitem.sortidconfig]]>
	</queryString>
