	<variable name="UomConversion" class="java.lang.Double">
		<variableExpression><![CDATA[$F{BOMQTY} * $F{MULTIPLY} / $F{FACTOR}]]></variableExpression>
	</variable>
	<variable name="parentspacing" class="java.lang.String">
