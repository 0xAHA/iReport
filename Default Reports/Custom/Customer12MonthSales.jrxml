	<parameter name="REPORTDESCRIPTION" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["12-month customer sales report by product."]]></defaultValueExpression>
	</parameter>
	<parameter name="customerID" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[Customer ID (0 for all)]]></parameterDescription>
		<defaultValueExpression><![CDATA["0"]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRange1" class="java.util.Date" isForPrompting="false">
		<parameterDescription><![CDATA[Start Date]]></parameterDescription>
		<defaultValueExpression><![CDATA[new GregorianCalendar(new GregorianCalendar().get(Calendar.YEAR) - 1, new GregorianCalendar().get(Calendar.MONTH), 1).getTime()]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRange2" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    customer.name AS CUSTOMERNAME,
    COALESCE(product.num, soitem.productnum) AS PRODUCTNUM,
    product.description AS PRODUCTDESCRIPTION,
    postsoitem.qty AS QTY,
    postso.postdate AS POSTDATE,
    company.name AS COMPANY,
    currency.symbol AS SYMBOL
FROM postsoitem
    JOIN soitem ON postsoitem.soitemid = soitem.id
    JOIN so ON soitem.soid = so.id
    JOIN customer ON so.customerid = customer.id
    LEFT JOIN product ON soitem.productid = product.id
    LEFT JOIN postso ON postso.id = postsoitem.postsoid
    JOIN company ON company.id = 1
    LEFT JOIN currency ON currency.homecurrency = 1
WHERE (CAST($P{customerID} AS UNSIGNED) = 0 OR customer.id = CAST($P{customerID} AS UNSIGNED))
  AND postso.postdate BETWEEN $P{dateRange1} AND $P{dateRange2}
  AND soitem.typeid IN (10, 12, 80)
ORDER BY customer.name, product.num, postso.postdate]]>
	</queryString>
