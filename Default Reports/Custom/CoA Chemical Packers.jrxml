<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="CoA Chemical Packers" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="1510f9f1-fa14-4e47-a5fa-e0e3dc53fac5">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="96"/>
	<parameter name="module" class="java.lang.Object" isForPrompting="false">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="woNum" class="java.lang.String">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    wo.num                                    AS woNum,
    part.num                                  AS partNum,
    product.num                               AS productNum,
    wo.dateFinished                           AS dateFinished,
    CONCAT(sysuser.firstName, ' ', sysuser.lastName) AS userName,
    trackinginfo.info                         AS batchNum,
    CustomFieldByName(wo.customfields, 'pH (@20°C)')      AS result_ph,
    CustomFieldByName(wo.customfields, 'Specific Gravity') AS result_sg,
    CustomFieldByName(wo.customfields, 'Solid Content (%)') AS result_sc,
    CustomFieldByName(wo.customfields, 'Notes')           AS result_notes,
    CustomFieldByName(bom.customfields, 'ph Max')        AS phMax,
    CustomFieldByName(bom.customfields, 'pH Min')        AS phMin,
    CustomFieldByName(bom.customfields, 'SG Max')        AS sgMax,
    CustomFieldByName(bom.customfields, 'SG Min')        AS sgMin,
    CustomFieldByName(bom.customfields, 'Solids Max')    AS scMax,
    CustomFieldByName(bom.customfields, 'Solids Min')    AS scMin

FROM WO AS wo
INNER JOIN woItem
    ON wo.id = woItem.woId
INNER JOIN moItem AS mi
    ON woItem.moItemId = mi.id
INNER JOIN bom
    ON mi.bomId = bom.id
INNER JOIN part
    ON woItem.partId = part.id
INNER JOIN product
    ON product.partId = part.id
INNER JOIN sysuser
    ON wo.userId = sysuser.id
LEFT JOIN trackinginfo
    ON trackinginfo.recordid = woItem.id
    AND trackinginfo.tableid = -355941248
    AND trackinginfo.parttrackingid = 5

WHERE
    wo.num LIKE $P{woNum}
    AND woItem.typeID = 10;
]]>
	</queryString>
