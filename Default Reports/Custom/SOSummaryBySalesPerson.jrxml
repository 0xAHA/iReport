			<property name="Tab" value="Type"/>
			<property name="Group" value="Item Type"/>
			<parameterDescription><![CDATA[80,0]]></parameterDescription>
			<defaultValueExpression><![CDATA["80"]]></defaultValueExpression>
		</parameter>
		<parameter name="customerGroupID" class="java.lang.String" isForPrompting="false">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="CUSTOMERGROUP" class="java.lang.Boolean" isForPrompting="false">
			<property name="Tab" value="Hide/Show"/>
			<property name="Group" value="Order Fields"/>
			<parameterDescription><![CDATA[Customer Group]]></parameterDescription>
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="Carrier" class="java.lang.Boolean" isForPrompting="false">
			<property name="Tab" value="Hide/Show"/>
			<property name="Group" value="Order Fields"/>
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="DateCreated" class="java.lang.Boolean" isForPrompting="false">
			<property name="Tab" value="Hide/Show"/>
			<property name="Group" value="Order Fields"/>
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="VendorPO" class="java.lang.Boolean" isForPrompting="false">
			<property name="Tab" value="Hide/Show"/>
			<property name="Group" value="Order Fields"/>
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="vendorID" class="java.lang.String" isForPrompting="false">
			<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
		</parameter>
		<parameter name="ProductTree" class="java.lang.String" isForPrompting="false">
			<property name="Group" value="Filters"/>
		</parameter>
		<queryString>
			<![CDATA[SELECT
    $P!{cbGroupBy} AS GROUPBY,
    LOCATIONGROUP.NAME AS LG,
    CUSTOMER.NAME AS CUSTOMER,
    SO.NUM AS SO,
    SO.DATEISSUED,
    SOSTATUS.NAME AS STATUS,
    SO.SALESMAN AS "user",
    (case when $P{ckShowHistoricalProductNumber} = 1 then soitem.productnum else product.num end) AS PRODUCTNUM,
    UOM.CODE AS SOITEMUOMCODE,
    SOITEMSTATUS.NAME AS SOITEMSTATUS,
    SOITEM.DESCRIPTION,
    SOITEM.ID AS ITEMID,
    (SOITEM.UNITPRICE * SOITEM.QTYTOFULFILL) + SOITEM.ADJUSTAMOUNT AS OPRICE,
    SOITEM.QTYTOFULFILL AS QTYTOFULFILL,
    ROUND(
        ((SOITEM.QTYFULFILLED * SOITEM.UNITPRICE) +
            (IF(SOITEM.QTYTOFULFILL = 0,0,SOITEM.ADJUSTAMOUNT / SOITEM.QTYTOFULFILL) * SOITEM.QTYFULFILLED)) * 10
    ,1) / 10 AS FPRICE,
    soitem.qtyfulfilled AS QTYFULFILLED,
    MIN(SOITEM.DATESCHEDULEDFULFILLMENT) AS DATESCHEDULEDFULFILLMENT,
    SOITEM.DATESCHEDULEDFULFILLMENT AS ITEMFULFILLMENT,
    MIN(SO.DATEISSUED) AS MINDATEISSUED,
    SORDER.ORDERED,
    SORDER.SHIPPED,
    SORDER.ORDEREDQTY,
    SORDER.SHIPPEDQTY,
    POSTSO.POSTDATE,
    SO.DATEISSUED,
    CURRENCY.SYMBOL,
    SO.CUSTOMERPO,
    STATECONST.CODE AS SHIPTOSTATE,
    SOITEM.DATELASTFULFILLMENT,
    SO.DATEFIRSTSHIP,
    SO.DATECOMPLETED,
    qbclass.name AS class,
    soitemtype.name AS SOITEMTYPE,
    $P!{CustomField:SO1} AS socf1,
    $P!{CustomField:SO2} AS socf2,
    $P!{CustomField:SO3} AS socf3,
    $P!{CustomField:SO4} AS socf4,
    $P!{CustomField:SO5} AS socf5,
    $P!{CustomField:SO6} AS socf6,
    $P!{CustomField:Item1} AS itemcf1,
    $P!{CustomField:Item2} AS itemcf2,
    $P!{CustomField:Item3} AS itemcf3,
    $P!{CustomField:Item4} AS itemcf4,
    $P!{CustomField:Item5} AS itemcf5,
    $P!{CustomField:Item6} AS itemcf6,
COALESCE(ACCOUNTGROUP.NAME,'') AS CUSTGROUP,
CARRIER.NAME AS CARRIER,
SO.VENDORPO AS VENPO,
SO.DATECREATED AS DATECREATED,
SOITEM.TYPEID AS CREDIT

FROM
    so
    LEFT JOIN stateconst ON so.shiptostateid = stateconst.id
    INNER JOIN locationgroup ON locationgroup.id = so.locationgroupid
    INNER JOIN customer ON customer.id = so.customerid
    INNER JOIN sostatus ON sostatus.id = so.statusid
    INNER JOIN soitem ON soitem.soid = so.id
    LEFT JOIN soitemtype ON soitem.typeid = soitemtype.id
    LEFT JOIN product ON soitem.productid = product.id
    LEFT OUTER JOIN producttotree ON product.id = producttotree.productid
    LEFT OUTER JOIN producttree ON producttotree.producttreeid = producttree.id
    JOIN qbclass ON qbclass.id = so.qbclassid
    LEFT JOIN currency ON currency.homeCurrency = 1
    LEFT JOIN (
        SELECT
            postso.soid AS soid,
            MAX(postso.postdate) AS postdate
        FROM
            postso
        WHERE DATE(postso.postdate) BETWEEN $P{dateRange1} AND $P{dateRange2}
        GROUP BY postso.soid
    ) AS postso ON so.id = postso.soid
    INNER JOIN uom ON uom.id = soitem.uomid
    INNER JOIN soitemstatus ON soitem.statusid = soitemstatus.id
    INNER JOIN (
        SELECT
            SUM((soitem.unitprice * soitem.qtytofulfill) + soitem.adjustamount) AS ordered, SUM(soitem.qtytofulfill) AS orderedqty,
            SUM(soitem.qtyfulfilled) AS shippedqty,
            SUM(
                ROUND(
                    ((soitem.qtyfulfilled * soitem.unitprice) +
                        (IF(soitem.qtytofulfill = 0,0,soitem.adjustamount / soitem.qtytofulfill) * soitem.qtyfulfilled)) * 10
                    ,1) / 10
            ) AS shipped,
            soitem.soid
        FROM
            soitem
        WHERE soitem.typeid IN ($P!{ckSale}, $P!{ckMiscSale}, $P!{ckDropShip}, $P!{ckCreditReturn}, $P!{ckMiscCredit}, $P!{ckDiscountPercentage}, $P!{ckDiscountAmount}, $P!{ckAssoc.Price}, $P!{ckShipping}, $P!{ckTax}, $P!{ckKit})
        GROUP BY soitem.soid
    ) AS sorder ON so.id = sorder.soid
  LEFT JOIN (
      SELECT accountId,
         substring_index(GROUP_CONCAT(groupId ORDER BY id), ',', 1) AS groupId
      FROM accountGroupRelation
      WHERE groupId IN ($P!{customerGroupID})
      GROUP BY accountId
   ) AS accountGroupRelation ON accountGroupRelation.accountId = customer.accountId
   LEFT JOIN accountgroup ON accountgrouprelation.groupid = accountgroup.id
   LEFT OUTER JOIN CARRIER ON SO.CARRIERID = CARRIER.ID
   LEFT OUTER JOIN VENDORPARTS ON PRODUCT.PARTID = VENDORPARTS.PARTID AND VENDORPARTS.DEFAULTFLAG IS TRUE


WHERE
    soitem.typeid IN ($P!{ckSale}, $P!{ckMiscSale}, $P!{ckDropShip}, $P!{ckCreditReturn}, $P!{ckMiscCredit}, $P!{ckDiscountPercentage}, $P!{ckDiscountAmount}, $P!{ckAssoc.Price}, $P!{ckShipping}, $P!{ckTax}, $P!{ckKit})
    AND so.locationgroupid IN ($P!{locationGroupID})
    AND so.customerid LIKE $P{customerID}
    AND soitem.qbclassid LIKE $P{qbClassID}
    AND UPPER(so.salesman) LIKE UPPER($P{salesPerson})
    AND so.statusid IN ($P{ckEstimate}, $P{ckIssued}, $P{ckInProgress}, $P{ckFulfilled}, $P{ckClosedShort}, $P{ckVoided}, $P{ckExpired}, $P{ckCancelled})
    AND DATE($P!{cbApplyDateFilter}) BETWEEN $P{dateRange1} AND $P{dateRange2}
    AND COALESCE(product.num,'') LIKE $P{productNum}
    AND COALESCE(stateconst.name,'') LIKE $P!{cbShipToState/Province}
    AND COALESCE(UPPER($P!{cfFilter}),'') LIKE UPPER($P{cfFilterData})
    AND COALESCE(UPPER($P!{cfItemFilter}),'') LIKE UPPER($P{cfItemFilterData})
   AND COALESCE(accountgroup.id,0) IN ($P!{customerGroupID})
   AND IF($P{ProductTree} = "%", 1=1, COALESCE(producttree.name, '') LIKE $P{ProductTree})
   AND COALESCE(vendorparts.vendorid,'') LIKE $P{vendorID}




GROUP BY
    so.num, locationgroup.name, customer.name, so.dateissued, so.statusid,
    sostatus.name, so.salesman, soitem.productnum, uom.code, soitemstatus.name,
    sorder.ordered, itemfulfillment, sorder.shipped, soitem.description, soitem.id,
    soitem.totalprice, soitem.qtytofulfill, soitem.qtyfulfilled, soitem.unitprice, soitem.adjustamount,
    postso.postdate, qbclass.name, currency.symbol, stateconst.code

ORDER BY
    groupby, locationgroup.name, IF($P!{ckOrderByCustomer} = 1,customer.name,so.num), so.num]]>
		</queryString>
		<field name="LG" class="java.lang.String"/>
		<field name="CUSTOMER" class="java.lang.String"/>
		<field name="SO" class="java.lang.String"/>
		<field name="DATEISSUED" class="java.sql.Timestamp">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="STATUS" class="java.lang.String"/>
		<field name="user" class="java.lang.String"/>
		<field name="PRODUCTNUM" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="SOITEMUOMCODE" class="java.lang.String"/>
		<field name="SOITEMSTATUS" class="java.lang.String"/>
		<field name="DESCRIPTION" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="ITEMID" class="java.lang.Integer"/>
		<field name="OPRICE" class="java.lang.Double"/>
		<field name="QTYTOFULFILL" class="java.lang.Double">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="FPRICE" class="java.lang.Double"/>
		<field name="DATESCHEDULEDFULFILLMENT" class="java.sql.Timestamp">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="ITEMFULFILLMENT" class="java.sql.Timestamp"/>
		<field name="MINDATEISSUED" class="java.sql.Timestamp"/>
		<field name="ORDERED" class="java.lang.Double"/>
		<field name="SHIPPED" class="java.lang.Double"/>
