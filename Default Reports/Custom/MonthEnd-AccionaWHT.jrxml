	<subDataset name="InventoryValuation" uuid="9390145b-e955-4e35-bac4-742ad5ac2059">
		<queryString>
			<![CDATA[SELECT
  part.id AS PartID,
  part.num AS PartNumber,
  part.description AS PartDescription,
  SUM(tag.qty) AS Qty,
  ROUND(SUM(tag.qty * partcost.avgcost), 2) AS InventoryValue,
  partcost.avgcost AS AvgCost,
  CustomFieldByName(Part.CustomFields, "Cost Code") as CostCode
FROM part
JOIN partcost ON part.id = partcost.partid
JOIN tag ON part.id = tag.partid
JOIN location ON tag.locationid = location.id
WHERE part.activeFlag = 1]]>
		</queryString>
		<field name="PartID" class="java.lang.Integer"/>
		<field name="PartNumber" class="java.lang.String"/>
		<field name="PartDescription" class="java.lang.String"/>
		<field name="Qty" class="java.math.BigDecimal">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="InventoryValue" class="java.math.BigDecimal"/>
		<field name="AvgCost" class="java.math.BigDecimal">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="CostCode" class="java.lang.String"/>
		<variable name="CostDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_COST")]]></variableExpression>
		</variable>
	</subDataset>
	<subDataset name="Table Dataset 1" uuid="bbbb3a56-a601-4137-9b7e-5422fc6e5800"/>
	<parameter name="module" class="java.lang.Object" isForPrompting="false">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="locationGroupID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["-1"]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRange1" class="java.util.Date" isForPrompting="false">
		<parameterDescription><![CDATA[This Month]]></parameterDescription>
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRange2" class="java.util.Date" isForPrompting="false">
		<parameterDescription><![CDATA[]]></parameterDescription>
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT * FROM (
SELECT
    'PO' AS grping,
    part.num AS partnum,
    CAST(receiptitem.dateReceived AS DATETIME) AS itemDate,
    part.description,
    part.id AS part_id,
    SUM(receiptitem.qty) AS qty,
    vendor.name AS partner_name,
    vendor.accountNum AS partner_num,
    lg.name AS location,
    ROUND(SUM(receiptitem.qty * poitem.unitcost), 2) AS subtotal,
    CAST(po.num AS CHAR) AS ordernum,
    poitem.unitcost AS cost,
    CustomFieldByName(Part.CustomFields, "Cost Code") AS CostCode

  FROM receipt
  JOIN receiptitem ON receiptitem.receiptId = receipt.id
  JOIN part ON part.id = receiptitem.partId
  JOIN poitem ON poitem.id = receiptitem.poitemid
  JOIN po ON po.id = poitem.poid
  JOIN vendor ON vendor.id = po.vendorid
  JOIN location loc ON loc.id = receiptitem.locationid
  JOIN locationgroup lg ON lg.id = loc.locationGroupId

  WHERE receiptitem.dateReceived BETWEEN $P{dateRange1} AND DATE_SUB($P{dateRange2}, INTERVAL 1 SECOND)
    AND lg.id IN ($P!{locationGroupID})
  GROUP BY part.id, part.num, part.description, vendor.name, loc.name, poitem.unitcost, po.num, receiptitem.dateReceived

  UNION ALL

  SELECT
    'SO' AS grping,
    part.num AS partnum,
    CAST(postso.postdate AS DATETIME) AS itemDate,
    part.description,
    part.id AS part_id,
    SUM(postsoitem.qty) AS qty,
    vendor.name AS partner_name,
    vendor.accountNum AS partner_num,
    lg.name AS location,
    ROUND(SUM(postsoitem.postedTotalCost), 2) AS subtotal,
    CAST(so.num AS CHAR) AS ordernum,
    ROUND(SUM(postsoitem.postedTotalCost) / SUM(postsoitem.qty), 2) AS cost,
    -- postsoitem.postedTotalCost / postsoitem.qty AS cost,
    CustomFieldByName(Part.CustomFields, "Cost Code") AS CostCode

  FROM postso
  JOIN postsoitem ON postsoitem.postsoId = postso.id
  JOIN soitem ON soitem.id = postsoitem.soitemid
  JOIN product ON product.id = soitem.productid
  JOIN part ON part.id = product.partid
  JOIN so ON so.id = soitem.soid
  JOIN customer ON customer.id = so.customerid
  JOIN locationgroup lg ON lg.id = so.locationgroupid
  JOIN vendorparts ON vendorparts.partid = part.id
  JOIN vendor ON vendor.id = vendorparts.vendorid

  WHERE postso.postdate BETWEEN $P{dateRange1} AND DATE_SUB($P{dateRange2}, INTERVAL 1 SECOND)
    AND lg.id IN ($P!{locationGroupID})
    AND vendorparts.defaultflag = 1
  GROUP BY part.id, part.num, part.description, vendor.name, so.num, lg.name, soitem.unitprice, postso.postdate
) AS combined

ORDER BY
  grping]]>
	</queryString>
