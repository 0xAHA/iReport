	</variable>
	<variable name="CostCodeSubtotal" class="java.math.BigDecimal" resetType="Group" resetGroup="CostCode" calculation="Sum">
		<variableExpression><![CDATA[$F{subtotal}]]></variableExpression>
	</variable>
	<variable name="GrandTotal" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{subtotal}]]></variableExpression>
	</variable>
	<variable name="TotalPO" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{grping}.equals("PO") ? $F{subtotal} : new java.math.BigDecimal(0)]]></variableExpression>
		<initialValueExpression><![CDATA[$F{subtotal}]]></initialValueExpression>
	</variable>
	<variable name="TotalSO" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{grping}.equals("SO") ? $F{subtotal} : new java.math.BigDecimal(0)]]></variableExpression>
		<initialValueExpression><![CDATA[$F{subtotal}]]></initialValueExpression>
	</variable>
	<variable name="NetMovement" class="java.math.BigDecimal">
		<initialValueExpression><![CDATA[$V{TotalPO}.subtract($V{TotalSO})]]></initialValueExpression>
	</variable>
