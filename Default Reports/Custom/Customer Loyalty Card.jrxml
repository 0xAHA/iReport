<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Customer Loyalty Card" pageWidth="243" pageHeight="153" columnWidth="215" leftMargin="14" rightMargin="14" topMargin="14" bottomMargin="14" uuid="f4c369f8-cdb7-42f7-b5d1-b3e694ad0fec">
	<property name="ireport.zoom" value="3.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="customerID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="module" class="java.lang.Object" isForPrompting="false">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
customer.name AS CUSTOMERNAME,
customer.number AS CUSTOMERNUMBER,
customer.dateCreated AS CUSTOMERSINCE,
DATE_ADD(CustomFieldByName(CUSTOMER.customfields, 'Last Renewal'), INTERVAL 1 YEAR) AS EXPIRYDATE,
COALESCE(contact.contactName, address.name) AS CUSTOMERCONTACT,
company.name AS COMPANY
FROM
CUSTOMER
LEFT JOIN account ON customer.accountid = account.id
LEFT JOIN address ON account.id = address.accountid AND address.typeid = 50
LEFT JOIN contact ON address.id = contact.addressid AND contact.defaultFlag = 1
LEFT JOIN company ON company.id = 1
WHERE customer.id = $P{customerID}]]>
	</queryString>
	<field name="CUSTOMERNAME" class="java.lang.String"/>
	<field name="CUSTOMERCONTACT" class="java.lang.String"/>
	<field name="CUSTOMERNUMBER" class="java.lang.String"/>
	<field name="CUSTOMERSINCE" class="java.sql.Timestamp"/>
	<field name="EXPIRYDATE" class="java.sql.Timestamp"/>
	<field name="COMPANY" class="java.lang.String"/>
