<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="_ReceivingLabel" pageWidth="226" pageHeight="113" columnWidth="216" leftMargin="5" rightMargin="5" topMargin="5" bottomMargin="5" uuid="f840f8a8-84f9-4f21-8b26-4d368008fbba">
	<property name="ireport.zoom" value="3.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<style name="center" hAlign="Center" vAlign="Middle"/>
	<parameter name="receiptID" class="java.lang.String">
		<defaultValueExpression><![CDATA["0"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[CALL CreateList(1000, 'createlist');
Select
Part.Num as PartNum
,Part.Description as Description
,TrackingInfo.Info as Batch

From Receipt
Join ReceiptItem on ReceiptItem.ReceiptId = Receipt.Id
Join Part on Part.Id = ReceiptItem.PartId
Left Join TrackingInfo on TrackingInfo.RecordId = ReceiptItem.Id and TrackingInfo.TableId = 1259138490 and trackingInfo.parttrackingid = 1
left join tmp_createlist as copy on copy.cnt <= Coalesce(ReceiptItem.Qty,1)

Where Receipt.Id LIKE $P{receiptID}
and ReceiptItem.StatusId >= 30
and Part.TypeId IN (10,30)

Order By 1,3]]>
	</queryString>
	<field name="PartNum" class="java.lang.String"/>
	<field name="Description" class="java.lang.String"/>
	<field name="Batch" class="java.lang.String"/>
	<variable name="barcodeBatch" class="java.lang.String" resetType="Page">
		<variableExpression><![CDATA[$F{Batch}]]></variableExpression>
	</variable>
	<variable name="barcodePart" class="java.lang.String" resetType="Page">
		<variableExpression><![CDATA[$F{PartNum}]]></variableExpression>
	</variable>
	<background>
		<band splitType="Stretch"/>
	</background>
	<detail>
		<band height="103" splitType="Stretch">
			<textField>
				<reportElement x="50" y="18" width="166" height="35" uuid="6ec0f336-77e9-4326-b989-25c8c772fda4"/>
				<box topPadding="2" leftPadding="8"/>
				<textElement verticalAlignment="Top">
					<font fontName="Open Sans" size="8" isItalic="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{Description}]]></textFieldExpression>
			</textField>
			<image hAlign="Center">
				<reportElement x="166" y="53" width="50" height="50" uuid="7fb9089b-06a9-42d3-85f3-4d483be9dda3">
					<printWhenExpression><![CDATA[$F{Batch} != null]]></printWhenExpression>
				</reportElement>
				<imageExpression><![CDATA["https://bwipjs-api.metafloor.com/?bcid=qrcode&text="+ URLEncoder.encode($V{barcodeBatch}, "UTF-8")+"&scale=10"]]></imageExpression>
			</image>
			<staticText>
				<reportElement x="0" y="54" width="166" height="15" uuid="650dc0ea-ab1c-4756-aac4-5cf5ff43c1d8">
					<printWhenExpression><![CDATA[$F{Batch} != null]]></printWhenExpression>
				</reportElement>
				<box rightPadding="8"/>
				<textElement textAlignment="Right">
					<font fontName="Open Sans" size="7"/>
				</textElement>
				<text><![CDATA[Batch No.]]></text>
			</staticText>
			<textField>
				<reportElement x="0" y="59" width="166" height="21" uuid="e7046c5c-13e3-4bd1-a518-5c3ecfe5fc78">
					<printWhenExpression><![CDATA[$F{Batch} != null]]></printWhenExpression>
				</reportElement>
				<box rightPadding="8"/>
				<textElement textAlignment="Right" verticalAlignment="Bottom">
					<font fontName="Open Sans" size="12" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{Batch}]]></textFieldExpression>
			</textField>
			<image hAlign="Center">
				<reportElement x="0" y="0" width="50" height="50" uuid="ba881091-5790-4e7d-9e22-f9eac8e3d680"/>
				<imageExpression><![CDATA["https://bwipjs-api.metafloor.com/?bcid=qrcode&text="+ URLEncoder.encode($V{barcodePart}, "UTF-8")+"&scale=10"]]></imageExpression>
			</image>
			<textField>
				<reportElement x="50" y="5" width="166" height="21" uuid="695aaef1-2350-45bf-a55e-b173eb195f2d"/>
				<box topPadding="2" leftPadding="8"/>
				<textElement verticalAlignment="Top">
					<font fontName="Open Sans" size="10" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{PartNum}]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="50" y="0" width="166" height="15" uuid="f8ab2eae-4239-43ac-b428-80346b9897cb"/>
				<box leftPadding="8"/>
				<textElement>
					<font fontName="Open Sans" size="7"/>
				</textElement>
				<text><![CDATA[Part]]></text>
			</staticText>
		</band>
	</detail>
</jasperReport>
