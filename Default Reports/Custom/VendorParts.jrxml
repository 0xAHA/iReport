	<parameter name="vendorName" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="ReportTitle" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["Vendor Parts Report"]]></defaultValueExpression>
	</parameter>
	<parameter name="ShowTimeStamp" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT 
    CASE WHEN vendor.NAME IS NULL THEN 1 ELSE 0 END AS HASVENDOR,
    part.NUM AS PARTNUM,
    part.DESCRIPTION,
    COALESCE(vendor.NAME, 'NO DEFAULT VENDOR') AS VENDORNAME,
    vendorparts.vendorPartNumber AS VENDORPARTNUM,
    uom.CODE AS UOMCODE,
    part.abccode,
    company.NAME AS COMPANYNAME
FROM part
    LEFT JOIN vendorparts ON part.id = vendorparts.partid AND vendorparts.defaultflag = 1
    LEFT JOIN vendor ON vendorparts.vendorid = vendor.id
    LEFT JOIN uom ON part.uomid = uom.id
    INNER JOIN company ON company.id = 1
WHERE part.typeid = 10
    AND part.activeflag = 1
    AND (vendor.NAME LIKE $P{vendorName} OR ($P{vendorName} = '%' AND vendor.NAME IS NULL))
ORDER BY HASVENDOR, VENDORNAME, PARTNUM]]>
	</queryString>
	<field name="HASVENDOR" class="java.lang.Integer"/>
	<field name="PARTNUM" class="java.lang.String"/>
	<field name="DESCRIPTION" class="java.lang.String"/>
	<field name="VENDORNAME" class="java.lang.String"/>
	<field name="VENDORPARTNUM" class="java.lang.String"/>
	<field name="UOMCODE" class="java.lang.String"/>
	<field name="abccode" class="java.lang.String"/>
	<field name="COMPANYNAME" class="java.lang.String"/>
