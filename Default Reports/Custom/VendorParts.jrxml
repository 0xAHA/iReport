						<bottomPen lineWidth="1.0"/>
					</box>
					<textElement verticalAlignment="Middle">
						<font fontName="Open Sans" size="12" isBold="true"/>
					</textElement>
					<text><![CDATA[Parts Without Default Vendor]]></text>
				</staticText>
			</band>
		</groupHeader>
	</group>
