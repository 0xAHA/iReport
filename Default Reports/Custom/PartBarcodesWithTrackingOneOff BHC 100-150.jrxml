<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="PartBarcodesWithTrackingOneOff" pageWidth="425" pageHeight="283" whenNoDataType="AllSectionsNoDetail" columnWidth="419" leftMargin="3" rightMargin="3" topMargin="3" bottomMargin="3" uuid="e8a3f5c9-7d2b-4a6e-b1c8-9f4e2d6a8c5b">
