<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Sales_Report_with_Samples" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="a1b2c3d4-e5f6-47a8-b9c0-d1e2f3a4b5c6">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<property name="net.sf.jasperreports.export.xls.white.page.background" value="false"/>
	<property name="net.sf.jasperreports.export.xls.remove.empty.space.between.columns" value="true"/>
	<property name="net.sf.jasperreports.export.xls.remove.empty.space.between.rows" value="true"/>
	<parameter name="dateRange1" class="java.util.Date" isForPrompting="false">
		<parameterDescription><![CDATA[Last 7 Days]]></parameterDescription>
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRange2" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
  COALESCE(so.salesman, 'TOTAL') AS 'Sales Person',
  SUM(si.totalPrice) AS 'Product Sales',
  SUM(CASE WHEN so.billtoName = 'Samples'
           THEN si.qtyFulfilled ELSE 0 END) AS 'Samples Given',
  so.dateCompleted AS lastDate
FROM SO so
JOIN SOITEM si
  ON si.soId = so.Id
JOIN producttotree ptt
  ON ptt.productID = si.productID
WHERE
  si.dateLastFulfillment BETWEEN $P{dateRange1} AND $P{dateRange2}
  AND so.statusId IN (60, 70)
  AND ptt.producttreeId IN (4, 5, 6, 7, 8)
  AND so.salesman <> 'admin'
GROUP BY
  so.salesman WITH ROLLUP
ORDER BY
  CASE WHEN so.salesman IS NULL THEN 2 ELSE 1 END,
  so.salesman]]>
	</queryString>
	<field name="Sales Person" class="java.lang.String"/>
	<field name="Product Sales" class="java.math.BigDecimal"/>
	<field name="Samples Given" class="java.math.BigDecimal"/>
	<field name="lastDate" class="java.sql.Timestamp"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band height="50" splitType="Stretch">
			<staticText>
				<reportElement x="0" y="0" width="555" height="30" uuid="b2c3d4e5-f6a7-48b9-c0d1-e2f3a4b5c6d7"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font size="16" isBold="true"/>
				</textElement>
				<text><![CDATA[Sales Report with Samples]]></text>
			</staticText>
			<textField>
				<reportElement x="0" y="30" width="555" height="20" uuid="c3d4e5f6-a7b8-49c0-d1e2-f3a4b5c6d7e8"/>
				<textElement textAlignment="Center">
					<font size="10"/>
				</textElement>
				<textFieldExpression><![CDATA["Period: " +
new java.text.SimpleDateFormat("dd/MM/yyyy").format($P{dateRange1}) +
" to " +
new java.text.SimpleDateFormat("dd/MM/yyyy").format(new java.util.Date($P{dateRange2}.getTime() - 86400000))]]></textFieldExpression>
			</textField>
		</band>
	</title>
	<columnHeader>
		<band height="20" splitType="Stretch">
			<staticText>
				<reportElement mode="Opaque" x="0" y="0" width="250" height="20" backcolor="#CCCCCC" uuid="d4e5f6a7-b8c9-40d1-e2f3-a4b5c6d7e8f9"/>
				<box>
					<pen lineWidth="0.5"/>
					<topPen lineWidth="0.5"/>
