<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="CommissionByRepBySO" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="b84b1a7e-afc0-4746-b7c6-327a1b0b72e2">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="dateRange1" class="java.util.Date" isForPrompting="false">
		<parameterDescription><![CDATA[This Month]]></parameterDescription>
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRange2" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="salesPerson" class="java.lang.String">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT SO.SALESMAN AS SALESMAN
	,CUSTOMER.NUMBER AS CUSTOMER_NUMBER
	,CUSTOMER.NAME AS CUSTOMER_NAME
	,SO.NUM AS DOCUMENT_NUMBER
	,SO.SALESMANID AS SALESMANID
	,POSTSO.POSTDATE AS DATE_COMPLETED
	,SUM(POSTSOITEM.TOTALPRICE) AS SUB_TOTAL
	,SUM(POSTSOITEM.TOTALTAX) AS TAX
	,SUM(POSTSOITEM.POSTEDTOTALCOST) AS TOTAL_COST
	,CAST(CustomFieldByName(SysUser.CustomFields, 'COMMISSION') AS DECIMAL(10, 2)) AS REPCOMMISSIONRATE
	,PART.TYPEID AS PARTTYPEID
FROM POSTSO
JOIN POSTSOITEM ON POSTSOITEM.POSTSOID = POSTSO.ID
JOIN SOITEM ON SOITEM.ID = POSTSOITEM.SOITEMID
JOIN SO ON SO.ID = SOITEM.SOID
LEFT JOIN SYSUSER ON SYSUSER.ID = SO.SALESMANID
LEFT JOIN CUSTOMER ON CUSTOMER.ID = SO.CUSTOMERID
LEFT JOIN PRODUCT ON PRODUCT.ID = SOITEM.PRODUCTID
JOIN PART ON PART.ID = PRODUCT.PARTID
JOIN COMPANY ON COMPANY.ID = 1
WHERE POSTSO.POSTDATE BETWEEN $P{dateRange1}
		AND DATE_SUB($P{dateRange2}, INTERVAL 1 SECOND)
	AND UPPER(SO.SALESMAN) LIKE UPPER($P{salesPerson})
	AND SoItem.TypeId IN (10)
	AND PART.TYPEID IN (10)
GROUP BY 1
	,3
	,4
ORDER BY 1
	,3
	,4 ASC]]>
	</queryString>
