	<subDataset name="orderInfo" uuid="96b5790c-d0a8-4f9b-98bb-d34e4b6dcd59">
		<parameter name="shipID" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="colSalesPerson" class="java.lang.Boolean">
			<parameterDescription><![CDATA[Sales Person]]></parameterDescription>
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="colPaymentTerms" class="java.lang.Boolean">
			<parameterDescription><![CDATA[Payment Terms]]></parameterDescription>
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="colFOBPoint" class="java.lang.Boolean">
			<parameterDescription><![CDATA[FOB Point]]></parameterDescription>
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="colShippingTerms" class="java.lang.Boolean">
			<parameterDescription><![CDATA[Shipping Terms]]></parameterDescription>
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="colShipVia" class="java.lang.Boolean">
			<parameterDescription><![CDATA[Carrier]]></parameterDescription>
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="colReqShipDate" class="java.lang.Boolean">
			<parameterDescription><![CDATA[Requested Ship Date]]></parameterDescription>
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="colOrderCurrency" class="java.lang.Boolean" isForPrompting="false">
			<parameterDescription><![CDATA[Order Currency]]></parameterDescription>
			<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
		</parameter>
		<parameter name="colOrderCurrencyRate" class="java.lang.Boolean" isForPrompting="false">
			<parameterDescription><![CDATA[Order Currency Rate]]></parameterDescription>
			<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT so.salesMan AS soSeller, paymentTerms.name AS paymentTerms, fobPoint.name AS fobPoint, shipTerms.name AS shippingTerms, carrier.name AS carrier, so.dateFirstShip AS shipDate, currency.code AS currencyCode, currency.symbol, so.currencyRate, homeCurrency.code AS homeCurrencyCode
FROM so
        INNER JOIN paymentTerms ON so.paymentTermsId = paymentTerms.id
        INNER JOIN fobPoint ON so.fobPointId = fobPoint.id
        INNER JOIN shipTerms ON so.shipTermsId = shipTerms.id
        INNER JOIN ship ON ship.orderTypeId = 20 AND ship.soId = so.id
        INNER JOIN carrier ON ship.carrierId = carrier.id
        INNER JOIN customer on so.customerid = customer.id
        LEFT OUTER JOIN currency on customer.currencyid = currency.id
        LEFT OUTER JOIN currency AS homeCurrency on homeCurrency.homeCurrency = 1

WHERE ship.id = $P{shipID}]]>
		</queryString>
		<field name="SOSELLER" class="java.lang.String"/>
		<field name="PAYMENTTERMS" class="java.lang.String"/>
		<field name="FOBPOINT" class="java.lang.String"/>
		<field name="SHIPPINGTERMS" class="java.lang.String"/>
		<field name="CARRIER" class="java.lang.String"/>
		<field name="SHIPDATE" class="java.sql.Timestamp"/>
		<field name="CURRENCYCODE" class="java.lang.String"/>
		<field name="SYMBOL" class="java.lang.Integer"/>
		<field name="CURRENCYRATE" class="java.lang.Double"/>
		<field name="HOMECURRENCYCODE" class="java.lang.String"/>
		<variable name="DateFormat" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[(System.getProperty("REPORT_DATE_FORMAT"))]]></variableExpression>
		</variable>
	</subDataset>
	<subDataset name="itemInfo" uuid="ef4e920e-5f04-4f4d-b4bf-356230be25a8">
		<parameter name="shipID" class="java.lang.String">
			<defaultValueExpression><![CDATA["7"]]></defaultValueExpression>
		</parameter>
		<parameter name="module" class="java.lang.Object" isForPrompting="false">
			<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
		</parameter>
		<parameter name="colItemLineNumber" class="java.lang.Boolean">
			<parameterDescription><![CDATA[Item Line Number]]></parameterDescription>
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="colType" class="java.lang.Boolean">
			<parameterDescription><![CDATA[Item Type]]></parameterDescription>
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="colItemNumberAndDescription" class="java.lang.Boolean">
			<parameterDescription><![CDATA[Item Number And Description]]></parameterDescription>
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="colUnitPrice" class="java.lang.Boolean">
			<parameterDescription><![CDATA[Item Unit Price]]></parameterDescription>
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="colQtyShipped" class="java.lang.Boolean">
			<parameterDescription><![CDATA[Item Qty Shipped]]></parameterDescription>
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="colExtendedPrice" class="java.lang.Boolean">
			<parameterDescription><![CDATA[Item Extended Price]]></parameterDescription>
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="colTaxCode" class="java.lang.Boolean">
			<parameterDescription><![CDATA[]]></parameterDescription>
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="colCurrencyUnitPrice" class="java.lang.Boolean" isForPrompting="false">
			<parameterDescription><![CDATA[Item Currency Unit Price]]></parameterDescription>
			<defaultValueExpression><![CDATA["PropertyMulti Currency"]]></defaultValueExpression>
		</parameter>
		<parameter name="colCurrencyExtendedPrice" class="java.lang.Boolean" isForPrompting="false">
			<parameterDescription><![CDATA[Item Currency Extended Price]]></parameterDescription>
			<defaultValueExpression><![CDATA["PropertyMulti Currency"]]></defaultValueExpression>
		</parameter>
		<parameter name="colItemCurrencyTax" class="java.lang.Boolean" isForPrompting="false">
			<parameterDescription><![CDATA[Item Currency Tax Amount]]></parameterDescription>
			<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
		</parameter>
		<parameter name="postSoId" class="java.lang.Integer" isForPrompting="false">
			<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
		</parameter>
		<parameter name="IncludeCustomerPartNumbers" class="java.lang.Boolean" isForPrompting="false">
			<defaultValueExpression><![CDATA[new Boolean(true)]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT SoItem.soLineItem, SoItemType.name AS soItemType, SoItem.unitPrice + (SoItem.adjustAmount/SoItem.qtyToFulfill) AS unitCost, SoItemUom.code AS uomCode, SoItem.productNum,
    SoItem.customerPartNum, ObjectToObject.recordId2 AS kitParentLine, SoItem.note AS soItemNote, SoItem.description AS productDescription,
    PostSoItem.qty AS qtyToFulfill, ShipItem.id AS shipItemId, TaxRate.code AS itemTaxCode, SoItem.taxRate AS itemTaxRate,
    Currency.code AS currencyCode, Currency.symbol AS Symbol, PostSoItem.totalPrice, COALESCE(so.currencyRate, 1) AS currencyRate,
    (SoItem.unitPrice + (SoItem.adjustAmount/SoItem.qtyToFulfill)) / COALESCE(So.currencyRate, 1) * COALESCE(uomConversion.factor/uomConversion.multiply, 1) AS currencyUnitPrice,
    (PostSoItem.totalPrice / COALESCE(So.currencyRate, 1)) AS currencyTotalExtendedPrice,
    POSTSOITEM.TOTALTAX  AS soItemTaxAmount, SoItem.typeId AS soItemTypeId,
    HomeCurrency.symbol AS homeCurrencySymbol, Vendorparts.VendorPartNumber AS VendorPartNumber

FROM So
    INNER JOIN SoItem ON So.id = SoItem.soId
    INNER JOIN TaxRate ON soItem.taxId = TaxRate.id
    INNER JOIN Uom AS SoItemUom ON SoItem.uomId = SoItemUom.id
    INNER JOIN SoItemType ON SoItem.typeId = SoItemType.id
    INNER JOIN PostSoItem ON SoItem.id = PostSoItem.soItemId
    LEFT JOIN ShipItem ON PostSoItem.shipItemId = ShipItem.id
    INNER JOIN Customer ON So.customerId = Customer.id
    LEFT OUTER JOIN UomConversion ON SoItemUom.id = UomConversion.fromUomId AND SoItem.uomId = UomConversion.toUomId
    LEFT OUTER JOIN ObjectToObject ON ObjectToObject.typeId = 30 AND SoItem.id = ObjectToObject.recordId1
    LEFT OUTER JOIN Currency ON Customer.currencyId = Currency.id
    LEFT OUTER JOIN Currency AS HomeCurrency ON HomeCurrency.homeCurrency = 1
    LEFT JOIN Product ON Soitem.productid = product.id
    LEFT JOIN Part ON Product.partid = part.id
    LEFT JOIN Vendorparts ON Part.id = VendorParts.id

WHERE PostSoItem.postSoId = $P{postSoId}

ORDER BY SoItem.soLineItem]]>
		</queryString>
		<field name="SOLINEITEM" class="java.lang.Integer"/>
		<field name="SOITEMTYPE" class="java.lang.String"/>
		<field name="UNITCOST" class="java.lang.Double"/>
		<field name="UOMCODE" class="java.lang.String"/>
		<field name="PRODUCTNUM" class="java.lang.String"/>
		<field name="CUSTOMERPARTNUM" class="java.lang.String"/>
		<field name="KITPARENTLINE" class="java.lang.Integer"/>
		<field name="SOITEMNOTE" class="java.lang.String"/>
		<field name="PRODUCTDESCRIPTION" class="java.lang.String"/>
		<field name="QTYTOFULFILL" class="java.lang.Double"/>
		<field name="SHIPITEMID" class="java.lang.Integer"/>
		<field name="ITEMTAXCODE" class="java.lang.String"/>
		<field name="ITEMTAXRATE" class="java.lang.Double"/>
		<field name="CURRENCYCODE" class="java.lang.String"/>
		<field name="SYMBOL" class="java.lang.Integer"/>
		<field name="TOTALPRICE" class="java.lang.Double"/>
		<field name="CURRENCYRATE" class="java.lang.Double"/>
		<field name="CURRENCYUNITPRICE" class="java.lang.Double"/>
		<field name="CURRENCYTOTALEXTENDEDPRICE" class="java.lang.Double"/>
		<field name="SOITEMTAXAMOUNT" class="java.lang.Double"/>
		<field name="SOITEMTYPEID" class="java.lang.Integer"/>
		<field name="HOMECURRENCYSYMBOL" class="java.lang.Integer"/>
		<field name="VendorPartNumber" class="java.lang.String"/>
		<variable name="PartInfo" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[(($F{KITPARENTLINE} == null)
	? ""
	: "     ")
+ ((($F{PRODUCTNUM} == null) || ($F{PRODUCTNUM}.length() < 1))
	? ""
	: (($F{CUSTOMERPARTNUM} == null) || ($F{CUSTOMERPARTNUM}.length() < 1))
		? $F{PRODUCTNUM}
		: $F{PRODUCTNUM} + " (" + $F{CUSTOMERPARTNUM} + ")")
+ ((($F{PRODUCTNUM} == null) || ($F{PRODUCTNUM}.length() < 1) || ($F{PRODUCTDESCRIPTION}.length() < 1) || ($F{PRODUCTDESCRIPTION}.length() < 1))
	? ""
	: " - ")
+ ((($F{PRODUCTDESCRIPTION}.length() < 1) || ($F{PRODUCTDESCRIPTION}.length() < 1))
	? ""
	: $F{PRODUCTDESCRIPTION})]]></variableExpression>
		</variable>
		<variable name="QtyDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_QTY")]]></variableExpression>
		</variable>
		<variable name="QtyOrdered" class="java.lang.Double">
			<variableExpression><![CDATA[($F{QTYTOFULFILL} == null) ? new Double(0) : $F{QTYTOFULFILL}]]></variableExpression>
		</variable>
		<variable name="extendedPrice" class="java.lang.Double">
			<variableExpression><![CDATA[($F{SOITEMTYPEID}== 30 || $F{SOITEMTYPEID}== 40) ?
    com.evnt.eve.modules.ReportHelperModule.getRoundedMoneyValue($F{TOTALPRICE}, true) :
    com.evnt.eve.modules.ReportHelperModule.getRoundedMoneyValue($F{UNITCOST} * $F{QTYTOFULFILL}, true)]]></variableExpression>
		</variable>
		<variable name="TrackingInfo" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[((($P{module} == null) || ($F{SHIPITEMID} == null)) ?
    "" :
    ((com.evnt.eve.modules.ReportHelperModule) $P{module}).getAllShipItemTrackingInfo("ShipItem", $F{SHIPITEMID}.toString()))]]></variableExpression>
		</variable>
		<variable name="PriceDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_PRICE")]]></variableExpression>
		</variable>
		<variable name="CostDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_COST")]]></variableExpression>
		</variable>
		<variable name="TotalsDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_TOTAL")]]></variableExpression>
		</variable>
		<variable name="CanDisplaySymbol" class="java.lang.Boolean">
			<variableExpression><![CDATA[$F{SYMBOL} == null || $F{SYMBOL}.equals("") || new java.awt.Font("Open Sans", java.awt.Font.PLAIN ,1).canDisplay(com.fbi.sdk.constants.setup.CurrencySymbolConst.getConstant($F{SYMBOL}).getSymbol().charAt(0))]]></variableExpression>
			<initialValueExpression><![CDATA[true]]></initialValueExpression>
		</variable>
		<variable name="isMultiCurrency" class="java.lang.Boolean">
			<variableExpression><![CDATA[com.evnt.eve.modules.CurrencyModule.isMultiCurrency()]]></variableExpression>
		</variable>
		<variable name="ItemNum" class="java.lang.String">
			<variableExpression><![CDATA[($F{KITPARENTLINE} == null ? "" : "     ") +
($F{PRODUCTNUM} == null || $F{PRODUCTNUM}.length() < 1 ?
    "" :
    ($F{CUSTOMERPARTNUM} == null || $F{CUSTOMERPARTNUM}.length() < 1 || !$P{IncludeCustomerPartNumbers} ?
        $F{PRODUCTNUM} :
        $F{PRODUCTNUM} + " (" + $F{CUSTOMERPARTNUM} + ")"))]]></variableExpression>
		</variable>
	</subDataset>
