		<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
	</parameter>
	<parameter name="ShowCurrencyTotals" class="java.lang.Boolean" isForPrompting="false">
		<property name="show" value="Multi Currency"/>
		<defaultValueExpression><![CDATA[Boolean.getBoolean("Multi Currency")]]></defaultValueExpression>
	</parameter>
	<parameter name="postSoId" class="java.lang.Integer" isForPrompting="false">
		<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
	</parameter>
	<parameter name="IncludeCustomerPartNumbers" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Boolean(true)]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT COMPANY.NAME AS COMPANYNAME, SO.NUM AS SONUM, SO.CUSTOMERCONTACT, SO.CUSTOMERPO, SO.BILLTOADDRESS, SO.SHIPTOADDRESS,
    SO.BILLTONAME, SO.SHIPTONAME, SO.BILLTOCITY, SO.SHIPTOCITY, BILLSTATE.NAME AS BILLTOSTATE, SHIPSTATE.NAME AS SHIPTOSTATE,
    SO.BILLTOZIP, SO.SHIPTOZIP, BILLCOUNTRY.NAME AS BILLCOUNTRY, SHIPCOUNTRY.NAME AS SHIPCOUNTRY, SUBSTRING(SHIPNUMTABLE.SHIPNUM FROM 2 FOR 40) AS SHIPNUM,
/*SHIPNUMTABLE.SHIPNUM,*/
    SO.LOCATIONGROUPID, COALESCE(SO.NOTE, '') AS SONOTE, SO.CUSTOMERID, CAST(SHIPNUMTABLE.DATESHIPPED AS DATE) AS DATESHIPPED,
    SO.CURRENCYRATE, CURRENCY.CODE AS CURRENCYCODE, CURRENCY.SYMBOL AS SYMBOL, COMPANY.ABN, ESTIMATEPROPERTY.SYSVALUE AS ESTIMATETITLE,
    BARCODESPROPERTY.SYSVALUE AS BARCODESHAVEDI, FOOTERPROPERTY.SYSVALUE AS SOFOOTER,
    SUM(POSTSOITEM.TOTALPRICE) AS SUBTOTAL,
    POSTSO.TOTALTAX AS ORDERTOTALTAX,
    POSTSO.TOTALTAX / SO.CURRENCYRATE AS CURRENCYTAXTOTAL,
    (SUM(POSTSOITEM.TOTALPRICE) + POSTSO.TOTALTAX) / SO.CURRENCYRATE AS CURRENCYGRANDTOTAL,
    SUM(POSTSOITEM.TOTALPRICE / SO.CURRENCYRATE) AS CURRENCYSUBTOTAL, HOMECURRENCY.SYMBOL AS HOMECURRENCYSYMBOL, sysuser.initials as SALESMAN, CUSTOMER.NUMBER AS CUSTOMERACCOUNT, PAYMENTTERMS.NAME AS PAYMENTTERMS, CARRIER.NAME AS CARRIERNAME,SO.DATEFIRSTSHIP,CUSTOMER.NAME as CNAME


FROM PostSo
    INNER JOIN PostSoItem ON PostSo.id = PostSoItem.postSoId
    LEFT JOIN ShipItem ON PostSoItem.shipItemId = ShipItem.id
    LEFT JOIN Ship ON ShipItem.shipId = Ship.id
    INNER JOIN SoItem ON PostSoItem.soItemId = SoItem.id
    INNER JOIN So ON SoItem.soId = So.id AND PostSo.soId = So.id
    INNER JOIN Customer ON So.customerId = Customer.id
    LEFT JOIN StateConst BillState ON So.billToStateId = BillState.id
    LEFT JOIN StateConst ShipState ON So.shipToStateId = ShipState.id
    LEFT JOIN CountryConst BillCountry ON So.billToCountryId = BillCountry.id
    LEFT JOIN CountryConst ShipCountry ON So.shipToCountryId = ShipCountry.id
    LEFT JOIN Currency ON Customer.currencyId = Currency.id
    LEFT JOIN Currency AS HomeCurrency ON HomeCurrency.homeCurrency = 1
    INNER JOIN Company ON Company.id = 1
    INNER JOIN (SELECT PostSo.id AS postSoId, Ship.num AS shipNum, Ship.dateShipped
                FROM PostSo
                INNER JOIN PostSoItem ON PostSo.id = PostSoItem.postSoId
                INNER JOIN ShipItem ON PostSoItem.shipItemId = ShipItem.id
                INNER JOIN Ship ON ShipItem.shipId = Ship.id
                WHERE PostSo.id = $P!{postSoId} LIMIT 1) AS ShipNumTable ON PostSo.id = ShipNumTable.postSoId
    LEFT OUTER JOIN sysProperties estimateProperty ON estimateProperty.sysKey = 'Estimate Title'
    LEFT OUTER JOIN sysProperties barcodesProperty ON barcodesProperty.sysKey = 'Barcodes have DI'
    LEFT OUTER JOIN sysProperties footerProperty ON footerProperty.sysKey = 'SO Notice'
left join paymentterms on paymentterms.id = so.paymenttermsid
left join carrier on carrier.id = so.carrierid
left join sysuser on sysuser.id = so.salesmanid


WHERE PostSo.id = $P!{postSoId}
  AND SoItem.typeId != 40

GROUP BY Company.name, So.num, So.customerContact, So.customerPo, So.billToAddress, So.shipToAddress,
    So.billToName, So.shipToName, So.billToCity, So.shipToCity, BillState.name, ShipState.name,
    So.billToZip, So.shipToZip, BillCountry.name, ShipCountry.name, ShipNumTable.shipNum,
    So.locationGroupId, So.note, So.customerId, ShipNumTable.dateShipped,
    So.currencyRate, Currency.code, Currency.symbol, company.abn, EstimateProperty.sysValue,
    BarcodesProperty.sysValue, FooterProperty.sysValue, HomeCurrency.symbol, salesman, customer.number, paymentterms.name, carriername]]>
	</queryString>
