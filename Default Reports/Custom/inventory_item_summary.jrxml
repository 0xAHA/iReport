	</variable>
	<variable name="totalAdjusted" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{adjustedQty}]]></variableExpression>
	</variable>
	<variable name="totalClosing" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{closingQty}]]></variableExpression>
	</variable>
	<variable name="DateFormat" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[(System.getProperty("REPORT_DATE_FORMAT"))]]></variableExpression>
	</variable>
