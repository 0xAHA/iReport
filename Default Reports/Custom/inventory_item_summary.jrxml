<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="inventory_item_summary" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="cb13fb4f-31c7-4f0a-bf5a-4af04bba757a">
	<property name="ireport.zoom" value="1.4641000000000006"/>
	<property name="ireport.x" value="51"/>
	<property name="ireport.y" value="0"/>
	<parameter name="partNum" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="productTree1" class="java.lang.String" isForPrompting="false"/>
	<parameter name="productTree2" class="java.lang.String" isForPrompting="false"/>
	<parameter name="ShowAllTrees" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA["true"]]></defaultValueExpression>
	</parameter>
	<parameter name="locationGroupID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRange1" class="java.util.Date">
		<parameterDescription><![CDATA[Last 365 Days]]></parameterDescription>
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRange2" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    COALESCE(producttree.name, "N/A") AS productTree,
    part.num AS partNum,
    part.description AS partDescription,
    SUM(COALESCE(opening.qty, 0)) AS openingQty,
    SUM(COALESCE(purchases.qty, 0)) AS purchaseQty,
    ABS(SUM(COALESCE(sales.qty, 0))) - SUM(COALESCE(returns.qty, 0)) AS soldQty,
    SUM(COALESCE(adjustments.qty, 0)) AS adjustedQty,
    SUM(COALESCE(closing.qty, 0)) AS closingQty,
    company.name AS companyName
FROM part
LEFT JOIN product ON part.id = product.partid
LEFT JOIN producttotree ON product.id = producttotree.productid
LEFT JOIN producttree ON producttotree.producttreeid = producttree.id
CROSS JOIN company
LEFT JOIN (
    SELECT il.partId, SUM(il.qtyonhand) AS qty
    FROM inventorylog il
    INNER JOIN (
        SELECT partId, locationGroupId, MAX(eventDate) AS maxDate, MAX(id) AS maxId
        FROM inventorylog
        WHERE eventDate < $P{dateRange1}
          AND locationGroupId IN ($P!{locationGroupID})
        GROUP BY partId, locationGroupId
    ) AS latest ON il.partId = latest.partId
        AND il.locationGroupId = latest.locationGroupId
        AND il.eventDate = latest.maxDate
        AND il.id = latest.maxId
    GROUP BY il.partId
) AS opening ON part.id = opening.partId
LEFT JOIN (
    SELECT il.partId, SUM(il.changeQty) AS qty
    FROM inventorylog il
    LEFT JOIN receiptitem ri ON CAST(SUBSTRING_INDEX(SUBSTRING_INDEX(il.info, 'Receipt Item ', -1), ' ', 1) AS UNSIGNED) = ri.id
    WHERE il.eventDate BETWEEN $P{dateRange1} AND SUBDATE($P{dateRange2}, INTERVAL 1 Second)
      AND il.typeId IN (10, 15)
      AND il.locationGroupId IN ($P!{locationGroupID})
      AND (ri.soitemid IS NULL OR il.info NOT LIKE '%Receipt Item%')
    GROUP BY il.partId
) AS purchases ON part.id = purchases.partId
LEFT JOIN (
    SELECT il.partId, SUM(il.changeQty) AS qty
    FROM inventorylog il
    INNER JOIN receiptitem ri ON CAST(SUBSTRING_INDEX(SUBSTRING_INDEX(il.info, 'Receipt Item ', -1), ' ', 1) AS UNSIGNED) = ri.id
    WHERE il.eventDate BETWEEN $P{dateRange1} AND SUBDATE($P{dateRange2}, INTERVAL 1 Second)
      AND il.typeId = 10
      AND il.locationGroupId IN ($P!{locationGroupID})
      AND ri.soitemid IS NOT NULL
    GROUP BY il.partId
) AS returns ON part.id = returns.partId
LEFT JOIN (
    SELECT partId, SUM(changeQty) AS qty
    FROM inventorylog
    WHERE eventDate BETWEEN $P{dateRange1} AND SUBDATE($P{dateRange2}, INTERVAL 1 Second)
      AND typeId IN (20, 90)
      AND locationGroupId IN ($P!{locationGroupID})
    GROUP BY partId
) AS sales ON part.id = sales.partId
LEFT JOIN (
    SELECT partId, SUM(changeQty) AS qty
    FROM inventorylog
    WHERE eventDate BETWEEN $P{dateRange1} AND SUBDATE($P{dateRange2}, INTERVAL 1 Second)
      AND typeId IN (60, 64, 65, 67, 68, 70, 71)
      AND locationGroupId IN ($P!{locationGroupID})
    GROUP BY partId
) AS adjustments ON part.id = adjustments.partId
LEFT JOIN (
    SELECT il.partId, SUM(il.qtyonhand) AS qty
    FROM inventorylog il
    INNER JOIN (
        SELECT partId, locationGroupId, MAX(eventDate) AS maxDate, MAX(id) AS maxId
        FROM inventorylog
        WHERE eventDate <= SUBDATE($P{dateRange2}, INTERVAL 1 Second)
          AND locationGroupId IN ($P!{locationGroupID})
        GROUP BY partId, locationGroupId
    ) AS latest ON il.partId = latest.partId
        AND il.locationGroupId = latest.locationGroupId
        AND il.eventDate = latest.maxDate
        AND il.id = latest.maxId
    GROUP BY il.partId
) AS closing ON part.id = closing.partId
WHERE company.id = 1
  AND part.num LIKE $P{partNum}
  AND (product.activeflag = 1 OR product.activeflag IS NULL)
  AND ($P{ShowAllTrees} = 1 OR producttree.id IN ($P!{productTree1}))
  AND (
    COALESCE(opening.qty, 0) != 0
    OR COALESCE(purchases.qty, 0) != 0
    OR COALESCE(sales.qty, 0) != 0
    OR COALESCE(adjustments.qty, 0) != 0
    OR COALESCE(returns.qty, 0) != 0
  )
GROUP BY producttree.id, part.id, company.name
ORDER BY producttree.name, part.num]]>
	</queryString>
	<field name="partNum" class="java.lang.String"/>
	<field name="partDescription" class="java.lang.String"/>
	<field name="openingQty" class="java.math.BigDecimal"/>
	<field name="purchaseQty" class="java.math.BigDecimal"/>
	<field name="soldQty" class="java.math.BigDecimal"/>
	<field name="adjustedQty" class="java.math.BigDecimal"/>
	<field name="closingQty" class="java.math.BigDecimal"/>
	<field name="companyName" class="java.lang.String"/>
	<field name="productTree" class="java.lang.String"/>
	<variable name="totalOpening" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{openingQty}]]></variableExpression>
	</variable>
	<variable name="totalPurchase" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{purchaseQty}]]></variableExpression>
	</variable>
	<variable name="totalSold" class="java.math.BigDecimal" calculation="Sum">
