				<reportElement mode="Opaque" x="662" y="0" width="70" height="20" backcolor="#E0E0E0" uuid="975054c0-c0d1-465e-9833-8179e5493e5c"/>
				<box>
					<pen lineWidth="0.5"/>
					<topPen lineWidth="0.5"/>
					<leftPen lineWidth="0.0"/>
					<bottomPen lineWidth="0.5"/>
					<rightPen lineWidth="0.0"/>
