	</parameter>
	<queryString>
		<![CDATA[SELECT po.vendorcontact, po.vendorso, po.vendorid, po.currencyRate, currency.code AS currencyCode, currency.symbol,
    /*Ship To*/
    po.shiptoname, po.shiptoaddress, po.shiptocity, shipState.code AS shiptostate,
	po.shiptozip, shipcountry.name AS shiptoCountry,
	/*Bill To*/
    po.remittoname, po.remitaddress, po.remitcity, billstate.code AS billtostate,
    po.remitzip, billcountry.name AS billtocountry,
          SUM(poItem.unitCost * poItem.qtyToFulfill * poItem.taxRate / po.currencyRate) AS currencyTaxTotal,
          SUM(poItem.unitCost * poItem.qtyToFulfill / po.currencyRate) AS currencySubTotal,
          SUM(poItem.unitCost * poItem.qtyToFulfill * poItem.taxRate) AS totalTax,
	SUM(poItem.unitCost * poItem.qtyToFulfill) AS totalcost, po.note, po.id AS recordid


FROM po
    INNER JOIN poitem ON po.id = poitem.poid
    INNER JOIN vendor ON po.vendorid = vendor.id
    LEFT OUTER JOIN stateconst AS shipState ON po.shiptostateid = shipState.id
    LEFT OUTER JOIN stateconst AS billState ON po.remitstateid = billState.id
    LEFT OUTER JOIN countryconst AS shipCountry ON po.shiptocountryid = shipCountry.id
    LEFT OUTER JOIN countryconst AS billCountry ON po.remitcountryid = billCountry.id
    LEFT OUTER JOIN currency ON vendor.currencyId = currency.id

WHERE po.num = $P{poNum}

GROUP BY po.vendorcontact, po.vendorso, po.vendorid, po.shiptozip, shipcountry.name,  po.currencyRate, currency.code, currency.symbol,
    po.shiptoname, po.shiptoaddress, po.shiptocity, shipState.code, po.remitzip, billcountry.name,
	po.remittoname, po.remitaddress, po.remitcity, billstate.code, po.note, po.id, po.totalTax]]>
	</queryString>
