		<field name="DATECONFIRMED" class="java.sql.Timestamp"/>
		<field name="DATECREATED" class="java.sql.Timestamp"/>
		<field name="DATEREVISION" class="java.sql.Timestamp"/>
		<field name="PAYMENTTERMS" class="java.lang.String"/>
