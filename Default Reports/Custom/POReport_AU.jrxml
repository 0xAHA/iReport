		<parameter name="colOrderCurrency" class="java.lang.Boolean" isForPrompting="false">
			<parameterDescription><![CDATA[Order Currency]]></parameterDescription>
			<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
		</parameter>
		<parameter name="colOrderCurrencyRate" class="java.lang.Boolean" isForPrompting="false">
			<parameterDescription><![CDATA[Order Currency Rate]]></parameterDescription>
			<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT po.num, po.note, po.locationgroupid, po.datelastmodified, po.revisionnum, currency.code AS currencyCode, currency.symbol, po.currencyRate,
    po.dateissued, potype.name AS potype, po.statusid, postatus.name AS postatus, po.buyer,
    fobpoint.name AS fobpoint, shipterms.name AS shippingterms, carrier.name AS carriername, po.datefirstship,
    po.dateCompleted, po.dateconfirmed, po.datecreated, po.daterevision,
	paymentterms.name AS paymentterms, po.id AS recordid, company.name AS company, company.abn AS abn

FROM po
    INNER JOIN potype ON po.typeid = potype.id
    INNER JOIN fobpoint ON po.fobpointid = fobpoint.id
    INNER JOIN shipterms ON po.shiptermsid = shipterms.id
    INNER JOIN paymentterms ON po.paymenttermsid = paymentterms.id
    INNER JOIN carrier ON po.carrierid = carrier.id
    INNER JOIN vendor ON po.vendorid = vendor.id
    LEFT OUTER JOIN postatus ON (postatus.id = po.statusid)
    JOIN company ON company.id = 1
    LEFT OUTER JOIN currency ON vendor.currencyId = currency.id

WHERE po.id = $P{poId}]]>
		</queryString>
		<field name="NUM" class="java.lang.String"/>
		<field name="NOTE" class="java.lang.String"/>
		<field name="LOCATIONGROUPID" class="java.lang.Integer"/>
		<field name="DATELASTMODIFIED" class="java.sql.Timestamp"/>
		<field name="REVISIONNUM" class="java.lang.Integer"/>
		<field name="CURRENCYCODE" class="java.lang.String"/>
