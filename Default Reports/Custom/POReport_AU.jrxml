			<parameterDescription><![CDATA[Item Currency Unit Cost]]></parameterDescription>
			<defaultValueExpression><![CDATA["PropertyMulti Currency"]]></defaultValueExpression>
		</parameter>
		<parameter name="colItemCurrencyTotal" class="java.lang.Boolean" isForPrompting="false">
			<parameterDescription><![CDATA[Item Currency Total Cost]]></parameterDescription>
			<defaultValueExpression><![CDATA["PropertyMulti Currency"]]></defaultValueExpression>
		</parameter>
		<parameter name="colItemTaxCode" class="java.lang.Boolean" isForPrompting="false">
			<parameterDescription><![CDATA[Item Tax Code]]></parameterDescription>
			<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
		</parameter>
		<parameter name="colItemTax" class="java.lang.Boolean" isForPrompting="false">
			<parameterDescription><![CDATA[Item Tax]]></parameterDescription>
			<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
		</parameter>
		<parameter name="colItemCurrencyTax" class="java.lang.Boolean" isForPrompting="false">
			<parameterDescription><![CDATA[Item Currency Tax]]></parameterDescription>
			<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT poitem.id, poitem.polineitem, poitemtype.name AS type,
    poitem.partnum, poitem.vendorpartnum, poitem.description, poitem.note,
    poitem.qtytofulfill, uom.code AS uomcode, poitem.unitcost, poitem.totalcost,
    poitem.datescheduledfulfillment, currency.code AS currencyCode, COALESCE(currency.symbol, 91) AS Symbol,
    poItem.unitCost * COALESCE(uomConversion.factor/uomConversion.multiply, 1) / COALESCE(po.currencyRate, 1)  AS currencyUnitCost,
    ROUND((poItem.unitCost * COALESCE(uomConversion.factor/uomConversion.multiply, 1)) * poItem.qtyToFulfill / COALESCE(po.currencyRate, 1) , 2)
    AS currencyTotalCost, (poitem.qtytofulfill * poitem.unitcost) * poitem.taxrate / COALESCE(po.currencyRate, 1) AS currencyTotalTax,
    TaxRate.code AS taxCode, poitem.taxrate, COALESCE(po.currencyRate, 1) AS currencyRate


FROM po
    INNER JOIN poitem ON po.id = poitem.poid
    INNER JOIN poitemtype ON poitem.typeid = poitemtype.id
    INNER JOIN uom ON poitem.uomid = uom.id
    INNER JOIN vendor ON po.vendorid = vendor.id
    LEFT OUTER JOIN uomConversion ON uom.id = uomConversion.fromUomId AND poitem.uomId = uomConversion.toUomId
    LEFT OUTER JOIN currency ON vendor.currencyId = currency.id
    LEFT OUTER JOIN TaxRate ON poitem.taxid = taxrate.id

WHERE po.id = $P{poId}

ORDER BY poitem.polineitem]]>
		</queryString>
		<field name="ID" class="java.lang.Integer"/>
		<field name="POLINEITEM" class="java.lang.Integer"/>
		<field name="TYPE" class="java.lang.String"/>
		<field name="PARTNUM" class="java.lang.String"/>
		<field name="VENDORPARTNUM" class="java.lang.String"/>
		<field name="DESCRIPTION" class="java.lang.String"/>
		<field name="NOTE" class="java.lang.String"/>
		<field name="QTYTOFULFILL" class="java.lang.Double"/>
		<field name="UOMCODE" class="java.lang.String"/>
		<field name="UNITCOST" class="java.lang.Double"/>
		<field name="TOTALCOST" class="java.lang.Double"/>
		<field name="DATESCHEDULEDFULFILLMENT" class="java.sql.Timestamp"/>
		<field name="CURRENCYCODE" class="java.lang.String"/>
		<field name="SYMBOL" class="java.lang.Integer"/>
		<field name="CURRENCYUNITCOST" class="java.lang.Double"/>
