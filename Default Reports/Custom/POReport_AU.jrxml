		<field name="ABN" class="java.lang.String"/>
		<variable name="ORDERNUMBER" class="java.lang.String">
			<variableExpression><![CDATA[$V{BarcodesHaveDI} == null ?
    $F{NUM} :
    $V{BarcodesHaveDI}.equals("true") ?
        "P" + $F{NUM} :
        $F{NUM}]]></variableExpression>
		</variable>
		<variable name="BarcodesHaveDI" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("Barcodes have DI")]]></variableExpression>
		</variable>
		<variable name="isUseDayMonth" class="java.lang.Boolean" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_USE_DAY_MONTH_YEAR").equalsIgnoreCase("true")]]></variableExpression>
		</variable>
		<variable name="DateFormat" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[(System.getProperty("REPORT_DATE_FORMAT"))]]></variableExpression>
		</variable>
	</subDataset>
