	<queryString>
		<![CDATA[SELECT COMPANY.NAME AS COMPANYNAME, SO.NUM AS SONUM, SO.CUSTOMERCONTACT, SO.CUSTOMERPO, SO.BILLTOADDRESS, SO.SHIPTOADDRESS,
    Customer.Name as BILLTONAME, Customer.Name as SHIPTONAME, SO.BILLTOCITY, SO.SHIPTOCITY, BILLSTATE.NAME AS BILLTOSTATE, SHIPSTATE.NAME AS SHIPTOSTATE,
    SO.BILLTOZIP, SO.SHIPTOZIP, BILLCOUNTRY.NAME AS BILLCOUNTRY, SHIPCOUNTRY.NAME AS SHIPCOUNTRY, SHIP.NUM AS SHIPNUM,
    SO.LOCATIONGROUPID, COALESCE(SO.NOTE, '') AS SONOTE, SO.CUSTOMERID, CAST(Ship.DateCreated AS DATE) AS DATESHIPPED,
    SO.CURRENCYRATE, CURRENCY.CODE AS CURRENCYCODE, CURRENCY.SYMBOL AS SYMBOL, COMPANY.ABN, ESTIMATEPROPERTY.SYSVALUE AS ESTIMATETITLE,
    BARCODESPROPERTY.SYSVALUE AS BARCODESHAVEDI, FOOTERPROPERTY.SYSVALUE AS SOFOOTER,
    SUM(SHIPITEM.QTYSHIPPED * SOITEM.UNITPRICE) AS SUBTOTAL,
    SUM(SOITEM.TAXRATE * SHIPITEM.QTYSHIPPED * SOITEM.UNITPRICE) AS ORDERTOTALTAX,
    SUM(SHIPITEM.QTYSHIPPED * SOITEM.UNITPRICE * SOITEM.TAXRATE / SO.CURRENCYRATE) AS CURRENCYTAXTOTAL,
    SUM((SHIPITEM.QTYSHIPPED * SOITEM.UNITPRICE / SO.CURRENCYRATE) + (SOITEM.TAXRATE * SHIPITEM.QTYSHIPPED * SOITEM.UNITPRICE) / SO.CURRENCYRATE) AS CURRENCYGRANDTOTAL,
    SUM(SHIPITEM.QTYSHIPPED * SOITEM.UNITPRICE / SO.CURRENCYRATE) AS CURRENCYSUBTOTAL, NOTINVENTORY.ITEMCOUNT,
    HOMECURRENCY.SYMBOL AS HOMECURRENCYSYMBOL

FROM Ship
    INNER JOIN ShipItem ON Ship.id = ShipItem.shipId
    INNER JOIN SoItem ON ShipItem.soItemId = SoItem.id
    INNER JOIN So ON SoItem.soId = So.id AND Ship.soId = So.id
    INNER JOIN Customer ON So.customerId = Customer.id
    LEFT JOIN StateConst BillState ON So.billToStateId = BillState.id
    LEFT JOIN StateConst ShipState ON So.shipToStateId = ShipState.id
    LEFT JOIN CountryConst BillCountry ON So.billToCountryId = BillCountry.id
    LEFT JOIN CountryConst ShipCountry ON So.shipToCountryId = ShipCountry.id
    LEFT JOIN Currency ON Customer.currencyId = Currency.id
    LEFT JOIN currency AS homeCurrency ON homeCurrency.homeCurrency = 1
    INNER JOIN Company ON Company.id = 1
    LEFT OUTER JOIN sysProperties estimateProperty ON estimateProperty.sysKey = 'Estimate Title'
    LEFT OUTER JOIN sysProperties barcodesProperty ON barcodesProperty.sysKey = 'Barcodes have DI'
    LEFT OUTER JOIN sysProperties footerProperty ON footerProperty.sysKey = 'SO Notice'
    LEFT OUTER JOIN (SELECT COUNT(SoItem.id) AS itemCount, So.id
                     FROM So
                     INNER JOIN SoItem ON SoItem.soId = So.id
                     LEFT OUTER JOIN Product ON Product.id = SoItem.productId
                     LEFT OUTER JOIN Part ON Part.id = Product.partId
                     WHERE (Part.typeId != 10 OR Part.typeId IS NULL)
                     GROUP BY So.id
    ) AS NotInventory ON NotInventory.id = So.id

WHERE Ship.id = $P!{shipID}
  AND SoItem.typeId != 40

GROUP BY Company.name, So.num, So.customerContact, So.customerPo, So.billToAddress, So.shipToAddress,
    So.billToName, So.shipToName, So.billToCity, So.shipToCity, BillState.name, ShipState.name,
    So.billToZip, So.shipToZip, BillCountry.name, ShipCountry.name, Ship.num,
    So.locationGroupId, So.note, So.customerId, Ship.dateShipped,
    So.currencyRate, Currency.code, Currency.symbol, company.abn, EstimateProperty.sysValue,
    BarcodesProperty.sysValue, FooterProperty.sysValue, NotInventory.itemCount, homeCurrency.symbol]]>
	</queryString>
