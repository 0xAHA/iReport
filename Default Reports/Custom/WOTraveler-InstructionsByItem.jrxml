		<queryString>
			<![CDATA[SELECT
    WOITEM.TYPEID,
    PART.NUM AS BOMITEMPART,
    WOITEM.ID AS BOMITEMID,
    PART.DESCRIPTION AS PARTDESCRIPTION,
    COALESCE(BOMINSTRUCTIONITEM.DETAILS, '') AS BOMITEMINSTRUCTIONS,
    COALESCE(BOMITEM.DESCRIPTION, '') AS BOMITEMDESCRIPTION,
    (WOITEM.QTYTARGET / WO.QTYTARGET) AS BOMITEMQTY,
    WOITEM.QTYTARGET AS WOITEMTOTAL,
    TRACKINFO.TRACKVALUE AS TRACKVALUE,
    BOMITEM.SORTIDCONFIG,
    WOITEMUOM.CODE AS UOMCODE,
    WO.STATUSID AS WOSTATUS,
    WOITEM.ID AS WOITEMID,
    MOITEM.INSTRUCTIONNOTE

FROM
    wo
    INNER JOIN woitem ON wo.id = woitem.woid
    INNER JOIN moitem ON woitem.moitemid = moitem.id
    LEFT JOIN bomitem ON moitem.bomitemid = bomitem.id
    LEFT JOIN part ON woitem.partid = part.id
    LEFT JOIN uom AS woitemuom ON woitem.uomid = woitemuom.id
    LEFT JOIN parttotracking ON woitem.partid = parttotracking.partid
    LEFT OUTER JOIN (
        SELECT
            partrackinfo.partid,
            GROUP_CONCAT(partrackinfo.trackValue, '___' SEPARATOR '') AS trackValue
        FROM
            (SELECT
                parttotracking.partid,
                GROUP_CONCAT(parttracking.abbr) AS trackValue
            FROM
                parttotracking
                INNER JOIN parttracking ON parttotracking.parttrackingid = parttracking.id
            GROUP BY parttotracking.partid, parttracking.sortorder
            ORDER BY parttracking.sortorder
            ) AS partrackinfo
        GROUP BY partrackinfo.partid
        ) trackinfo ON woitem.partid = trackinfo.partid
    LEFT JOIN bominstructionitem ON bominstructionitem.bomid = bomitem.bomid AND bominstructionitem.name = bomitem.description
WHERE
    woitem.typeid IN (10,31)
    AND wo.num = $P{woNum}

ORDER BY COALESCE(moitem.sortidinstruct, 500)]]>
		</queryString>
