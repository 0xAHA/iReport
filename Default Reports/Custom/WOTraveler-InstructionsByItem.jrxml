		<queryString>
			<![CDATA[SELECT DISTINCT
    wo.datescheduled AS DATESCHEDULED,
    wo.qtyordered AS QTYORDERED,
    wo.datestarted AS DATESTARTED,
    wo.datefinished AS DATEFINISHED,
    mo.num AS MONUM,
    bom.num AS BOMNUM,
    locationgroup.name AS WOLG,
    location.name AS WOLOC

FROM
    wo
    INNER JOIN moitem ON wo.moitemid = moitem.id
    INNER JOIN mo ON moitem.moid = mo.id
    LEFT JOIN bom ON moitem.bomid = bom.id
    LEFT JOIN locationgroup ON wo.locationgroupid = locationgroup.id
    LEFT JOIN location ON wo.locationid = location.id

WHERE wo.num LIKE $P{woNum}]]>
		</queryString>
