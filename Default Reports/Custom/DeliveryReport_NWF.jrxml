	<parameter name="carrier" class="java.lang.String">
		<parameterDescription><![CDATA[Route #]]></parameterDescription>
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT ship.num AS pick, soitem.productnum AS partnum, soitem.description,
    SUM(shipitem.qtyshipped) AS pickitemqty, uom.code AS uom,
    40 AS pickitemstatus, shipstatus.name as pickstatus,
    MIN(shipitem.id) AS itemid,
    '' AS sourcelocation,
    '' AS destlocation,
    carrier.name AS carriername,
    carrierservice.name AS carrierservicename,
    customer.name AS customername,
    so.num AS salesordernum,
    so.customerpo,
    COALESCE(ship.shiptoname, so.shiptoname, '') AS shiptoname,
    COALESCE(ship.shiptoaddress, so.shiptoaddress) AS shiptoaddress,
    COALESCE(ship.shiptocity, so.shiptocity) AS shiptocity,
    stateconst.code AS shiptostate,
    COALESCE(ship.shiptozip, so.shiptozip) AS shiptozip,
    CASE WHEN ROW_NUMBER() OVER (PARTITION BY ship.id ORDER BY soitem.productnum) = 1
         THEN COALESCE(ship.cartoncount, 0)
         ELSE 0 END AS cartoncount,
    company.name AS company
FROM ship
    INNER JOIN shipitem ON shipitem.shipid = ship.id
    INNER JOIN soitem ON shipitem.soitemid = soitem.id
    INNER JOIN so ON ship.soid = so.id
    INNER JOIN uom ON soitem.uomid = uom.id
    INNER JOIN product ON soitem.productid = product.id
    LEFT JOIN part ON product.partid = part.id
    INNER JOIN carrier ON ship.carrierid = carrier.id
    LEFT JOIN carrierservice ON ship.carrierserviceid = carrierservice.id
    LEFT JOIN stateconst ON COALESCE(ship.shiptostateid, so.shiptostateid) = stateconst.id
    LEFT JOIN customer ON so.customerid = customer.id
    INNER JOIN shipstatus ON shipstatus.id = ship.statusid
    CROSS JOIN company
WHERE company.id = 1
  AND carrier.name LIKE $P{carrier}
  AND ship.statusid = 20
  AND soitem.typeid IN (10,30,40,50,60,70)
  AND (part.typeid IN (10,21,22,30,40,50) OR part.typeid IS NULL)
  AND shipitem.qtyshipped > 0
GROUP BY ship.id, ship.num, soitem.productnum, soitem.description, uom.code, shipstatus.name, carrier.name, carrierservice.name,
         customer.name, so.num, so.customerpo, ship.shiptoname, so.shiptoname,
         ship.shiptoaddress, so.shiptoaddress, ship.shiptocity, so.shiptocity,
         stateconst.code, ship.shiptozip, so.shiptozip, ship.cartoncount, company.name
ORDER BY carrierservice.name, COALESCE(ship.shiptoname, so.shiptoname), ship.num, soitem.productnum]]>
	</queryString>
