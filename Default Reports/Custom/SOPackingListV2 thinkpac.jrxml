			<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT GROUP_CONCAT(IF(SHIPITEM.SHIPID = $P!{ShipID}, SHIPITEM.ID, NULL)) AS SHIPITEMID,
   SOITEM.SOLINEITEM AS SOLINEITEM,
   SOITEM.PRODUCTNUM AS PRODUCTNUM,
   SOITEM.CUSTOMERPARTNUM AS CUSTPARTNUM,
   SOITEM.DESCRIPTION AS PRODUCTDESCRIPTION,
   SOITEM.NOTE AS NOTE,
   SOITEM.QTYTOFULFILL AS QTYTOFULFILL,
   SOITEM.QTYFULFILLED AS QTYFULFILLED,
   SOITEM.QTYPICKED AS QTYPICKED,
   IF(soitem.typeid = 80, IF(soitem.qtyfulfilled = 0, soitem.qtytofulfill, soitem.qtyfulfilled), COALESCE(SUM(IF(SHIPITEM.SHIPID = $P!{ShipID}, SHIPITEM.QTYSHIPPED, 0)),0)) AS QTYSHIPPED,
     SOITEM.QTYTOFULFILL - ( IF(soitem.typeid = 80, IF(soitem.qtyfulfilled = 0, soitem.qtytofulfill, soitem.qtyfulfilled), COALESCE(SUM(IF(SHIPITEM.SHIPID = $P!{ShipID}, SHIPITEM.QTYSHIPPED, 0)),0))) - COALESCE((
      SELECT SUM(SI.QTYSHIPPED)
      FROM SHIPITEM AS SI
         JOIN SHIP AS S ON S.ID = SI.SHIPID
      WHERE S.STATUSID IN (20, 30)
         AND SI.SHIPID < $P!{ShipID} -- i can't see a situation where sequential shipments would not have sequential shipIDs
         AND SI.SOITEMID = SOITEM.ID),0) AS QTYREMAINING,
   PART.TRACKINGFLAG AS HASTRACKING,
   UOM.CODE AS UOMCODE,
   PRODUCT.WEIGHT AS PRODUCTWEIGHT,
   PART.TYPEID,
   COMPANY.NAME AS COMPANYNAME,
   SOITEM.UNITPRICE + COALESCE(SOITEM.ADJUSTAMOUNT / IF(SOITEM.QTYTOFULFILL = 0, 1, SOITEM.QTYTOFULFILL)) AS UNITPRICE,
   HOMECURRENCY.SYMBOL AS HOMECURRENCYSYMBOL,
   $P!{CustomField:Item1} AS itemcf1,
    $P!{CustomField:Item2} AS itemcf2,
    $P!{CustomField:Item3} AS itemcf3,
OBO.RECORDID2 AS KITPARENTLINE

FROM soitem
   INNER JOIN uom ON soitem.uomid = uom.id
   INNER JOIN product ON soitem.productid = product.id
   INNER JOIN company ON company.id = 1
   LEFT OUTER JOIN part ON product.partid = part.id
   LEFT OUTER JOIN shipitem ON shipitem.soItemId = soitem.id
   LEFT OUTER JOIN ship ON ship.id = shipItem.shipId
   LEFT OUTER JOIN currency AS homeCurrency ON homeCurrency.homeCurrency = 1
   LEFT JOIN objecttoobject AS obo ON obo.recordid1 = soitem.id AND obo.typeid = 30 AND obo.tableid1  = 1002104832

WHERE soitem.soid = $P!{SOID}
   AND (
      shipitem.shipID = $P!{ShipID}
      OR (CASE WHEN $P!{ckShowKitHeaders} = 80 THEN soItem.typeid = 80 AND shipitem.shipid IS NULL ELSE FALSE END)
      OR (CASE WHEN $P!{ckShowBackOrderItems} = 100 THEN soItem.typeId != 80 ELSE FALSE END)
   )
   AND soitem.typeid IN (10,30,40,50,60,70,$P!{ckShowKitHeaders})
   AND (
      part.typeid IN (10,21,22,30,40,50)
      OR (CASE WHEN $P!{ckShowKitHeaders} = 80 THEN part.typeid IS NULL END)
   )
   AND IF($P!{ShowKitHeadersOnly}, obo.recordid1 IS NULL, 1=1)

GROUP BY soItem.id

ORDER BY soitem.solineitem

-- rev 6/3/2020]]>
		</queryString>
		<field name="SHIPITEMID" class="java.lang.String"/>
		<field name="SOLINEITEM" class="java.lang.Integer"/>
		<field name="PRODUCTNUM" class="java.lang.String"/>
		<field name="CUSTPARTNUM" class="java.lang.String"/>
		<field name="PRODUCTDESCRIPTION" class="java.lang.String"/>
		<field name="NOTE" class="java.lang.String"/>
		<field name="QTYTOFULFILL" class="java.lang.Double"/>
		<field name="QTYFULFILLED" class="java.lang.Double"/>
		<field name="QTYPICKED" class="java.lang.Double"/>
		<field name="QTYSHIPPED" class="java.lang.Double"/>
		<field name="QTYREMAINING" class="java.lang.Double"/>
		<field name="HASTRACKING" class="java.lang.Integer"/>
		<field name="UOMCODE" class="java.lang.String"/>
		<field name="PRODUCTWEIGHT" class="java.lang.Double"/>
		<field name="TYPEID" class="java.lang.Integer"/>
		<field name="COMPANYNAME" class="java.lang.String"/>
		<field name="UNITPRICE" class="java.lang.Double"/>
		<field name="HOMECURRENCYSYMBOL" class="java.lang.Integer"/>
		<field name="itemcf1" class="java.lang.String"/>
		<field name="itemcf2" class="java.lang.String"/>
		<field name="itemcf3" class="java.lang.String"/>
		<field name="KITPARENTLINE" class="java.lang.Integer"/>
		<variable name="CountCustParts" class="java.lang.Integer" calculation="Sum">
			<variableExpression><![CDATA[(($F{CUSTPARTNUM} == null) || ($F{CUSTPARTNUM}.length() < 1)) ? new Integer(0) : new Integer(1)]]></variableExpression>
		</variable>
		<variable name="PartInfo" class="java.lang.String">
			<variableExpression><![CDATA[($F{KITPARENTLINE} == null ? "" : "     ") + (
    ($F{PRODUCTNUM} == null) ? "" :
	(($F{CUSTPARTNUM} == null) || ($F{CUSTPARTNUM}.length() < 1)) ? $F{PRODUCTNUM} + " - " + $F{PRODUCTDESCRIPTION} : $F{CUSTPARTNUM} + " (" + $F{PRODUCTNUM} + ") - " + $F{PRODUCTDESCRIPTION})]]></variableExpression>
		</variable>
		<variable name="QtyRemaining" class="java.lang.Double">
			<variableExpression><![CDATA[new Double(
($P{ShipStatus}.trim().equals("30"))
	? $F{QTYTOFULFILL}.doubleValue() - $F{QTYFULFILLED}.doubleValue()
	: $F{QTYTOFULFILL}.doubleValue() - $F{QTYFULFILLED}.doubleValue() - $F{QTYPICKED}.doubleValue()
)]]></variableExpression>
		</variable>
		<variable name="TrackingInfo" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[(($P{module} == null || $F{SHIPITEMID} == null || $F{HASTRACKING} != 1)
    ? ""
    : ((com.evnt.eve.modules.ReportHelperModule) $P{module}).getAllShipItemTrackingInfo("ShipItem", $F{SHIPITEMID}).replaceAll("    ","\n"))]]></variableExpression>
		</variable>
		<variable name="QtyShipped" class="java.lang.Double" resetType="Group" resetGroup="soLineItemGroup" calculation="Sum">
			<variableExpression><![CDATA[$F{QTYSHIPPED}]]></variableExpression>
		</variable>
		<variable name="PriceDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_PRICE")]]></variableExpression>
		</variable>
		<variable name="QtyDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_QTY")]]></variableExpression>
		</variable>
		<variable name="CostDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_COST")]]></variableExpression>
		</variable>
		<variable name="isMultiCurrency" class="java.lang.Boolean">
			<variableExpression><![CDATA[com.evnt.eve.modules.CurrencyModule.isMultiCurrency()]]></variableExpression>
		</variable>
		<variable name="TotalQtyOrdered" class="java.lang.Integer" calculation="Sum">
			<variableExpression><![CDATA[$P{ShowKitHeadersOnly} ? $F{QTYTOFULFILL} :
$F{TYPEID} != null ? $F{QTYTOFULFILL} : null]]></variableExpression>
		</variable>
		<variable name="TotalQtyShipped" class="java.lang.Integer" calculation="Sum">
			<variableExpression><![CDATA[$P{ShowKitHeadersOnly} ? $V{QtyShipped} :
$F{TYPEID} != null ? $V{QtyShipped} : null]]></variableExpression>
		</variable>
		<variable name="TotalQtyRemaining" class="java.lang.Integer" calculation="Sum">
			<variableExpression><![CDATA[$P{ShowKitHeadersOnly} ? ($P{ShowHistoricalQtyRemaining} ? $F{QTYREMAINING} : $V{QtyRemaining}) :
$F{TYPEID} != null ?
    $P{ShowHistoricalQtyRemaining} ? $F{QTYREMAINING} : $V{QtyRemaining}
    : null]]></variableExpression>
		</variable>
		<group name="New Column Header" isReprintHeaderOnEachPage="true">
			<groupExpression><![CDATA[1]]></groupExpression>
		</group>
		<group name="soLineItemGroup">
			<groupExpression><![CDATA[$F{SOLINEITEM}]]></groupExpression>
		</group>
	</subDataset>
	<subDataset name="CartonInfo" uuid="fb6d29de-56ea-433e-bc1b-60f30d8987a2">
		<parameter name="ISSUBREPORTONLY" class="java.lang.String" isForPrompting="false"/>
