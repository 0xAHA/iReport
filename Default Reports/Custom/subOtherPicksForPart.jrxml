	<style name="10" fontName="Open Sans" fontSize="10" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false" pdfEncoding="Cp1252" isPdfEmbedded="false"/>
	<style name="10b" fontName="Open Sans" fontSize="10" isBold="true" isItalic="false" isUnderline="false" isStrikeThrough="false" pdfEncoding="Cp1252" isPdfEmbedded="false"/>
	<style name="body" isDefault="true" fontName="Open Sans" fontSize="10" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false" pdfEncoding="Cp1252" isPdfEmbedded="false"/>
	<parameter name="currentPickID" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
	</parameter>
	<parameter name="partID" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
	</parameter>
	<parameter name="locationGroupID" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    GROUP_CONCAT(DISTINCT PICK.NUM ORDER BY PICK.NUM SEPARATOR ', ') AS PICKNUMBER,
    GROUP_CONCAT(DISTINCT SUBSTRING(PICK.NUM FROM 2 FOR 50) ORDER BY PICK.NUM SEPARATOR ', ') AS ORDERNUMBER,
    SUM(PICKITEM.QTY) AS PICKITEMQTY,
    GROUP_CONCAT(DISTINCT
        CASE
            WHEN SUBSTRING(PICK.NUM FROM 1 FOR 1) = 'S' THEN
                (SELECT CUSTOMER.NAME
                 FROM so
                 INNER JOIN customer ON so.customerid = customer.id
                 WHERE so.num = SUBSTRING(PICK.NUM FROM 2 FOR 50))
            ELSE ''
        END
    SEPARATOR ', ') AS CUSTOMERNAME,
    DESTLG.NAME AS DESTLOCATIONGROUP,
    destlocation.name AS DESTLOCATIONNAME,
    SHIPPING.SHIPPINGQTY
FROM pick
    INNER JOIN pickstatus ON pick.statusid = pickstatus.id
    INNER JOIN pickitem ON pick.id = pickitem.pickid
    LEFT OUTER JOIN tag desttag ON pickitem.desttagid = desttag.id
    LEFT OUTER JOIN location destlocation ON desttag.locationid = destlocation.id
    LEFT OUTER JOIN locationgroup destlg ON destlocation.locationgroupid = destlg.id
    CROSS JOIN (
        SELECT COALESCE(SUM(TAG.QTY) - SUM(TAG.QTYCOMMITTED), 0) AS SHIPPINGQTY
        FROM tag TAG
        INNER JOIN location LOC ON TAG.LOCATIONID = LOC.ID
        WHERE TAG.PARTID = $P{partID}
          AND LOC.TYPEID = 20
          AND LOC.DEFAULTFLAG = true
          AND LOC.LOCATIONGROUPID = $P{locationGroupID}
    ) AS SHIPPING
WHERE pick.id != $P{currentPickID}
  AND pickitem.partid = $P{partID}
  AND pick.locationgroupid = $P{locationGroupID}
  AND pick.statusid IN (20, 30)
  AND pickitem.statusid IN (20,30)
GROUP BY DESTLG.NAME, destlocation.name, SHIPPING.SHIPPINGQTY]]>
	</queryString>
	<field name="PICKNUMBER" class="java.lang.String"/>
	<field name="ORDERNUMBER" class="java.lang.String"/>
	<field name="PICKITEMQTY" class="java.math.BigDecimal"/>
	<field name="CUSTOMERNAME" class="java.lang.String"/>
	<field name="DESTLOCATIONGROUP" class="java.lang.String"/>
	<field name="SHIPPINGQTY" class="java.math.BigDecimal"/>
	<field name="DESTLOCATIONNAME" class="java.lang.String"/>
	<variable name="QtyDecimal" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_QTY")]]></variableExpression>
	</variable>
