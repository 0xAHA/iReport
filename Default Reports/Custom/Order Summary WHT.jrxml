<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="OrderSummary" pageWidth="792" pageHeight="612" orientation="Landscape" columnWidth="752" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="7ad7244c-ca05-420e-9cad-ab81ce9adfb9">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="cbApplyDateFilter" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["receiptitem.dateReceived"]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRange1" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRange2" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="ckFulfilled" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["40"]]></defaultValueExpression>
	</parameter>
	<parameter name="ckReceived" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["30"]]></defaultValueExpression>
	</parameter>
	<parameter name="ckReconciled" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["20"]]></defaultValueExpression>
	</parameter>
	<parameter name="ckEntered" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["10"]]></defaultValueExpression>
	</parameter>
	<parameter name="ckShowPurchaseOrders" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["10"]]></defaultValueExpression>
	</parameter>
	<parameter name="ckShowSalesOrders" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["20"]]></defaultValueExpression>
	</parameter>
	<parameter name="ckShowTransferOrders" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["40"]]></defaultValueExpression>
	</parameter>
	<parameter name="partNum" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="receiptID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="locationGroupID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="vendorID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="customerID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
po.dateissued AS IssueDate,
receipt.ordertypeid,
po.num AS orderNum,
vendor.name AS fromLocationGroup,
polgname.name AS toLocationGroup,
part.num AS partNum,
part.description AS partDesc,
receiptitem.datereceived,
receiptitem.datebilled,
receiptitem.dateReconciled,
receiptitem.dateLastModified,
receiptitem.qty AS qty,
uom.code AS uom,
receiptitem.billedtotalcost,
company.name AS company,
receiptitem.landedtotalcost,
CURRENCY.SYMBOL

FROM receiptitem
  JOIN receipt ON receiptitem.receiptid = receipt.id
  JOIN poitem ON receiptitem.poitemid = poitem.id AND receiptitem.ordertypeid = 10
  LEFT JOIN po ON poitem.poid = po.id
  LEFT JOIN vendor ON po.vendorid = vendor.id
  LEFT JOIN locationgroup polgname ON po.locationgroupid = polgname.id
  JOIN part ON poitem.partid = part.id
  JOIN company ON company.id = 1
  JOIN uom ON receiptitem.uomid = uom.id
LEFT JOIN currency ON currency.homeCurrency = 1

WHERE IF($P!{cbApplyDateFilter} = 1, po.dateissued, $P!{cbApplyDateFilter}) BETWEEN $P{dateRange1} AND DATE_SUB($P{dateRange2}, INTERVAL 1 SECOND)
AND receiptitem.statusid IN ($P!{ckEntered}, $P!{ckReconciled}, $P!{ckReceived}, $P!{ckFulfilled})
AND receipt.ordertypeid IN ($P!{ckShowPurchaseOrders})
AND part.num LIKE $P{partNum}
AND receipt.id LIKE $P{receiptID}
AND vendor.id LIKE $P{vendorID}
AND receipt.locationgroupid IN ($P!{locationGroupID})
AND IF("$P!{customerID}" = "%", 1 = 1, 1 = 0)

UNION ALL

SELECT
so.dateissued AS IssueDate,
receipt.ordertypeid,
so.num AS orderNum,
solgname.name AS fromLocationGroup,
customer.name AS toLocationGroup,
part.num AS partNum,
part.description AS partDesc,
receiptitem.datereceived,
receiptitem.datebilled,
receiptitem.dateReconciled,
receiptitem.dateLastModified,
receiptitem.qty AS qty,
uom.code AS uom,
receiptitem.billedtotalcost,
company.name AS company,
receiptitem.landedtotalcost,
CURRENCY.SYMBOL

FROM receiptitem
  JOIN receipt ON receiptitem.receiptid = receipt.id
  JOIN soitem ON receiptitem.soitemid = soitem.id AND receiptitem.ordertypeid = 20
  LEFT JOIN so ON soitem.soid = so.id
  LEFT JOIN customer ON so.customerid = customer.id
  LEFT JOIN locationgroup solgname ON so.locationgroupid = solgname.id
  LEFT JOIN product ON soitem.productid = product.id
  LEFT JOIN part ON product.partid = part.id
  JOIN company ON company.id = 1
  JOIN uom ON receiptitem.uomid = uom.id
LEFT JOIN currency ON currency.homeCurrency = 1

WHERE IF($P!{cbApplyDateFilter} = 1, so.dateissued, $P!{cbApplyDateFilter}) BETWEEN $P{dateRange1} AND DATE_SUB($P{dateRange2}, INTERVAL 1 SECOND)
AND receiptitem.statusid IN ($P!{ckEntered}, $P!{ckReconciled}, $P!{ckReceived}, $P!{ckFulfilled})
AND receipt.ordertypeid IN ($P!{ckShowSalesOrders})
AND part.num LIKE $P{partNum}
AND receipt.id LIKE $P{receiptID}
AND customer.id LIKE $P{customerID}
AND receipt.locationgroupid IN ($P!{locationGroupID})
AND IF("$P!{vendorID}" = "%", 1 = 1, 1 = 0)

UNION ALL

SELECT
xo.dateissued AS IssueDate,
receipt.ordertypeid,
xo.num AS orderNum,
fromlg.name AS fromLocationGroup,
xo.shiptoname AS toLocationGroup,
part.num AS partNum,
part.description AS partDesc,
receiptitem.datereceived,
receiptitem.datebilled,
receiptitem.dateReconciled,
receiptitem.dateLastModified,
receiptitem.qty AS qty,
uom.code AS uom,
receiptitem.billedtotalcost,
company.name AS company,
receiptitem.landedtotalcost,
CURRENCY.SYMBOL

FROM receiptitem
  JOIN receipt ON receiptitem.receiptid = receipt.id
  JOIN xoitem ON receiptitem.xoitemid = xoitem.id AND receiptitem.ordertypeid = 40
  LEFT JOIN xo ON xoitem.xoid = xo.id
  LEFT JOIN locationgroup fromlg ON xo.fromlgid = fromlg.id
  LEFT JOIN part ON xoitem.partid = part.id
  JOIN company ON company.id = 1
  JOIN uom ON receiptitem.uomid = uom.id
LEFT JOIN currency ON currency.homeCurrency = 1

WHERE IF($P!{cbApplyDateFilter} = 1, xo.dateissued, $P!{cbApplyDateFilter}) BETWEEN $P{dateRange1} AND DATE_SUB($P{dateRange2}, INTERVAL 1 SECOND)
AND receiptitem.statusid IN ($P!{ckEntered}, $P!{ckReconciled}, $P!{ckReceived}, $P!{ckFulfilled})
AND receipt.ordertypeid IN ($P!{ckShowTransferOrders})
AND part.num LIKE $P{partNum}
AND receipt.id LIKE $P{receiptID}
AND receipt.locationgroupid IN ($P!{locationGroupID})
AND IF("$P!{vendorID}" = "%", 1 = 1, 1 = 0)
AND IF("$P!{customerID}" = "%", 1 = 1, 1 = 0)

ORDER BY 3, 4, 1,7,8,9,10]]>
	</queryString>
	<field name="IssueDate" class="java.sql.Timestamp"/>
	<field name="ordertypeid" class="java.lang.Integer"/>
	<field name="orderNum" class="java.lang.String"/>
	<field name="fromLocationGroup" class="java.lang.String"/>
	<field name="toLocationGroup" class="java.lang.String"/>
	<field name="partNum" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="partDesc" class="java.lang.String"/>
	<field name="datereceived" class="java.sql.Timestamp">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="datebilled" class="java.sql.Timestamp"/>
	<field name="dateReconciled" class="java.sql.Timestamp"/>
	<field name="dateLastModified" class="java.sql.Timestamp"/>
	<field name="qty" class="java.lang.Double">
