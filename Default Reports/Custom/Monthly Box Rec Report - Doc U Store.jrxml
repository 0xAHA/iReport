<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Monthly Box Rec Report - Doc U Store" pageWidth="2400" pageHeight="842" columnWidth="2360" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="46d58ae2-4ce3-4c01-b5a5-8e4bd2147711">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<queryString>
		<![CDATA[SELECT
part.num AS part_num
,part.description AS part_description
,COALESCE(start_q.qty,0) AS start_qty
,SUM(IF(MONTH(il.datecreated) = '1', il.changeqty, 0))AS JAN
,SUM(IF(MONTH(il.datecreated) = '2', il.changeqty, 0)) AS FEB
,SUM(IF(MONTH(il.datecreated) = '3', il.changeqty, 0)) AS MAR
,SUM(IF(MONTH(il.datecreated) = '4', il.changeqty, 0)) AS APR
,SUM(IF(MONTH(il.datecreated) = '5', il.changeqty, 0)) AS MAY
,SUM(IF(MONTH(il.datecreated) = '6', il.changeqty, 0)) AS JUN
,SUM(IF(MONTH(il.datecreated) = '7', il.changeqty, 0)) AS JUL
,SUM(IF(MONTH(il.datecreated) = '8', il.changeqty, 0)) AS AUG
,SUM(IF(MONTH(il.datecreated) = '9', il.changeqty, 0)) AS SEP
,SUM(IF(MONTH(il.datecreated) = '10', il.changeqty, 0)) AS `OCT`
,SUM(IF(MONTH(il.datecreated) = '11', il.changeqty, 0)) AS NOV
,SUM(IF(MONTH(il.datecreated) = '12', il.changeqty, 0)) AS `DEC`
FROM part
JOIN inventorylog il ON il.partid = part.id AND il.typeid = 64
LEFT JOIN (SELECT
				partid
				,il.qtyonhand AS qty
				,MAX(il.id) AS ilid
				FROM inventorylog il
				 WHERE YEAR(il.datecreated) < '2025'
				 GROUP BY 1) AS start_q ON start_q.partid = part.id
WHERE YEAR(il.datecreated) = '2025'
GROUP BY 1
ORDER BY 1]]>
	</queryString>
