		<queryString>
			<![CDATA[/* Product Info */
SELECT (CASE WHEN $P!{cbGroupBy} = ''
             THEN SOITEM.DESCRIPTION
             ELSE  $P!{cbGroupBy} END) AS GROUPBY, SO.NUM AS SONUM, CUSTOMER.NAME AS CUSTNAME,
    (CASE WHEN SOITEM.TYPEID = 11
         THEN 'MISC. SALE'
         ELSE (CASE WHEN SOITEM.TYPEID = 21
                    THEN 'MISC. CREDIT'
                   ELSE SOITEM.PRODUCTNUM END) END) AS PRODUCTNUM, SOITEM.DESCRIPTION,
    SUM((CASE WHEN SOITEM.UOMID != PRODUCT.UOMID THEN ((POSTSOITEM.QTY*UOMCONVERSION.MULTIPLY)/UOMCONVERSION.FACTOR) ELSE POSTSOITEM.QTY END)) AS QTY,
    SUM(IF(SOITEM.TYPEID = 80, KL.COGS, POSTSOITEM.POSTEDTOTALCOST)) AS POSTEDTOTALCOST,
    (CASE WHEN SOITEM.UOMID != PRODUCT.UOMID THEN ((SOITEM.UNITPRICE + (CASE WHEN SOITEM.ADJUSTAMOUNT != 0 THEN (SOITEM.ADJUSTAMOUNT / SOITEM.QTYTOFULFILL) ELSE 0 END))/UOMCONVERSION.MULTIPLY)*UOMCONVERSION.FACTOR ELSE (SOITEM.UNITPRICE + (CASE WHEN SOITEM.ADJUSTAMOUNT != 0 THEN (SOITEM.ADJUSTAMOUNT / SOITEM.QTYTOFULFILL) ELSE 0 END)) END) AS UNITPRICE,
   COALESCE(UOM.CODE, MISCUOM.CODE) AS UOMCODE, CustomFieldById(customer.CustomFields,23) AS DISTRIBUTOR

FROM so
    INNER JOIN customer ON so.customerid = customer.id
    INNER JOIN soitem ON so.id = soitem.soid

    left join objecttoobject on objecttoobject.tableid1 = 1002104832 and objecttoobject.tableid2 = 1002104832 and objecttoobject.recordid1 = soitem.id
    left join soitem as kh on kh.id = objecttoobject.recordid2

    LEFT JOIN product ON soitem.productid = product.id
    LEFT JOIN part on part.id = product.partid
    INNER JOIN postsoitem ON soitem.id = postsoitem.soitemid
    INNER JOIN postso ON postsoitem.postsoid = postso.id
    LEFT JOIN uom ON product.uomid = uom.id
    LEFT JOIN uom as miscuom on soitem.uomid = miscuom.id
    LEFT JOIN uomconversion ON product.uomid = uomconversion.touomid AND soitem.uomid = uomconversion.fromuomid
    left join (
        select
            kh.id as khid,
            SUM(postsoitem.postedtotalcost) as COGS
            FROM objecttoobject
                join soitem as kh on kh.id = objecttoobject.recordid2
                join soitem as ki on ki.id = objecttoobject.recordid1
                join postsoitem on postsoitem.soitemid = ki.id
                join postso on postso.id = postsoitem.postsoid
        where objecttoobject.tableid1 = 1002104832 and objecttoobject.tableid2 = 1002104832
        and postso.postdate between $P{dateRange1} AND $P{dateRange2}
        group by 1
    ) as kl on kl.khid = soitem.id and soitem.typeid = 80 /* Bring in this table when the sale line is a kit item */


WHERE UPPER(so.num) LIKE UPPER($P{soNum})
  AND UPPER(so.salesman) LIKE UPPER($P{salesPerson})
  AND so.customerid LIKE $P{customerID}
  AND COALESCE(soitem.qbclassid,so.qbclassid,0) like $P{qbClassID}
  AND postso.postdate BETWEEN $P{dateRange1} AND $P{dateRange2}
  AND soitem.typeid IN ($P{ckLineItemSale},$P{ckLineItemMisc. Sale},$P{ckLineItemDrop Ship},$P{ckLineItemCredit Return},$P{ckLineItemMisc. Credit},$P{ckLineItemDiscount Percentage},$P{ckLineItemDiscount Amount},$P{ckLineItemSubtotal},$P{ckLineItemAssoc. Price},$P{ckLineItemShipping},$P{ckLineItemTax},$P{ckLineItemKit},$P{ckLineItemNote})
  AND soitem.productnum LIKE $P{productNum}
  AND so.locationgroupid IN ($P!{locationGroupID})
and CustomFieldById(customer.CustomFields,23) = "false"
  AND kh.id is null /* Lines who have no kit header - so that means kit headers, and ordinary sales */
  AND COALESCE(part.typeid,0) IN ($P{ckPartTypeNon Parts},$P{ckPartTypeInventory},$P{ckPartTypeService},$P{ckPartTypeLabor},$P{ckPartTypeOverhead},$P{ckPartTypeNon-Inventory},$P{ckPartTypeInternal Use},$P{ckPartTypeCapital Equipment},$P{ckPartTypeShipping},$P{ckPartTypeTax},$P{ckPartTypeMisc})

GROUP BY soitem.productnum, uomcode, sonum, custname, soitem.description, soitem.unitprice, groupby, soitem.typeid, product.uomid, uomconversion.multiply, uomconversion.factor, unitprice,Distributor

ORDER BY 1, productnum, uomcode, sonum, custname, soitem.description, soitem.unitprice]]>
		</queryString>
		<field name="GROUPBY" class="java.lang.String"/>
		<field name="SONUM" class="java.lang.String"/>
		<field name="CUSTNAME" class="java.lang.String"/>
		<field name="PRODUCTNUM" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="DESCRIPTION" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="QTY" class="java.lang.Double">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="POSTEDTOTALCOST" class="java.lang.Double">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="UNITPRICE" class="java.lang.Double">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="UOMCODE" class="java.lang.String"/>
