	</field>
	<field name="PartUPC" class="java.lang.String"/>
	<field name="PALLETQTY" class="java.math.BigDecimal"/>
	<field name="INFODATE" class="java.sql.Timestamp">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="ExpGtin" class="java.lang.String"/>
	<field name="CheckBit" class="java.lang.String"/>
