<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Nerang_SSCC Label" pageWidth="595" pageHeight="842" columnWidth="595" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="beba3fb4-d43c-4673-9b06-245840737cc4">
	<property name="ireport.zoom" value="1.3636363636363675"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="357"/>
	<style name="Barcode" hAlign="Center" vAlign="Middle" fontName="Open Sans" fontSize="7" isBold="true" pdfFontName="Helvetica"/>
	<parameter name="shipID" class="java.lang.String">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT

    so.num AS orderNum,
    so.customerPo AS altOrderNum,
    soitem.productNum,
    soitem.description,
    substring(shipcarton.sscc,11,7) as SSCC,
    right(10 - right((substring(shipcarton.sscc,11,1)*3 +
         substring(shipcarton.sscc,12,1) +
         substring(shipcarton.sscc,13,1)*3 +
         substring(shipcarton.sscc,14,1) +
         substring(shipcarton.sscc,15,1)*3 +
         substring(shipcarton.sscc,16,1) +
         substring(shipcarton.sscc,17,1)*3) + 85,1),1) as CheckBit,
    Product.UPC as PartUPC, sum(shipitem.qtyshipped) AS PALLETQTY,
Date_Format(TRACKINGINFO.INFODATE, "%y%m%d") as ExpGtin,
TRACKINGINFO.INFODATE, TBATCH.INFO as BOXSERIAL

FROM
    shipitem
    JOIN ship ON ship.id = shipitem.shipId
     LEFT JOIN soitem ON soitem.id = shipitem.soitemId
    LEFT JOIN so ON so.id = soitem.soId
    LEFT JOIN product ON product.id = shipitem.itemid

    LEFT JOIN shipcarton ON shipcarton.id = shipitem.shipCartonId
    LEFT JOIN TRACKINGINFO on trackinginfo.recordid = shipitem.id and parttrackingid = 3 and tableid = 1555030112
  LEFT JOIN TRACKINGINFO  as TBATCH on TBATCH.recordid = shipitem.id and TBATCH.parttrackingid = 1 and TBATCH.tableid = 1555030112
WHERE ship.id = $P{shipID}
group by shipitem.shipcartonid]]>
	</queryString>
