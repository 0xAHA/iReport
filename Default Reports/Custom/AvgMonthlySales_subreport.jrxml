<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="AvgMonthlySales_subreport" pageWidth="80" pageHeight="20" columnWidth="80" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="a8f5c2d9-7e4b-4c6e-b1a3-9f8e6d7c5a4b">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="PartNum" class="java.lang.String"/>
	<parameter name="LocationGroupID" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
    COALESCE(ROUND(SUM(soitem.qtyToFulfill) / 3, 2), 0) as AvgMonthlySales
FROM part
    LEFT JOIN soitem ON soitem.productnum = part.num
    LEFT JOIN so ON soitem.soid = so.id
WHERE part.num = $P{PartNum}
    AND so.statusid >= 60
    AND so.dateCompleted >= DATE_FORMAT(DATE_SUB(LAST_DAY(DATE_SUB(CURDATE(), INTERVAL 1 MONTH)), INTERVAL 2 MONTH), '%Y-%m-01')
    AND so.dateCompleted <= LAST_DAY(DATE_SUB(CURDATE(), INTERVAL 1 MONTH))
    AND ($P{LocationGroupID} = '-1' OR so.locationgroupid IN ($P!{LocationGroupID}))]]>
	</queryString>
	<field name="AvgMonthlySales" class="java.math.BigDecimal"/>
	<detail>
		<band height="14">
			<textField pattern="#,##0.00" isBlankWhenNull="true">
				<reportElement x="0" y="0" width="80" height="14" uuid="b4e6f8a1-9c5d-4e3f-b7a2-8f9e6d7c5b4a"/>
				<textElement textAlignment="Right">
					<font fontName="Open Sans" size="10"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{AvgMonthlySales}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
</jasperReport>
