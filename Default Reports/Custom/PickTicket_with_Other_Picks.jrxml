	<queryString>
		<![CDATA[SELECT
    PICK.ID AS PICKID,
    PICK.NUM AS PICKNUMBER,
    PICKTYPE.NAME AS PICKTYPE,
    PICKSTATUS.NAME AS PICKSTATUS,
    PRIORITY.NAME AS PICKPRIORITY,
    PICKLG.NAME AS PICKLOCATIONGROUP,
    PICKLG.ID AS PICKLOCATIONGROUPID,
    PICK.DATECREATED AS PICKDATECREATED,
    PICK.DATESCHEDULED AS PICKDATESCHEDULED,
    PICK.DATEFINISHED AS PICKDATEFINISHED,
    PICK.DATELASTMODIFIED AS PICKDATELASTMODIFIED,
    PICK.DATESTARTED AS PICKDATESTARTED,
    SUBSTRING(PICK.NUM FROM 2 FOR 50) AS ORDERNUMBER,
    PICKITEM.ID AS PICKITEMID,
    PICKITEMSTATUS.NAME AS PICKITEMSTATUS,
    PART.NUM AS PICKITEMPARTNUM,
    PART.ID AS PARTID,
    CARRIER.NAME AS CARRIER,
    PART.DESCRIPTION AS PICKITEMPARTDESC,
    PICKITEM.QTY AS PICKITEMQTY,
    PICKITEM.SLOTNUM AS SLOTNUM,
    UOM.CODE AS PICKITEMUOM,
    MAINLOCATION.NAME AS PICKITEMLOCNAME,
    MAINLG.NAME AS PICKITEMLOCGRPNAME,
    MAINTAG.NUM AS PICKITEMTAGNUM,
    DESTLOCATION.NAME AS PICKITEMDESTLOCNAME,
    DESTLG.NAME AS PICKITEMDESTLOCGRPNAME,
    PICKITEM.SLOTNUM AS PICKSLOTNUM,
    (CASE
        WHEN PICKITEM.ORDERTYPEID = 10 THEN POITEM.NOTE
        WHEN PICKITEM.ORDERTYPEID = 20 THEN SOITEM.NOTE
        WHEN PICKITEM.ORDERTYPEID = 40 THEN XOITEM.NOTE
    END) AS PICKITEMNOTE,
    COMPANY.NAME AS COMPANY,
    COALESCE(SOITEM.DESCRIPTION, PART.DESCRIPTION) AS SOITEMDESCRIPTION,
    carrierservice.name AS carrierservice,
    (SELECT SUM(TAG.QTY)
     FROM tag TAG
     WHERE TAG.PARTID = PART.ID
       AND TAG.LOCATIONID = PICKITEM.SRCLOCATIONID) AS QTYONHAND
FROM pick
    INNER JOIN picktype ON pick.typeid = picktype.id
    INNER JOIN pickstatus ON pick.statusid = pickstatus.id
    INNER JOIN priority ON pick.priority = priority.id
    INNER JOIN locationgroup picklg ON pick.locationgroupid = picklg.id
    INNER JOIN company ON company.id = 1
    LEFT OUTER JOIN pickitem ON pick.id = pickitem.pickid
    LEFT OUTER JOIN tag maintag ON COALESCE(pickitem.srctagid, pickitem.tagid) = maintag.id
    LEFT OUTER JOIN location mainlocation ON pickitem.srclocationid = mainlocation.id
    LEFT OUTER JOIN locationgroup mainlg ON mainlocation.locationgroupid = mainlg.id
    LEFT OUTER JOIN pickitemstatus ON pickitem.statusid = pickitemstatus.id
    LEFT OUTER JOIN part ON pickitem.partid = part.id
    LEFT OUTER JOIN uom ON pickitem.uomid = uom.id
    LEFT OUTER JOIN tag desttag ON pickitem.desttagid = desttag.id
    LEFT OUTER JOIN location destlocation ON desttag.locationid = destlocation.id
    LEFT OUTER JOIN locationgroup destlg ON destlocation.locationgroupid = destlg.id
    LEFT OUTER JOIN poitem ON (pickitem.poitemid = poitem.id AND pickitem.ordertypeid = 10)
    LEFT OUTER JOIN soitem ON (pickitem.soitemid = soitem.id AND pickitem.ordertypeid = 20)
    LEFT OUTER JOIN woitem ON (pickitem.woitemid = woitem.id AND pickitem.ordertypeid = 30)
    LEFT OUTER JOIN xoitem ON (pickitem.xoitemid = xoitem.id AND pickitem.ordertypeid = 40)
    LEFT OUTER JOIN po ON ((CASE
                               WHEN SUBSTRING(pick.num FROM 1 FOR 1) = 'P' THEN SUBSTRING(pick.num FROM 2 FOR 50)
                               ELSE ''
                           END) = po.num)
    LEFT OUTER JOIN so ON ((CASE
                               WHEN SUBSTRING(pick.num FROM 1 FOR 1) = 'S' THEN SUBSTRING(pick.num FROM 2 FOR 50)
                               ELSE ''
                           END) = so.num)
    LEFT OUTER JOIN wo ON ((CASE
                               WHEN SUBSTRING(pick.num FROM 1 FOR 1) = 'W' THEN SUBSTRING(pick.num FROM 2 FOR 50)
                               ELSE ''
                           END) = wo.num)
    LEFT OUTER JOIN xo ON ((CASE
                               WHEN SUBSTRING(pick.num FROM 1 FOR 1) = 'T' THEN SUBSTRING(pick.num FROM 2 FOR 50)
                               ELSE ''
                           END) = xo.num)
    LEFT OUTER JOIN carrier ON ((CASE
                                    WHEN SUBSTRING(pick.num FROM 1 FOR 1) = 'P' THEN po.carrierid
                                    WHEN SUBSTRING(pick.num FROM 1 FOR 1) = 'S' THEN so.carrierid
                                    WHEN SUBSTRING(pick.num FROM 1 FOR 1) = 'T' THEN xo.carrierid
                                END) = carrier.id)
    LEFT OUTER JOIN carrierservice ON ((CASE
                                    WHEN SUBSTRING(pick.num FROM 1 FOR 1) = 'P' THEN po.carrierserviceid
                                    WHEN SUBSTRING(pick.num FROM 1 FOR 1) = 'S' THEN so.carrierserviceid
                                    WHEN SUBSTRING(pick.num FROM 1 FOR 1) = 'T' THEN xo.carrierserviceid
                                END) = carrierservice.id)
WHERE pick.num = $P{pickNum}
  AND pickitem.statusid IN (20, 30)
ORDER BY part.num, mainlocation.name]]>
	</queryString>
