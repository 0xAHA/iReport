	<parameter name="path" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:/Program Files/Fishbowl/Server/reports/SalesOrder/"]]></defaultValueExpression>
	</parameter>
	<parameter name="module" class="java.lang.Object" isForPrompting="false">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="REPORTDESCRIPTION" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["Monthly summary of invoices by customer, showing order number, customer name, invoice date, and subtotal. Defaults to last month's data."]]></defaultValueExpression>
	</parameter>
	<parameter name="ReportTitle" class="java.lang.String" isForPrompting="false"/>
	<parameter name="dateRange1" class="java.util.Date" isForPrompting="false">
		<parameterDescription><![CDATA[Last Month]]></parameterDescription>
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRange2" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="customerID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
	(SELECT NAME FROM COMPANY WHERE ID = 1) AS COMPANY,
	SO.NUM AS ORDERNUM,
	CUSTOMER.NAME AS CUSTOMER,
	SO.DATEISSUED AS INVOICEDATE,
	IF(SO.TOTALPRICE = 0, SOI.SUMMEDPRICE + SO.TOTALTAX, SO.TOTALPRICE) AS SUBTOTAL,
	CURRENCY.SYMBOL
FROM customer
	INNER JOIN so ON customer.id = so.customerid
	LEFT JOIN currency ON currency.homeCurrency = 1
	LEFT JOIN(
		SELECT COALESCE(SUM(ROUND(soitem.unitPrice * soItem.qtyToFulfill + COALESCE(soItem.adjustAmount, 0), 2)),0) AS summedprice, soitem.soid
		FROM soitem
		GROUP BY soitem.soid
	) AS SOI ON so.id = SOI.soid
WHERE so.statusId NOT IN (10, 80)
	AND customer.id LIKE $P{customerID}
	AND so.dateIssued BETWEEN $P{dateRange1} AND $P{dateRange2}
ORDER BY so.num]]>
	</queryString>
	<field name="COMPANY" class="java.lang.String"/>
	<field name="ORDERNUM" class="java.lang.String"/>
	<field name="CUSTOMER" class="java.lang.String"/>
	<field name="INVOICEDATE" class="java.sql.Timestamp"/>
	<field name="SUBTOTAL" class="java.math.BigDecimal"/>
	<field name="SYMBOL" class="java.lang.Integer">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<variable name="PriceDecimal" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_PRICE")]]></variableExpression>
	</variable>
