			<variableExpression><![CDATA[(System.getProperty("REPORT_DATE_FORMAT"))]]></variableExpression>
		</variable>
		<variable name="isMultiCurrency" class="java.lang.Boolean">
			<variableExpression><![CDATA[com.evnt.eve.modules.CurrencyModule.isMultiCurrency()]]></variableExpression>
		</variable>
		<variable name="totalOrderCost" class="java.lang.Double" resetType="Group" resetGroup="orderNum" calculation="Sum">
			<variableExpression><![CDATA[$F{billedtotalcost}]]></variableExpression>
		</variable>
		<variable name="totalLandedCost" class="java.lang.Double" resetType="Group" resetGroup="orderNum" calculation="Sum">
			<variableExpression><![CDATA[$F{landedTotalCost}]]></variableExpression>
		</variable>
		<variable name="TotalOrderQty" class="java.lang.Double" resetType="Group" resetGroup="orderNum" calculation="Sum">
			<variableExpression><![CDATA[$F{qty}]]></variableExpression>
		</variable>
		<variable name="GrandTotalQty" class="java.lang.Double" calculation="Sum">
			<variableExpression><![CDATA[$F{qty}]]></variableExpression>
		</variable>
		<variable name="GrandTotalLandedCost" class="java.lang.Double" calculation="Sum">
			<variableExpression><![CDATA[$F{landedTotalCost}]]></variableExpression>
		</variable>
		<variable name="GrandTotalOrderCost" class="java.lang.Double" calculation="Sum">
			<variableExpression><![CDATA[$F{billedtotalcost}]]></variableExpression>
		</variable>
		<group name="orderNum">
			<groupExpression><![CDATA[($F{ordertypeid} == 10 ? "PO: "
: $F{ordertypeid} == 20 ? "SO: "
: "TO: ")+ $F{orderNum}]]></groupExpression>
		</group>
	</subDataset>
