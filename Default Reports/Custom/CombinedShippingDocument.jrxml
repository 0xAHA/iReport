	<queryString>
		<![CDATA[SELECT Distinct
Ship.Id as ShipId,
CASE WHEN CustomFieldByName(Customer.CustomFields,'Shipping Document') = 'Delivery Docket & Invoice' THEN '1'
       WHEN CustomFieldByName(Customer.CustomFields,'Shipping Document') = 'Delivery Docket' THEN '2'
        WHEN CustomFieldByName(Customer.CustomFields,'Shipping Document') = 'Tax Invoice' THEN '3'
         WHEN CustomFieldByName(Customer.CustomFields,'Shipping Document') = 'None' THEN '4'
          ELSE '1' END as PW

FROM Ship
Join Carrier on Carrier.Id = Ship.CarrierId
INNER JOIN ShipItem ON Ship.id = ShipItem.shipId
Left Join So on So.Id = Ship.SoId
Left join Customer on Customer.Id = So.CustomerId
Where Ship.StatusId = 20
and Carrier.Name LIKE $P{carrier}]]>
	</queryString>
	<field name="ShipId" class="java.lang.Integer"/>
	<field name="PW" class="java.lang.String"/>
