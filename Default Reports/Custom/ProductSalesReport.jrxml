	<parameter name="path" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:/Program Files/Fishbowl/Server/reports/SalesOrder/"]]></defaultValueExpression>
	</parameter>
	<parameter name="module" class="java.lang.Object" isForPrompting="false">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="REPORTDESCRIPTION" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["Product sales report showing quantity sold in the selected period, average monthly sold over 6 months, and average monthly sold over 12 months. Defaults to last month's data."]]></defaultValueExpression>
	</parameter>
	<parameter name="ReportTitle" class="java.lang.String" isForPrompting="false"/>
	<parameter name="dateRange1" class="java.util.Date" isForPrompting="false">
		<parameterDescription><![CDATA[Last Month]]></parameterDescription>
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRange2" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="productTreeID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
	(SELECT NAME FROM COMPANY WHERE ID = 1) AS COMPANY,
	COALESCE(PRODUCTTREE.NAME, 'No Product Tree') AS CATEGORY,
	PRODUCT.DESCRIPTION AS PRODUCTNAME,
	PRODUCT.NUM AS SKU,
	COALESCE(SALES_PERIOD.QTY, 0) AS QTY_PERIOD,
	COALESCE(ROUND(SALES_6MONTHS.QTY / 6, 2), 0) AS AVG_6MONTHS,
	COALESCE(ROUND(SALES_12MONTHS.QTY / 12, 2), 0) AS AVG_12MONTHS,
	$P{dateRange1} AS STARTDATE,
	$P{dateRange2} AS ENDDATE
FROM product
	LEFT JOIN producttotree ON product.id = producttotree.productid
	LEFT JOIN producttree ON producttotree.producttreeid = producttree.id
	LEFT JOIN (
		SELECT soitem.productnum, SUM(soitem.qtyToFulfill) AS QTY
		FROM soitem
		INNER JOIN so ON soitem.soid = so.id
		WHERE so.statusid >= 60
			AND so.dateCompleted BETWEEN $P{dateRange1} AND $P{dateRange2}
		GROUP BY soitem.productnum
	) SALES_PERIOD ON SALES_PERIOD.productnum = product.num
	LEFT JOIN (
		SELECT soitem.productnum, SUM(soitem.qtyToFulfill) AS QTY
		FROM soitem
		INNER JOIN so ON soitem.soid = so.id
		WHERE so.statusid >= 60
			AND so.dateCompleted >= DATE_SUB(LAST_DAY(DATE_SUB(CURDATE(), INTERVAL 1 MONTH)), INTERVAL 5 MONTH)
			AND so.dateCompleted <= LAST_DAY(DATE_SUB(CURDATE(), INTERVAL 1 MONTH))
		GROUP BY soitem.productnum
	) SALES_6MONTHS ON SALES_6MONTHS.productnum = product.num
	LEFT JOIN (
		SELECT soitem.productnum, SUM(soitem.qtyToFulfill) AS QTY
		FROM soitem
		INNER JOIN so ON soitem.soid = so.id
		WHERE so.statusid >= 60
			AND so.dateCompleted >= DATE_SUB(LAST_DAY(DATE_SUB(CURDATE(), INTERVAL 1 MONTH)), INTERVAL 11 MONTH)
			AND so.dateCompleted <= LAST_DAY(DATE_SUB(CURDATE(), INTERVAL 1 MONTH))
		GROUP BY soitem.productnum
	) SALES_12MONTHS ON SALES_12MONTHS.productnum = product.num
WHERE product.id > 0
	AND product.activeflag = 1
	AND COALESCE(producttotree.producttreeid, 0) LIKE $P{productTreeID}
	AND (SALES_PERIOD.QTY > 0 OR SALES_6MONTHS.QTY > 0 OR SALES_12MONTHS.QTY > 0)
ORDER BY producttree.name, product.description]]>
	</queryString>
	<field name="COMPANY" class="java.lang.String"/>
	<field name="CATEGORY" class="java.lang.String"/>
	<field name="PRODUCTNAME" class="java.lang.String"/>
	<field name="SKU" class="java.lang.String"/>
	<field name="QTY_PERIOD" class="java.math.BigDecimal"/>
	<field name="AVG_6MONTHS" class="java.math.BigDecimal"/>
	<field name="AVG_12MONTHS" class="java.math.BigDecimal"/>
	<field name="STARTDATE" class="java.util.Date"/>
	<field name="ENDDATE" class="java.util.Date"/>
