	<parameter name="CombineLikeItems" class="java.lang.Boolean">
		<property name="Tooltip" value="Choose to combine similar line items and show the total qty if the Part#, Location, Tag, and Destination all match "/>
		<parameterDescription><![CDATA[]]></parameterDescription>
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="cbShowAvailableQuantities" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[Before Pick,Before Pick, After Pick, After Pick]]></parameterDescription>
		<defaultValueExpression><![CDATA["Line Item"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT PICK.ID AS PICKID,
    substring(PICK.NUM,'2 to 100') AS PICKNUMBER,
    PICKTYPE.NAME AS PICKTYPE,
    PICKSTATUS.NAME AS PICKSTATUS,
    PRIORITY.NAME AS PICKPRIORITY,
    PICKLG.NAME AS PICKLOCATIONGROUP,
    PICKLG.ID AS PICKLOCATIONGROUPID,
    PICK.DATECREATED AS PICKDATECREATED,
    PICK.DATESCHEDULED AS PICKDATESCHEDULED,
    PICK.DATEFINISHED AS PICKDATEFINISHED,
    PICK.DATELASTMODIFIED AS PICKDATELASTMODIFIED,
    PICK.DATESTARTED AS PICKDATESTARTED,
    PICKITEMSTATUS.NAME AS PICKITEMSTATUS,
    PICKITEMSTATUS.ID AS PICKITEMSTATUSID,
    PART.NUM AS PICKITEMPARTNUM,
    PART.DESCRIPTION AS PICKITEMPARTDESC,

    -- Ensure PICKITEMID exists even when items are grouped
    IF($P!{CombineLikeItems} = true, MIN(PICKITEM.ID), PICKITEM.ID) AS PICKITEMID,

    -- Ensure PICKITEMQTY is properly aggregated
    IF($P!{CombineLikeItems} = true, SUM(PICKITEM.QTY), PICKITEM.QTY) AS PICKITEMQTY,

    UOM.CODE AS PICKITEMUOM,
    COALESCE(MAINLOCATION.NAME, '') AS PICKITEMLOCNAME,
    COALESCE(MAINLG.NAME, '') AS PICKITEMLOCGRPNAME,
    MAINTAG.NUM AS PICKITEMTAGNUM,
    COALESCE(DESTLOCATION.NAME, '') AS PICKITEMDESTLOCNAME,
    COALESCE(DESTLG.NAME, '') AS PICKITEMDESTLOCGRPNAME,
    PICKITEM.SLOTNUM AS PICKITEMSLOTNUM,
    COMPANY.NAME AS COMPANY,

    (CASE
        WHEN PICKITEM.ORDERTYPEID = 10 THEN POITEM.NOTE
        WHEN PICKITEM.ORDERTYPEID = 20 THEN SOITEM.NOTE
        WHEN PICKITEM.ORDERTYPEID = 40 THEN XOITEM.NOTE
    END) AS PICKITEMNOTE,

    COALESCE(SOITEM.DESCRIPTION, PART.DESCRIPTION) AS SOITEMDESCRIPTION,
    CARRIER.NAME AS CARRIER,
    kitHeader.productNum AS kitHeaderName,
    kitHeader.description AS kitHeaderDescription,
    kitHeader.id AS kitFlag,
    PART.ID AS PARTID,

    /* SHIP TO */
    SO.SHIPTONAME, SO.SHIPTOADDRESS, SO.SHIPTOCITY, SO.SHIPTOZIP,
    SHIPSTATE.CODE AS SHIPTOSTATE, SHIPCOUNTRY.NAME AS SHIPTOCOUNTRY,

    /* BILL TO */
    SO.BILLTONAME AS BILLTONAME, SO.BILLTOADDRESS, SO.BILLTOCITY, SO.BILLTOZIP,
    BILLSTATE.CODE AS BILLTOSTATE, BILLCOUNTRY.NAME AS BILLTOCOUNTRY,

    /* Fix: Ensure Qoh is properly handled */
    IF($P!{CombineLikeItems} = true,
        SUM((SELECT COALESCE(SUM(QtyInventoryTotals.QtyOnHand),0)
            FROM QtyInventoryTotals
            WHERE QtyInventoryTotals.PartId = PART.ID
            AND QtyInventoryTotals.LocationGroupID = PickLG.Id)),
        (SELECT COALESCE(SUM(QtyInventoryTotals.QtyOnHand),0)
            FROM QtyInventoryTotals
            WHERE QtyInventoryTotals.PartId = PART.ID
            AND QtyInventoryTotals.LocationGroupID = PickLG.Id)) AS Qoh,

    /* Additional Inventory Metrics */
    IF($P!{CombineLikeItems} = true,
        SUM((SELECT COALESCE(SUM(QtyInventoryTotals.QtyNotAvailableToPick),0)
            FROM QtyInventoryTotals
            WHERE QtyInventoryTotals.PartId = PART.ID
            AND QtyInventoryTotals.LocationGroupID = PickLG.Id)),
        (SELECT COALESCE(SUM(QtyInventoryTotals.QtyNotAvailableToPick),0)
            FROM QtyInventoryTotals
            WHERE QtyInventoryTotals.PartId = PART.ID
            AND QtyInventoryTotals.LocationGroupID = PickLG.Id)) AS NotPickable,

    IF($P!{CombineLikeItems} = true,
        SUM((SELECT COALESCE(SUM(QtyCommitted.Qty),0)
            FROM QtyCommitted
            WHERE QtyCommitted.PartId = PART.ID
            AND QtyCommitted.LocationGroupID = PickLG.Id)),
        (SELECT COALESCE(SUM(QtyCommitted.Qty),0)
            FROM QtyCommitted
            WHERE QtyCommitted.PartId = PART.ID
            AND QtyCommitted.LocationGroupID = PickLG.Id)) AS QtyCommitted,

    Customer.Name AS CustomerName,
    PaymentTerms.Name AS PaymentTerms,

    COALESCE((SELECT SUM(PosTransaction.Amount)
        FROM PosTransaction
        WHERE PosTransaction.SoId = SO.Id), 0) AS PaidAmt,

    SO.TotalPrice AS TotalPrice,

    (SELECT SUM(SoItem.QtyToFulFill * SoItem.UnitPrice)
        FROM SoItem
        WHERE SoItem.TypeId = 60 AND SoItem.SoId = SO.Id) AS ShippingAmt

FROM pick
    INNER JOIN picktype ON pick.typeid = picktype.id
    INNER JOIN pickstatus ON pick.statusid = pickstatus.id
    INNER JOIN priority ON pick.priority = priority.id
    INNER JOIN locationgroup picklg ON pick.locationgroupid = picklg.id
    LEFT OUTER JOIN pickitem ON pick.id = pickitem.pickid
    LEFT OUTER JOIN tag maintag ON COALESCE(pickitem.srctagid, pickitem.tagid) = maintag.id
    LEFT OUTER JOIN location mainlocation ON pickitem.srclocationid = mainlocation.id
    LEFT OUTER JOIN locationgroup mainlg ON mainlocation.locationgroupid = mainlg.id
    LEFT OUTER JOIN pickitemstatus ON pickitem.statusid = pickitemstatus.id
    LEFT OUTER JOIN part ON pickitem.partid = part.id
    LEFT OUTER JOIN uom ON pickitem.uomid = uom.id
    LEFT OUTER JOIN tag desttag ON pickitem.desttagid = desttag.id
    LEFT OUTER JOIN location destlocation ON desttag.locationid = destlocation.id
    LEFT OUTER JOIN locationgroup destlg ON destlocation.locationgroupid = destlg.id
    LEFT OUTER JOIN poitem ON (pickitem.poitemid = poitem.id AND pickitem.ordertypeid = 10)
    LEFT OUTER JOIN soitem ON (pickitem.soitemid = soitem.id AND pickitem.ordertypeid = 20)
    LEFT OUTER JOIN woitem ON (pickitem.woitemid = woitem.id AND pickitem.ordertypeid = 30)
    LEFT OUTER JOIN xoitem ON (pickitem.xoitemid = xoitem.id AND pickitem.ordertypeid = 40)
    LEFT OUTER JOIN so ON soitem.soid = so.id
    LEFT JOIN PaymentTerms ON PaymentTerms.Id = SO.PaymentTermsId
    LEFT JOIN Customer ON Customer.Id = SO.CustomerId
    LEFT OUTER JOIN carrier ON SO.carrierid = carrier.id
    JOIN company ON company.id = 1
    LEFT OUTER JOIN objectToObject AS obo ON obo.recordid1 = soitem.id AND obo.typeid = 30
    LEFT OUTER JOIN soitem AS kitHeader ON kitHeader.id = obo.recordid2 AND kitheader.typeid = 80
    LEFT OUTER JOIN countryconst billcountry ON billcountry.id = SO.billtocountryid
    LEFT OUTER JOIN countryconst shipcountry ON shipcountry.id = SO.shiptocountryid
    LEFT OUTER JOIN stateconst shipState ON SO.shiptostateid = shipState.id
    LEFT OUTER JOIN stateconst billState ON SO.billtostateid = billState.id

WHERE (pick.num = $P{pickNum})

GROUP BY IF($P!{CombineLikeItems} = true, MAINLG.NAME, pickitem.id),
         IF($P!{CombineLikeItems} = true, MAINLOCATION.NAME, pickitem.id),
         IF($P!{CombineLikeItems} = true, DESTLG.NAME, pickitem.id),
         IF($P!{CombineLikeItems} = true, DESTLOCATION.NAME, pickitem.id),
         IF($P!{CombineLikeItems} = true, MAINTAG.NUM, pickitem.id),
         IF($P!{CombineLikeItems} = true, PART.NUM, pickitem.id)

ORDER BY COALESCE($P!{cbPrimarySortBy}, 'ZZ'), COALESCE($P!{cbSecondarySortBy}, 'ZZ')]]>
	</queryString>
