<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ShippingLabel_CP" pageWidth="283" pageHeight="425" columnWidth="267" leftMargin="8" rightMargin="8" topMargin="8" bottomMargin="8" uuid="6ca7c556-1915-4ad3-8830-4d53c7260788">
	<property name="ireport.zoom" value="1.3310000000000004"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="shipID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="module" class="java.lang.Object" isForPrompting="false">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
        company.EANUCCPrefix AS EANUCCPrefix,
        so.num          AS orderNum,
        so.customerPo      AS altOrderNum,
        soitem.productNum,
        soitem.description,
        ship.shiptoname,
        ship.shiptoaddress,
        ship.shiptocity,
        sc.name                                   AS shiptostate,
        ship.shiptozip,
        ship.dateshipped,
        shipcarton.sscc                           AS SSCC,
        RIGHT(
              10 - RIGHT(
                     (SUBSTRING(shipcarton.sscc,11,1)*3 +
                      SUBSTRING(shipcarton.sscc,12,1)   +
                      SUBSTRING(shipcarton.sscc,13,1)*3 +
                      SUBSTRING(shipcarton.sscc,14,1)   +
                      SUBSTRING(shipcarton.sscc,15,1)*3 +
                      SUBSTRING(shipcarton.sscc,16,1)   +
                      SUBSTRING(shipcarton.sscc,17,1)*3) + 85
                   ,1)
             ,1)                                  AS CheckBit,
        product.UPC                               AS PartUPC,
        SUM(shipitem.qtyshipped)                  AS PALLETQTY,
        DATE_FORMAT(trackinginfo.infodate,'%y%m%d') AS ExpGtin,
        trackinginfo.infodate,
        GROUP_CONCAT(DISTINCT tbatch.info ORDER BY tbatch.info SEPARATOR ', ')
                                                  AS BOXSERIAL,
        CASE
    WHEN LENGTH(product.UPC) = 12 THEN
        CONCAT(
            '0',
            product.UPC,
            MOD(
                10 - MOD(
                    SUBSTRING(product.UPC,1,1)*3 +
                    SUBSTRING(product.UPC,2,1)*1 +
                    SUBSTRING(product.UPC,3,1)*3 +
                    SUBSTRING(product.UPC,4,1)*1 +
                    SUBSTRING(product.UPC,5,1)*3 +
                    SUBSTRING(product.UPC,6,1)*1 +
                    SUBSTRING(product.UPC,7,1)*3 +
                    SUBSTRING(product.UPC,8,1)*1 +
                    SUBSTRING(product.UPC,9,1)*3 +
                    SUBSTRING(product.UPC,10,1)*1 +
                    SUBSTRING(product.UPC,11,1)*3 +
                    SUBSTRING(product.UPC,12,1)*1,
                10),
            10)
        )
    WHEN LENGTH(company.EANUCCPrefix) BETWEEN 6 AND 10 THEN
        CONCAT(
            '0',
            company.EANUCCPrefix,
            LPAD('00000', 12 - LENGTH(company.EANUCCPrefix), '0'),
            MOD(
                10 - MOD(
                    SUBSTRING(CONCAT(company.EANUCCPrefix, LPAD('00000', 12 - LENGTH(company.EANUCCPrefix), '0')),1,1)*3 +
                    SUBSTRING(CONCAT(company.EANUCCPrefix, LPAD('00000', 12 - LENGTH(company.EANUCCPrefix), '0')),2,1)*1 +
                    SUBSTRING(CONCAT(company.EANUCCPrefix, LPAD('00000', 12 - LENGTH(company.EANUCCPrefix), '0')),3,1)*3 +
                    SUBSTRING(CONCAT(company.EANUCCPrefix, LPAD('00000', 12 - LENGTH(company.EANUCCPrefix), '0')),4,1)*1 +
                    SUBSTRING(CONCAT(company.EANUCCPrefix, LPAD('00000', 12 - LENGTH(company.EANUCCPrefix), '0')),5,1)*3 +
                    SUBSTRING(CONCAT(company.EANUCCPrefix, LPAD('00000', 12 - LENGTH(company.EANUCCPrefix), '0')),6,1)*1 +
                    SUBSTRING(CONCAT(company.EANUCCPrefix, LPAD('00000', 12 - LENGTH(company.EANUCCPrefix), '0')),7,1)*3 +
                    SUBSTRING(CONCAT(company.EANUCCPrefix, LPAD('00000', 12 - LENGTH(company.EANUCCPrefix), '0')),8,1)*1 +
                    SUBSTRING(CONCAT(company.EANUCCPrefix, LPAD('00000', 12 - LENGTH(company.EANUCCPrefix), '0')),9,1)*3 +
                    SUBSTRING(CONCAT(company.EANUCCPrefix, LPAD('00000', 12 - LENGTH(company.EANUCCPrefix), '0')),10,1)*1 +
                    SUBSTRING(CONCAT(company.EANUCCPrefix, LPAD('00000', 12 - LENGTH(company.EANUCCPrefix), '0')),11,1)*3 +
                    SUBSTRING(CONCAT(company.EANUCCPrefix, LPAD('00000', 12 - LENGTH(company.EANUCCPrefix), '0')),12,1)*1,
                10),
            10)
        )
    ELSE '00012345678905'
END AS GTIN14,4

FROM        shipitem
JOIN        ship                ON ship.id         = shipitem.shipId
LEFT JOIN   soitem              ON soitem.id       = shipitem.soitemId
LEFT JOIN   so                  ON so.id           = soitem.soId
LEFT JOIN   product             ON product.id      = shipitem.itemid
LEFT JOIN   shipcarton          ON shipcarton.id   = shipitem.shipCartonId
LEFT JOIN   trackinginfo        ON trackinginfo.recordid   = shipitem.id
                               AND trackinginfo.parttrackingid = 3
                               AND trackinginfo.tableid        = 1555030112
LEFT JOIN   trackinginfo AS tbatch
                               ON tbatch.recordid = shipitem.id
                               AND tbatch.parttrackingid = 1
                               AND tbatch.tableid        = 1555030112
LEFT JOIN   stateconst sc       ON sc.id           = ship.shiptostateid
LEFT JOIN company ON company.id = 1

WHERE       ship.id = $P{shipID}
GROUP BY    shipitem.shipcartonid;   -- one row/label per ship carton, eg: pallet]]>
	</queryString>
