					<box rightPadding="2">
						<pen lineWidth="0.25"/>
					</box>
					<textElement textAlignment="Right" verticalAlignment="Middle"/>
					<textFieldExpression><![CDATA[$V{PREVIOUS_MONTH_RUNNING}]]></textFieldExpression>
				</textField>
			</band>
		</groupFooter>
	</group>
