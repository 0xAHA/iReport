<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="WeeklySales" pageWidth="792" pageHeight="612" orientation="Landscape" whenNoDataType="AllSectionsNoDetail" columnWidth="732" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="a1b2c3d4-e5f6-7890-a1b2-c3d4e5f67890">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<queryString>
		<![CDATA[SELECT
    YEAR(postso.postdate) AS SALESYEAR,
    MONTH(postso.postdate) AS SALESMONTH,
    DATE_FORMAT(postso.postdate, '%b %Y') AS MONTHYEAR,
    CASE
        WHEN DAY(postso.postdate) BETWEEN 1 AND 7 THEN '1-7'
        WHEN DAY(postso.postdate) BETWEEN 8 AND 14 THEN '8-14'
        WHEN DAY(postso.postdate) BETWEEN 15 AND 21 THEN '15-21'
        WHEN DAY(postso.postdate) BETWEEN 22 AND 28 THEN '22-28'
        ELSE '29-31'
    END AS PERIOD,
    CASE
        WHEN DAY(postso.postdate) BETWEEN 1 AND 7 THEN 1
        WHEN DAY(postso.postdate) BETWEEN 8 AND 14 THEN 2
        WHEN DAY(postso.postdate) BETWEEN 15 AND 21 THEN 3
        WHEN DAY(postso.postdate) BETWEEN 22 AND 28 THEN 4
        ELSE 5
    END AS PERIODORDER,
    SUM(((SOITEM.UNITPRICE + (SOITEM.ADJUSTAMOUNT / (CASE WHEN SOITEM.QTYTOFULFILL = 0 THEN 1 ELSE SOITEM.QTYTOFULFILL END))) * POSTSOITEM.QTY)) AS WEEKLYSALES,
    1 AS PERIODTYPE,
    DATE_FORMAT(postso.postdate, '%b-%y') AS CURRENTMONTH,
    DATE_FORMAT(DATE_SUB(postso.postdate, INTERVAL 1 YEAR), '%b-%y') AS PREVIOUSMONTH,
    Company.Name as COMPANY
FROM postsoitem
    JOIN soitem ON postsoitem.soitemid = soitem.id
    LEFT JOIN postso ON postso.id = postsoitem.postsoid
    JOIN Company on Company.Id = 1
WHERE postso.postdate BETWEEN
    CASE WHEN MONTH(CURDATE()) >= 7
        THEN CONCAT(YEAR(CURDATE()), '-07-01')
        ELSE CONCAT(YEAR(CURDATE())-1, '-07-01')
    END
    AND CURDATE()
  AND (soitem.typeid = 10 OR soitem.typeid = 12 OR soitem.typeid = 80)
GROUP BY SALESYEAR, SALESMONTH, MONTHYEAR, PERIOD, PERIODORDER, CURRENTMONTH, PREVIOUSMONTH

UNION ALL

SELECT
    YEAR(DATE_ADD(postso.postdate, INTERVAL 1 YEAR)) AS SALESYEAR,
    MONTH(DATE_ADD(postso.postdate, INTERVAL 1 YEAR)) AS SALESMONTH,
    DATE_FORMAT(DATE_ADD(postso.postdate, INTERVAL 1 YEAR), '%b %Y') AS MONTHYEAR,
    CASE
        WHEN DAY(postso.postdate) BETWEEN 1 AND 7 THEN '1-7'
        WHEN DAY(postso.postdate) BETWEEN 8 AND 14 THEN '8-14'
        WHEN DAY(postso.postdate) BETWEEN 15 AND 21 THEN '15-21'
        WHEN DAY(postso.postdate) BETWEEN 22 AND 28 THEN '22-28'
        ELSE '29-31'
    END AS PERIOD,
    CASE
        WHEN DAY(postso.postdate) BETWEEN 1 AND 7 THEN 1
        WHEN DAY(postso.postdate) BETWEEN 8 AND 14 THEN 2
        WHEN DAY(postso.postdate) BETWEEN 15 AND 21 THEN 3
        WHEN DAY(postso.postdate) BETWEEN 22 AND 28 THEN 4
        ELSE 5
    END AS PERIODORDER,
    SUM(((SOITEM.UNITPRICE + (SOITEM.ADJUSTAMOUNT / (CASE WHEN SOITEM.QTYTOFULFILL = 0 THEN 1 ELSE SOITEM.QTYTOFULFILL END))) * POSTSOITEM.QTY)) AS WEEKLYSALES,
    2 AS PERIODTYPE,
    DATE_FORMAT(DATE_ADD(postso.postdate, INTERVAL 1 YEAR), '%b-%y') AS CURRENTMONTH,
    DATE_FORMAT(postso.postdate, '%b-%y') AS PREVIOUSMONTH,
    Company.Name as COMPANY
FROM postsoitem
    JOIN soitem ON postsoitem.soitemid = soitem.id
    LEFT JOIN postso ON postso.id = postsoitem.postsoid
    JOIN Company on Company.Id = 1
WHERE postso.postdate BETWEEN
    DATE_SUB(
        CASE WHEN MONTH(CURDATE()) >= 7
            THEN CONCAT(YEAR(CURDATE()), '-07-01')
            ELSE CONCAT(YEAR(CURDATE())-1, '-07-01')
        END,
        INTERVAL 1 YEAR
    )
    AND DATE_SUB(CURDATE(), INTERVAL 1 YEAR)
  AND (soitem.typeid = 10 OR soitem.typeid = 12 OR soitem.typeid = 80)
GROUP BY SALESYEAR, SALESMONTH, MONTHYEAR, PERIOD, PERIODORDER, CURRENTMONTH, PREVIOUSMONTH
ORDER BY SALESYEAR, SALESMONTH, PERIODORDER, PERIODTYPE]]>
	</queryString>
	<field name="SALESYEAR" class="java.lang.Integer"/>
	<field name="SALESMONTH" class="java.lang.Integer"/>
	<field name="MONTHYEAR" class="java.lang.String"/>
	<field name="PERIOD" class="java.lang.String"/>
	<field name="WEEKLYSALES" class="java.math.BigDecimal"/>
	<field name="PERIODTYPE" class="java.lang.Integer"/>
	<field name="CURRENTMONTH" class="java.lang.String"/>
	<field name="PREVIOUSMONTH" class="java.lang.String"/>
	<field name="COMPANY" class="java.lang.String"/>
	<field name="PERIODORDER" class="java.lang.String"/>
	<variable name="CURRENT_WEEK" class="java.math.BigDecimal" resetType="Group" resetGroup="WeekGroup" calculation="Sum">
		<variableExpression><![CDATA[$F{PERIODTYPE} == 1 ? $F{WEEKLYSALES} : 0]]></variableExpression>
	</variable>
	<variable name="PREVIOUS_WEEK" class="java.math.BigDecimal" resetType="Group" resetGroup="WeekGroup" calculation="Sum">
		<variableExpression><![CDATA[$F{PERIODTYPE} == 2 ? $F{WEEKLYSALES} : 0]]></variableExpression>
	</variable>
	<variable name="CURRENT_MONTH_RUNNING" class="java.math.BigDecimal" resetType="Group" resetGroup="MonthGroup" calculation="Sum">
		<variableExpression><![CDATA[$F{PERIODTYPE} == 1 ? $F{WEEKLYSALES} : 0]]></variableExpression>
	</variable>
	<variable name="PREVIOUS_MONTH_RUNNING" class="java.math.BigDecimal" resetType="Group" resetGroup="MonthGroup" calculation="Sum">
		<variableExpression><![CDATA[$F{PERIODTYPE} == 2 ? $F{WEEKLYSALES} : 0]]></variableExpression>
	</variable>
	<group name="MonthGroup">
		<groupExpression><![CDATA[$F{MONTHYEAR}]]></groupExpression>
		<groupHeader>
			<band height="20">
				<textField>
					<reportElement x="0" y="0" width="100" height="20" uuid="a1a2a3a4-b5b6-c7c8-d9d0-e1e2e3e4e5e6"/>
					<box leftPadding="2">
						<bottomPen lineWidth="0.5" lineColor="#CCCCCC"/>
					</box>
					<textElement verticalAlignment="Middle">
						<font size="10" isBold="true"/>
