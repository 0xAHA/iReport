					<textFieldExpression><![CDATA[$F{MONTHYEAR}]]></textFieldExpression>
				</textField>
			</band>
		</groupHeader>
		<groupFooter>
			<band height="5"/>
		</groupFooter>
	</group>
	<group name="WeekGroup">
		<groupExpression><![CDATA[$F{MONTHYEAR} + $F{PERIOD}]]></groupExpression>
		<groupHeader>
			<band/>
		</groupHeader>
		<groupFooter>
			<band height="20">
				<textField>
					<reportElement x="0" y="0" width="100" height="20" uuid="b1b2b3b4-c5c6-d7d8-e9e0-f1f2f3f4f5f6"/>
					<box leftPadding="15">
						<pen lineWidth="0.25"/>
					</box>
					<textElement verticalAlignment="Middle"/>
					<textFieldExpression><![CDATA[$F{PERIOD}]]></textFieldExpression>
				</textField>
				<textField pattern="¤#,##0.00">
					<reportElement x="100" y="0" width="100" height="20" uuid="c1c2c3c4-d5d6-e7e8-f9f0-a1a2a3a4a5a6"/>
					<box rightPadding="2">
						<pen lineWidth="0.25"/>
					</box>
					<textElement textAlignment="Right" verticalAlignment="Middle"/>
					<textFieldExpression><![CDATA[$V{CURRENT_WEEK}]]></textFieldExpression>
				</textField>
				<textField pattern="¤#,##0.00">
					<reportElement x="200" y="0" width="100" height="20" uuid="d1d2d3d4-e5e6-f7f8-a9a0-b1b2b3b4b5b6"/>
					<box rightPadding="2">
						<pen lineWidth="0.25"/>
					</box>
					<textElement textAlignment="Right" verticalAlignment="Middle"/>
					<textFieldExpression><![CDATA[$V{CURRENT_MONTH_RUNNING}]]></textFieldExpression>
				</textField>
				<textField>
					<reportElement x="300" y="0" width="80" height="20" uuid="e1e2e3e4-f5f6-a7a8-b9b0-c1c2c3c4c5c6"/>
					<box leftPadding="2">
						<pen lineWidth="0.25"/>
					</box>
					<textElement textAlignment="Center" verticalAlignment="Middle"/>
