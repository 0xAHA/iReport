	<variable name="CustomerContact" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[$F{CUSTOMERCONTACT} != null && !$F{CUSTOMERCONTACT}.equals("") ?
    "Contact: " + $F{CUSTOMERCONTACT} :
    ""]]></variableExpression>
