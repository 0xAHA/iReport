				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font fontName="Open Sans" size="12" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$V{isAustralia}
 ? !$V{isMultiCurrency} ? (($V{subTotal} + $F{TOTALTAX}.doubleValue()) - $V{paymentTotal}) :
    $F{SYMBOL} == null
     ? com.fbi.sdk.constants.setup.CurrencySymbolConst.getFormattedCurrency($F{HOMECURRENCYSYMBOL}, (($V{subTotal} + $F{TOTALTAX}.doubleValue()) - $V{paymentTotal}), $V{TotalsDecimal})
     : $V{CanDisplaySymbol}
       ? com.fbi.sdk.constants.setup.CurrencySymbolConst.getFormattedCurrency($F{SYMBOL}, $V{currencySubtotal} + $F{CURRENCYTAXTOTAL}.doubleValue() - ($V{paymentTotal} / $F{CURRENCYRATE}), $V{TotalsDecimal})
       : new DecimalFormat($V{totalsDecimalNoSymbol}).format($V{currencySubtotal} + $F{CURRENCYTAXTOTAL}.doubleValue() - ($V{paymentTotal} / $F{CURRENCYRATE}))
 : !$V{isMultiCurrency}
    ? (($V{subTotal} + $F{TOTALTAX}.doubleValue()) - $V{paymentTotal})
    : $F{SYMBOL} == null
      ? com.fbi.sdk.constants.setup.CurrencySymbolConst.getFormattedCurrency($F{HOMECURRENCYSYMBOL}, (($V{subTotal} + $F{TOTALTAX}.doubleValue()) - $V{paymentTotal}), $V{TotalsDecimal})
      : $V{CanDisplaySymbol}
        ? com.fbi.sdk.constants.setup.CurrencySymbolConst.getFormattedCurrency($F{SYMBOL}, $V{currencySubtotal} + $F{CURRENCYTAXTOTAL}.doubleValue() - ($V{paymentTotal} / $F{CURRENCYRATE}), $V{TotalsDecimal})
        : new DecimalFormat($V{totalsDecimalNoSymbol}).format($V{currencySubtotal} + $F{CURRENCYTAXTOTAL}.doubleValue() - ($V{paymentTotal} / $F{CURRENCYRATE}))]]></textFieldExpression>
				<patternExpression><![CDATA[$V{PriceDecimal}]]></patternExpression>
