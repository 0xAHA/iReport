		<field name="DATELASTFULFILLMENT" class="java.sql.Timestamp"/>
		<field name="DATESCHEDULEDFULFILLMENT" class="java.sql.Timestamp"/>
		<field name="REVLEVEL" class="java.lang.String"/>
		<field name="ITEMSTATUS" class="java.lang.String"/>
		<field name="SHOWITEMFLAG" class="java.lang.Integer"/>
