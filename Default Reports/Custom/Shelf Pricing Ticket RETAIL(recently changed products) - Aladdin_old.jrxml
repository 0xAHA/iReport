<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Shelf Pricing Ticket RETAIL(recently changed products) - Aladdin" columnCount="2" pageWidth="595" pageHeight="842" whenNoDataType="AllSectionsNoDetail" columnWidth="283" leftMargin="14" rightMargin="14" topMargin="14" bottomMargin="14" uuid="31d9e752-0d4c-420e-b157-6e6598704174">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.9487171000000014"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<import value="java.util.*"/>
	<style name="default" isDefault="true" fontName="SansSerif" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false" pdfEncoding="Cp1252" isPdfEmbedded="false"/>
	<style name="18" fontName="SansSerif" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false" pdfEncoding="Cp1252" isPdfEmbedded="false"/>
	<style name="center" hAlign="Center" vAlign="Middle"/>
	<parameter name="REPORTDESCRIPTION" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["Product Barcodes for 2x4 Avery 8163 Labels"]]></defaultValueExpression>
	</parameter>
	<parameter name="ShowOtherProduct" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Boolean(false)]]></defaultValueExpression>
	</parameter>
	<parameter name="ChangedSince" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[WITH ranked AS (
  SELECT
      pa.id,
      pa.num,
      pa.description,
      pa.price,
      r.`timestamp`                                  AS ts,
      pa.rev,
      ROW_NUMBER() OVER (
        PARTITION BY pa.id
        ORDER BY r.`timestamp` DESC, pa.rev DESC
      )                                              AS rn
  FROM product_aud pa
  JOIN revinfo r ON r.id = pa.rev
),
products_to_show AS (
  SELECT r1.id
  FROM ranked r1
  JOIN ranked r2
    ON r2.id = r1.id
   AND r2.rn = 2                       -- second-most-recent
  WHERE r1.rn = 1                      -- most-recent
    AND r1.ts >= $P{ChangedSince}      -- pass as Timestamp/Long per your schema
    AND NOT (
          r1.num         <=> r2.num
      AND r1.description <=> r2.description
      AND r1.price       <=> r2.price
    )
)

SELECT
  product.num AS prodNum,
  part.num AS partNum,
  product.description AS DESCRIPTION,
  (CASE WHEN pr_bulk.id IS NOT NULL
        THEN product.price * (1 + pr_bulk.paPercent)
        ELSE product.price
   END) * (1 + IFNULL(taxrate.rate, 0))           AS priceIncGST,
  uom.name                                        AS UOM,
  other_product.price                             AS priceSingleIncGST,
  other_product.case_qty                          AS case_qty,
  other_product.prodNum                           AS other_prodNum,
  other_product.uom                               AS other_UOM

FROM product
JOIN products_to_show pts       ON pts.id = product.id
JOIN part                       ON part.defaultproductid = product.id
LEFT JOIN taxrate               ON product.taxId = taxrate.id
LEFT JOIN uom                   ON product.uomId = uom.id

/* bulk pricing context */
JOIN producttotree ptt          ON ptt.productid = product.id
JOIN producttree pt             ON pt.id = ptt.producttreeid
LEFT JOIN producttree pt1       ON pt1.id = pt.parentid AND pt1.id != 1
LEFT JOIN producttree pt2       ON pt2.id = pt1.parentid AND pt2.id != 1
LEFT JOIN producttree pt3       ON pt3.id = pt2.parentid AND pt3.id != 1
LEFT JOIN producttree pt4       ON pt4.id = pt3.parentid AND pt4.id != 1
LEFT JOIN producttree pt5       ON pt5.id = pt4.parentid AND pt5.id != 1
LEFT JOIN pricingrule pr_bulk   ON pr_bulk.id = 5
                                AND pr_bulk.productinclid = COALESCE(pt5.id,pt4.id,pt3.id,pt2.id,pt1.id,pt.id)

/* single-unit alt product/pricing */
LEFT JOIN (
    SELECT
      p2.partid,
      p2.num AS prodNum,
      (CASE WHEN pr_single.id IS NOT NULL
            THEN p2.price * (1 + pr_single.paPercent)
            ELSE p2.price
       END) * (1 + IFNULL(tr2.rate, 0))           AS price,
      uc.factor                                   AS case_qty,
      uom2.name                                   AS uom
    FROM product p2
    JOIN taxrate tr2           ON tr2.id = p2.taxid
    JOIN part part2            ON part2.id = p2.partid AND part2.defaultproductid <> p2.id
    LEFT JOIN uomconversion uc ON uc.touomid = part2.uomid AND uc.fromuomid = p2.uomid
    LEFT JOIN uom uom2         ON p2.uomid = uom2.id

    /* replicate pricing context for "single" */
    JOIN producttotree ptt2    ON ptt2.productid = p2.id
    JOIN producttree pt_s      ON pt_s.id = ptt2.producttreeid
    LEFT JOIN producttree pt1s ON pt1s.id = pt_s.parentid AND pt1s.id != 1
    LEFT JOIN producttree pt2s ON pt2s.id = pt1s.parentid AND pt2s.id != 1
    LEFT JOIN producttree pt3s ON pt3s.id = pt2s.parentid AND pt3s.id != 1
    LEFT JOIN producttree pt4s ON pt4s.id = pt3s.parentid AND pt4s.id != 1
    LEFT JOIN producttree pt5s ON pt5s.id = pt4s.parentid AND pt5s.id != 1
    LEFT JOIN pricingrule pr_single
                               ON pr_single.id = 4
                              AND pr_single.productinclid =
                                  COALESCE(pt5s.id,pt4s.id,pt3s.id,pt2s.id,pt1s.id,pt_s.id)
) AS other_product ON other_product.partid = part.id

ORDER BY prodNum]]>
	</queryString>
