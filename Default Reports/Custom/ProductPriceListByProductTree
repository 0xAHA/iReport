	<queryString>
		<![CDATA[SELECT
producttree.name AS PRODUCT_TREE_NAME,
product.num AS PRODUCT_CODE,
product.description AS PRODUCT_DESCRIPTION,
productUOM.code AS PACKAGING,
vendor.name AS VENDOR,
vendorparts.lastcost AS VENDOR_COST_EXC,
IF(partTaxRate.rate is null, vendorparts.lastcost, vendorparts.lastcost + (vendorparts.lastcost * partTaxRate.rate)) AS VENDOR_COST_INC,
partTaxRate.code AS PURCHASE_TAX_CODE,
part.stdcost AS WHOLESALE_PRICE_EXC,
part.stdcost + (part.stdcost * productTaxRate.rate) AS WHOLESALE_PRICE_INC,
product.price AS SELL_PRICE_EXC,
product.price + (product.price * productTaxRate.rate) AS SELL_PRICE_INC,
productTaxRate.code AS SELL_TAX_CODE,
packagingSize.info AS packagingSize

FROM product
Left Join ProductToTree On ProductToTree.ProductId = Product.Id
Left Join ProductTree on ProductTree.Id = ProductToTree.ProductTreeId
LEFT JOIN part ON part.id = product.partid
LEFT JOIN partcost ON partcost.partid = part.id
LEFT JOIN vendorparts ON vendorparts.partid = part.id
LEFT JOIN vendor ON vendor.id = vendorparts.vendorid
LEFT JOIN taxrate AS productTaxRate ON productTaxRate.id = product.taxid
LEFT JOIN taxrate AS partTaxRate ON partTaxRate.id = part.taxid
LEFT JOIN uom AS productUOM ON productUOM.id = product.uomid
LEFT JOIN customvarcharlong AS packagingSize ON packagingSize.recordid = product.id AND packagingSize.customfieldid = 13


WHERE part.id > 0
AND part.activeflag = 1
AND product.activeflag = 1
AND part.typeid = 10
AND ((COALESCE(producttree.id,0) IN ($P!{productTree1})) OR ((COALESCE(producttree.id,0) LIKE $P{productTree2})))

ORDER BY producttree.name, product.num]]>
	</queryString>
