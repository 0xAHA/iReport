<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ShippingSummary" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="aebdede0-b54e-497f-9253-5a52bcd037ed">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="carrier" class="java.lang.String">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT Distinct
Carrier.Name as Carrier,
CarrierService.Name as CarrierService,
PaymentTerms.Name as PaymentTerms,
Ship.Num as InvoiceNum,
Customer.Name as Customer,
So.Phone as Phone,
Sum(SoItem.UnitPrice*ShipItem.QtyShipped) as SubTotal,
Sum(SoItem.UnitPrice*SoItem.TaxRate*ShipItem.QtyShipped) as TaxAmt


FROM Ship
Join Carrier on Carrier.Id = Ship.CarrierId
Left Join CarrierService on CarrierService.Id = Ship.CarrierServiceId
INNER JOIN ShipItem ON Ship.id = ShipItem.shipId
Join SoItem on SoItem.Id = ShipItem.SoItemId
Left Join So on So.Id = Ship.SoId
Join PaymentTerms on PaymentTerms.Id = So.PaymentTermsId
Left join Customer on Customer.Id = So.CustomerId

Where Ship.StatusId = 20
and Carrier.Name LIKE $P{carrier}

Group By Ship.Id
Order By Carrier.Id,PaymentTerms.Id,Customer.Id,Ship.Id]]>
	</queryString>
	<field name="Carrier" class="java.lang.String"/>
	<field name="CarrierService" class="java.lang.String"/>
	<field name="PaymentTerms" class="java.lang.String"/>
	<field name="InvoiceNum" class="java.lang.String"/>
	<field name="Customer" class="java.lang.String"/>
	<field name="Phone" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="SubTotal" class="java.math.BigDecimal">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="TaxAmt" class="java.lang.Double"/>
	<variable name="TermsTotal" class="java.lang.Double" resetType="Group" resetGroup="PaymentTerms" calculation="Sum">
		<variableExpression><![CDATA[$F{SubTotal}.doubleValue()+$F{TaxAmt}.doubleValue()]]></variableExpression>
	</variable>
	<variable name="Total" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{SubTotal}.doubleValue()+$F{TaxAmt}.doubleValue()]]></variableExpression>
	</variable>
	<variable name="PriceDecimal" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_PRICE")]]></variableExpression>
	</variable>
	<variable name="TotalsDecimal" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_TOTAL")]]></variableExpression>
	</variable>
