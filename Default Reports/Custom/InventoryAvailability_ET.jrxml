	<queryString>
		<![CDATA[SELECT
    PART.NUM AS PART,
    PRODUCT.NUM AS PRODUCT,
    PRODUCT.DESCRIPTION,
    locationgroup.name AS LOCATIONGROUP,
    produom.CODE AS UOMCODE,
    (SELECT NAME FROM COMPANY WHERE ID = 1) AS COMPANY,
    ROUND(COALESCE(INVENTORYTOTALS.TOTALONHAND,0), 4)*Coalesce(UC.Multiply,1) / Coalesce(UC.Factor,1) AS QTY,
    ROUND(COALESCE(INVENTORYTOTALS.TOTALNOTAVAILABLE,0), 4)*Coalesce(UC.Multiply,1) / Coalesce(UC.Factor,1) AS UNAVAILABLE,
    ROUND(COALESCE(INVENTORYTOTALS.TOTALDROPSHIP,0), 4)*Coalesce(UC.Multiply,1) / Coalesce(UC.Factor,1) AS DROPSHIP,
    ROUND(COALESCE(COMMITTED.TOTAL,0), 4)*Coalesce(UC.Multiply,1) / Coalesce(UC.Factor,1) AS QTYCOMMITTED,
    ROUND(COALESCE(INVENTORYTOTALS.TOTALALLOCATED,0), 4)*Coalesce(UC.Multiply,1) / Coalesce(UC.Factor,1) AS ALLOCATED,
    ROUND(COALESCE(INVENTORYTOTALS.TOTALONORDER,0), 4)*Coalesce(UC.Multiply,1) / Coalesce(UC.Factor,1) AS ONORDER,
    ROUND((COALESCE(INVENTORYTOTALS.TOTALONHAND,0) - COALESCE(INVENTORYTOTALS.TOTALALLOCATED,0) - COALESCE(INVENTORYTOTALS.TOTALNOTAVAILABLE,0) + COALESCE(INVENTORYTOTALS.TOTALDROPSHIP,0)), 4)*Coalesce(UC.Multiply,1) / Coalesce(UC.Factor,1) AS AVAILABLE,
    ROUND(COALESCE(INVENTORYTOTALS.totalNotAvailabletopick,0), 4)*Coalesce(UC.Multiply,1) / Coalesce(UC.Factor,1) AS totalNotAvailabletopick,
    $P!{CustomField:Part1} AS partcf1,
    $P!{CustomField:Part2} AS partcf2,
    $P!{CustomField:Part3} AS partcf3
FROM
    part
    LEFT JOIN product ON product.partid = part.id
    LEFT JOIN uom produom on produom.id = product.uomid
    LEFT JOIN uomconversion uc on uc.touomid = product.uomid and uc.fromuomid = part.uomid
    LEFT JOIN (
        SELECT
            partId,
            locationGroupId,
            SUM(qtyOnHand) AS totalOnHand,
            SUM(qtyNotAvailable) AS totalNotAvailable,
            SUM(qtyNotAvailabletopick) AS totalNotAvailabletopick,
            SUM(qtyDropship) AS totalDropship,
            SUM(qtyAllocated) AS totalAllocated,
            SUM(qtyOnOrder) AS totalOnOrder
        FROM
            qtyInventoryTotals
        WHERE locationGroupId IN ($P!{locationGroupID})
        GROUP BY partId, locationGroupId
    ) AS inventoryTotals ON inventoryTotals.partId = part.id
    LEFT JOIN locationgroup ON locationgroup.id = inventoryTotals.locationGroupId
    LEFT JOIN (
        SELECT
            partId,
            locationGroupId,
            SUM(qty) AS total
        FROM
            qtyCommitted
        WHERE locationGroupId IN ($P!{locationGroupID})
        GROUP BY partId, locationGroupId
    ) AS committed ON committed.partId = part.id AND committed.locationGroupId = inventoryTotals.locationGroupId
WHERE
    part.num LIKE $P{partNum}
    AND part.id != 0
    AND part.typeid = 10
    AND part.activeflag = 1
    AND COALESCE(UPPER($P!{cfFilter}),'') LIKE UPPER($P{cfFilterData})
    AND (
        CASE
            WHEN $P{ShowPartsWithZeroQuantity} = 1 THEN 1
            ELSE CASE
                WHEN (COALESCE(INVENTORYTOTALS.TOTALONHAND,0) + COALESCE(INVENTORYTOTALS.TOTALNOTAVAILABLE,0) + COALESCE(INVENTORYTOTALS.TOTALDROPSHIP,0) + COALESCE(COMMITTED.TOTAL,0) + COALESCE(INVENTORYTOTALS.TOTALALLOCATED,0) + COALESCE(INVENTORYTOTALS.TOTALONORDER,0)) > 0 THEN 1
                ELSE 0
            END
        END = 1
    )
GROUP BY LOCATIONGROUP,Coalesce(PRODUCT,PART)
ORDER BY lOCATIONGROUP, PART, QTY]]>
	</queryString>
