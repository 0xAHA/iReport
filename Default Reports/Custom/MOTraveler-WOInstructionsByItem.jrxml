	</parameter>
	<queryString>
		<![CDATA[SELECT
    MO.ID AS MOID,
    MO.NUM AS MONUM,
    MOSTATUS.NAME AS MOSTATUS,
    MO.NOTE AS MONOTE,
    WO.NUM AS WONUM,
    WO.DATESTARTED AS WODATESTARTED,
    WO.DATEFINISHED AS WODATEFINISHED,
    WO.DATESCHEDULED WODATESCHEDULED,
    UOM.CODE AS UOMCODE,
    WOSTATUS.NAME AS WOSTATUS,
    BOM.NUM AS BOMNUM,
    WO.QTYORDERED,
    CONCAT(WOLG.NAME,' - ',WOLOC.NAME) AS WOLOCATION,
    TRACKINFO.TRACKVALUE,
    WOUSERS.USERS AS WOUSERS,
    PART.NUM AS WOITEMPART,
    PRIORITY.NAME AS PRIORITY,
    (WOITEM.QTYTARGET/WO.QTYTARGET) AS WOITEMQTY,
    WOITEM.QTYTARGET AS WOITEMTOTAL,
    PART.DESCRIPTION AS WOITEMDESCRIPTION,
    COMPANY.NAME AS COMPANY,
    (SELECT
        GROUP_CONCAT(WO.NUM SEPARATOR ',')
        FROM
            WO
            INNER JOIN MOITEM ON WO.MOITEMID = MOITEM.ID
        WHERE MOITEM.MOID = MO.ID
    ) AS WONUMS,
    (SELECT
        S1.SYSVALUE
        FROM
            SYSPROPERTIES S1
        WHERE S1.SYSKEY = 'Barcodes have DI'
    ) AS BARCODESHAVEDI,
    WO.ID AS WOID,
    COALESCE(LABOR.LABOR,0) AS LABOR,
    LABOR.UOM AS LABORUOM,
    SUBSTRING(wo.num,-3,3) STAGES

FROM mo
    INNER JOIN moitem ON mo.id = moitem.moid
    INNER JOIN mostatus ON mo.statusid = mostatus.id
    LEFT JOIN wo ON moitem.id = wo.moitemid
    LEFT JOIN priority ON wo.priorityid = priority.id
    LEFT JOIN wostatus ON wo.statusid = wostatus.id
    LEFT JOIN locationgroup AS wolg ON wo.locationgroupid = wolg.id
    LEFT JOIN location AS woloc ON wo.locationid = woloc.id
    LEFT JOIN woitem ON wo.id = woitem.woid AND woitem.typeid = 10
    LEFT JOIN (
        SELECT
            SUM(WOITEM.QTYTARGET) AS LABOR,
            WOITEM.WOID,
            UOM.CODE AS UOM
        FROM
            woitem
            JOIN part ON woitem.partid = part.id AND part.typeid = 21
            JOIN uom ON woitem.uomid = uom.id
        GROUP BY
            2, 3
        ) AS labor ON wo.id = labor.woid
    LEFT JOIN part ON woitem.partid = part.id
    LEFT JOIN uom ON woitem.uomid = uom.id
    LEFT JOIN bom ON moitem.bomid = bom.id
    LEFT JOIN parttotracking ON moitem.partid = parttotracking.partid
    LEFT OUTER JOIN (
        SELECT
            partrackinfo.partid,
            GROUP_CONCAT(partrackinfo.trackValue, '___' SEPARATOR '\n') AS trackValue
        FROM (
            SELECT
                parttotracking.partid,
                GROUP_CONCAT(parttracking.abbr SEPARATOR ', ') AS trackValue
            FROM
                parttotracking
                INNER JOIN parttracking ON parttotracking.parttrackingid = parttracking.id
            GROUP BY
                parttotracking.partid, parttracking.sortorder
            ORDER BY parttracking.sortorder
        ) AS partrackinfo
        GROUP BY partrackinfo.partid
    ) AS trackinfo ON woitem.partid = trackinfo.partid
    LEFT OUTER JOIN (
        SELECT
            woassignedusers.woid,
            GROUP_CONCAT(sysuser.username SEPARATOR ', ') AS users
        FROM
            woassignedusers
            INNER JOIN sysuser ON woassignedusers.userid = sysuser.id
        GROUP BY woassignedusers.woid
        ) AS wousers ON wousers.woid = wo.id
    INNER JOIN company ON company.id = 1

WHERE
    mo.num LIKE $P{moNum}
    AND (moitem.bomid IS NOT NULL
        OR moitem.partid IS NOT NULL
        OR moitem.onetimeitem = 0)
    AND (wo.qtyordered IS NOT NULL
        OR trackinfo.trackvalue IS NOT NULL)
    AND mo.statusid > 10

ORDER BY
    $P!{cbOrderBy}, stages DESC, wo.num DESC]]>
	</queryString>
