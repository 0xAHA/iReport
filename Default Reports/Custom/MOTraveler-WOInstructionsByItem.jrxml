		<queryString>
			<![CDATA[SELECT
    MO.DATESCHEDULED AS MODATESCHEDULED,
    LOCATIONGROUP.NAME AS MOLG,
    MO.DATEISSUED AS DATEISSUED,
    MO.DATECOMPLETED AS MODATECOMPLETED,
    SO.NUM AS SONUM,
    CUSTOMER.NAME AS CUSTOMERNAME,
    SO.CUSTOMERPO AS CUSTOMERPO

FROM
    mo
    INNER JOIN locationgroup ON mo.locationgroupid = locationgroup.id
    INNER JOIN moitem ON mo.id = moitem.moid
        AND moitem.typeid = 50
    LEFT JOIN soitem ON soitem.id = moitem.soitemid
    LEFT JOIN so ON soitem.soid = so.id
    LEFT JOIN customer ON so.customerid = customer.id

WHERE
    mo.num LIKE $P{moNum}
    AND mo.statusid > 10

LIMIT 1]]>
		</queryString>
