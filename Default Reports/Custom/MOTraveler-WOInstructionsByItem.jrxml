		<parameter name="module" class="java.lang.Object" isForPrompting="false">
			<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT
    PART.NUM,
    PART.DESCRIPTION,
    WOITEM.QTYTARGET,
    TRACKINFO.TRACKVALUE,
    UOM.CODE AS UOM,
    woitem.id AS woitemid,
    wo.statusid

FROM
    woitem
    JOIN wo ON woitem.woid = wo.id
    INNER JOIN Part ON woitem.partid = part.id
    INNER JOIN uom ON woitem.uomid = uom.id
    LEFT JOIN parttotracking ON woitem.partid = parttotracking.partid
    LEFT OUTER JOIN (
        SELECT
            partrackinfo.partid,
            GROUP_CONCAT(partrackinfo.trackValue, '___' SEPARATOR '\n') AS trackValue
        FROM (
            SELECT
                parttotracking.partid,
                GROUP_CONCAT(parttracking.abbr SEPARATOR ', ') AS trackValue
            FROM
                parttotracking
                INNER JOIN parttracking ON parttotracking.parttrackingid = parttracking.id
            GROUP BY parttotracking.partid, parttracking.sortorder
            ORDER BY parttracking.sortorder
        ) AS partrackinfo
    GROUP BY partrackinfo.partid
    ) trackinfo ON woitem.partid = trackinfo.partid

WHERE
    woitem.typeid = 10
    AND woitem.woid = $P{WoId}]]>
		</queryString>
