($F{FROMCITY} == null ? "" : $F{FROMCITY}) + ", " + ($F{FROMSTATE} == null ? "  " : $F{FROMSTATE}) + "  " + ($F{FROMZIP} == null ? "" : $F{FROMZIP}) +
