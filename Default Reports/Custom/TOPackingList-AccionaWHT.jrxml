						<printWhenExpression><![CDATA[new Boolean($F{SHIPTONAME} != null)]]></printWhenExpression>
					</reportElement>
					<box leftPadding="3" rightPadding="3"/>
					<textElement textAlignment="Left" verticalAlignment="Top" rotation="None">
