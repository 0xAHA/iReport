<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ProductionStagingDemandAllStages" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="de660097-54c0-4de6-89de-02fc2a478d5e">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="150"/>
	<property name="ireport.y" value="0"/>
	<parameter name="dateRange1" class="java.util.Date" isForPrompting="false">
		<parameterDescription><![CDATA[This Month]]></parameterDescription>
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRange2" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="locationID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRange2_dup" class="java.util.Date">
		<defaultValueExpression><![CDATA[$P{dateRange2}]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    part.num AS ITEMNUM,
    part.description AS Description,
    uom.code AS UoM,
    company.name AS COMPANY,
    ROUND(COALESCE(SUM(inv.totalOnHand), 0), 5) AS SoH,
    ROUND(COALESCE(SUM(inv.totalNotAvailable), 0), 5) AS QAHold,
    ROUND(COALESCE(SUM(alloc.allocatedQty), 0), 5) AS Allocated,
    ROUND(GREATEST(
        COALESCE(SUM(inv.totalOnHand), 0)
        - COALESCE(SUM(alloc.allocatedQty), 0)
        - COALESCE(SUM(inv.totalNotAvailable), 0),
        0
    ), 5) AS AvailableToPick,
    ROUND(COALESCE(SUM(woagg.ROUNDEDPARTQTYALLOCATED), 0), 5) AS WOQtyNeeded,
    ROUND((
        COALESCE(SUM(inv.totalOnHand), 0)
        - COALESCE(SUM(alloc.allocatedQty), 0)
        - COALESCE(SUM(inv.totalNotAvailable), 0)
        - COALESCE(SUM(woagg.ROUNDEDPARTQTYALLOCATED), 0)
    ), 5) AS Diff
FROM part
    LEFT JOIN uom ON part.uomid = uom.id
    LEFT JOIN company ON company.id = 1

    -- Inventory quantities
    LEFT JOIN (
        SELECT partId, SUM(qtyOnHand) AS totalOnHand, SUM(qtyNotAvailable) AS totalNotAvailable
        FROM qtyInventoryTotals
        GROUP BY partId
    ) AS inv ON inv.partId = part.id

    -- Allocated quantities (past-due WOs) with proper UOM conversion
    LEFT JOIN (
        SELECT
            woitem.partid,
            ROUND(SUM(woitem.qtytarget * coalesce(uomconversion.multiply,1) / coalesce(uomconversion.factor,1)), 5) AS allocatedQty
        FROM woitem
        JOIN wo ON wo.id = woitem.woid
        JOIN part ON part.id = woitem.partid
        LEFT JOIN uomconversion
            ON uomconversion.fromuomid = woitem.uomid
           AND uomconversion.touomid = part.uomid
        WHERE wo.statusid IN (10, 20, 30)
          AND DATE(wo.datescheduled) < DATE($P{dateRange2_dup})
        GROUP BY woitem.partid
    ) AS alloc ON alloc.partid = part.id

    -- Future WO quantities with UOM conversion
    LEFT JOIN (
        SELECT
            woitem.partid,
            ROUND(SUM(woitem.qtytarget * coalesce(uomconversion.multiply,1) / coalesce(uomconversion.factor,1)), 5) AS ROUNDEDPARTQTYALLOCATED
        FROM woitem
        JOIN wo ON wo.id = woitem.woid
        JOIN part ON part.id = woitem.partid
        LEFT JOIN uomconversion
            ON uomconversion.fromuomid = woitem.uomid
           AND uomconversion.touomid = part.uomid
        WHERE wo.statusid IN (10, 20, 30)
          AND DATE(wo.datescheduled) > DATE($P{dateRange2_dup}) - INTERVAL 1 DAY
        GROUP BY woitem.partid
    ) AS woagg ON woagg.partid = part.id

WHERE
    part.typeid = 10
    AND part.activeflag = 1
    AND (part.num LIKE 'food%' OR part.num LIKE 'pack%')
GROUP BY
    part.num, part.description, uom.code, company.name
ORDER BY
    part.num;
]]>
	</queryString>
