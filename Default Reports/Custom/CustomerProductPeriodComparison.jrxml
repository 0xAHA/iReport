	<parameter name="path" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:/Program Files/Fishbowl/Server/reports/WorkOrder/"]]></defaultValueExpression>
	</parameter>
	<parameter name="module" class="java.lang.Object" isForPrompting="false">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="REPORTDESCRIPTION" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["Prints the gross sales for the date range specified, ordered from greatest to least.  An empty date range will report on gross sales to date"]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRange1" class="java.util.Date" isForPrompting="false">
		<parameterDescription><![CDATA[This Month]]></parameterDescription>
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRange2" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="salesPerson" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[Select
ConCat(Product.Num, ' - ', Product.Description) as UserName
,ProductTree.Name as CustomerName
,customer.name as ProductNum
,SUM(PostSoItem.TotalPrice) as Price
,1 AS Period
,CONCAT(DATE_FORMAT($P{dateRange1},"%d/%m/%Y"), '\nto\n', DATE_FORMAT(SUBDATE($P{dateRange2},INTERVAL 1 Second),"%d/%m/%Y")) AS Dte1
,CONCAT(DATE_FORMAT(SUBDATE($P{dateRange1}, INTERVAL 1 YEAR),"%d/%m/%Y"), '\nto\n', DATE_FORMAT(SUBDATE(SUBDATE($P{dateRange2},INTERVAL 1 Second), INTERVAL 1 YEAR),"%d/%m/%Y")) AS Dte2
,Company.Name as COMPANY

From PostSo
Join PostSoItem on PostSoItem.PostSoId = PostSo.Id
Join SoItem on SoItem.Id = PostSoItem.SoItemId
Join Product on Product.Id = SoItem.ProductId
Join So on So.Id = SoItem.SoId
Join customer on customer.id = so.customerid
left join sysuser on sysuser.id = customer.defaultsalesmanid
Left Join ProductToTree on ProductToTree.ProductId = SoItem.ProductId
Left Join ProductTree on ProductTree.Id = ProductToTree.ProductTreeId
Left Join ProductTree PT1 on PT1.Id = ProductTree.ParentId and PT1.Id != 1
Left Join ProductTree PT2 on PT2.Id = PT1.ParentId and PT2.Id != 1
Left Join ProductTree PT3 on PT3.Id = PT2.ParentId and PT3.Id != 1
Left Join ProductTree PT4 on PT4.Id = PT3.ParentId and PT4.Id != 1
Left Join ProductTree PT5 on PT5.Id = PT4.ParentId and PT5.Id != 1
Left Join ProductTree PT6 on PT6.Id = PT5.ParentId and PT6.Id != 1
Left Join ProductTree PT7 on PT7.Id = PT6.ParentId and PT7.Id != 1
Left Join ProductTree PT8 on PT8.Id = PT7.ParentId and PT8.Id != 1
Left Join ProductTree PT9 on PT9.Id = PT8.ParentId and PT9.Id != 1
Left Join ProductTree PT10 on PT10.Id = PT9.ParentId and PT10.Id != 1
Left Join ProductTree PT11 on PT11.Id = PT10.ParentId and PT11.Id != 1
Join Company on Company.Id = 1

Where PostSo.PostDate between $P{dateRange1} and SUBDATE($P{dateRange2},INTERVAL 1 Second)
and coalesce(sysuser.username,'kyeski') LIKE $P{salesPerson}

Group By 1,3

UNION ALL

Select
ConCat(Product.Num, ' - ', Product.Description) as UserName
,ProductTree.Name as CustomerName
,customer.name as ProductNum
,SUM(PostSoItem.TotalPrice)
,2
,CONCAT(DATE_FORMAT($P{dateRange1},"%d/%m/%Y"), '\nto\n', DATE_FORMAT(SUBDATE($P{dateRange2},INTERVAL 1 Second),"%d/%m/%Y")) AS Dte1
,CONCAT(DATE_FORMAT(SUBDATE($P{dateRange1}, INTERVAL 1 YEAR),"%d/%m/%Y"), '\nto\n', DATE_FORMAT(SUBDATE(SUBDATE($P{dateRange2},INTERVAL 1 Second), INTERVAL 1 YEAR),"%d/%m/%Y")) AS Dte2
,Company.Name as COMPANY

From PostSo
Join PostSoItem on PostSoItem.PostSoId = PostSo.Id
Join SoItem on SoItem.Id = PostSoItem.SoItemId
Join Product on Product.Id = SoItem.ProductId
Join So on So.Id = SoItem.SoId
Join customer on customer.id = so.customerid
left join sysuser on sysuser.id = customer.defaultsalesmanid
Left Join ProductToTree on ProductToTree.ProductId = SoItem.ProductId
Left Join ProductTree on ProductTree.Id = ProductToTree.ProductTreeId
Left Join ProductTree PT1 on PT1.Id = ProductTree.ParentId and PT1.Id != 1
Left Join ProductTree PT2 on PT2.Id = PT1.ParentId and PT2.Id != 1
Left Join ProductTree PT3 on PT3.Id = PT2.ParentId and PT3.Id != 1
Left Join ProductTree PT4 on PT4.Id = PT3.ParentId and PT4.Id != 1
Left Join ProductTree PT5 on PT5.Id = PT4.ParentId and PT5.Id != 1
Left Join ProductTree PT6 on PT6.Id = PT5.ParentId and PT6.Id != 1
Left Join ProductTree PT7 on PT7.Id = PT6.ParentId and PT7.Id != 1
Left Join ProductTree PT8 on PT8.Id = PT7.ParentId and PT8.Id != 1
Left Join ProductTree PT9 on PT9.Id = PT8.ParentId and PT9.Id != 1
Left Join ProductTree PT10 on PT10.Id = PT9.ParentId and PT10.Id != 1
Left Join ProductTree PT11 on PT11.Id = PT10.ParentId and PT11.Id != 1
Join Company on Company.Id = 1

Where PostSo.PostDate between SUBDATE($P{dateRange1}, INTERVAL 1 YEAR) and SUBDATE(SUBDATE($P{dateRange2},INTERVAL 1 Second), INTERVAL 1 YEAR)
and coalesce(sysuser.username,'kyeski') LIKE $P{salesPerson}

Group By 1,3
ORDER BY 1,3]]>
	</queryString>
