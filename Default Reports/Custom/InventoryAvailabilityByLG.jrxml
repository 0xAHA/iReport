	<queryString>
		<![CDATA[SELECT
    PART.NUM AS PART,
    PART.DESCRIPTION,
    UOM.CODE AS UOMCODE,
    PART.ID AS PARTID,
    (SELECT NAME FROM COMPANY WHERE ID = 1) AS COMPANY,
    LOCATIONGROUP.NAME AS LG,
    LOCATIONGROUP.ID AS LOCATIONGROUPID,
    DEFAULTLOCATION.LOCATIONID,
    DEFLOC.NAME AS DEFAULTLOCATIONNAME,
    COALESCE(DEFQOH.QTY, 0) AS DEFAULTLOCQTY,
    COALESCE(
        (SELECT SUM(QOH.QTY)
         FROM QOHVIEW QOH
         JOIN LOCATION L ON QOH.LOCATIONID = L.ID
         WHERE QOH.PARTID = PART.ID
           AND L.LOCATIONGROUPID = LOCATIONGROUP.ID
           AND QOH.LOCATIONID != DEFAULTLOCATION.LOCATIONID
        ), 0
    ) AS OTHERLOCATIONQTY

FROM
    PART
    JOIN DEFAULTLOCATION ON DEFAULTLOCATION.PARTID = PART.ID
    JOIN LOCATION DEFLOC ON DEFLOC.ID = DEFAULTLOCATION.LOCATIONID
    JOIN LOCATIONGROUP ON LOCATIONGROUP.ID = DEFLOC.LOCATIONGROUPID
    LEFT JOIN UOM ON PART.UOMID = UOM.ID
    LEFT JOIN QOHVIEW DEFQOH ON DEFQOH.PARTID = PART.ID
        AND DEFQOH.LOCATIONID = DEFAULTLOCATION.LOCATIONID

WHERE
    PART.NUM LIKE $P{partNum}
    AND PART.ID != 0
    AND PART.TYPEID = 10
    AND PART.ACTIVEFLAG = 1
    AND LOCATIONGROUP.ID IN ($P!{locationGroupID})
    AND COALESCE(DEFQOH.QTY, 0) = 0

ORDER BY
    LOCATIONGROUP.ID, PART.NUM

LIMIT $P!{Count}
OFFSET $P!{Skip}]]>
	</queryString>
