					<font size="11" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[new java.text.SimpleDateFormat("dd/MM/yyyy").format($P{dateRange1}) + " - " +
new java.text.SimpleDateFormat("dd/MM/yyyy").format(new java.util.Date($P{dateRange2}.getTime() - 86400000))]]></textFieldExpression>
			</textField>
		</band>
	</title>
