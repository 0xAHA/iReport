	<style name="default" isDefault="true" fontName="SansSerif" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false" pdfEncoding="Cp1252" isPdfEmbedded="false"/>
	<parameter name="REPORTDESCRIPTION" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["SO Part Barcodes for Avery L7148 Labels (96x51mm)"]]></defaultValueExpression>
	</parameter>
	<parameter name="soNum" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT DISTINCT
    part.NUM,
    part.DESCRIPTION,
    vendorparts.vendorpartnumber AS Vendorpartnumber,
    vendor.name AS Vendor,
    uom.name AS UOM
FROM soItem
    INNER JOIN so ON so.id = soItem.soId
    INNER JOIN product ON product.id = soItem.productId
    INNER JOIN part ON part.id = product.partId
    LEFT JOIN vendorparts ON part.id = vendorparts.partId AND vendorparts.defaultflag = true
    LEFT JOIN uom ON vendorparts.uomId = uom.id
    LEFT JOIN vendor ON vendorparts.vendorId = vendor.id
WHERE so.num LIKE $P{soNum}
ORDER BY part.NUM]]>
	</queryString>
	<field name="NUM" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="DESCRIPTION" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="Vendorpartnumber" class="java.lang.String"/>
	<field name="Vendor" class="java.lang.String"/>
	<field name="UOM" class="java.lang.String"/>
