	<detail>
		<band height="21" splitType="Stretch">
			<textField>
				<reportElement x="0" y="0" width="173" height="20" uuid="e1eb007a-f263-4be8-a8c8-cb6822b8a6b8"/>
				<box>
					<bottomPen lineWidth="0.5"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Open Sans" size="11" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{part_num}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="173" y="0" width="284" height="20" uuid="8e9df982-b234-4a4e-9ea0-a3cb7a583701"/>
				<box>
					<bottomPen lineWidth="0.5"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Open Sans" size="11" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{part_description}.endsWith("Archive Box")
    ? $F{part_description}.substring(0, $F{part_description}.length() - "Archive Box".length()).trim()
    : $F{part_description}]]></textFieldExpression>
			</textField>
			<textField pattern="###0" isBlankWhenNull="true">
				<reportElement mode="Opaque" x="457" y="0" width="159" height="20" backcolor="#CCCCCC" uuid="840b75ba-4450-4147-bea7-3a4daa5447a8"/>
				<box>
					<bottomPen lineWidth="0.5"/>
				</box>
