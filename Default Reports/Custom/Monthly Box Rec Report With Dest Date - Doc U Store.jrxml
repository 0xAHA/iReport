<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Monthly Box Rec Report - Doc U Store" pageWidth="2475" pageHeight="842" columnWidth="2435" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="46d58ae2-4ce3-4c01-b5a5-8e4bd2147711">
	<property name="ireport.zoom" value="1.0000000000000024"/>
	<property name="ireport.x" value="1357"/>
	<property name="ireport.y" value="0"/>
	<parameter name="cbReportYear" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[1,Current Year,2024,2024,2025,2025,2026,2026,2027,2027,2028,2028,2029,2029,2030,2030,2031,2031,2032,2032,2033,2033,2034,2034,2035,2035,2036,2036,2037,2037,2038,2038,2039,2039,2040,2040,2041,2041,2042,2042,2043,2043,2044,2044,2045,2045,2046,2046,2047,2047,2048,2048,2049,2049,2050,2050]]></parameterDescription>
		<defaultValueExpression><![CDATA["CAST(YEAR(now()) AS CHAR)"]]></defaultValueExpression>
	</parameter>
	<parameter name="partNum" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[WITH
params AS (
  SELECT
    CASE WHEN $P{cbReportYear} = '1'
         THEN YEAR(CURDATE())
         ELSE CAST($P{cbReportYear} AS UNSIGNED)
    END AS yr,

    CAST(CONCAT(
      CASE WHEN $P{cbReportYear} = '1' THEN YEAR(CURDATE()) ELSE $P{cbReportYear} END,
      '-01-01'
    ) AS DATE) AS yr_start,

    CAST(CONCAT(
      CASE WHEN $P{cbReportYear} = '1' THEN YEAR(CURDATE()) + 1 ELSE CAST($P{cbReportYear} AS UNSIGNED) + 1 END,
      '-01-01'
    ) AS DATE) AS yr_end_excl,

    CAST(CONCAT(
      CASE WHEN $P{cbReportYear} = '1' THEN YEAR(CURDATE()) ELSE $P{cbReportYear} END,
      '-06-30'
    ) AS DATE) AS june_30_end,

    CAST(CONCAT(
      CASE WHEN $P{cbReportYear} = '1' THEN YEAR(CURDATE()) ELSE $P{cbReportYear} END,
      '-12-31'
    ) AS DATE) AS dec_31_end
),

-- Monthly cycle count movements for the year
il_year AS (
  SELECT
      il.partid,
      MONTH(il.datecreated) AS m,
      SUM(il.changeqty) AS change_qty
  FROM inventorylog il
  JOIN params p
    ON il.datecreated >= p.yr_start
   AND il.datecreated < p.yr_end_excl
  WHERE il.typeid = 64
  GROUP BY il.partid, MONTH(il.datecreated)
),

-- Opening balance (last inventory log entry before year start per location group, summed)
opening AS (
  SELECT
    il.partid,
    SUM(il.qtyonhand) AS start_qty
  FROM (
    SELECT
      il.partid,
      il.locationgroupid,
      il.qtyonhand,
      ROW_NUMBER() OVER (
        PARTITION BY il.partid, il.locationgroupid
        ORDER BY il.datecreated DESC, il.id DESC
      ) AS rn
    FROM inventorylog il
    JOIN params p ON il.datecreated < p.yr_start
  ) il
  WHERE il.rn = 1
  GROUP BY il.partid
),

-- June 30 balance (latest entry per location group up to June 30, excluding MISC and DESTROYED)
june_total AS (
  SELECT
    il.partid,
    SUM(il.qtyonhand) AS june_qty
  FROM (
    SELECT
      il.partid,
      il.locationgroupid,
      il.qtyonhand,
      ROW_NUMBER() OVER (
        PARTITION BY il.partid, il.locationgroupid
        ORDER BY il.datecreated DESC, il.id DESC
      ) AS rn
    FROM inventorylog il
    JOIN params p ON il.datecreated <= p.june_30_end
    JOIN locationgroup lg ON lg.id = il.locationgroupid
    WHERE lg.name <> 'DESTROYED'
      AND lg.name NOT LIKE 'Misc%'
  ) il
  WHERE il.rn = 1
  GROUP BY il.partid
),

-- December 31 balance (latest entry per location group up to Dec 31, excluding MISC and DESTROYED)
dec_total AS (
  SELECT
    il.partid,
    SUM(il.qtyonhand) AS dec_qty
  FROM (
    SELECT
      il.partid,
      il.locationgroupid,
      il.qtyonhand,
      ROW_NUMBER() OVER (
        PARTITION BY il.partid, il.locationgroupid
        ORDER BY il.datecreated DESC, il.id DESC
      ) AS rn
    FROM inventorylog il
    JOIN params p ON il.datecreated <= p.dec_31_end
    JOIN locationgroup lg ON lg.id = il.locationgroupid
    WHERE lg.name <> 'DESTROYED'
      AND lg.name NOT LIKE 'Misc%'
  ) il
  WHERE il.rn = 1
  GROUP BY il.partid
),

-- Current quantity in DESTROYED location group (latest entry per location group)
destroyed_current AS (
  SELECT
    il.partid,
    SUM(il.qtyonhand) AS destroyed_qty
  FROM (
    SELECT
      il.partid,
      il.locationgroupid,
      il.qtyonhand,
      ROW_NUMBER() OVER (
        PARTITION BY il.partid, il.locationgroupid
        ORDER BY il.datecreated DESC, il.id DESC
      ) AS rn
    FROM inventorylog il
    JOIN locationgroup lg ON lg.id = il.locationgroupid
    WHERE lg.name = 'DESTROYED'
  ) il
  WHERE il.rn = 1
  GROUP BY il.partid
),

-- Miscellaneous count at June 30 (latest entry per location group)
misc_june AS (
  SELECT
    il.partid,
    SUM(il.qtyonhand) AS misc_qty_june
  FROM (
    SELECT
      il.partid,
      il.locationgroupid,
      il.qtyonhand,
      ROW_NUMBER() OVER (
        PARTITION BY il.partid, il.locationgroupid
        ORDER BY il.datecreated DESC, il.id DESC
      ) AS rn
    FROM inventorylog il
    JOIN params p ON il.datecreated <= p.june_30_end
    JOIN locationgroup lg ON lg.id = il.locationgroupid
    WHERE lg.name LIKE 'Misc%'
  ) il
  WHERE il.rn = 1
  GROUP BY il.partid
),

-- Miscellaneous count at December 31 (latest entry per location group)
misc_dec AS (
  SELECT
    il.partid,
    SUM(il.qtyonhand) AS misc_qty_dec
  FROM (
    SELECT
      il.partid,
      il.locationgroupid,
      il.qtyonhand,
      ROW_NUMBER() OVER (
        PARTITION BY il.partid, il.locationgroupid
        ORDER BY il.datecreated DESC, il.id DESC
      ) AS rn
    FROM inventorylog il
    JOIN params p ON il.datecreated <= p.dec_31_end
    JOIN locationgroup lg ON lg.id = il.locationgroupid
    WHERE lg.name LIKE 'Misc%'
  ) il
  WHERE il.rn = 1
  GROUP BY il.partid
)

SELECT
    prt.num AS part_num,
    prt.description AS part_description,
    COALESCE(op.start_qty, 0) AS start_qty,

    COALESCE(SUM(CASE WHEN i.m = 1 THEN i.change_qty END), 0) AS JAN,
    COALESCE(SUM(CASE WHEN i.m = 2 THEN i.change_qty END), 0) AS FEB,
    COALESCE(SUM(CASE WHEN i.m = 3 THEN i.change_qty END), 0) AS MAR,
    COALESCE(SUM(CASE WHEN i.m = 4 THEN i.change_qty END), 0) AS APR,
    COALESCE(SUM(CASE WHEN i.m = 5 THEN i.change_qty END), 0) AS MAY,
    COALESCE(SUM(CASE WHEN i.m = 6 THEN i.change_qty END), 0) AS JUN,

    -- Miscellaneous count at June 30
    COALESCE(mj.misc_qty_june, 0) AS misc_june_30,

    -- Total Qty at June 30 (sum of latest qtyonhand per location group, excluding MISC and DESTROYED)
    COALESCE(jt.june_qty, 0) AS total_qty_june_30,

    COALESCE(SUM(CASE WHEN i.m = 7 THEN i.change_qty END), 0) AS JUL,
    COALESCE(SUM(CASE WHEN i.m = 8 THEN i.change_qty END), 0) AS AUG,
    COALESCE(SUM(CASE WHEN i.m = 9 THEN i.change_qty END), 0) AS SEP,
    COALESCE(SUM(CASE WHEN i.m = 10 THEN i.change_qty END), 0) AS OCT,
    COALESCE(SUM(CASE WHEN i.m = 11 THEN i.change_qty END), 0) AS NOV,
    COALESCE(SUM(CASE WHEN i.m = 12 THEN i.change_qty END), 0) AS `DEC`,

    -- Miscellaneous count at December 31
    COALESCE(md.misc_qty_dec, 0) AS misc_dec_31,

    -- Total Qty at December 31 (sum of latest qtyonhand per location group, excluding MISC and DESTROYED)
    COALESCE(dt.dec_qty, 0) AS total_qty_dec_31,

    -- Total destroyed (latest qtyonhand from DESTROYED location group)
    COALESCE(dc.destroyed_qty, 0) AS qty_for_destruc_dec_31

FROM part prt
LEFT JOIN il_year i ON i.partid = prt.id
LEFT JOIN opening op ON op.partid = prt.id
LEFT JOIN june_total jt ON jt.partid = prt.id
LEFT JOIN dec_total dt ON dt.partid = prt.id
LEFT JOIN destroyed_current dc ON dc.partid = prt.id
LEFT JOIN misc_june mj ON mj.partid = prt.id
LEFT JOIN misc_dec md ON md.partid = prt.id

WHERE prt.num LIKE $P{partNum}

GROUP BY
    prt.id, prt.num, prt.description,
    op.start_qty,
    jt.june_qty,
    dt.dec_qty,
    dc.destroyed_qty,
    mj.misc_qty_june, md.misc_qty_dec

HAVING
    -- Show rows where there's any activity or non-zero balance
    COALESCE(op.start_qty, 0)
    + COALESCE(SUM(i.change_qty), 0)
    <> 0
    OR COALESCE(dc.destroyed_qty, 0) <> 0
    OR COALESCE(dt.dec_qty, 0) <> 0

ORDER BY prt.num;]]>
	</queryString>
	<field name="part_num" class="java.lang.String"/>
	<field name="part_description" class="java.lang.String"/>
	<field name="start_qty" class="java.math.BigDecimal"/>
	<field name="JAN" class="java.math.BigDecimal"/>
	<field name="FEB" class="java.math.BigDecimal"/>
	<field name="MAR" class="java.math.BigDecimal"/>
	<field name="APR" class="java.math.BigDecimal"/>
	<field name="MAY" class="java.math.BigDecimal"/>
	<field name="JUN" class="java.math.BigDecimal"/>
	<field name="misc_june_30" class="java.math.BigDecimal"/>
	<field name="total_qty_june_30" class="java.math.BigDecimal"/>
	<field name="JUL" class="java.math.BigDecimal"/>
	<field name="AUG" class="java.math.BigDecimal"/>
	<field name="SEP" class="java.math.BigDecimal"/>
	<field name="OCT" class="java.math.BigDecimal"/>
	<field name="NOV" class="java.math.BigDecimal"/>
	<field name="DEC" class="java.math.BigDecimal"/>
	<field name="misc_dec_31" class="java.math.BigDecimal"/>
	<field name="total_qty_dec_31" class="java.math.BigDecimal"/>
	<field name="qty_for_destruc_dec_31" class="java.math.BigDecimal"/>
	<variable name="CurrentYear" class="java.lang.String">
		<variableExpression><![CDATA[new java.text.SimpleDateFormat("yyyy").format(new java.util.Date())]]></variableExpression>
		<initialValueExpression><![CDATA["" + (new java.util.Date().getYear() + 1900)]]></initialValueExpression>
	</variable>
