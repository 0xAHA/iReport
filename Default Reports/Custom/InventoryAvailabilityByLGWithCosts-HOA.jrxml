	<variable name="backordered" class="java.math.BigDecimal" resetType="None">
		<variableExpression><![CDATA[$F{ALLOCATED} - ($F{QTY} - $F{UNAVAILABLE}) >= 0
? $F{ALLOCATED} - ($F{QTY} - $F{UNAVAILABLE})
: 0]]></variableExpression>
	</variable>
	<variable name="Available" class="java.math.BigDecimal" resetType="None">
		<variableExpression><![CDATA[new BigDecimal($F{QTY}.doubleValue() - $F{ALLOCATED}.doubleValue() - $F{UNAVAILABLE}.doubleValue() + $F{DROPSHIP}.doubleValue())]]></variableExpression>
	</variable>
	<variable name="PriceDecimal" class="java.lang.String" resetType="None">
