	</parameter>
	<parameter name="vendorID" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[SELECT
    PART.NUM AS PART,
    PART.DESCRIPTION,
    UOM.CODE AS UOMCODE,
    PART.ID,
    (SELECT NAME FROM COMPANY WHERE ID = 1) AS COMPANY,
    LOCATIONGROUP.NAME AS LG,
    LOCATIONGROUP.ID AS LGID,
    VENDOR.NAME AS VENDORNAME,
    COALESCE(QTYONHAND.QTY, 0) AS QTY,
    COALESCE(QTYNOTAVAILABLE.QTY, 0) AS UNAVAILABLE,
    COALESCE(QTYDROPSHIP.QTY, 0) AS DROPSHIP,
    COALESCE(QTYCOMMITTED.QTY, 0) AS QTYCOMMITTED,
    COALESCE(QTYALLOCATED.QTY, 0) AS ALLOCATED,
    COALESCE(QTYONORDER.QTY, 0) AS ONORDER,
    COALESCE(PARTCOST.avgCost * QTYONHAND.QTY, 0) AS TOTALCOST,
    COALESCE(NULLIF(CustomFieldByName(PART.customfields, 'Medicine'), ''), 'false') AS MEDICINES,
    COALESCE(NULLIF(CustomFieldByName(PART.customfields, 'Uniforms'), ''), 'false') AS UNIFORMS,
    CustomFieldByName(PART.customfields, 'Inv Assets') AS INVASSETS
FROM
    part
    LEFT JOIN locationgroup ON locationgroup.id IN ($P!{locationGroupID})
    LEFT JOIN uom ON part.uomid = uom.id
    LEFT JOIN vendorparts ON vendorparts.partid = part.id AND vendorparts.defaultflag = 1
    LEFT JOIN vendor ON vendor.id = vendorparts.vendorid
    LEFT JOIN qtyonorder ON qtyonorder.partid = part.id AND qtyonorder.locationgroupid = locationgroup.id
    LEFT JOIN qtyallocated ON qtyallocated.partid = part.id AND qtyallocated.locationgroupid = locationgroup.id
    LEFT JOIN qtycommitted ON qtycommitted.partid = part.id AND qtycommitted.locationgroupid = locationgroup.id
    LEFT JOIN qtynotavailable ON qtynotavailable.partid = part.id AND qtynotavailable.locationgroupid = locationgroup.id
    LEFT JOIN qtydropship ON qtydropship.partid = part.id AND qtydropship.locationgroupid = locationgroup.id
    LEFT JOIN qtyonhand ON qtyonhand.partid = part.id AND qtyonhand.locationgroupid = locationgroup.id
    LEFT JOIN partcost ON partcost.partid = part.id
WHERE
    part.num LIKE $P{partNum}
    AND part.id != 0
    AND part.typeid = 10
    AND part.activeflag = 1
    AND (vendorparts.vendorid LIKE $P{vendorID} OR $P{vendorID} = '%')
HAVING
    IF($P{ShowPartsWithZeroQuantity}, 1=1, (qty + unavailable + dropship + qtycommitted + allocated + onorder) > 0)
    AND (
        ($P{ShowInventoryAssets} AND (INVASSETS = 'Inventory' OR INVASSETS IS NULL OR INVASSETS = '') AND MEDICINES = 'false' AND UNIFORMS = 'false')
        OR ($P{ShowMedicines} AND MEDICINES = 'true')
        OR ($P{ShowUniforms} AND UNIFORMS = 'true')
        OR ($P{ShowLoanAssets} AND INVASSETS = 'Loan Asset')
        OR ($P{ShowCapitalAssets} AND INVASSETS = 'Capital Asset')
    )
ORDER BY
    locationgroup.id, MEDICINES DESC, UNIFORMS DESC, INVASSETS, part.num]]>
	</queryString>
