<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="PartBarcodesWithTrackingOneOff" pageWidth="141" pageHeight="85" whenNoDataType="AllSectionsNoDetail" columnWidth="135" leftMargin="3" rightMargin="3" topMargin="3" bottomMargin="3" uuid="e8a3f5c9-7d2b-4a6e-b1c8-9f4e2d6a8c5b">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="4.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<import value="java.util.*"/>
	<style name="default" isDefault="true" fontName="SansSerif" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false" pdfFontName="Helvetica" pdfEncoding="Cp1252" isPdfEmbedded="false"/>
	<style name="barcode" hAlign="Center" vAlign="Middle"/>
	<parameter name="partNum" class="java.lang.String">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="locationID" class="java.lang.String">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="OnePerUniqueTracking" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
	</parameter>
	<parameter name="path" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["../Labels/"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[CALL CreateList(1000, 'createlist');
SELECT
    part.num as partnum,
    part.description as partdescription,
    CASE WHEN parttracking.typeid = 40 THEN 1 ELSE tag.qty END as tagqty,
    tag.locationid,
    location.name as locationname,
    parttracking.typeid,
    trackingtext.info AS TRACKINGTEXT,
    trackingdate.info AS TRACKINGDATE,
    trackingdecimal.info AS TRACKINGDECIMAL,
    trackinginteger.info AS TRACKINGINTEGER,
    serialnum.serialnum AS SERIALNUM,
    parttracking.name AS TRACKINGNAME

FROM part
    JOIN tag ON part.id = tag.partid
    JOIN location ON tag.locationid = location.id
    LEFT JOIN parttotracking ON part.id = parttotracking.partid AND parttotracking.primaryflag = 1
    LEFT JOIN parttracking ON parttotracking.parttrackingid = parttracking.id
    LEFT OUTER JOIN trackingtext ON tag.id = trackingtext.tagid AND parttracking.id = trackingtext.parttrackingid
    LEFT OUTER JOIN trackinginteger ON tag.id = trackinginteger.tagid AND parttracking.id = trackinginteger.parttrackingid
    LEFT OUTER JOIN trackingdecimal ON tag.id = trackingdecimal.tagid AND parttracking.id = trackingdecimal.parttrackingid
    LEFT OUTER JOIN trackingdate ON tag.id = trackingdate.tagid AND parttracking.id = trackingdate.parttrackingid
    LEFT OUTER JOIN serial ON tag.id = serial.tagid
    LEFT OUTER JOIN serialnum ON serial.id = serialnum.serialid AND parttracking.id = serialnum.parttrackingid
left join tmp_createlist as copy on copy.cnt <= CASE WHEN parttracking.typeid = 40 OR $P{OnePerUniqueTracking} THEN 1
					  ELSE tag.qty END

WHERE part.id > 0
    AND part.activeflag = 1
    AND part.typeid = 10
    AND UPPER(part.num) LIKE UPPER($P{partNum})
    AND location.id LIKE $P{locationID}

ORDER BY part.num, serial.id, COALESCE(trackingtext.info, trackingdate.info, trackingdecimal.info, trackinginteger.info, serialnum.serialnum)]]>
	</queryString>
	<field name="partnum" class="java.lang.String"/>
	<field name="partdescription" class="java.lang.String"/>
	<field name="tagqty" class="java.math.BigDecimal"/>
	<field name="locationid" class="java.lang.Integer"/>
	<field name="locationname" class="java.lang.String"/>
	<field name="TYPEID" class="java.lang.Integer"/>
	<field name="TRACKINGTEXT" class="java.lang.String"/>
	<field name="TRACKINGDATE" class="java.sql.Timestamp"/>
	<field name="TRACKINGDECIMAL" class="java.math.BigDecimal"/>
	<field name="TRACKINGINTEGER" class="java.lang.Integer"/>
	<field name="SERIALNUM" class="java.lang.String"/>
	<field name="TRACKINGNAME" class="java.lang.String"/>
	<variable name="DateFormat" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[(System.getProperty("REPORT_DATE_FORMAT"))]]></variableExpression>
	</variable>
	<variable name="PriceDecimal" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_PRICE")]]></variableExpression>
	</variable>
	<variable name="QtyDecimal" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_QTY")]]></variableExpression>
	</variable>
	<variable name="CostDecimal" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_COST")]]></variableExpression>
	</variable>
	<background>
		<band/>
	</background>
	<detail>
		<band height="79" splitType="Stretch">
			<textField isBlankWhenNull="true">
				<reportElement key="textField-1" style="default" x="0" y="0" width="135" height="10" uuid="a7d2f5c8-9e3b-4c6d-b1a4-8f5e9d2c6a1b"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Arial" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{partnum}]]></textFieldExpression>
			</textField>
			<componentElement>
				<reportElement style="barcode" x="0" y="23" width="135" height="29" uuid="c5e8f3a9-6d2b-4a7c-b9e1-8f4d2a6c5e3b"/>
				<jr:barbecue xmlns:jr="http://jasperreports.sourceforge.net/jasperreports/components" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports/components http://jasperreports.sourceforge.net/xsd/components.xsd" type="Code128B" drawText="false" checksumRequired="false" barWidth="0" barHeight="29">
					<jr:codeExpression><![CDATA[$F{partnum}]]></jr:codeExpression>
				</jr:barbecue>
			</componentElement>
			<textField isBlankWhenNull="true">
				<reportElement key="textField-2" style="default" x="0" y="52" width="135" height="10" uuid="d9f2a6c4-8e1b-4d5a-b3c7-9f6e2d8a5c1b">
					<printWhenExpression><![CDATA[$F{TYPEID} != null]]></printWhenExpression>
				</reportElement>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Arial" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{TYPEID} == 10 ? $F{TRACKINGNAME} + ": " + $F{TRACKINGTEXT}
        :  $F{TYPEID} == 20 || $F{TYPEID} == 30 ? $F{TRACKINGNAME} + ": " + new SimpleDateFormat($V{DateFormat}).format($F{TRACKINGDATE})
        :  $F{TYPEID} == 40 ? $F{TRACKINGNAME} + ": " + $F{SERIALNUM}
        :  $F{TYPEID} == 50 ? $F{TRACKINGNAME} + ": " + $F{TRACKINGINTEGER}
        :  $F{TYPEID} == 60 ? $F{TRACKINGNAME} + ": " + $F{TRACKINGDECIMAL}
        :  $F{TRACKINGNAME} + ": " + ($F{TRACKINGTEXT} != null ? $F{TRACKINGTEXT} : "")]]></textFieldExpression>
			</textField>
			<componentElement>
				<reportElement style="barcode" x="0" y="62" width="135" height="17" uuid="e1c4f8a6-9d2b-4a5c-b7e3-8f9d6a2c4e5b">
					<printWhenExpression><![CDATA[$F{TYPEID} != null]]></printWhenExpression>
				</reportElement>
				<jr:barbecue xmlns:jr="http://jasperreports.sourceforge.net/jasperreports/components" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports/components http://jasperreports.sourceforge.net/xsd/components.xsd" type="Code128B" drawText="false" checksumRequired="false" barWidth="0" barHeight="29">
					<jr:codeExpression><![CDATA[$F{TYPEID} == 10 ? $F{TRACKINGTEXT}
:  $F{TYPEID} == 20 ? $F{TRACKINGDATE}
:  $F{TYPEID} == 30 ? $F{TRACKINGDATE}
:  $F{TYPEID} == 40 ? $F{SERIALNUM}
:  $F{TYPEID} == 50 ? String.valueOf($F{TRACKINGINTEGER})
:  $F{TYPEID} == 60 ? String.valueOf($F{TRACKINGDECIMAL})
:  $F{TRACKINGTEXT}]]></jr:codeExpression>
				</jr:barbecue>
			</componentElement>
			<textField isBlankWhenNull="true">
				<reportElement key="textField-1" style="default" x="0" y="10" width="135" height="10" uuid="f6a9d2c8-7e1b-4c5d-b9a3-8f4e6d2a9c5b"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Arial" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{partdescription}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
	<columnFooter>
		<band splitType="Prevent"/>
	</columnFooter>
	<summary>
		<band splitType="Prevent"/>
	</summary>
</jasperReport>
