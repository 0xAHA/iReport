		</parameter>
		<parameter name="LabelsToPrint" class="java.lang.Integer" isForPrompting="false">
			<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
		</parameter>
		<parameter name="LabelsPerPart" class="java.lang.Integer" isForPrompting="false">
			<property name="Group" value="Label Generation &amp; Display"/>
			<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[CALL CreateList($P!{LabelsPerPart}, 'createlist');
SELECT
part.NUM,
part.DESCRIPTION,
VENDOR.NAME as VENDORNAME,
VENDOR.ACCOUNTNUM as VENDORNUM
FROM tmp_createlist CL, part
    LEFT JOIN defaultlocation ON part.id = defaultlocation.partID
    INNER JOIN vendorparts ON part.id = vendorparts.partid
    INNER JOIN uom ON vendorparts.uomid = uom.id
    INNER JOIN vendor ON vendorparts.vendorid = vendor.id
WHERE part.id > 0
  AND part.activeflag = 1
  AND UPPER(part.num) LIKE UPPER($P{partNum})
LIMIT $P!{LabelsToPrint} OFFSET $P!{Skip}]]>
		</queryString>
		<field name="NUM" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="DESCRIPTION" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="VENDORNAME" class="java.lang.String"/>
		<field name="VENDORNUM" class="java.lang.String"/>
		<variable name="isMultiCurrency" class="java.lang.Boolean">
			<variableExpression><![CDATA[com.evnt.eve.modules.CurrencyModule.isMultiCurrency()]]></variableExpression>
		</variable>
		<variable name="PriceDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_PRICE")]]></variableExpression>
		</variable>
	</subDataset>
