	<parameter name="path" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["../Custom/"]]></defaultValueExpression>
	</parameter>
	<parameter name="module" class="java.lang.Object" isForPrompting="false">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="shipID" class="java.lang.String"/>
	<parameter name="Count" class="java.lang.Integer" isForPrompting="false">
		<defaultValueExpression><![CDATA[100]]></defaultValueExpression>
	</parameter>
	<parameter name="partNum" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA['%']]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
so.num AS OrderNum
,so.customerPO AS CustPO
,soItem.soLineItem AS LineNumber
,soItem.productNum AS PartNum
,soItem.description AS Description
,shipItem.qtyShipped AS Qty
,part.num AS Barcode
,now() AS DANDT
FROM ship
JOIN shipItem ON shipItem.shipId = ship.id
JOIN soItem ON soItem.id = shipItem.soItemId
JOIN product ON product.id = soItem.productId
JOIN part ON part.id = product.partId
JOIN so ON so.id = soItem.soId
JOIN mysql.help_topic ht ON ht.help_topic_id < CAST(shipItem.qtyShipped AS SIGNED)
WHERE ship.id = $P{shipID}
ORDER BY 3]]>
	</queryString>
	<field name="OrderNum" class="java.lang.String"/>
	<field name="CustPO" class="java.lang.String"/>
	<field name="LineNumber" class="java.lang.Integer"/>
	<field name="PartNum" class="java.lang.String"/>
	<field name="Description" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="Qty" class="java.math.BigDecimal">
