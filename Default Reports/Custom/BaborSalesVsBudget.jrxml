<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="BaborSalesVsBudget" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="782" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="0c0bbbd3-cf24-4599-94ce-ce9bee8d318a">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<style name="NegativeRed" forecolor="#000000">
		<conditionalStyle>
			<conditionExpression><![CDATA[((java.math.BigDecimal)$V{currentPeriodVar}).compareTo(java.math.BigDecimal.ZERO) < 0]]></conditionExpression>
			<style forecolor="#CC0000"/>
		</conditionalStyle>
	</style>
	<style name="NegativeRedYTD" forecolor="#000000">
		<conditionalStyle>
			<conditionExpression><![CDATA[((java.math.BigDecimal)$V{ytdVar}).compareTo(java.math.BigDecimal.ZERO) < 0]]></conditionExpression>
			<style forecolor="#CC0000"/>
		</conditionalStyle>
	</style>
	<parameter name="dateRange1" class="java.sql.Date" isForPrompting="false">
		<property name="Group" value="Filters"/>
		<parameterDescription><![CDATA[This Month]]></parameterDescription>
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRange2" class="java.sql.Date" isForPrompting="false">
		<property name="Group" value="Filters"/>
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    COALESCE(CONCAT(su.firstName, ' ', su.lastName), 'Unassigned') AS salesPersonName,
    COALESCE(ag.name, 'Uncategorised') AS customerGroup,
    COALESCE(qbc.name, '') AS stateName,
    c.name AS customerName,
    COALESCE(CAST(CustomFieldByName(c.customFields, 'Annual Budget') AS DECIMAL(18,2)), 0) AS annualBudget,
    COALESCE(CAST(CustomFieldByName(c.customFields, 'Jan Budget') AS DECIMAL(18,2)), 0) AS janBudget,
    COALESCE(CAST(CustomFieldByName(c.customFields, 'Feb Budget') AS DECIMAL(18,2)), 0) AS febBudget,
    COALESCE(CAST(CustomFieldByName(c.customFields, 'Mar Budget') AS DECIMAL(18,2)), 0) AS marBudget,
    COALESCE(CAST(CustomFieldByName(c.customFields, 'Apr Budget') AS DECIMAL(18,2)), 0) AS aprBudget,
    COALESCE(CAST(CustomFieldByName(c.customFields, 'May Budget') AS DECIMAL(18,2)), 0) AS mayBudget,
    COALESCE(CAST(CustomFieldByName(c.customFields, 'Jun Budget') AS DECIMAL(18,2)), 0) AS junBudget,
    COALESCE(CAST(CustomFieldByName(c.customFields, 'Jul Budget') AS DECIMAL(18,2)), 0) AS julBudget,
    COALESCE(CAST(CustomFieldByName(c.customFields, 'Aug Budget') AS DECIMAL(18,2)), 0) AS augBudget,
    COALESCE(CAST(CustomFieldByName(c.customFields, 'Sep Budget') AS DECIMAL(18,2)), 0) AS sepBudget,
    COALESCE(CAST(CustomFieldByName(c.customFields, 'Oct Budget') AS DECIMAL(18,2)), 0) AS octBudget,
    COALESCE(CAST(CustomFieldByName(c.customFields, 'Nov Budget') AS DECIMAL(18,2)), 0) AS novBudget,
    COALESCE(CAST(CustomFieldByName(c.customFields, 'Dec Budget') AS DECIMAL(18,2)), 0) AS decBudget,
    COALESCE(cpSales.currentPeriodActual, 0) AS currentPeriodActual,
    COALESCE(ytdSales.ytdActual, 0) AS ytdActual
FROM customer c
LEFT JOIN accountgrouprelation agr ON agr.accountId = c.accountId
LEFT JOIN accountgroup ag ON ag.id = agr.groupId
LEFT JOIN qbclass qbc ON qbc.id = c.qbClassId
LEFT JOIN sysuser su ON su.id = c.defaultSalesmanId
LEFT JOIN (
    SELECT
        so.customerId,
        SUM(postsoitem.totalPrice) AS currentPeriodActual
    FROM postsoitem
    INNER JOIN postso ON postso.id = postsoitem.postSOId
    INNER JOIN so ON so.id = postso.soId
    WHERE postso.postDate >= $P{dateRange1}
      AND postso.postDate <= $P{dateRange2}
    GROUP BY so.customerId
) cpSales ON cpSales.customerId = c.id
LEFT JOIN (
    SELECT
        so.customerId,
        SUM(postsoitem.totalPrice) AS ytdActual
    FROM postsoitem
    INNER JOIN postso ON postso.id = postsoitem.postSOId
    INNER JOIN so ON so.id = postso.soId
    WHERE postso.postDate >= CONCAT(YEAR($P{dateRange2}), '-01-01')
      AND postso.postDate <= $P{dateRange2}
    GROUP BY so.customerId
) ytdSales ON ytdSales.customerId = c.id
WHERE (
    COALESCE(CAST(CustomFieldByName(c.customFields, 'Annual Budget') AS DECIMAL(18,2)), 0) > 0
    OR COALESCE(CAST(CustomFieldByName(c.customFields, 'Jan Budget') AS DECIMAL(18,2)), 0) > 0
    OR COALESCE(CAST(CustomFieldByName(c.customFields, 'Feb Budget') AS DECIMAL(18,2)), 0) > 0
    OR COALESCE(CAST(CustomFieldByName(c.customFields, 'Mar Budget') AS DECIMAL(18,2)), 0) > 0
    OR COALESCE(CAST(CustomFieldByName(c.customFields, 'Apr Budget') AS DECIMAL(18,2)), 0) > 0
    OR COALESCE(CAST(CustomFieldByName(c.customFields, 'May Budget') AS DECIMAL(18,2)), 0) > 0
    OR COALESCE(CAST(CustomFieldByName(c.customFields, 'Jun Budget') AS DECIMAL(18,2)), 0) > 0
    OR COALESCE(CAST(CustomFieldByName(c.customFields, 'Jul Budget') AS DECIMAL(18,2)), 0) > 0
    OR COALESCE(CAST(CustomFieldByName(c.customFields, 'Aug Budget') AS DECIMAL(18,2)), 0) > 0
    OR COALESCE(CAST(CustomFieldByName(c.customFields, 'Sep Budget') AS DECIMAL(18,2)), 0) > 0
    OR COALESCE(CAST(CustomFieldByName(c.customFields, 'Oct Budget') AS DECIMAL(18,2)), 0) > 0
    OR COALESCE(CAST(CustomFieldByName(c.customFields, 'Nov Budget') AS DECIMAL(18,2)), 0) > 0
    OR COALESCE(CAST(CustomFieldByName(c.customFields, 'Dec Budget') AS DECIMAL(18,2)), 0) > 0
    OR COALESCE(cpSales.currentPeriodActual, 0) > 0
    OR COALESCE(ytdSales.ytdActual, 0) > 0
)
ORDER BY salesPersonName, customerGroup, qbc.name, c.name]]>
	</queryString>
	<field name="salesPersonName" class="java.lang.String"/>
	<field name="customerGroup" class="java.lang.String"/>
	<field name="stateName" class="java.lang.String"/>
	<field name="customerName" class="java.lang.String"/>
	<field name="annualBudget" class="java.math.BigDecimal"/>
	<field name="janBudget" class="java.math.BigDecimal"/>
	<field name="febBudget" class="java.math.BigDecimal"/>
	<field name="marBudget" class="java.math.BigDecimal"/>
	<field name="aprBudget" class="java.math.BigDecimal"/>
	<field name="mayBudget" class="java.math.BigDecimal"/>
	<field name="junBudget" class="java.math.BigDecimal"/>
	<field name="julBudget" class="java.math.BigDecimal"/>
	<field name="augBudget" class="java.math.BigDecimal"/>
	<field name="sepBudget" class="java.math.BigDecimal"/>
	<field name="octBudget" class="java.math.BigDecimal"/>
	<field name="novBudget" class="java.math.BigDecimal"/>
	<field name="decBudget" class="java.math.BigDecimal"/>
	<field name="currentPeriodActual" class="java.math.BigDecimal"/>
	<field name="ytdActual" class="java.math.BigDecimal"/>
	<variable name="currentPeriodMonth" class="java.lang.Integer" resetType="None">
		<variableExpression><![CDATA[Integer.valueOf(new java.text.SimpleDateFormat("M").format($P{dateRange1}))]]></variableExpression>
	</variable>
	<variable name="currentMonthBudget" class="java.math.BigDecimal" resetType="None">
		<variableExpression><![CDATA[$F{annualBudget}.compareTo(java.math.BigDecimal.ZERO) > 0
    ? $F{annualBudget}.divide(new java.math.BigDecimal(12), 2, java.math.RoundingMode.HALF_UP)
    : (
        $V{currentPeriodMonth}.intValue() == 1 ? $F{janBudget} :
        $V{currentPeriodMonth}.intValue() == 2 ? $F{febBudget} :
        $V{currentPeriodMonth}.intValue() == 3 ? $F{marBudget} :
        $V{currentPeriodMonth}.intValue() == 4 ? $F{aprBudget} :
        $V{currentPeriodMonth}.intValue() == 5 ? $F{mayBudget} :
        $V{currentPeriodMonth}.intValue() == 6 ? $F{junBudget} :
        $V{currentPeriodMonth}.intValue() == 7 ? $F{julBudget} :
        $V{currentPeriodMonth}.intValue() == 8 ? $F{augBudget} :
        $V{currentPeriodMonth}.intValue() == 9 ? $F{sepBudget} :
        $V{currentPeriodMonth}.intValue() == 10 ? $F{octBudget} :
        $V{currentPeriodMonth}.intValue() == 11 ? $F{novBudget} :
        $F{decBudget}
    )]]></variableExpression>
	</variable>
	<variable name="ytdMonthCount" class="java.lang.Integer" resetType="None">
		<variableExpression><![CDATA[Integer.valueOf(new java.text.SimpleDateFormat("M").format($P{dateRange2}))]]></variableExpression>
	</variable>
	<variable name="ytdBudget" class="java.math.BigDecimal" resetType="None">
		<variableExpression><![CDATA[$F{annualBudget}.compareTo(java.math.BigDecimal.ZERO) > 0
    ? $F{annualBudget}.divide(new java.math.BigDecimal(12), 2, java.math.RoundingMode.HALF_UP).multiply(new java.math.BigDecimal($V{ytdMonthCount}))
    : (
        ($V{ytdMonthCount}.intValue() >= 1 ? $F{janBudget} : java.math.BigDecimal.ZERO)
        .add($V{ytdMonthCount}.intValue() >= 2 ? $F{febBudget} : java.math.BigDecimal.ZERO)
        .add($V{ytdMonthCount}.intValue() >= 3 ? $F{marBudget} : java.math.BigDecimal.ZERO)
        .add($V{ytdMonthCount}.intValue() >= 4 ? $F{aprBudget} : java.math.BigDecimal.ZERO)
        .add($V{ytdMonthCount}.intValue() >= 5 ? $F{mayBudget} : java.math.BigDecimal.ZERO)
        .add($V{ytdMonthCount}.intValue() >= 6 ? $F{junBudget} : java.math.BigDecimal.ZERO)
        .add($V{ytdMonthCount}.intValue() >= 7 ? $F{julBudget} : java.math.BigDecimal.ZERO)
        .add($V{ytdMonthCount}.intValue() >= 8 ? $F{augBudget} : java.math.BigDecimal.ZERO)
        .add($V{ytdMonthCount}.intValue() >= 9 ? $F{sepBudget} : java.math.BigDecimal.ZERO)
        .add($V{ytdMonthCount}.intValue() >= 10 ? $F{octBudget} : java.math.BigDecimal.ZERO)
        .add($V{ytdMonthCount}.intValue() >= 11 ? $F{novBudget} : java.math.BigDecimal.ZERO)
        .add($V{ytdMonthCount}.intValue() >= 12 ? $F{decBudget} : java.math.BigDecimal.ZERO)
    )]]></variableExpression>
	</variable>
	<variable name="currentPeriodVar" class="java.math.BigDecimal" resetType="None">
		<variableExpression><![CDATA[$F{currentPeriodActual}.subtract($V{currentMonthBudget})]]></variableExpression>
	</variable>
	<variable name="ytdVar" class="java.math.BigDecimal" resetType="None">
		<variableExpression><![CDATA[$F{ytdActual}.subtract($V{ytdBudget})]]></variableExpression>
	</variable>
	<!-- State group totals -->
	<variable name="stateActualCP" class="java.math.BigDecimal" resetType="Group" resetGroup="stateGroup" calculation="Sum">
		<variableExpression><![CDATA[$F{currentPeriodActual}]]></variableExpression>
	</variable>
	<variable name="stateBudgetCP" class="java.math.BigDecimal" resetType="Group" resetGroup="stateGroup" calculation="Sum">
		<variableExpression><![CDATA[$V{currentMonthBudget}]]></variableExpression>
	</variable>
	<variable name="stateVarCP" class="java.math.BigDecimal" resetType="Group" resetGroup="stateGroup" calculation="Sum">
		<variableExpression><![CDATA[$V{currentPeriodVar}]]></variableExpression>
	</variable>
	<variable name="stateActualYTD" class="java.math.BigDecimal" resetType="Group" resetGroup="stateGroup" calculation="Sum">
		<variableExpression><![CDATA[$F{ytdActual}]]></variableExpression>
	</variable>
	<variable name="stateBudgetYTD" class="java.math.BigDecimal" resetType="Group" resetGroup="stateGroup" calculation="Sum">
