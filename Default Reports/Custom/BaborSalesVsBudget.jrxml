				<textField pattern="#,##0.00">
					<reportElement uuid="a9f4dfe3-496b-4f5e-bef4-d48f2885ffd6" x="520" y="0" width="88" height="18"/>
					<box><topPen lineWidth="0.5"/><bottomPen lineWidth="1.0"/></box>
					<textElement textAlignment="Right" verticalAlignment="Middle">
						<font size="8" isBold="true"/>
					</textElement>
					<textFieldExpression><![CDATA[$V{cgActualYTD}]]></textFieldExpression>
				</textField>
				<textField pattern="#,##0.00">
					<reportElement uuid="8bcd03cb-e4ff-408d-af58-e8b3d660c595" x="608" y="0" width="88" height="18"/>
					<box><topPen lineWidth="0.5"/><bottomPen lineWidth="1.0"/></box>
					<textElement textAlignment="Right" verticalAlignment="Middle">
						<font size="8" isBold="true"/>
					</textElement>
					<textFieldExpression><![CDATA[$V{cgBudgetYTD}]]></textFieldExpression>
