	</variable>
	<variable name="stateVarYTD" class="java.math.BigDecimal" resetType="Group" resetGroup="stateGroup" calculation="Sum">
		<variableExpression><![CDATA[$V{ytdVar}]]></variableExpression>
	</variable>
	<!-- Customer Group totals -->
	<variable name="cgActualCP" class="java.math.BigDecimal" resetType="Group" resetGroup="customerGrouping" calculation="Sum">
		<variableExpression><![CDATA[$F{currentPeriodActual}]]></variableExpression>
	</variable>
	<variable name="cgBudgetCP" class="java.math.BigDecimal" resetType="Group" resetGroup="customerGrouping" calculation="Sum">
		<variableExpression><![CDATA[$V{currentMonthBudget}]]></variableExpression>
	</variable>
	<variable name="cgVarCP" class="java.math.BigDecimal" resetType="Group" resetGroup="customerGrouping" calculation="Sum">
		<variableExpression><![CDATA[$V{currentPeriodVar}]]></variableExpression>
	</variable>
	<variable name="cgActualYTD" class="java.math.BigDecimal" resetType="Group" resetGroup="customerGrouping" calculation="Sum">
		<variableExpression><![CDATA[$F{ytdActual}]]></variableExpression>
	</variable>
	<variable name="cgBudgetYTD" class="java.math.BigDecimal" resetType="Group" resetGroup="customerGrouping" calculation="Sum">
		<variableExpression><![CDATA[$V{ytdBudget}]]></variableExpression>
	</variable>
	<variable name="cgVarYTD" class="java.math.BigDecimal" resetType="Group" resetGroup="customerGrouping" calculation="Sum">
		<variableExpression><![CDATA[$V{ytdVar}]]></variableExpression>
	</variable>
	<!-- Sales Person totals -->
	<variable name="spActualCP" class="java.math.BigDecimal" resetType="Group" resetGroup="salesPersonGroup" calculation="Sum">
		<variableExpression><![CDATA[$F{currentPeriodActual}]]></variableExpression>
	</variable>
	<variable name="spBudgetCP" class="java.math.BigDecimal" resetType="Group" resetGroup="salesPersonGroup" calculation="Sum">
		<variableExpression><![CDATA[$V{currentMonthBudget}]]></variableExpression>
	</variable>
	<variable name="spVarCP" class="java.math.BigDecimal" resetType="Group" resetGroup="salesPersonGroup" calculation="Sum">
		<variableExpression><![CDATA[$V{currentPeriodVar}]]></variableExpression>
	</variable>
	<variable name="spActualYTD" class="java.math.BigDecimal" resetType="Group" resetGroup="salesPersonGroup" calculation="Sum">
		<variableExpression><![CDATA[$F{ytdActual}]]></variableExpression>
	</variable>
	<variable name="spBudgetYTD" class="java.math.BigDecimal" resetType="Group" resetGroup="salesPersonGroup" calculation="Sum">
		<variableExpression><![CDATA[$V{ytdBudget}]]></variableExpression>
	</variable>
	<variable name="spVarYTD" class="java.math.BigDecimal" resetType="Group" resetGroup="salesPersonGroup" calculation="Sum">
		<variableExpression><![CDATA[$V{ytdVar}]]></variableExpression>
	</variable>
	<!-- Grand totals -->
	<variable name="grandActualCP" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{currentPeriodActual}]]></variableExpression>
	</variable>
	<variable name="grandBudgetCP" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$V{currentMonthBudget}]]></variableExpression>
	</variable>
	<variable name="grandVarCP" class="java.math.BigDecimal" calculation="Sum">
