	</variable>
	<variable name="grandActualYTD" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{ytdActual}]]></variableExpression>
	</variable>
	<variable name="grandBudgetYTD" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$V{ytdBudget}]]></variableExpression>
	</variable>
	<variable name="grandVarYTD" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$V{ytdVar}]]></variableExpression>
	</variable>
