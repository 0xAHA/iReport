<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="OrderingByLeadTimeDetail" pageWidth="555" pageHeight="802" columnWidth="555" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="853c27aa-9424-458c-8641-9aa42344256a">
	<property name="ireport.zoom" value="1.7715610000000035"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="dateRange2" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRange1" class="java.util.Date" isForPrompting="false">
		<parameterDescription><![CDATA[All]]></parameterDescription>
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[Select
Coalesce(Vendor.Name,'A1') as Vendor
,Wo.Num as WoNum
,Wo.DateScheduledToStart as DateRequired
,Part.Num as PartNum
,Part.Description as PartDesc
,VendorParts.LeadTime as Spee3DLeadTime
,Sum(WoItem.QtyTarget * Coalesce(WOUomConversion.Multiply,1)) as QtyNeeded
,PartUom.Code as PartUom
,CEIL(Sum(WoItem.QtyTarget * Coalesce(WOUomConversion.Multiply,1)) / Coalesce(VendorUomConversion.Factor,1)) as OrderQty
,CEIL(qtyinv.qty / Coalesce(VendorUomConversion.Factor,1)) as VendorOnhandQty
,VendorPartsUom.Code as VendorUom
,Cast(Date_Sub(Wo.DateScheduledToStart, INTERVAL Coalesce(VendorParts.LeadTime,0) Day) as Date) as OrderByDate
,vendor.note as Alert
,qtyinv.qty as QtyOnhand

From Mo
Join MoItem on MoItem.MoId = Mo.Id
Join Wo on Wo.MoItemId = MoItem.Id
Join WoItem on WoItem.WoId = Wo.Id and WoItem.TypeId != 10
Join Part on Part.id = WoItem.PartId
Left Join UomConversion WOUomConversion on WOUomConversion.FromUomId = WoItem.UomId and WOUomConversion.ToUomId = Part.UomId
Join Uom PartUom on PartUom.Id = Part.UomId
Left Join VendorParts on VendorParts.PartId = Part.Id and VendorParts.DefaultFlag = 1
Left Join Uom VendorPartsUom on VendorPartsUom.Id = VendorParts.UomId
Left Join Vendor on Vendor.Id = VendorParts.VendorId
Left Join UomConversion VendorUomConversion on VendorUomConversion.FromUomId = Part.UomId and VendorUomConversion.ToUomId = VendorParts.UomId
join partreorder on partreorder.partid = part.id /* only return parts with ROP and OUL */
left join (select sum(qtyonhand.qty) as qty, qtyonhand.partid from qtyonhand
    left join part on part.id = qtyonhand.partid
    group by part.id) as qtyinv on qtyinv.partid = part.id

Where Wo.StatusId IN (10,30)
and MoItem.Stage = 0
and Cast(Date_Sub(Wo.DateScheduledToStart, INTERVAL Coalesce(VendorParts.LeadTime,0) Day) as Date) between $P{dateRange1} and Date_Sub($P{dateRange2}, INTERVAL 1 Second)

Group By Wo.Num, Part.Id, Cast(Date_Sub(Wo.DateScheduledToStart, INTERVAL Coalesce(VendorParts.LeadTime,0) Day) as Date)
Order By Coalesce(Vendor.Name,'A1'), Part.Num]]>
	</queryString>
