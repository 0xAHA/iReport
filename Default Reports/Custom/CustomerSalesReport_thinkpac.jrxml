<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="sales_order_completed_report" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="a7c3f8e1-4b2d-4f3a-9c1e-5d8a6f2b4e7c">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="ReportMonth" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new java.util.Date()]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    customer.name AS customerName,
    SUM(CASE
        WHEN MONTH(so.dateCompleted) = MONTH($P{ReportMonth})
        AND YEAR(so.dateCompleted) = YEAR($P{ReportMonth})
        THEN so.subTotal
        ELSE 0
    END) AS currentMonthSales,
    SUM(CASE
        WHEN MONTH(so.dateCompleted) = MONTH($P{ReportMonth})
        AND YEAR(so.dateCompleted) = YEAR($P{ReportMonth}) - 1
        THEN so.subTotal
        ELSE 0
    END) AS previousYearMonthSales,
    SUM(CASE
        WHEN so.dateCompleted >= DATE_SUB(DATE_FORMAT($P{ReportMonth}, '%Y-%m-01'), INTERVAL 11 MONTH)
        AND so.dateCompleted <= LAST_DAY($P{ReportMonth})
        THEN so.subTotal
        ELSE 0
    END) AS currentRolling12Sales,
    SUM(CASE
        WHEN so.dateCompleted >= DATE_SUB(DATE_FORMAT($P{ReportMonth}, '%Y-%m-01'), INTERVAL 23 MONTH)
        AND so.dateCompleted <= LAST_DAY(DATE_SUB($P{ReportMonth}, INTERVAL 12 MONTH))
        THEN so.subTotal
        ELSE 0
    END) AS previousYearRolling12Sales
FROM customer
LEFT JOIN so ON so.customerID = customer.id AND so.dateCompleted IS NOT NULL
GROUP BY customer.id, customer.name
HAVING currentMonthSales > 0 OR previousYearMonthSales > 0 OR currentRolling12Sales > 0 OR previousYearRolling12Sales > 0
ORDER BY customer.name ASC]]>
	</queryString>
	<field name="customerName" class="java.lang.String"/>
	<field name="currentMonthSales" class="java.math.BigDecimal"/>
	<field name="previousYearMonthSales" class="java.math.BigDecimal"/>
	<field name="currentRolling12Sales" class="java.math.BigDecimal"/>
	<field name="previousYearRolling12Sales" class="java.math.BigDecimal"/>
	<variable name="currentMonthSales_SUM" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{currentMonthSales}]]></variableExpression>
	</variable>
	<variable name="previousYearMonthSales_SUM" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{previousYearMonthSales}]]></variableExpression>
	</variable>
	<variable name="currentRolling12Sales_SUM" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{currentRolling12Sales}]]></variableExpression>
	</variable>
	<variable name="previousYearRolling12Sales_SUM" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{previousYearRolling12Sales}]]></variableExpression>
	</variable>
