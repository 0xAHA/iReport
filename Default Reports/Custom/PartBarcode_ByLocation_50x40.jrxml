	<style name="18" fontName="SansSerif" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false" pdfFontName="Helvetica" pdfEncoding="Cp1252" isPdfEmbedded="false"/>
	<style name="barcode" hAlign="Center" vAlign="Middle"/>
	<parameter name="REPORTDESCRIPTION" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["Part Barcodes for one off Labels. Prints one label for each qty of items for a specific location."]]></defaultValueExpression>
	</parameter>
	<parameter name="path_1" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["../Custom/"]]></defaultValueExpression>
	</parameter>
	<parameter name="locationID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="partNum" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="ShowDescription" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Boolean(true)]]></defaultValueExpression>
	</parameter>
	<parameter name="ShowLocation" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Boolean(true)]]></defaultValueExpression>
	</parameter>
	<parameter name="StartAtLabel" class="java.lang.Integer" isForPrompting="false">
		<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
	</parameter>
	<parameter name="OnePerPart" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[CALL CREATELIST($P!{StartAtLabel} - 1, 'CL');
SELECT part.num as PARTNUM, TAG.PARTID AS PARTID, TAG.LOCATIONID AS LOCATIONID, part.DESCRIPTION AS DESCRIPTION, CURRENCY.SYMBOL, COALESCE(location.name, '') AS LOCATION, COALESCE(locationgroup.name, '') AS LOCATIONGROUP
FROM part
    LEFT JOIN currency ON currency.homeCurrency = 1
    JOIN Tag ON part.id = tag.partid
    LEFT JOIN location ON tag.locationid = location.id
    LEFT JOIN locationgroup ON location.locationgroupid = locationgroup.id
    LEFT JOIN TMP_CL as copy ON copy.cnt <= CASE WHEN $P{OnePerPart} THEN 1 ELSE CEIL(tag.qty) END
WHERE part.id > 0
  AND part.activeflag = 1
  AND UPPER(part.num) LIKE UPPER($P{partNum})
  AND CAST(location.id AS CHAR) LIKE $P{locationID}
Order By 1,7,6]]>
	</queryString>
