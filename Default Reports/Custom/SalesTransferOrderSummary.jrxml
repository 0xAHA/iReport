	<parameter name="ACAApproverFilter" class="java.lang.String" isForPrompting="false">
		<property name="Group" value="Filters"/>
		<property name="Tooltip" value="Filter by ACA Approver name. Use % for wildcard searches. Leave blank for all approvers."/>
		<parameterDescription><![CDATA[ACA Approver Filter]]></parameterDescription>
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    COMPANY.NAME AS COMPANY,
    orders.ACAapprover,
    orders.ordertype,
    orders.ordernum,
    orders.fromlocation,
    orders.tolocation,
    orders.salesperson,
    orders.datecreated,
    orders.datescheduled,
    orders.status,
    orders.customerpo,
    0 AS ordered,
    0 AS shipped,
    '' AS productnum,
    '' AS description,
    0 AS itemqtyordered,
    0 AS itemqtyshipped
FROM COMPANY
CROSS JOIN (
    -- Sales Orders
    SELECT
        CASE
            WHEN TRIM(COALESCE(CustomFieldByName(so.customfields, 'ACA Approver'), '')) = ''
            THEN 'No Approver'
            ELSE TRIM(CustomFieldByName(so.customfields, 'ACA Approver'))
        END AS ACAapprover,
        'SO' AS ordertype,
        so.num AS ordernum,
        locationgroup.name AS fromlocation,
        customer.name AS tolocation,
        so.salesman AS salesperson,
        so.datecreated,
        so.datefirstship AS datescheduled,
        sostatus.name AS status,
        so.customerpo,
        so.id AS orderid
    FROM so
        INNER JOIN locationgroup ON locationgroup.id = so.locationgroupid
        INNER JOIN customer ON customer.id = so.customerid
        INNER JOIN sostatus ON sostatus.id = so.statusid
    WHERE $P{ckSalesOrders} = 'SO'
        AND so.locationgroupid IN ($P!{locationGroupID})
        AND so.datecreated BETWEEN $P{dateRange1} AND $P{dateRange2}
        AND so.statusid IN ($P{ckEnteredOrEstimate},$P{ckIssued},$P{ckInProgress},$P{ckFulfilledShipped},$P{ckClosedShortFulfilled},$P{ckVoidedClosedShort},$P{ckCancelled},$P{ckExpiredVoid},$P{ckHistorical})

    UNION ALL

    -- Transfer Orders
    SELECT
        CASE
            WHEN TRIM(COALESCE(CustomFieldByName(xo.customfields, 'ACA Approver'), '')) = ''
            THEN 'No Approver'
            ELSE TRIM(CustomFieldByName(xo.customfields, 'ACA Approver'))
        END AS ACAapprover,
        'TO' AS ordertype,
        xo.num AS ordernum,
        fromlg.name AS fromlocation,
        tolg.name AS tolocation,
        '' AS salesperson,
        xo.datecreated,
        xo.datecreated AS datescheduled,
        xostatus.name AS status,
        '' AS customerpo,
        xo.id AS orderid
    FROM xo
        JOIN locationgroup fromlg ON fromlg.id = xo.fromlgid
        JOIN locationgroup tolg ON tolg.id = xo.shiptolgid
        JOIN xostatus ON xostatus.id = xo.statusid
    WHERE $P{ckTransferOrders} = 'TO'
        AND (fromlg.id IN ($P!{locationGroupID}) OR tolg.id IN ($P!{locationGroupID}))
        AND xo.datecreated BETWEEN $P{dateRange1} AND $P{dateRange2}
        AND xo.statusid IN ($P{ckEnteredOrEstimate},$P{ckRequest},$P{ckIssued},$P{ckPicking},$P{ckPartial},$P{ckPicked},$P{ckFulfilledShipped},$P{ckClosedShortFulfilled},$P{ckVoidedClosedShort},$P{ckExpiredVoid})
) AS orders
WHERE COMPANY.id = 1
    AND orders.ACAapprover LIKE $P{ACAApproverFilter}
ORDER BY orders.ACAapprover, orders.ordertype, orders.ordernum]]>
	</queryString>
