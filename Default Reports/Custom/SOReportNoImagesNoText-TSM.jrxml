		<field name="PRODUCTID" class="java.lang.Integer"/>
		<field name="DepositAmount" class="java.lang.Double"/>
		<variable name="ItemNum" class="java.lang.String">
			<variableExpression><![CDATA[($F{KITPARENTLINE} == null ? "" : "     ") +
($F{PRODUCTNUM} == null || $F{PRODUCTNUM}.length() < 1 ?
    "" :
    ($F{CUSTOMERPARTNUM} == null || $F{CUSTOMERPARTNUM}.length() < 1 || !$P{IncludeCustomerPartNumbers} ?
        $F{PRODUCTNUM} :
        $F{PRODUCTNUM} + " (" + $F{CUSTOMERPARTNUM} + ")"))]]></variableExpression>
		</variable>
		<variable name="ItemDesc" class="java.lang.String">
			<variableExpression><![CDATA[$F{DESCRIPTION}]]></variableExpression>
			<initialValueExpression><![CDATA[]]></initialValueExpression>
		</variable>
		<variable name="ItemNumDesc" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[$V{ItemNum}
+ ($V{ItemNum}.length() >= 1 && $V{ItemDesc}.length() >= 1 ? " - " : "")
+ $V{ItemDesc}]]></variableExpression>
		</variable>
		<variable name="PriceDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_PRICE")]]></variableExpression>
		</variable>
		<variable name="QtyDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_QTY")]]></variableExpression>
		</variable>
		<variable name="CostDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_COST")]]></variableExpression>
		</variable>
		<variable name="DateFormat" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[(System.getProperty("REPORT_DATE_FORMAT"))]]></variableExpression>
		</variable>
		<variable name="TotalsDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_TOTAL")]]></variableExpression>
		</variable>
		<variable name="isMultiCurrency" class="java.lang.Boolean">
			<variableExpression><![CDATA[com.evnt.eve.modules.CurrencyModule.isMultiCurrency()]]></variableExpression>
		</variable>
		<variable name="CanDisplaySymbol" class="java.lang.Boolean">
			<variableExpression><![CDATA[$F{COALESCESYMBOL} == null || $F{COALESCESYMBOL}.equals("")
 ? true
 : new java.awt.Font("Open Sans", java.awt.Font.PLAIN ,1).canDisplay(com.fbi.sdk.constants.setup.CurrencySymbolConst.getConstant($F{COALESCESYMBOL}).getSymbol().charAt(0))]]></variableExpression>
			<initialValueExpression><![CDATA[true]]></initialValueExpression>
		</variable>
		<variable name="totalsDecimalNoSymbol" class="java.lang.String">
			<variableExpression><![CDATA[$V{TotalsDecimal}.substring(1,$V{TotalsDecimal}.length())]]></variableExpression>
		</variable>
		<variable name="priceDecimalNoSymbol" class="java.lang.String">
			<variableExpression><![CDATA[$V{PriceDecimal}.substring(1,$V{PriceDecimal}.length())]]></variableExpression>
		</variable>
		<variable name="isUnitedStates" class="java.lang.Boolean">
			<variableExpression><![CDATA[!(com.evnt.eve.modules.AccountingModule.isInternational())]]></variableExpression>
		</variable>
		<variable name="isAustralia" class="java.lang.Boolean">
			<variableExpression><![CDATA[com.evnt.eve.modules.AccountingModule.isAu()]]></variableExpression>
		</variable>
		<variable name="isCanada" class="java.lang.Boolean">
			<variableExpression><![CDATA[com.evnt.eve.modules.AccountingModule.isCa()]]></variableExpression>
		</variable>
		<variable name="SubTotal" class="java.lang.Double" calculation="Sum">
			<variableExpression><![CDATA[$F{TYPEID} == 90 || $F{TYPEID} == 40
    ? 0.0
    : $F{CURRENCYEXTPRICE} + $F{kitTotal}]]></variableExpression>
		</variable>
		<variable name="homeCurrencySubtotal" class="java.lang.Double" calculation="Sum">
			<variableExpression><![CDATA[$F{TYPEID} == 90 || $F{TYPEID} == 40
    ? 0.0
    : $F{HOMECURRENCYEXTPRICE} + $F{kitTotal}]]></variableExpression>
		</variable>
		<variable name="taxTotal" class="java.lang.Double" calculation="Highest">
			<variableExpression><![CDATA[$P{AddTaxIntegrationEstimatedTaxToTotal} && $F{STATUSID} < 60
? $F{ESTIMATEDTAX} / $F{CURRENCYRATE}
: $F{CURRENCYTAXTOTAL}]]></variableExpression>
		</variable>
		<variable name="homeCurrencyTaxTotal" class="java.lang.Double" calculation="Highest">
			<variableExpression><![CDATA[$P{AddTaxIntegrationEstimatedTaxToTotal} && $F{STATUSID} < 60
? $F{ESTIMATEDTAX}
: $F{HOMECURRENCYTAXTOTAL}]]></variableExpression>
		</variable>
		<variable name="GrandTotal" class="java.lang.Double">
			<variableExpression><![CDATA[$V{SubTotal} + $V{taxTotal}]]></variableExpression>
		</variable>
		<variable name="homeCurrencyGrandTotal" class="java.lang.Double">
			<variableExpression><![CDATA[$V{homeCurrencySubtotal} + $V{homeCurrencyTaxTotal}]]></variableExpression>
		</variable>
		<variable name="paymentTotal" class="java.lang.Double">
			<variableExpression><![CDATA[$F{CURRENCYPAYMENTAMOUNT} == null
? 0
: $F{CURRENCYPAYMENTAMOUNT}]]></variableExpression>
			<initialValueExpression><![CDATA[]]></initialValueExpression>
		</variable>
		<variable name="homeCurrencyPaymentTotal" class="java.lang.Double">
			<variableExpression><![CDATA[$F{HOMECURRENCYPAYMENTAMOUNT} == null
? 0
: $F{HOMECURRENCYPAYMENTAMOUNT}]]></variableExpression>
			<initialValueExpression><![CDATA[]]></initialValueExpression>
		</variable>
		<variable name="DepositAmount" class="java.lang.Double"/>
		<group name="Total Info"/>
	</subDataset>
	<subDataset name="PaymentInfo" uuid="653f16c2-2413-40d7-a6c4-607aa28ac64e">
		<parameter name="soId" class="java.lang.Integer">
			<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
		</parameter>
		<parameter name="ShowCreditCardNumber" class="java.lang.Boolean" isForPrompting="false">
			<parameterDescription><![CDATA[]]></parameterDescription>
			<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
		</parameter>
		<parameter name="ShowHomeCurrency" class="java.lang.Boolean" isForPrompting="false">
			<property name="show" value="Multi Currency"/>
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="FieldTitle:PaymentDate" class="java.lang.String" isForPrompting="false">
			<property name="Tab" value="Field Titles"/>
			<property name="Group" value="Payments"/>
			<property name="Sort" value="1"/>
			<parameterDescription><![CDATA[Date]]></parameterDescription>
		</parameter>
		<parameter name="FieldTitle:Payment" class="java.lang.String" isForPrompting="false">
			<property name="Tab" value="Field Titles"/>
			<property name="Group" value="Payments"/>
			<property name="Sort" value="2"/>
			<parameterDescription><![CDATA[Payment]]></parameterDescription>
		</parameter>
		<parameter name="FieldTitle:Amount" class="java.lang.String" isForPrompting="false">
			<property name="Tab" value="Field Titles"/>
			<property name="Group" value="Payments"/>
			<property name="Sort" value="3"/>
			<parameterDescription><![CDATA[Amount]]></parameterDescription>
		</parameter>
		<queryString>
			<![CDATA[SELECT posTransaction.amount, paymentMethod.name AS paymentMethod, COALESCE(posTransaction.currencyRate, 1) AS currencyRate,     COALESCE(currency.symbol,homecurrency.symbol,91) AS COALESCESYMBOL, (posTransaction.amount / COALESCE(posTransaction.currencyRate, 1)) AS currencyAmount, posTransaction.info AS reference, posTransaction.dateTime AS paymentDate, homeCurrency.symbol AS homeCurrencySymbol
FROM so
     INNER JOIN posTransaction ON so.id = posTransaction.soId
     LEFT OUTER JOIN paymentMethod ON posTransaction.paymentMethodId = paymentMethod.id
     INNER JOIN customer on so.customerid = customer.id
     LEFT OUTER JOIN currency ON customer.currencyId = currency.id
     LEFT OUTER JOIN currency AS homeCurrency ON homeCurrency.homeCurrency = 1
WHERE $P{soId} = so.id]]>
		</queryString>
		<field name="AMOUNT" class="java.lang.Double"/>
		<field name="PAYMENTMETHOD" class="java.lang.String"/>
		<field name="CURRENCYRATE" class="java.lang.Double"/>
		<field name="COALESCESYMBOL" class="java.lang.Integer"/>
		<field name="CURRENCYAMOUNT" class="java.lang.Double"/>
		<field name="REFERENCE" class="java.lang.String"/>
		<field name="PAYMENTDATE" class="java.sql.Timestamp"/>
		<field name="HOMECURRENCYSYMBOL" class="java.lang.Integer"/>
		<variable name="PriceDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_PRICE")]]></variableExpression>
		</variable>
		<variable name="DateFormat" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[(System.getProperty("REPORT_DATE_FORMAT"))]]></variableExpression>
		</variable>
		<variable name="isMultiCurrency" class="java.lang.Boolean">
			<variableExpression><![CDATA[com.evnt.eve.modules.CurrencyModule.isMultiCurrency()]]></variableExpression>
		</variable>
		<variable name="CanDisplaySymbol" class="java.lang.Boolean">
			<variableExpression><![CDATA[$F{COALESCESYMBOL} == null || $F{COALESCESYMBOL}.equals("")
 ? true
 : new java.awt.Font("Open Sans", java.awt.Font.PLAIN ,1).canDisplay(com.fbi.sdk.constants.setup.CurrencySymbolConst.getConstant($F{COALESCESYMBOL}).getSymbol().charAt(0))]]></variableExpression>
			<initialValueExpression><![CDATA[true]]></initialValueExpression>
		</variable>
		<variable name="priceDecimalNoSymbol" class="java.lang.String">
			<variableExpression><![CDATA[$V{PriceDecimal}.substring(1,$V{PriceDecimal}.length())]]></variableExpression>
		</variable>
	</subDataset>
