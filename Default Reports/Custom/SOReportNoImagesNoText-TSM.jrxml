	<queryString>
		<![CDATA[SELECT DISTINCT so.note, so.id AS recordID, company.name AS company, so.locationgroupid, sostatus.name AS sostatus,
    so.datecompleted as sodatecompleted, so.datecreated as sodatecreated, so.datefirstship as sodatefirstship,
    so.daterevision as sodaterevision, so.datelastmodified as sodatelastmodified, so.dateissued as sodateissued, so.dateexpired as sodateexpired,
    so.revisionnum, so.num AS sonum, paymentterms.name AS paymentterms,
    /* Customer info */
    COALESCE(so.customercontact,'') as customercontact, so.customerpo, so.customerid, customer.name AS customerName,
    /* Non-Currency */
    so.totalTax AS totaltax,
    so.estimatedTax,
    so.statusid,
    /* Country version */
    COALESCE(UPPER(sysProperties.sysValue), 'US') AS qbVersion,
    /* Ship To */
    so.shiptoname, so.shiptoaddress, so.shiptocity, so.shiptozip,
    shipstate.code AS shiptostate, shipcountry.name AS shiptocountry,
    /* Bill To */
    so.billtoname AS billToName, so.billtoaddress, so.billtocity, so.billtozip,
    billstate.code AS billtostate, billcountry.name AS billtocountry,
    /* Currency */
    so.currencyRate, currency.code AS currencyCode,
    COALESCE(currency.symbol,homecurrency.symbol,91) AS COALESCESYMBOL,

    SUM(soitem.unitPrice * soItem.qtyToFulfill + COALESCE(soItem.adjustAmount, 0)) AS totalprice,
    SUM(ROUND(soitem.unitPrice * soItem.qtyToFulfill + COALESCE(soItem.adjustAmount, 0), 2)) AS roundedTotalPrice,

    COALESCE(so.mcTotalTax, 0) AS currencyTaxTotal,

    CASE COALESCE(UPPER(sysProperties.sysValue), 'US')
        WHEN 'US' THEN SUM(Round((soItem.unitPrice * soItem.qtyToFulfill / so.currencyRate) + (COALESCE(soItem.adjustAmount, 0) / so.currencyRate), 2))
        WHEN 'CA' THEN SUM(Round((soItem.unitPrice * soItem.qtyToFulfill / so.currencyRate) + (COALESCE(soItem.adjustAmount, 0) / so.currencyRate), 2))
        WHEN 'AU' THEN SUM(Round((soItem.unitPrice * soItem.qtyToFulfill + soItem.adjustAmount) / so.currencyRate, 2))
        ELSE 0.0 END AS currencySubtotal,

    CASE COALESCE(UPPER(sysProperties.sysValue), 'US')
        WHEN 'US' THEN SUM((soItem.unitPrice * soItem.qtyToFulfill / so.currencyRate) + (COALESCE(soItem.adjustAmount, 0) / so.currencyRate))
        WHEN 'CA' THEN SUM((soItem.unitPrice * soItem.qtyToFulfill / so.currencyRate) + (COALESCE(soItem.adjustAmount, 0) / so.currencyRate))
        WHEN 'AU' THEN SUM((soItem.unitPrice * soItem.qtyToFulfill + soItem.adjustAmount) / so.currencyRate)
        ELSE 0.0 END AS currencySubtotalNotRounded,

    /* AU ABN */
    company.ABN,
    /* Payment Info*/
    COALESCE(paymentInfo.amount,0) AS paymentAmount, so.currencyRate,
    COALESCE(paymentInfo.amount,0)/COALESCE(so.currencyRate, 1) AS currencyPaymentAmount, homeCurrency.symbol AS homeCurrencySymbol, COALESCE(contact.datus,'') AS fax, so.phone, so.email

FROM so
    INNER JOIN customer ON so.customerid = customer.id
    INNER JOIN company ON company.id = 1
    INNER JOIN paymentterms ON so.paymenttermsid = paymentterms.id
    LEFT OUTER JOIN sostatus ON so.statusid = sostatus.id
    LEFT OUTER JOIN soitem ON so.id = soitem.soid AND soitem.typeid != 40
    LEFT JOIN product on product.id = soitem.productid
    LEFT OUTER JOIN countryconst billcountry ON billcountry.id = so.billtocountryid
    LEFT OUTER JOIN countryconst shipcountry ON shipcountry.id = so.shiptocountryid
    LEFT OUTER JOIN stateconst shipState ON so.shiptostateid = shipState.id
    LEFT OUTER JOIN stateconst billState ON so.billtostateid = billState.id
    LEFT OUTER JOIN sysProperties ON sysProperties.sysKey = 'QBVersion'
    LEFT OUTER JOIN currency ON customer.currencyId = currency.id
    LEFT OUTER JOIN currency AS homeCurrency ON homeCurrency.homeCurrency = 1
    LEFT OUTER JOIN (SELECT DISTINCT SUM(posTransaction.amount) AS amount, posTransaction.soId
                     FROM posTransaction
	 	GROUP BY posTransaction.soId) AS paymentInfo ON so.id = paymentInfo.soId
    LEFT JOIN (SELECT contact.datus, so.id AS soid
			FROM contact
			JOIN so ON so.num = $P{soNum}
			JOIN customer ON contact.accountid = customer.accountid AND customer.id = so.customerid
			WHERE contact.typeid = 40 AND contact.defaultflag = 1
			LIMIT 1) AS contact ON contact.soid = so.id


WHERE so.num = $P{soNum}

GROUP BY so.note, company.name, so.locationgroupid, so.customercontact, so.customerpo, so.customerid, so.id, so.totaltax,
    so.shiptoname, so.shiptoaddress, so.shiptocity, so.shiptozip,
    shipstate.code, shipcountry.name,
    so.billtoname, so.billtoaddress, so.billtocity, so.billtozip,
    billstate.code, billcountry.name, customer.name, currency.code, currency.symbol, so.currencyRate, sysProperties.sysValue,
    /* CA and AU */
    company.ABN, so.mcTotalTax, paymentInfo.amount, so.currencyRate, homeCurrency.symbol, fax, so.phone, so.email]]>
	</queryString>
	<field name="NOTE" class="java.lang.String"/>
	<field name="RECORDID" class="java.lang.Integer"/>
	<field name="CUSTOMERCONTACT" class="java.lang.String"/>
	<field name="CUSTOMERPO" class="java.lang.String"/>
	<field name="CUSTOMERID" class="java.lang.Integer"/>
	<field name="CUSTOMERNAME" class="java.lang.String"/>
	<field name="TOTALTAX" class="java.lang.Double"/>
	<field name="QBVERSION" class="java.lang.String"/>
	<field name="SHIPTONAME" class="java.lang.String"/>
	<field name="SHIPTOADDRESS" class="java.lang.String"/>
	<field name="SHIPTOCITY" class="java.lang.String"/>
	<field name="SHIPTOZIP" class="java.lang.String"/>
	<field name="SHIPTOSTATE" class="java.lang.String"/>
	<field name="SHIPTOCOUNTRY" class="java.lang.String"/>
	<field name="BILLTONAME" class="java.lang.String"/>
	<field name="BILLTOADDRESS" class="java.lang.String"/>
	<field name="BILLTOCITY" class="java.lang.String"/>
	<field name="BILLTOZIP" class="java.lang.String"/>
	<field name="BILLTOSTATE" class="java.lang.String"/>
	<field name="BILLTOCOUNTRY" class="java.lang.String"/>
	<field name="CURRENCYRATE" class="java.lang.Double"/>
	<field name="CURRENCYCODE" class="java.lang.String"/>
	<field name="COALESCESYMBOL" class="java.lang.Integer"/>
	<field name="TOTALPRICE" class="java.lang.Double"/>
	<field name="ROUNDEDTOTALPRICE" class="java.lang.Double"/>
	<field name="CURRENCYTAXTOTAL" class="java.lang.Double"/>
	<field name="CURRENCYSUBTOTAL" class="java.lang.Double"/>
	<field name="CURRENCYSUBTOTALNOTROUNDED" class="java.lang.Double"/>
	<field name="ABN" class="java.lang.String"/>
	<field name="PAYMENTAMOUNT" class="java.lang.Double"/>
	<field name="CURRENCYPAYMENTAMOUNT" class="java.lang.Double"/>
	<field name="HOMECURRENCYSYMBOL" class="java.lang.Integer"/>
	<field name="FAX" class="java.lang.String"/>
	<field name="PHONE" class="java.lang.String"/>
	<field name="EMAIL" class="java.lang.String"/>
	<field name="estimatedTax" class="java.lang.Double"/>
	<field name="statusID" class="java.lang.Integer"/>
	<field name="COMPANY" class="java.lang.String"/>
	<field name="LOCATIONGROUPID" class="java.lang.Integer"/>
	<field name="SOSTATUS" class="java.lang.String"/>
	<field name="SODATELASTMODIFIED" class="java.sql.Timestamp"/>
	<field name="SODATEISSUED" class="java.sql.Timestamp"/>
	<field name="SODATECOMPLETED" class="java.sql.Timestamp"/>
	<field name="SODATECREATED" class="java.sql.Timestamp"/>
	<field name="SODATEFIRSTSHIP" class="java.sql.Timestamp"/>
	<field name="SODATEREVISION" class="java.sql.Timestamp"/>
	<field name="REVISIONNUM" class="java.lang.Integer"/>
	<field name="SONUM" class="java.lang.String"/>
	<field name="paymentterms" class="java.lang.String"/>
	<field name="SODATEEXPIRED" class="java.sql.Timestamp"/>
	<variable name="CustomerContact" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[$F{CUSTOMERCONTACT} != null && !$F{CUSTOMERCONTACT}.equals("") ?
    ($P{FieldTitle:Contact}.equals("%") ? "Contact: " : $P{FieldTitle:Contact} + " ") + $F{CUSTOMERCONTACT} :
    ""]]></variableExpression>
	</variable>
	<variable name="CustomerPO" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[$F{CUSTOMERPO} != null && !$F{CUSTOMERPO}.equals("") ?
    ($P{FieldTitle:PONumber}.equals("%") ? "PO Number: " : $P{FieldTitle:PONumber} + " ") + $F{CUSTOMERPO} :
    ""]]></variableExpression>
	</variable>
	<variable name="FooterMessage" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[System.getProperty("SO Notice")]]></variableExpression>
	</variable>
	<variable name="BarcodesHaveDI" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[System.getProperty("Barcodes have DI")]]></variableExpression>
	</variable>
	<variable name="EstimateTitle" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[System.getProperty("Estimate Title")]]></variableExpression>
	</variable>
	<variable name="PriceDecimal" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_PRICE")]]></variableExpression>
	</variable>
	<variable name="QtyDecimal" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_QTY")]]></variableExpression>
	</variable>
	<variable name="CostDecimal" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_COST")]]></variableExpression>
	</variable>
	<variable name="TotalsDecimal" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_TOTAL")]]></variableExpression>
	</variable>
	<variable name="isMultiCurrency" class="java.lang.Boolean">
		<variableExpression><![CDATA[com.evnt.eve.modules.CurrencyModule.isMultiCurrency()]]></variableExpression>
	</variable>
	<variable name="currencySubtotal" class="java.lang.Double">
		<variableExpression><![CDATA[$V{TotalsDecimal}.equals("$ #,##0.00") || $V{TotalsDecimal}.equals("$ #,##0.##") ?
$F{CURRENCYSUBTOTAL} :
$F{CURRENCYSUBTOTALNOTROUNDED}]]></variableExpression>
	</variable>
	<variable name="subTotal" class="java.lang.Double">
		<variableExpression><![CDATA[$V{TotalsDecimal}.equals("$ #,##0.00") || $V{TotalsDecimal}.equals("$ #,##0.##") ?
$F{ROUNDEDTOTALPRICE} :
$F{TOTALPRICE}]]></variableExpression>
	</variable>
	<variable name="paymentTotal" class="java.lang.Double">
		<variableExpression><![CDATA[($F{PAYMENTAMOUNT} == null) ? 0 : $F{PAYMENTAMOUNT}]]></variableExpression>
		<initialValueExpression><![CDATA[]]></initialValueExpression>
	</variable>
	<variable name="CanDisplaySymbol" class="java.lang.Boolean">
		<variableExpression><![CDATA[$F{COALESCESYMBOL} == null || $F{COALESCESYMBOL}.equals("") || new java.awt.Font("Open Sans", java.awt.Font.PLAIN ,1).canDisplay(com.fbi.sdk.constants.setup.CurrencySymbolConst.getConstant($F{COALESCESYMBOL}).getSymbol().charAt(0))]]></variableExpression>
		<initialValueExpression><![CDATA[true]]></initialValueExpression>
	</variable>
	<variable name="totalsDecimalNoSymbol" class="java.lang.String">
		<variableExpression><![CDATA[$V{TotalsDecimal}.substring(1,$V{TotalsDecimal}.length())]]></variableExpression>
	</variable>
	<variable name="priceDecimalNoSymbol" class="java.lang.String">
		<variableExpression><![CDATA[$V{PriceDecimal}.substring(1,$V{PriceDecimal}.length())]]></variableExpression>
	</variable>
	<variable name="taxTotal" class="java.lang.Double">
		<variableExpression><![CDATA[$P{AddTaxIntegrationEstimatedTaxToTotal} && $F{statusID} < 60
    ? !$V{isMultiCurrency}
        ? $F{estimatedTax}
        : com.fbi.sdk.constants.setup.CurrencySymbolConst.getFormattedCurrency($F{COALESCESYMBOL}, $F{estimatedTax}/$F{CURRENCYRATE}, "$ #,##0.00")
: !$V{isMultiCurrency} ? $F{TOTALTAX} :
    $F{COALESCESYMBOL} == null
    ? com.fbi.sdk.constants.setup.CurrencySymbolConst.getFormattedCurrency($F{HOMECURRENCYSYMBOL}, $F{TOTALTAX}, "$ #,##0.00")
  : $V{CanDisplaySymbol}
    ? com.fbi.sdk.constants.setup.CurrencySymbolConst.getFormattedCurrency($F{COALESCESYMBOL}, $F{CURRENCYTAXTOTAL}, "$ #,##0.00")
    : new DecimalFormat("#,##0.00").format($F{CURRENCYTAXTOTAL})]]></variableExpression>
	</variable>
	<variable name="homeCurrencyTaxTotal" class="java.lang.Double">
		<variableExpression><![CDATA[$P{AddTaxIntegrationEstimatedTaxToTotal} && $F{statusID} < 60
    ? com.fbi.sdk.constants.setup.CurrencySymbolConst.getFormattedCurrency($F{HOMECURRENCYSYMBOL},$F{estimatedTax}, $V{TotalsDecimal})
: $F{COALESCESYMBOL} == null || $V{isAustralia}
 ? com.fbi.sdk.constants.setup.CurrencySymbolConst.getFormattedCurrency($F{HOMECURRENCYSYMBOL}, $F{TOTALTAX}, $V{TotalsDecimal})
 : com.fbi.sdk.constants.setup.CurrencySymbolConst.getFormattedCurrency($F{HOMECURRENCYSYMBOL}, $F{CURRENCYTAXTOTAL} * $F{CURRENCYRATE}, $V{TotalsDecimal})]]></variableExpression>
	</variable>
	<variable name="DateFormat" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[(System.getProperty("REPORT_DATE_FORMAT"))]]></variableExpression>
	</variable>
	<variable name="OrderNumber" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[$V{BarcodesHaveDI} == null ?
    $F{SONUM} :
	$V{BarcodesHaveDI}.equals("true") ?
        "" + $F{SONUM} :
        $F{SONUM}]]></variableExpression>
	</variable>
	<variable name="isAustralia" class="java.lang.Boolean">
		<variableExpression><![CDATA[com.fbi.util.PropertyUtil.isAu()]]></variableExpression>
	</variable>
	<variable name="isUnitedStates" class="java.lang.Boolean">
		<variableExpression><![CDATA[!(com.evnt.eve.modules.AccountingModule.isInternational())]]></variableExpression>
	</variable>
	<variable name="isCanada" class="java.lang.Boolean">
		<variableExpression><![CDATA[com.fbi.util.PropertyUtil.isCaOrInternational()]]></variableExpression>
	</variable>
	<group name="CustomerAddresses">
		<groupExpression><![CDATA[1]]></groupExpression>
		<groupHeader>
			<band height="81" splitType="Stretch">
				<textField isStretchWithOverflow="true" pattern="" isBlankWhenNull="true">
					<reportElement key="textField-21" mode="Transparent" x="0" y="17" width="265" height="44" forecolor="#000000" backcolor="#FFFFFF" uuid="1c8b1487-cd4d-4c9a-8447-a3e0c5c09f67"/>
					<box leftPadding="3"/>
					<textElement verticalAlignment="Top" rotation="None">
						<font fontName="Open Sans" size="10" isItalic="false"/>
						<paragraph lineSpacing="Single"/>
					</textElement>
					<textFieldExpression><![CDATA[$F{CUSTOMERNAME}+ "\n" +
($F{CUSTOMERNAME}.equals($F{BILLTONAME}) ? "" : $F{BILLTONAME}) + "\n" +
($F{BILLTOADDRESS} != null ? $F{BILLTOADDRESS} + "\n" : "") +
($F{BILLTOCITY} != null ? $F{BILLTOCITY} : "") +
	($F{BILLTOSTATE} != null ? ", " + $F{BILLTOSTATE} + "  " : "  ") +
	($F{BILLTOZIP} != null ? $F{BILLTOZIP} : "") +
( "\n" + $F{BILLTOCOUNTRY}) +
($P{ShowBillToPhoneNumber} ? "\n" + "Phone: " + $F{PHONE} : "") +
($P{ShowBillToEmail} ? "\n" + "Email: " + $F{EMAIL} : "") +
($P{ShowBillToFax} ? "\n" + "Fax: " + $F{FAX} : "")]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="true" pattern="" isBlankWhenNull="true">
					<reportElement key="textField-5" positionType="Float" mode="Transparent" x="270" y="63" width="265" height="11" forecolor="#000000" backcolor="#FFFFFF" uuid="fe0772ca-27d4-4969-9206-439c7df37011">
						<printWhenExpression><![CDATA[!(($P{ShowContact} == false || $F{CUSTOMERCONTACT}.equals(""))
    &&
($P{Column:PONumber} == true || $F{CUSTOMERPO}.equals("")))]]></printWhenExpression>
					</reportElement>
					<box leftPadding="3"/>
					<textElement verticalAlignment="Middle" rotation="None">
						<font fontName="Open Sans" size="10" isItalic="false"/>
						<paragraph lineSpacing="Single"/>
					</textElement>
					<textFieldExpression><![CDATA[(($P{ShowContact} == true && !$F{CUSTOMERCONTACT}.equals(""))
    ? $V{CustomerContact}
    : "")]]></textFieldExpression>
				</textField>
				<textField>
					<reportElement key="staticText-1" mode="Opaque" x="270" y="0" width="265" height="17" forecolor="#000000" backcolor="#EAEAEA" uuid="c43a7ad1-900b-41d8-bdc4-b2d4bb50cca9"/>
					<box leftPadding="3"/>
					<textElement verticalAlignment="Bottom" rotation="None" markup="none">
						<font fontName="Open Sans" size="10" isBold="true"/>
						<paragraph lineSpacing="Single"/>
					</textElement>
					<textFieldExpression><![CDATA[$P{FieldTitle:ShipTo}.equals("%") ? "Deliver To:" : $P{FieldTitle:ShipTo}]]></textFieldExpression>
				</textField>
				<textField>
					<reportElement key="staticText-2" mode="Opaque" x="0" y="0" width="265" height="17" forecolor="#000000" backcolor="#EAEAEA" uuid="0cc88809-f6f4-428c-906a-6412d4aa11c7"/>
					<box leftPadding="3"/>
					<textElement verticalAlignment="Bottom" rotation="None" markup="none">
						<font fontName="Open Sans" size="10" isBold="true"/>
						<paragraph lineSpacing="Single"/>
					</textElement>
					<textFieldExpression><![CDATA[$P{FieldTitle:BillTo}.equals("%") ? "Invoice To:" : $P{FieldTitle:BillTo}]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="true" pattern="" isBlankWhenNull="true">
					<reportElement key="textField-5" mode="Transparent" x="270" y="17" width="265" height="44" forecolor="#000000" backcolor="#FFFFFF" uuid="b9d722a1-674b-4312-8da5-0dae8abed027">
						<printWhenExpression><![CDATA[$F{SHIPTONAME} != null]]></printWhenExpression>
					</reportElement>
					<box leftPadding="3"/>
					<textElement verticalAlignment="Top" rotation="None">
						<font fontName="Open Sans" size="10" isBold="false" isItalic="false"/>
						<paragraph lineSpacing="Single"/>
					</textElement>
					<textFieldExpression><![CDATA[$F{CUSTOMERNAME}+ "\n" +
($F{CUSTOMERNAME}.equals($F{SHIPTONAME}) ? "" : $F{SHIPTONAME}) + "\n" +
($F{SHIPTOADDRESS} != null ? $F{SHIPTOADDRESS} + "\n" : "") +
($F{SHIPTOCITY} != null ? $F{SHIPTOCITY} : "") +
    ($F{SHIPTOSTATE} != null ? ", " + $F{SHIPTOSTATE} + "  " : "  ") +
    ($F{SHIPTOZIP} != null ? $F{SHIPTOZIP} : "") +
($P{ShowCountry} ? "\n" + $F{SHIPTOCOUNTRY} : "")]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="true" pattern="" isBlankWhenNull="true">
					<reportElement key="textField-5" positionType="Float" mode="Transparent" x="1" y="63" width="265" height="11" isRemoveLineWhenBlank="true" forecolor="#000000" backcolor="#FFFFFF" uuid="b14d2047-00ad-46c8-9872-95a04e423348">
						<printWhenExpression><![CDATA[com.fbi.util.PropertyUtil.isCaOrInternational()]]></printWhenExpression>
					</reportElement>
					<box leftPadding="3"/>
					<textElement verticalAlignment="Middle" rotation="None">
						<font fontName="Open Sans" size="10" isItalic="false"/>
						<paragraph lineSpacing="Single"/>
					</textElement>
					<textFieldExpression><![CDATA[($P{FieldTitle:GST/HST}.equals("%") ? "GST/HST: " : $P{FieldTitle:GST/HST} + " ") + (($F{ABN} == null) ? "" : $F{ABN})]]></textFieldExpression>
				</textField>
			</band>
		</groupHeader>
