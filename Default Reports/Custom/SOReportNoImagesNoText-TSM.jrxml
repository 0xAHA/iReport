		</parameter>
		<queryString>
			<![CDATA[SELECT DISTINCT
    SOITEM.ID AS ITEMID,
    SOITEM.SOLINEITEM,
    SOITEMTYPE.NAME AS ITEMTYPE,
    SOITEM.TYPEID,
    SOITEM.CUSTOMERPARTNUM,
    SOITEM.PRODUCTNUM,
    SOITEM.DESCRIPTION,
    SOITEM.NOTE,
    SOITEM.QTYPICKED,
    COALESCE(SOITEM.QTYTOFULFILL,0) AS QTYTOFULFILL,
    UOM.CODE AS UOMCODE,
    COALESCE(SOITEM.ADJUSTAMOUNT,0) AS ADJUSTAMOUNT,
    MOITEM.SOITEMID AS SOITEMTOMOITEMID,
    SOITEM.DATELASTFULFILLMENT,
    SOITEM.DATESCHEDULEDFULFILLMENT,
    SOITEM.REVLEVEL,
    SOITEMSTATUS.NAME AS ITEMSTATUS,
    SOITEM.SHOWITEMFLAG,
    OBJECTTOOBJECT.RECORDID2 AS KITPARENTLINE,
    SO.STATUSID,
    PRODUCT.DETAILS AS PRODUCT_DETAILS,
    PRODUCT.ID AS PRODUCTID,

/* HOME CURRENCY */
    COALESCE(SOITEM.UNITPRICE,0)  + (COALESCE(SOITEM.ADJUSTAMOUNT, 0) / IF(soitem.QTYTOFULFILL = 0,1,soitem.qtyTofulfill))AS HOMECURRENCYUNITPRICE,
    COALESCE(SOITEM.TOTALPRICE,0) AS HOMECURRENCYTOTALPRICE,
    ROUND(SOITEM.UNITPRICE * SOITEM.QTYTOFULFILL,2) + COALESCE(SOITEM.ADJUSTAMOUNT,0) AS HOMECURRENCYEXTPRICE,
    SOITEM.UNITPRICE * SOITEM.QTYTOFULFILL + COALESCE(SOITEM.ADJUSTAMOUNT,0) AS HOMECURRENCYEXTPRICENOTROUNDED,
    IF(COALESCE(UPPER(SYSPROPERTIES.SYSVALUE), 'US') = 'US', 0.0, ROUND(SOITEM.TAXRATE * SOITEM.TOTALPRICE,2)) AS HOMECURRENCYSOITEMTAX,
    IF(COALESCE(UPPER(SYSPROPERTIES.SYSVALUE), 'US') = 'US',0.0, SOITEM.TAXRATE * SOITEM.TOTALPRICE) AS HOMECURRENCYNONROUNDEDSOITEMTAX,
    SO.TOTALTAX AS HOMECURRENCYTAXTOTAL,
    HOMECURRENCY.SYMBOL AS HOMECURRENCYSYMBOL,
    COALESCE(PAYMENTINFO.AMOUNT,0) AS HOMECURRENCYPAYMENTAMOUNT,
    HOMECURRENCY.CODE AS HOMECURRENCYCODE,

/* CURRENCY */
    CURRENCY.CODE AS CURRENCYCODE,
    HOMECURRENCY.CODE AS HOMECURRENCYCODE,
    COALESCE(currency.symbol,homecurrency.symbol,91) AS COALESCESYMBOL,
    (SOITEM.UNITPRICE / COALESCE(SO.CURRENCYRATE, 1) + ((COALESCE(SOITEM.ADJUSTAMOUNT, 0) /
            IF(soitem.QTYTOFULFILL = 0,1,soitem.qtyTofulfill)) / SO.CURRENCYRATE)) AS CURRENCYUNITPRICE,

    soitem.totalprice / COALESCE(so.currencyRate,0) AS CURRENCYTOTALPRICE,
    CASE COALESCE(UPPER(SYSPROPERTIES.SYSVALUE), 'US')
        WHEN 'US' THEN (ROUND(SOITEM.UNITPRICE * SOITEM.QTYTOFULFILL,2) / SO.CURRENCYRATE) + (COALESCE(SOITEM.ADJUSTAMOUNT, 0) / SO.CURRENCYRATE)
        WHEN 'CA' THEN (ROUND(SOITEM.UNITPRICE * SOITEM.QTYTOFULFILL,2) / SO.CURRENCYRATE) + (COALESCE(SOITEM.ADJUSTAMOUNT, 0) / SO.CURRENCYRATE)
        WHEN 'AU' THEN (ROUND(SOITEM.UNITPRICE * SOITEM.QTYTOFULFILL,2) + SOITEM.ADJUSTAMOUNT) / SO.CURRENCYRATE
        ELSE 0.0 END AS CURRENCYEXTPRICE,
    CASE COALESCE(UPPER(SYSPROPERTIES.SYSVALUE), 'US')
        WHEN 'US' THEN (SOITEM.UNITPRICE * SOITEM.QTYTOFULFILL / SO.CURRENCYRATE) + (COALESCE(SOITEM.ADJUSTAMOUNT, 0) / SO.CURRENCYRATE)
        WHEN 'CA' THEN (SOITEM.UNITPRICE * SOITEM.QTYTOFULFILL / SO.CURRENCYRATE) + (COALESCE(SOITEM.ADJUSTAMOUNT, 0) / SO.CURRENCYRATE)
        WHEN 'AU' THEN ((SOITEM.UNITPRICE * SOITEM.QTYTOFULFILL + SOITEM.ADJUSTAMOUNT) / SO.CURRENCYRATE)
        ELSE 0.0 END AS CURRENCYEXTPRICENOTROUNDED,
    IF(COALESCE(UPPER(SYSPROPERTIES.SYSVALUE), 'US') = 'US',0.0, ROUND(SOITEM.TAXRATE * SOITEM.TOTALPRICE/COALESCE(SO.CURRENCYRATE, 1),2)) AS CURRENCYSOITEMTAX,
    IF(COALESCE(UPPER(SYSPROPERTIES.SYSVALUE), 'US') = 'US',0.0, SOITEM.TAXRATE * SOITEM.TOTALPRICE/COALESCE(SO.CURRENCYRATE, 1)) AS CURRENCYNONROUNDEDSOITEMTAX,
    IF(COALESCE(so.mctotaltax,0) = 0, COALESCE(so.totaltax / so.currencyrate, 0),so.mctotaltax) AS CURRENCYTAXTOTAL,
    COALESCE(PAYMENTINFO.AMOUNT,0)/COALESCE(SO.CURRENCYRATE, 1) AS CURRENCYPAYMENTAMOUNT,
    COALESCE(SO.CURRENCYRATE, 1) AS CURRENCYRATE, ordertax.name AS ordertaxname,

/* CA AND AU TAX CODE */
    TAXRATE.CODE AS ITEMTAXCODE,
    SO.ESTIMATEDTAX,

    coalesce(collapsedKitInfo.totalprice,0) as kitTotal,

    $P!{CustomField:Item1} AS itemcf1,
    $P!{CustomField:Item2} AS itemcf2,
    $P!{CustomField:Item3} AS itemcf3,
    CAST(CustomFieldByName(So.CustomFields,'Deposit Amount') as DECIMAL(10,5)) as DepositAmount

FROM so
    INNER JOIN soitem ON so.id = soitem.soid
    LEFT JOIN product on product.id = soitem.productid
    INNER JOIN soitemtype ON soitem.typeid = soitemtype.id
    INNER JOIN soitemstatus ON soitem.statusid = soitemstatus.id
    INNER JOIN uom ON soitem.uomid = uom.id
    INNER JOIN customer ON so.customerid = customer.id
    LEFT OUTER JOIN taxRate ON soItem.taxId = taxRate.id
    LEFT OUTER JOIN objecttoobject ON soitem.id = objecttoobject.recordid1 AND objecttoobject.typeid = 30
    LEFT OUTER JOIN moitem ON soitem.id = moitem.soitemid
    LEFT OUTER JOIN sysProperties ON sysProperties.sysKey = 'QBVersion'
    LEFT OUTER JOIN currency ON so.currencyid = currency.id
    LEFT OUTER JOIN currency AS homeCurrency ON homeCurrency.homeCurrency = 1
    LEFT OUTER JOIN (SELECT DISTINCT SUM(posTransaction.amount) AS amount, posTransaction.soId
                     FROM posTransaction
	 	GROUP BY posTransaction.soId) AS paymentInfo ON so.id = paymentInfo.soId
    LEFT JOIN taxrate ordertax ON so.taxrateid = ordertax.id
    LEFT OUTER JOIN (select sum(totalprice) as totalPrice, objecttoobject.recordid2 as parentID
                    from soitem
                    join objecttoobject on objecttoobject.recordid1 = soitem.id and objecttoobject.typeid = 30
                    where soitem.showitemflag = 0
                    group by parentID) as collapsedKitInfo on collapsedKitInfo.parentID = soitem.id and soitem.typeid = 80 and soitem.totalprice = 0

WHERE so.id = $P{soId}
AND soitem.showitemflag = 1
AND IF($P{ShowZeroPriceItems} = false, (soitem.unitprice + soitem.adjustamount) <> 0, 1 = 1)

ORDER BY soitem.solineitem]]>
		</queryString>
		<field name="ITEMID" class="java.lang.Integer"/>
		<field name="SOLINEITEM" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="ITEMTYPE" class="java.lang.String"/>
		<field name="TYPEID" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="CUSTOMERPARTNUM" class="java.lang.String">
