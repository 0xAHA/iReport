		</field>
		<field name="DESCRIPTION" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="NOTE" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="QTYPICKED" class="java.lang.Double">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="QTYTOFULFILL" class="java.lang.Double">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="UOMCODE" class="java.lang.String"/>
		<field name="ADJUSTAMOUNT" class="java.lang.Double">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="SOITEMTOMOITEMID" class="java.lang.Integer"/>
		<field name="DATELASTFULFILLMENT" class="java.sql.Timestamp">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="DATESCHEDULEDFULFILLMENT" class="java.sql.Timestamp">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="REVLEVEL" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="ITEMSTATUS" class="java.lang.String"/>
		<field name="SHOWITEMFLAG" class="java.lang.Boolean">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="KITPARENTLINE" class="java.lang.Integer"/>
