	<style name="center" hAlign="Center" vAlign="Middle"/>
	<parameter name="REPORTDESCRIPTION" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["Product Barcodes for 2x4 Avery 8163 Labels"]]></defaultValueExpression>
	</parameter>
	<parameter name="productNum" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="ShowOtherProduct" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Boolean(false)]]></defaultValueExpression>
	</parameter>
	<parameter name="Skip" class="java.lang.Integer" isForPrompting="false">
		<defaultValueExpression><![CDATA[0]]></defaultValueExpression>
	</parameter>
	<parameter name="Count" class="java.lang.Integer" isForPrompting="false">
		<defaultValueExpression><![CDATA[90]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT DISTINCT
  product.num AS prodNum,
  part.num AS partNum,
  product.description AS DESCRIPTION,
  CASE WHEN p.id is not null THEN product.price * (1 + p.paPercent)
    ELSE product.price END * (1 + IFNULL(taxrate.rate, 0)) AS priceIncGST,
  uom.name AS UOM,
  other_product.price AS priceSingleIncGST,
  other_product.case_qty AS case_qty,
  other_product.prodNum AS other_prodNum,
  other_product.uom AS other_UOM

FROM product
JOIN part ON part.id = product.partid and product.uomid = part.uomid
LEFT JOIN taxrate ON product.taxId = taxrate.id
LEFT JOIN UOM ON product.uomId = uom.id

/* bulk weirdness */
join producttotree ptt on ptt.productid = product.id
join producttree pt on pt.id = ptt.producttreeid
left join producttree pt1 on pt1.id = pt.parentid and pt1.id != 1
left join producttree pt2 on pt2.id = pt1.parentid and pt2.id != 1
left join producttree pt3 on pt3.id = pt2.parentid and pt3.id != 1
left join producttree pt4 on pt4.id = pt3.parentid and pt4.id != 1
left join producttree pt5 on pt5.id = pt4.parentid and pt5.id != 1
/* PR id 11 is the Bulk POS pricing */
left join pricingrule p on p.id = 11 and p.productinclid = coalesce(pt5.id,pt4.id,pt3.id,pt2.id,pt1.id,pt.id)

LEFT JOIN (
    SELECT
      product.partid,
      product.uomid,
      product.num AS prodNum,
      CASE WHEN p.id is not null THEN product.price * (1 + p.paPercent)
          ELSE product.price END * (1 + IFNULL(taxrate.rate, 0)) AS price,
      uc.factor AS case_qty,
      uom.name AS uom
    FROM product
    JOIN taxrate ON taxrate.id = product.taxid
    JOIN part ON part.id = product.partid
    LEFT JOIN uomconversion uc ON uc.touomid = part.uomid AND uc.fromuomid = product.uomid
    LEFT JOIN uom ON product.uomid = uom.id
    /* single weirdness */
    join producttotree ptt on ptt.productid = product.id
    join producttree pt on pt.id = ptt.producttreeid
    left join producttree pt1 on pt1.id = pt.parentid and pt1.id != 1
    left join producttree pt2 on pt2.id = pt1.parentid and pt2.id != 1
    left join producttree pt3 on pt3.id = pt2.parentid and pt3.id != 1
    left join producttree pt4 on pt4.id = pt3.parentid and pt4.id != 1
    left join producttree pt5 on pt5.id = pt4.parentid and pt5.id != 1
    /* PR id 4 is the Single POS pricing */
    left join pricingrule p on p.id = 4 and p.productinclid = coalesce(pt5.id,pt4.id,pt3.id,pt2.id,pt1.id,pt.id)
    WHERE product.activeflag = 1
) AS other_product ON other_product.partid = part.id
    AND other_product.uomid != product.uomid

WHERE product.id > 0
  AND product.activeflag = 1
  AND UPPER(product.num) LIKE UPPER($P{productNum})
ORDER BY 1
LIMIT $P!{Count} OFFSET $P!{Skip}]]>
	</queryString>
