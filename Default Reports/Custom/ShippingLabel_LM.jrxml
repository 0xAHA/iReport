	</field>
	<background>
		<band splitType="Stretch"/>
	</background>
	<detail>
		<band height="555" splitType="Stretch">
			<textField>
				<reportElement x="0" y="45" width="802" height="90" forecolor="#FF0000" uuid="a6eeaab4-ede1-4732-8c8a-42dcdc1f1c14"/>
				<textElement textAlignment="Center" markup="styled">
					<font size="48" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{customerpo}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="135" width="802" height="90" uuid="2670a1eb-c3c1-45ff-a84e-4307b74e7e56"/>
