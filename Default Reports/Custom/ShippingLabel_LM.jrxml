<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ShippingLabel_LM" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="7a534f11-b95b-481d-81b5-ca5c788289a5">
	<property name="ireport.zoom" value="0.9090909090909091"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="shipID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT DISTINCT
    so.note,
    so.id AS recordID,
    company.name AS company,
    so.locationgroupid,
    sostatus.name AS sostatus,
    so.datecompleted AS sodatecompleted,
    so.datecreated AS sodatecreated,
    so.datefirstship AS sodatefirstship,
    so.daterevision AS sodaterevision,
    so.datelastmodified AS sodatelastmodified,
    so.dateissued AS sodateissued,
    so.revisionnum,
    so.num AS sonum,
    so.paymentlink,

    /* Customer info */
    COALESCE(so.customercontact,'') AS customercontact,
    so.customerpo,
    so.customerid,
    customer.name AS customerName,

    /* Non-Currency */
    so.totalTax AS totaltax,
    so.estimatedTax,
    so.statusid,

    /* Country version */
    COALESCE(UPPER(sysProperties.sysValue), 'US') AS qbVersion,

    /* Ship To */
    so.shiptoname,
    so.shiptoaddress,
    so.shiptocity,
    so.shiptozip,
    shipstate.code AS shiptostate,
    shipcountry.name AS shiptocountry,

    /* Bill To */
    so.billtoname AS billToName,
    so.billtoaddress,
    so.billtocity,
    so.billtozip,
    billstate.code AS billtostate,
    billcountry.name AS billtocountry,

    /* Currency */
    so.currencyRate,
    currency.code AS currencyCode,
    COALESCE(currency.symbol, homecurrency.symbol, 91) AS COALESCESYMBOL,

    SUM(soitem.unitPrice * soItem.qtyToFulfill + COALESCE(soItem.adjustAmount, 0)) AS totalprice,
    SUM(ROUND(soitem.unitPrice * soItem.qtyToFulfill + COALESCE(soItem.adjustAmount, 0), 2)) AS roundedTotalPrice,

    COALESCE(so.mcTotalTax, 0) AS currencyTaxTotal,

    CASE COALESCE(UPPER(sysProperties.sysValue), 'US')
        WHEN 'US' THEN SUM(ROUND((soItem.unitPrice * soItem.qtyToFulfill / so.currencyRate) + (COALESCE(soItem.adjustAmount, 0) / so.currencyRate), 2))
        WHEN 'CA' THEN SUM(ROUND((soItem.unitPrice * soItem.qtyToFulfill / so.currencyRate) + (COALESCE(soItem.adjustAmount, 0) / so.currencyRate), 2))
        WHEN 'AU' THEN SUM(ROUND((soItem.unitPrice * soItem.qtyToFulfill + soItem.adjustAmount) / so.currencyRate, 2))
        ELSE 0.0
    END AS currencySubtotal,

    CASE COALESCE(UPPER(sysProperties.sysValue), 'US')
        WHEN 'US' THEN SUM((soItem.unitPrice * soItem.qtyToFulfill / so.currencyRate) + (COALESCE(soItem.adjustAmount, 0) / so.currencyRate))
        WHEN 'CA' THEN SUM((soItem.unitPrice * soItem.qtyToFulfill / so.currencyRate) + (COALESCE(soItem.adjustAmount, 0) / so.currencyRate))
        WHEN 'AU' THEN SUM((soItem.unitPrice * soItem.qtyToFulfill + soItem.adjustAmount) / so.currencyRate)
        ELSE 0.0
    END AS currencySubtotalNotRounded,

    /* AU ABN */
    company.ABN,

    /* Payment Info */
    COALESCE(paymentInfo.amount, 0) AS paymentAmount,
    so.currencyRate,
    COALESCE(paymentInfo.amount, 0) / COALESCE(so.currencyRate, 1) AS currencyPaymentAmount,
    homeCurrency.symbol AS homeCurrencySymbol,
    COALESCE(contact.datus, '') AS fax,
    so.phone,
    so.email,

    /* Ship Info */
    ship.id AS shipID,
    ship.ordertypeid AS ordertype

FROM so
    INNER JOIN ship ON ship.soid = so.id
    INNER JOIN customer ON so.customerid = customer.id
    INNER JOIN company ON company.id = 1
    LEFT OUTER JOIN sostatus ON so.statusid = sostatus.id
    LEFT OUTER JOIN soitem ON so.id = soitem.soid AND soitem.typeid != 40
    LEFT OUTER JOIN countryconst billcountry ON billcountry.id = so.billtocountryid
    LEFT OUTER JOIN countryconst shipcountry ON shipcountry.id = so.shiptocountryid
    LEFT OUTER JOIN stateconst shipState ON so.shiptostateid = shipState.id
    LEFT OUTER JOIN stateconst billState ON so.billtostateid = billState.id
    LEFT OUTER JOIN sysProperties ON sysProperties.sysKey = 'QBVersion'
    LEFT OUTER JOIN currency ON customer.currencyId = currency.id
    LEFT OUTER JOIN currency AS homeCurrency ON homeCurrency.homeCurrency = 1
    LEFT OUTER JOIN (
        SELECT DISTINCT SUM(posTransaction.amount) AS amount, posTransaction.soId
        FROM posTransaction
        GROUP BY posTransaction.soId
    ) AS paymentInfo ON so.id = paymentInfo.soId
    LEFT JOIN (
        SELECT contact.datus, so.id AS soid
        FROM contact
        JOIN customer ON contact.accountid = customer.accountid
        JOIN so ON customer.id = so.customerid
        WHERE contact.typeid = 40 AND contact.defaultflag = 1
        LIMIT 1
    ) AS contact ON contact.soid = so.id

WHERE ship.id = $P{shipID}

GROUP BY
    so.note, company.name, so.locationgroupid, so.customercontact, so.customerpo,
    so.customerid, so.id, so.totalTax, so.shiptoname, so.shiptoaddress,
    so.shiptocity, so.shiptozip, shipstate.code, shipcountry.name, so.billtoname,
    so.billtoaddress, so.billtocity, so.billtozip, billstate.code, billcountry.name,
    customer.name, currency.code, currency.symbol, so.currencyRate, sysProperties.sysValue,
    company.ABN, so.mcTotalTax, paymentInfo.amount, so.currencyRate,
    homeCurrency.symbol, fax, so.phone, so.email, ship.id, ship.ordertypeid]]>
	</queryString>
