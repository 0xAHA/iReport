				<textFieldExpression><![CDATA[$F{shiptoaddress} + "\n" +
$F{shiptocity} + " " + $F{shiptostate} + " " + $F{shiptozip}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
</jasperReport>
