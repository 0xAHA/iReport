<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Monthly Box Rec Report - 2025" pageWidth="2475" pageHeight="842" columnWidth="2435" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="46d58ae2-4ce3-4c01-b5a5-8e4bd2147711">
	<property name="ireport.zoom" value="0.8264462809917372"/>
	<property name="ireport.x" value="844"/>
	<property name="ireport.y" value="0"/>
	<queryString>
		<![CDATA[WITH
params AS (
  SELECT
    CAST('2025-01-01' AS DATE) AS yr_start,
    CAST('2026-01-01' AS DATE) AS yr_end
),

il_2025 AS (
  SELECT
      il.partid,
      MONTH(il.datecreated) AS m,
      SUM(il.changeqty)     AS change_qty
  FROM inventorylog il
  JOIN params p
    ON il.datecreated >= p.yr_start
   AND il.datecreated <  p.yr_end
  WHERE il.typeid = 64
  GROUP BY il.partid, MONTH(il.datecreated)
),

opening AS (
  SELECT partid, qtyonhand AS start_qty
  FROM (
    SELECT
        il.partid,
        il.qtyonhand,
        ROW_NUMBER() OVER (
          PARTITION BY il.partid
          ORDER BY il.datecreated DESC, il.id DESC
        ) AS rn
    FROM inventorylog il
    JOIN params p
      ON il.datecreated < p.yr_start
  ) t
  WHERE rn = 1
),


ti_year AS (
  SELECT
      t.partid,
      SUM(CASE
            WHEN tv.infoFormatted >= '2025-01-01'
             AND tv.infoFormatted <  '2026-01-01'
            THEN t.qty ELSE 0
          END) AS qty_for_destruc_dec_31
  FROM tag t
  JOIN tagtrackingview tv
    ON tv.tagid = t.id
   AND tv.typeID = 30
  WHERE tv.infoFormatted >= '2025-01-01'
    AND tv.infoFormatted <  '2026-01-01'
  GROUP BY t.partid
)

SELECT
    p.num         AS part_num,
    p.description AS part_description,
    COALESCE(o.start_qty, 0) AS start_qty,
    COALESCE(SUM(CASE WHEN i.m =  1 THEN i.change_qty END), 0) AS JAN,
    COALESCE(SUM(CASE WHEN i.m =  2 THEN i.change_qty END), 0) AS FEB,
    COALESCE(SUM(CASE WHEN i.m =  3 THEN i.change_qty END), 0) AS MAR,
    COALESCE(SUM(CASE WHEN i.m =  4 THEN i.change_qty END), 0) AS APR,
    COALESCE(SUM(CASE WHEN i.m =  5 THEN i.change_qty END), 0) AS MAY,
    COALESCE(SUM(CASE WHEN i.m =  6 THEN i.change_qty END), 0) AS JUN,
    COALESCE(SUM(CASE WHEN i.m =  7 THEN i.change_qty END), 0) AS JUL,
    COALESCE(SUM(CASE WHEN i.m =  8 THEN i.change_qty END), 0) AS AUG,
    COALESCE(SUM(CASE WHEN i.m =  9 THEN i.change_qty END), 0) AS SEP,
    COALESCE(SUM(CASE WHEN i.m = 10 THEN i.change_qty END), 0) AS OCT,
    COALESCE(SUM(CASE WHEN i.m = 11 THEN i.change_qty END), 0) AS NOV,
    COALESCE(SUM(CASE WHEN i.m = 12 THEN i.change_qty END), 0) AS `DEC`,

    COALESCE(ti.qty_for_destruc_dec_31, 0) AS qty_for_destruc_dec_31
FROM part p
LEFT JOIN il_2025 i  ON i.partid = p.id
LEFT JOIN opening o  ON o.partid = p.id
LEFT JOIN ti_year ti ON ti.partid = p.id
GROUP BY
    p.id, p.num, p.description, o.start_qty, ti.qty_for_destruc_dec_31
HAVING
      COALESCE(start_qty, 0)
    + COALESCE(qty_for_destruc_dec_31, 0)
    + COALESCE(JAN, 0)
    + COALESCE(FEB, 0)
    + COALESCE(MAR, 0)
    + COALESCE(APR, 0)
    + COALESCE(MAY, 0)
    + COALESCE(JUN, 0)
    + COALESCE(JUL, 0)
    + COALESCE(AUG, 0)
    + COALESCE(SEP, 0)
    + COALESCE(OCT, 0)
    + COALESCE(NOV, 0)
    + COALESCE(`DEC`, 0)
    <> 0
ORDER BY p.num]]>
	</queryString>
	<field name="part_num" class="java.lang.String"/>
	<field name="part_description" class="java.lang.String"/>
	<field name="start_qty" class="java.math.BigDecimal"/>
	<field name="JAN" class="java.math.BigDecimal"/>
	<field name="FEB" class="java.math.BigDecimal"/>
	<field name="MAR" class="java.math.BigDecimal"/>
	<field name="APR" class="java.math.BigDecimal"/>
	<field name="MAY" class="java.math.BigDecimal"/>
	<field name="JUN" class="java.math.BigDecimal"/>
	<field name="JUL" class="java.math.BigDecimal"/>
	<field name="AUG" class="java.math.BigDecimal"/>
	<field name="SEP" class="java.math.BigDecimal"/>
	<field name="OCT" class="java.math.BigDecimal"/>
	<field name="NOV" class="java.math.BigDecimal"/>
	<field name="DEC" class="java.math.BigDecimal"/>
	<field name="qty_for_destruc_dec_31" class="java.math.BigDecimal"/>
	<variable name="CurrentYear" class="java.lang.String">
		<variableExpression><![CDATA[new java.text.SimpleDateFormat("yyyy").format(new java.util.Date())]]></variableExpression>
		<initialValueExpression><![CDATA["" + (new java.util.Date().getYear() + 1900)]]></initialValueExpression>
	</variable>
	<variable name="FirstHalfTotal" class="java.math.BigDecimal">
		<variableExpression><![CDATA[$F{JAN}.add($F{FEB}).add($F{MAR}).add($F{APR}).add($F{MAY}).add($F{JUN})]]></variableExpression>
	</variable>
	<variable name="SecondHalfTotal" class="java.math.BigDecimal">
		<variableExpression><![CDATA[$F{JUL}.add($F{AUG}).add($F{SEP}).add($F{OCT}).add($F{NOV}).add($F{DEC})]]></variableExpression>
	</variable>
