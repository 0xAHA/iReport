	</parameter>
	<parameter name="Count" class="java.lang.Integer" isForPrompting="false">
		<defaultValueExpression><![CDATA[90]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT part.NUM, part.DESCRIPTION, vendorparts.vendorpartnumber, vendor.name as Vendor, uom.name As UOM

FROM part

    INNER JOIN vendorparts ON part.id = vendorparts.partid and vendorparts.defaultflag = true
    INNER JOIN uom ON vendorparts.uomid = uom.id
    INNER JOIN vendor ON vendorparts.vendorid = vendor.id


WHERE part.id > 0
  AND part.activeflag = 1
  AND part.num LIKE $P{partNum}
  AND vendorparts.vendorid LIKE $P{vendorID}

ORDER BY part.num

LIMIT $P!{Count}
OFFSET $P!{Skip}]]>
	</queryString>
