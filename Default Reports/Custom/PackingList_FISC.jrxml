	</parameter>
	<queryString>
		<![CDATA[SELECT
    SHIP.ID AS SHIPID,
    SHIP.ORDERTYPEID AS ORDERTYPE,
    SHIP.DATESHIPPED AS DATESHIPPED,
    CustomFieldById(so.CustomFields,39) AS TRANSTEMP,
    CustomFieldById(so.CustomFields,40) AS COUNTRYREQ,
    CustomFieldById(so.CustomFields,41) AS COUNTRIES,
    CustomFieldById(customer.CustomFields,47) AS SEALNUM,
    carrier.name AS CARRIERNAME,
    so.datefirstship as sodatefirstship

FROM
    ship
    LEFT JOIN so ON ship.soid = so.id
    LEFT JOIN carrier ON so.carrierid = carrier.id
    LEFT JOIN customer ON so.customerid = customer.id

WHERE ship.id = $P{shipID}]]>
	</queryString>
	<field name="SHIPID" class="java.lang.Integer"/>
	<field name="ORDERTYPE" class="java.lang.Integer"/>
	<field name="COUNTRYREQ" class="java.lang.String"/>
	<field name="TRANSTEMP" class="java.lang.String"/>
	<field name="COUNTRIES" class="java.lang.String"/>
	<field name="DATESHIPPED" class="java.sql.Timestamp"/>
	<field name="CARRIERNAME" class="java.lang.String"/>
	<field name="sodatefirstship" class="java.util.Date"/>
	<field name="SEALNUM" class="java.lang.String"/>
	<group name="SOPackingList">
		<groupExpression><![CDATA[new Integer(1)]]></groupExpression>
		<groupHeader>
			<band height="50" splitType="Stretch">
				<printWhenExpression><![CDATA[new Boolean($F{ORDERTYPE}.intValue() == 20)]]></printWhenExpression>
				<subreport isUsingCache="true" runToBottom="false">
					<reportElement key="subreport-5" mode="Opaque" x="0" y="0" width="535" height="50" forecolor="#000000" backcolor="#FFFFFF" uuid="fba8ca5d-4b1b-4c9a-a7be-5203ad229af0">
						<printWhenExpression><![CDATA[new Boolean($F{ORDERTYPE}.intValue() == 20)]]></printWhenExpression>
					</reportElement>
					<parametersMapExpression><![CDATA[$P{REPORT_PARAMETERS_MAP}]]></parametersMapExpression>
					<subreportParameter name="shipID">
						<subreportParameterExpression><![CDATA[$F{SHIPID}.toString()]]></subreportParameterExpression>
					</subreportParameter>
