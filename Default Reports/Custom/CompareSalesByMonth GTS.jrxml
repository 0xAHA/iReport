	</parameter>
	<queryString>
		<![CDATA[SELECT
    customer.name AS CUSTOMER,
    product.num AS PRODUCTNUM,
    product.description,
    merged.price,

    producttree.id AS ProductTreeID,
    producttree.name AS ProductTreeName,
    producttree.description AS PRODUCTTREEDESCRIPTION,

    COALESCE(SUM(CASE WHEN merged.period = 'last' THEN merged.qty ELSE 0 END), 0) AS LastMonthQty,

    CASE WHEN COALESCE(SUM(CASE WHEN merged.period = 'last' THEN merged.qty ELSE 0 END), 0) > 0
     THEN COALESCE(merged.price, 0) ELSE 0 END AS LastMonthPrice,

    COALESCE(SUM(CASE WHEN merged.period = 'last' THEN merged.total ELSE 0 END), 0) AS LastMonthTotal,

    COALESCE(SUM(CASE WHEN merged.period = 'this' THEN merged.qty ELSE 0 END), 0) AS ThisMonthQty,

    CASE WHEN COALESCE(SUM(CASE WHEN merged.period = 'this' THEN merged.qty ELSE 0 END), 0) > 0
     THEN COALESCE(merged.price, 0) ELSE 0 END AS ThisMonthPrice,

    COALESCE(SUM(CASE WHEN merged.period = 'this' THEN merged.total ELSE 0 END), 0) AS ThisMonthTotal,

    COALESCE(currency.symbol, '$') AS Currency,
    company.name AS COMPANY

FROM (
    -- Last month sales
    SELECT
        so.customerId,
        soitem.productId,
        ROUND((soitem.unitprice + (soitem.adjustamount / NULLIF(soitem.qtyToFulfill, 0))), 2) AS price,
        SUM((qty * COALESCE(uomconversion.multiply,1))/COALESCE(uomconversion.factor,1)) AS qty,
        SUM(qty * (soitem.unitprice + (soitem.adjustamount / NULLIF(soitem.qtyToFulfill, 0)))) AS total,
        'last' AS period
    FROM (
        -- Posted
        SELECT
            soitem.id AS soitemId,
            soitem.soId,
            soitem.productId,
            soitem.unitprice,
            soitem.adjustamount,
            soitem.qtyToFulfill,
            soitem.typeId,
            soitem.uomId,
            postsoitem.qty AS qty
        FROM soitem
        JOIN so ON soitem.soId = so.id
        JOIN postsoitem ON soitem.id = postsoitem.soitemId
        JOIN postso ON postsoitem.postsoId = postso.id
        WHERE postso.postdate BETWEEN $P{dateRange1LastMonth} AND $P{dateRange2LastMonth}
        AND so.locationGroupId IN ($P!{locationGroupID})

        UNION ALL

        -- Historical
        SELECT
            soitem.id AS soitemId,
            soitem.soId,
            soitem.productId,
            soitem.unitprice,
            soitem.adjustamount,
            soitem.qtyToFulfill,
            soitem.typeId,
            soitem.uomId,
            soitem.qtyOrdered AS qty
        FROM soitem
        JOIN so ON soitem.soId = so.id
        WHERE so.statusId = 95
        AND so.dateFirstShip BETWEEN $P{dateRange1LastMonth} AND $P{dateRange2LastMonth}
        AND so.locationGroupId IN ($P!{locationGroupID})
    ) AS soitem
    JOIN so ON soitem.soId = so.id
    JOIN customer ON so.customerId = customer.id
    JOIN product ON soitem.productId = product.id
    LEFT JOIN uomconversion ON soitem.uomId = uomconversion.fromuomId AND product.uomId = uomconversion.touomId
    WHERE soitem.typeId IN (10,11,12,21,30,31,40,50,60,70,80)
    AND customer.id LIKE '$P!{customerID}'
    AND product.num LIKE $P{productNum}
    GROUP BY so.customerId, soitem.productId, ROUND((soitem.unitprice + (soitem.adjustamount / NULLIF(soitem.qtyToFulfill, 0))), 2)

    UNION ALL

    -- This month sales
    SELECT
        so.customerId,
        soitem.productId,
        ROUND((soitem.unitprice + (soitem.adjustamount / NULLIF(soitem.qtyToFulfill, 0))), 2) AS price,
        SUM((qty * COALESCE(uomconversion.multiply,1))/COALESCE(uomconversion.factor,1)) AS qty,
        SUM(qty * (soitem.unitprice + (soitem.adjustamount / NULLIF(soitem.qtyToFulfill, 0)))) AS total,
        'this' AS period
    FROM (
        -- Posted
        SELECT
            soitem.id AS soitemId,
            soitem.soId,
            soitem.productId,
            soitem.unitprice,
            soitem.adjustamount,
            soitem.qtyToFulfill,
            soitem.typeId,
            soitem.uomId,
            postsoitem.qty AS qty
        FROM soitem
        JOIN so ON soitem.soId = so.id
        JOIN postsoitem ON soitem.id = postsoitem.soitemId
        JOIN postso ON postsoitem.postsoId = postso.id
        WHERE postso.postdate BETWEEN $P{dateRange1ThisMonth} AND $P{dateRange2ThisMonth}
        AND so.locationGroupId IN ($P!{locationGroupID})

        UNION ALL

        -- Historical
        SELECT
            soitem.id AS soitemId,
            soitem.soId,
            soitem.productId,
            soitem.unitprice,
            soitem.adjustamount,
            soitem.qtyToFulfill,
            soitem.typeId,
            soitem.uomId,
            soitem.qtyOrdered AS qty
        FROM soitem
        JOIN so ON soitem.soId = so.id
        WHERE so.statusId = 95
        AND so.dateFirstShip BETWEEN $P{dateRange1ThisMonth} AND $P{dateRange2ThisMonth}
        AND so.locationGroupId IN ($P!{locationGroupID})
    ) AS soitem
    JOIN so ON soitem.soId = so.id
    JOIN customer ON so.customerId = customer.id
    JOIN product ON soitem.productId = product.id
    LEFT JOIN uomconversion ON soitem.uomId = uomconversion.fromuomId AND product.uomId = uomconversion.touomId
    WHERE soitem.typeId IN (10,11,12,21,30,31,40,50,60,70,80)
    AND customer.id LIKE '$P!{customerID}'
    AND product.num LIKE $P{productNum}
    GROUP BY so.customerId, soitem.productId, ROUND((soitem.unitprice + (soitem.adjustamount / NULLIF(soitem.qtyToFulfill, 0))), 2)
) AS merged
JOIN customer ON customer.id = merged.customerId
JOIN product ON product.id = merged.productId

JOIN producttotree ON product.id = producttotree.productid
JOIN producttree ON producttotree.producttreeid = producttree.id

LEFT JOIN company ON 1=1
LEFT JOIN currency ON currency.homeCurrency = 1
WHERE IF($P{ShowProductsWithNoSales}, 1=1, merged.qty > 0)

AND (
    COALESCE(producttreeid, 0) IN ($P!{productTree1})
    OR COALESCE(producttreeid, 0) LIKE $P{productTree2}
)




GROUP BY customer.name, product.num, product.description, merged.price, company.name, currency.symbol
ORDER BY customer.name, product.num, merged.price;]]>
	</queryString>
