	<variable name="ThisMonthProduct_Sum" class="java.lang.Double" resetType="Group" resetGroup="ProductGroup" calculation="Sum">
		<variableExpression><![CDATA[($F{ThisMonthPrice} == null || $F{ThisMonthQty} == null || $F{ThisMonthQty} == 0) ? 0 : ($F{ThisMonthPrice} * $F{ThisMonthQty})]]></variableExpression>
	</variable>
	<variable name="LastMonthCustomer_Sum" class="java.lang.Double" resetType="Group" resetGroup="CustomerGroup" calculation="Sum">
		<variableExpression><![CDATA[($F{LastMonthPrice} == null || $F{LastMonthQty} == null || $F{LastMonthQty} == 0) ? 0 : ($F{LastMonthPrice} * $F{LastMonthQty})]]></variableExpression>
	</variable>
	<variable name="ThisMonthCustomer_Sum" class="java.lang.Double" resetType="Group" resetGroup="CustomerGroup" calculation="Sum">
		<variableExpression><![CDATA[($F{ThisMonthPrice} == null || $F{ThisMonthQty} == null || $F{ThisMonthQty} == 0) ? 0 : ($F{ThisMonthPrice} * $F{ThisMonthQty})]]></variableExpression>
	</variable>
	<variable name="ThisMonthQtySum" class="java.lang.Double" resetType="Group" resetGroup="ProductGroup" calculation="Sum">
		<variableExpression><![CDATA[$F{ThisMonthQty}]]></variableExpression>
	</variable>
