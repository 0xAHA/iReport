	</parameter>
	<queryString>
		<![CDATA[SELECT
    SO.NUM AS SONUM,
    CUSTOMER.NAME AS CUSTOMER,
    SO.CUSTOMERPO,
    SO.SALESMAN,
    SO.DATECREATED,
    (SOITEM.UNITPRICE * SOITEM.QTYTOFULFILL) + SOITEM.ADJUSTAMOUNT AS ORDEREDPRICE,
    SOITEM.TOTALCOST,
    SOITEM.TOTALPRICE,
    SOITEM.PRODUCTNUM,
    CASE
        WHEN SOITEM.TOTALPRICE > 0
        THEN ((SOITEM.TOTALPRICE - SOITEM.TOTALCOST) / SOITEM.TOTALPRICE) * 100
        ELSE 0
    END AS MARGINPCT

FROM
    SO
    INNER JOIN LOCATIONGROUP ON LOCATIONGROUP.ID = SO.LOCATIONGROUPID
    INNER JOIN CUSTOMER ON CUSTOMER.ID = SO.CUSTOMERID
    INNER JOIN SOSTATUS ON SOSTATUS.ID = SO.STATUSID
    INNER JOIN SOITEM ON SOITEM.SOID = SO.ID
    INNER JOIN SOITEMSTATUS ON SOITEM.STATUSID = SOITEMSTATUS.ID

WHERE
    SO.STATUSID NOT IN (90, 80)
    AND SOITEM.TYPEID NOT IN (90, 40)
    AND ($P{ShowFreightItems} = true OR SOITEM.TYPEID != 60)
    AND SO.LOCATIONGROUPID IN ($P!{locationGroupID})
    AND SO.CUSTOMERID LIKE $P{customerID}
    AND UPPER(SO.SALESMAN) LIKE UPPER($P{salesPerson})
    AND DATE(SO.DATECREATED) BETWEEN $P{dateRange1} AND $P{dateRange2}

ORDER BY
    SO.SALESMAN, SO.NUM, SO.DATECREATED]]>
	</queryString>
