	<import value="net.sf.jasperreports.engine.data.*"/>
	<style name="header" fontName="Open Sans" fontSize="12" isBold="true"/>
	<style name="body" isDefault="true" fontName="Open Sans" fontSize="10"/>
	<style name="column_head" fontName="Open Sans" fontSize="9" isBold="true"/>
	<parameter name="REPORTDESCRIPTION" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["Multi-Pick Inventory Report showing all started picks with availability"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    pick.num AS picknum,
    part.num AS partnum,
    part.description AS partdesc,
    location.name AS locationname,
    pickitemstatus.name AS pickitemstatus,
    pickitem.qty AS pickitemqty,
    COALESCE((SELECT SUM(tag.qty)
              FROM tag
              WHERE tag.locationid = pickitem.srclocationid
              AND tag.partid = pickitem.partid), 0) AS soh,
    COALESCE((SELECT SUM(pi2.qty)
              FROM pickitem pi2
              WHERE pi2.srclocationid = pickitem.srclocationid
              AND pi2.partid = pickitem.partid
              AND pi2.statusid IN (30, 40)), 0) AS committed,
    (COALESCE((SELECT SUM(tag.qty)
               FROM tag
               WHERE tag.locationid = pickitem.srclocationid
               AND tag.partid = pickitem.partid), 0) -
     COALESCE((SELECT SUM(pi2.qty)
               FROM pickitem pi2
               WHERE pi2.srclocationid = pickitem.srclocationid
               AND pi2.partid = pickitem.partid
               AND pi2.statusid IN (30, 40)), 0)) AS available
FROM pick
INNER JOIN pickitem ON pick.id = pickitem.pickid
INNER JOIN part ON pickitem.partid = part.id
INNER JOIN location ON pickitem.srclocationid = location.id
INNER JOIN pickitemstatus ON pickitem.statusid = pickitemstatus.id
LEFT JOIN ship ON ship.soid = pickitem.orderid
WHERE pick.statusid IN (20, 30, 40)
AND (pickitem.statusid IN (20, 30) OR (pickitem.statusid = 40 AND ship.statusid = 10))
ORDER BY part.num, location.name, pick.num]]>
	</queryString>
	<field name="picknum" class="java.lang.String"/>
	<field name="partnum" class="java.lang.String"/>
	<field name="partdesc" class="java.lang.String"/>
	<field name="locationname" class="java.lang.String"/>
	<field name="pickitemstatus" class="java.lang.String"/>
	<field name="pickitemqty" class="java.math.BigDecimal"/>
	<field name="soh" class="java.math.BigDecimal"/>
	<field name="committed" class="java.math.BigDecimal"/>
	<field name="available" class="java.math.BigDecimal"/>
