		<variable name="PartInfo" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[(($F{KITPARENTLINE} == null)
	? ""
	: "     ")
+ ((($F{PRODUCTNUM} == null) || ($F{PRODUCTNUM}.length() < 1))
	? ""
	: (($F{CUSTOMERPARTNUM} == null) || ($F{CUSTOMERPARTNUM}.length() < 1))
		? $F{PRODUCTNUM}
		: $F{PRODUCTNUM} + " (" + $F{CUSTOMERPARTNUM} + ")")
+ ((($F{PRODUCTNUM} == null) || ($F{PRODUCTNUM}.length() < 1) || ($F{PRODUCTDESCRIPTION}.length() < 1) || ($F{PRODUCTDESCRIPTION}.length() < 1))
	? ""
	: " - ")
+ ((($F{PRODUCTDESCRIPTION}.length() < 1) || ($F{PRODUCTDESCRIPTION}.length() < 1))
	? ""
	: $F{PRODUCTDESCRIPTION})]]></variableExpression>
		</variable>
		<variable name="QtyDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_QTY")]]></variableExpression>
		</variable>
		<variable name="QtyOrdered" class="java.lang.Double">
			<variableExpression><![CDATA[($F{QTYTOFULFILL} == null) ? new Double(0) : $F{QTYTOFULFILL}]]></variableExpression>
		</variable>
		<variable name="extendedPrice" class="java.lang.Double">
			<variableExpression><![CDATA[($F{SOITEMTYPEID}== 30 || $F{SOITEMTYPEID}== 40) ?
    com.evnt.eve.modules.ReportHelperModule.getRoundedMoneyValue($F{TOTALPRICE}, true) :
    com.evnt.eve.modules.ReportHelperModule.getRoundedMoneyValue($F{UNITCOST} * $F{QTYTOFULFILL}, true)]]></variableExpression>
		</variable>
		<variable name="TrackingInfo" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[((($P{module} == null) || ($F{SHIPITEMID} == null)) ? "" : ((com.evnt.eve.modules.ReportHelperModule) $P{module}).getAllShipItemTrackingInfo("ShipItem", $F{SHIPITEMID}.toString()))]]></variableExpression>
		</variable>
		<variable name="PriceDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_PRICE")]]></variableExpression>
		</variable>
		<variable name="CostDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_COST")]]></variableExpression>
		</variable>
		<variable name="TotalsDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_TOTAL")]]></variableExpression>
		</variable>
		<variable name="CanDisplaySymbol" class="java.lang.Boolean">
			<variableExpression><![CDATA[$F{SYMBOL} == null || $F{SYMBOL}.equals("") || new java.awt.Font("Open Sans", java.awt.Font.PLAIN ,1).canDisplay(com.fbi.sdk.constants.setup.CurrencySymbolConst.getConstant($F{SYMBOL}).getSymbol().charAt(0))]]></variableExpression>
			<initialValueExpression><![CDATA[true]]></initialValueExpression>
		</variable>
		<variable name="isMultiCurrency" class="java.lang.Boolean">
			<variableExpression><![CDATA[com.evnt.eve.modules.CurrencyModule.isMultiCurrency()]]></variableExpression>
		</variable>
		<variable name="Line" class="java.lang.Integer" incrementType="Group" incrementGroup="ITEMID">
			<variableExpression><![CDATA[$F{SOITEMTYPEID} == 80 ?
$V{Line} : $V{Line} + 1]]></variableExpression>
			<initialValueExpression><![CDATA[0]]></initialValueExpression>
		</variable>
		<variable name="TotalQty" class="java.lang.Double" calculation="Sum">
			<variableExpression><![CDATA[$F{QTYTOFULFILL}]]></variableExpression>
		</variable>
		<group name="ITEMID">
			<groupExpression><![CDATA[$F{SHIPITEMID}]]></groupExpression>
		</group>
	</subDataset>
