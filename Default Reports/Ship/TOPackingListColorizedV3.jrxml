			<property name="Tab" value="Field Titles"/>
			<property name="Group" value="Items"/>
			<property name="Sort" value="1"/>
			<parameterDescription><![CDATA[Qty Shipped]]></parameterDescription>
		</parameter>
		<parameter name="FieldTitle:QtyRemaining" class="java.lang.String" isForPrompting="false">
			<property name="Tab" value="Field Titles"/>
			<property name="Group" value="Items"/>
			<property name="Sort" value="2"/>
			<parameterDescription><![CDATA[Qty Remaining]]></parameterDescription>
		</parameter>
		<parameter name="Description" class="java.lang.Boolean" isForPrompting="false">
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="PartNumber" class="java.lang.Boolean" isForPrompting="false">
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="QtyOrdered" class="java.lang.Boolean" isForPrompting="false">
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="QtyShipped" class="java.lang.Boolean" isForPrompting="false">
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="QtyRemaining" class="java.lang.Boolean" isForPrompting="false">
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="LineNumber" class="java.lang.Boolean" isForPrompting="false">
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="ShowTotalQty" class="java.lang.Boolean" isForPrompting="false">
			<property name="Group" value="Totals"/>
			<property name="Tooltip" value="Choose to show the sum of the qty ordered column by checking this box"/>
			<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
		</parameter>
		<parameter name="PartNumDescription" class="java.lang.Boolean" isForPrompting="false">
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT SHIPITEM.ID AS SHIPITEMID,
       XOITEM.LINEITEM AS XOLINEITEM,
       PART.NUM AS PARTNUM,
       PART.DESCRIPTION AS PARTDESCRIPTION,
       XOITEM.NOTE AS NOTE,
       COALESCE(XOITEM.QTYTOFULFILL, 0) AS QTYTOFULFILL,
       COALESCE(XOITEM.QTYFULFILLED, 0) AS QTYFULFILLED,
       COALESCE(XOITEM.QTYPICKED, 0) AS QTYPICKED,
       UOM.CODE AS UOMCODE,
       COMPANY.NAME AS COMPANYNAME,
       PART.TRACKINGFLAG AS HASTRACKING,
       COALESCE(SUM(IF(SHIPITEM.SHIPID = $P!{ShipID}, SHIPITEM.QTYSHIPPED, 0)), 0) AS QTYSHIPPED

FROM xoitem
     INNER JOIN uom ON xoitem.uomid = uom.id
     INNER JOIN part ON xoitem.partid = part.id
     LEFT OUTER JOIN shipitem ON shipitem.shipID = $P{ShipID} AND shipitem.xoItemId = xoitem.id
     INNER JOIN company ON company.id = 1

WHERE part.typeid IN (10,21,22,30,40,50)
  AND xoitem.typeid = 10
  AND xoitem.xoid = $P{XOID}
  AND shipitem.shipID = $P{ShipID}

GROUP BY xoitem.id

ORDER BY xoitem.lineitem]]>
		</queryString>
		<field name="SHIPITEMID" class="java.lang.String"/>
		<field name="XOLINEITEM" class="java.lang.Integer"/>
		<field name="PARTNUM" class="java.lang.String"/>
		<field name="PARTDESCRIPTION" class="java.lang.String"/>
		<field name="NOTE" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="QTYTOFULFILL" class="java.lang.Double">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="QTYFULFILLED" class="java.lang.Double">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="QTYPICKED" class="java.lang.Double">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="UOMCODE" class="java.lang.String"/>
		<field name="COMPANYNAME" class="java.lang.String"/>
		<field name="HASTRACKING" class="java.lang.Integer"/>
		<field name="QTYSHIPPED" class="java.lang.Double">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<variable name="PartInfo" class="java.lang.String">
			<variableExpression><![CDATA[$F{PARTNUM}]]></variableExpression>
		</variable>
		<variable name="QtyRemaining" class="java.lang.Double">
			<variableExpression><![CDATA[new Double($F{QTYTOFULFILL}.doubleValue() - $F{QTYPICKED}.doubleValue())]]></variableExpression>
		</variable>
		<variable name="TrackingInfo" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[(($P{module} == null || $F{SHIPITEMID} == null || $F{HASTRACKING} != 1)
    ? ""
    : ((com.evnt.eve.modules.ReportHelperModule) $P{module}).getAllShipItemTrackingInfo("ShipItem", $F{SHIPITEMID}).replaceAll("    ","\n"))]]></variableExpression>
			<initialValueExpression><![CDATA[]]></initialValueExpression>
		</variable>
		<variable name="CountCustParts" class="java.lang.Integer" calculation="Sum">
			<variableExpression><![CDATA[(($F{PARTNUM} == null) || ($F{PARTNUM}.length() < 1)) ? new Integer(0) : new Integer(1)]]></variableExpression>
		</variable>
		<variable name="PriceDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_PRICE")]]></variableExpression>
		</variable>
		<variable name="QtyDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_QTY")]]></variableExpression>
		</variable>
		<variable name="CostDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_COST")]]></variableExpression>
		</variable>
		<variable name="TotalQtyOrdered" class="java.lang.Integer" calculation="Sum">
			<variableExpression><![CDATA[$F{QTYTOFULFILL}]]></variableExpression>
		</variable>
		<variable name="TotalQtyShipped" class="java.lang.Integer" calculation="Sum">
			<variableExpression><![CDATA[$F{QTYSHIPPED}]]></variableExpression>
		</variable>
		<variable name="TotalQtyRemaining" class="java.lang.Integer" calculation="Sum">
			<variableExpression><![CDATA[new Double($F{QTYTOFULFILL}.doubleValue() - $F{QTYPICKED}.doubleValue())]]></variableExpression>
		</variable>
	</subDataset>
