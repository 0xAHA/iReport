	<queryString>
		<![CDATA[SELECT
    PO.ID AS POID,
    PO.LOCATIONGROUPID AS LOCATIONGROUPID,
    SHIP.ID AS SHIPID,
    SHIP.STATUSID AS SHIPSTATUS,
    SHIP.NOTE AS MEMO,
    PO.VENDORSO AS SALESORDERNUMBER,
    COALESCE(SHIP.DATESHIPPED, CURRENT_DATE) AS SHIPDATE,
    SHIP.SHIPTONAME AS SHIPTONAME,
    SHIP.SHIPTOADDRESS AS SHIPTOADDRESS,
    SHIP.SHIPTOCITY AS SHIPTOCITY,
    SHIPSTATE.CODE AS SHIPTOSTATE,
    SHIP.SHIPTOZIP AS SHIPTOZIP,
    PO.REMITTONAME AS BILLTONAME,
    PO.REMITADDRESS AS BILLTOADDRESS,
    PO.REMITCITY AS BILLTOCITY,
    BILLSTATE.CODE AS BILLTOSTATE,
    PO.REMITZIP AS BILLTOZIP,
    SHIP.CARTONCOUNT AS CARTONCOUNT,
    PO.DATEFIRSTSHIP AS REGSHIPDATE,
    FOBPOINT.NAME AS FOBPOINT,
    SHIPTERMS.NAME AS SHIPPINGTERMS,
    CARRIER.NAME AS CARRIERNAME,
    PO.NUM AS PONUM,
    SHIPCOUNTRY.NAME AS SHIPCOUNTRY,
    BILLCOUNTRY.NAME AS BILLCOUNTRY,
    SHIP.NUM AS SHIPNUM,
    COMPANY.NAME AS COMPANY,
    (SELECT S1.SYSVALUE FROM SYSPROPERTIES S1 WHERE S1.SYSKEY = 'Barcodes have DI') AS BARCODESHAVEDI,
    SHIP.NOTE AS NOTE,
    carrierservice.name AS carrierservice,
po.phone AS poPhone

FROM
    ship
    INNER JOIN carrier ON ship.carrierid = carrier.id
    INNER JOIN po ON ship.poId = po.id
    INNER JOIN fobpoint ON po.fobpointid = fobpoint.id
    INNER JOIN shipterms ON po.shiptermsid = shipterms.id
    LEFT OUTER JOIN stateconst shipState ON ship.shiptostateid = shipState.id
    LEFT OUTER JOIN stateconst billState ON po.remitstateid = billState.id
    LEFT OUTER JOIN countryconst shipCountry ON ship.shiptocountryid = shipCountry.id
    LEFT OUTER JOIN countryconst billCountry ON po.remitcountryid = billCountry.id
    INNER JOIN company ON company.id = 1
    LEFT JOIN carrierservice ON ship.carrierserviceid = carrierservice.id

WHERE
    ship.ordertypeid = 10
    AND ship.id = $P{shipID}]]>
	</queryString>
	<field name="POID" class="java.lang.Integer"/>
	<field name="LOCATIONGROUPID" class="java.lang.Integer"/>
	<field name="SHIPID" class="java.lang.Integer"/>
	<field name="SHIPSTATUS" class="java.lang.Integer"/>
	<field name="MEMO" class="java.lang.String"/>
	<field name="SALESORDERNUMBER" class="java.lang.String"/>
	<field name="SHIPDATE" class="java.sql.Timestamp"/>
	<field name="SHIPTONAME" class="java.lang.String"/>
	<field name="SHIPTOADDRESS" class="java.lang.String"/>
	<field name="SHIPTOCITY" class="java.lang.String"/>
	<field name="SHIPTOSTATE" class="java.lang.String"/>
	<field name="SHIPTOZIP" class="java.lang.String"/>
	<field name="BILLTONAME" class="java.lang.String"/>
	<field name="BILLTOADDRESS" class="java.lang.String"/>
	<field name="BILLTOCITY" class="java.lang.String"/>
	<field name="BILLTOSTATE" class="java.lang.String"/>
	<field name="BILLTOZIP" class="java.lang.String"/>
	<field name="CARTONCOUNT" class="java.lang.Integer"/>
	<field name="REGSHIPDATE" class="java.sql.Timestamp"/>
	<field name="FOBPOINT" class="java.lang.String"/>
	<field name="SHIPPINGTERMS" class="java.lang.String"/>
	<field name="CARRIERNAME" class="java.lang.String"/>
	<field name="PONUM" class="java.lang.String"/>
	<field name="SHIPCOUNTRY" class="java.lang.String"/>
	<field name="BILLCOUNTRY" class="java.lang.String"/>
	<field name="SHIPNUM" class="java.lang.String"/>
	<field name="COMPANY" class="java.lang.String"/>
	<field name="BARCODESHAVEDI" class="java.lang.String"/>
	<field name="NOTE" class="java.lang.String"/>
	<field name="carrierservice" class="java.lang.String"/>
	<field name="poPhone" class="java.lang.String"/>
	<variable name="DateFormat" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[(System.getProperty("REPORT_DATE_FORMAT"))]]></variableExpression>
	</variable>
	<variable name="ORDERNUMBER" class="java.lang.String">
		<variableExpression><![CDATA[$F{BARCODESHAVEDI} == null ? $V{PREORDERNUMBER} :
	$F{BARCODESHAVEDI}.equals("true") && !$P{ShowUniqueShipNumbers} ? "P" + $V{PREORDERNUMBER} : $V{PREORDERNUMBER}]]></variableExpression>
	</variable>
	<variable name="PREORDERNUMBER" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[$P{ShowUniqueShipNumbers} ?
    $F{SHIPNUM} :
    (($F{SALESORDERNUMBER} == null || $F{SALESORDERNUMBER}.length() < 1) ?
        $F{PONUM} :
        $F{SALESORDERNUMBER})]]></variableExpression>
	</variable>
