($P{ckShowCountry}.equals("1") ? ($F{SHIPCOUNTRY} == null ? "" : "\n" + $F{SHIPCOUNTRY}) : "") +
($V{CustomerPO}.equals("") ? "" : "\n" + "\n" + $V{CustomerPO})]]></textFieldExpression>
