			<property name="Group" value="Carton Fields"/>
			<property name="Sort" value="4"/>
			<parameterDescription><![CDATA[L x W x H]]></parameterDescription>
		</parameter>
		<parameter name="ckShowBackOrderItems" class="java.lang.String" isForPrompting="false">
			<parameterDescription><![CDATA[100,101]]></parameterDescription>
			<defaultValueExpression><![CDATA["100"]]></defaultValueExpression>
		</parameter>
		<parameter name="ckShowKitHeaders" class="java.lang.String" isForPrompting="false">
			<parameterDescription><![CDATA[80,90]]></parameterDescription>
			<defaultValueExpression><![CDATA["80"]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT
    GROUP_CONCAT(SHIPITEM.ID) AS SHIPITEMID,
    SOITEM.SOLINEITEM AS SOLINEITEM,
    SOITEM.PRODUCTNUM AS PRODUCTNUM,
    SOITEM.CUSTOMERPARTNUM AS CUSTPARTNUM,
    SOITEM.DESCRIPTION AS PRODUCTDESCRIPTION,
    SOITEM.NOTE AS NOTE,
    COALESCE(SOITEM.QTYTOFULFILL, 0) AS QTYTOFULFILL,
    COALESCE(SOITEM.QTYFULFILLED, 0) AS QTYFULFILLED,
    COALESCE(SOITEM.QTYPICKED, 0) AS QTYPICKED,
    COMPANY.NAME AS COMPANYNAME,
    SHIPCARTON.ID AS SHIPCARTONID,
    SHIPCARTON.TRACKINGNUM AS TRACKINGNUMBER,
    SHIPCARTON.FREIGHTWEIGHT AS CARTONWEIGHT,
    SHIPCARTON.ID AS CARTONID,
    SHIPCARTON.CARTONNUM AS CARTONNUMBER,
    UOM.CODE AS UOMCODE,
    PRODUCT.WEIGHT AS PRODUCTWEIGHT,
    PART.TRACKINGFLAG AS HASTRACKING,
    COALESCE((
            SELECT
                SUM(SHIPITEM.QTYSHIPPED)
            FROM
                SHIPITEM
            WHERE
                SHIPITEM.SHIPID = $P{ShipID}
                AND SHIPITEM.SOITEMID = SOITEM.ID
                AND SHIPITEM.SHIPCARTONID = SHIPCARTON.ID
        ), 0
    ) AS QTYSHIPPED,
    COALESCE(WEIGHTUOM.CODE, 'lbs') AS WEIGHTUOM,
    SOITEM.UNITPRICE AS UNITPRICE,
    HOMECURRENCY.SYMBOL AS HOMECURRENCYSYMBOL,
    carrier.name AS CARRIERNAME,
    $P!{CustomField:Item1} AS itemcf1,
    $P!{CustomField:Item2} AS itemcf2,
    $P!{CustomField:Item3} AS itemcf3,
    COALESCE(SHIPCARTON.LEN,0) AS LEN,
    COALESCE(SHIPCARTON.WIDTH,0) AS WIDTH,
    COALESCE(SHIPCARTON.HEIGHT,0) AS HEIGHT,
    COALESCE(SHIPCARTON.SIZEUOM,'') AS UOM,
OBO.RECORDID2 AS KITPARENTLINE

FROM
    soitem
    LEFT OUTER JOIN uom ON soitem.uomid = uom.id
    LEFT OUTER JOIN product ON soitem.productid = product.id
    LEFT OUTER JOIN part ON product.partid = part.id
    LEFT OUTER JOIN shipitem ON shipitem.shipID = $P{ShipID} AND shipitem.soItemId = soitem.id
    LEFT OUTER JOIN shipcarton ON  shipitem.shipcartonid = shipcarton.id
    LEFT OUTER JOIN sysProperties ON sysProperties.sysKey = 'Default Weight UomId'
    LEFT OUTER JOIN uom weightUom ON sysProperties.sysValue = weightUom.id
    LEFT OUTER JOIN currency AS homeCurrency ON homeCurrency.homeCurrency = 1
    INNER JOIN company ON company.id = 1
    LEFT OUTER JOIN carrier ON shipcarton.carrierid = carrier.id
    LEFT JOIN objecttoobject AS obo ON obo.recordid1 = soitem.id AND obo.typeid = 30 AND obo.tableid1  = 1002104832

WHERE soitem.soid = $P!{SOID}
   AND (
      shipitem.shipID = $P!{ShipID}
      OR (CASE WHEN $P!{ckShowKitHeaders} = 80 THEN soItem.typeid = 80 AND shipitem.shipid IS NULL ELSE FALSE END)
   )
   AND soitem.typeid IN (10,30,40,50,60,$P!{ckShowKitHeaders})
   AND (
      part.typeid IN (10,21,22,30,40,50)
   )


GROUP BY shipcarton.id, soitem.id

ORDER BY
    shipcarton.id, soitem.solineitem]]>
		</queryString>
		<field name="SHIPITEMID" class="java.lang.String"/>
		<field name="SOLINEITEM" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="PRODUCTNUM" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="CUSTPARTNUM" class="java.lang.String"/>
		<field name="PRODUCTDESCRIPTION" class="java.lang.String"/>
		<field name="NOTE" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="QTYTOFULFILL" class="java.lang.Double">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="QTYFULFILLED" class="java.lang.Double">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="QTYPICKED" class="java.lang.Double">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="COMPANYNAME" class="java.lang.String"/>
		<field name="SHIPCARTONID" class="java.lang.Integer"/>
		<field name="TRACKINGNUMBER" class="java.lang.String"/>
		<field name="CARTONWEIGHT" class="java.lang.Double"/>
		<field name="CARTONID" class="java.lang.Integer"/>
		<field name="CARTONNUMBER" class="java.lang.Integer"/>
		<field name="UOMCODE" class="java.lang.String"/>
		<field name="PRODUCTWEIGHT" class="java.lang.Double"/>
		<field name="HASTRACKING" class="java.lang.Boolean"/>
		<field name="QTYSHIPPED" class="java.lang.Double">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="WEIGHTUOM" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="UNITPRICE" class="java.lang.Double">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="HOMECURRENCYSYMBOL" class="java.lang.Integer"/>
		<field name="CARRIERNAME" class="java.lang.String"/>
		<field name="itemcf1" class="java.lang.String"/>
		<field name="itemcf2" class="java.lang.String"/>
		<field name="itemcf3" class="java.lang.String"/>
		<field name="UOM" class="java.lang.String"/>
		<field name="LEN" class="java.lang.Double"/>
		<field name="WIDTH" class="java.lang.Double"/>
		<field name="HEIGHT" class="java.lang.Double"/>
		<field name="KITPARENTLINE" class="java.lang.Integer"/>
		<variable name="CountCustParts" class="java.lang.Integer" calculation="Sum">
			<variableExpression><![CDATA[(($F{CUSTPARTNUM} == null) || ($F{CUSTPARTNUM}.length() < 1)) ? new Integer(0) : new Integer(1)]]></variableExpression>
		</variable>
		<variable name="ShippingItemIDs" class="java.lang.String" resetType="Group" resetGroup="SOLineItem">
			<variableExpression><![CDATA[$F{SHIPITEMID}]]></variableExpression>
		</variable>
		<variable name="QtyRemaining" class="java.lang.Double">
			<variableExpression><![CDATA[new Double(
($P{ShipStatus}.trim().equals("30"))
	? $F{QTYTOFULFILL}.doubleValue() - $F{QTYFULFILLED}.doubleValue()
	: $F{QTYTOFULFILL}.doubleValue() - $F{QTYFULFILLED}.doubleValue() - $F{QTYPICKED}.doubleValue()
)]]></variableExpression>
		</variable>
		<variable name="PartInfo" class="java.lang.String">
			<variableExpression><![CDATA[($F{KITPARENTLINE} == null ? "" : "     ") + (
    ($F{PRODUCTNUM} == null) ? "" :
	(($F{CUSTPARTNUM} == null) || ($F{CUSTPARTNUM}.length() < 1)) ? $F{PRODUCTNUM} + "; " + $F{PRODUCTDESCRIPTION} : $F{CUSTPARTNUM} + " (" + $F{PRODUCTNUM} + "); " + $F{PRODUCTDESCRIPTION})]]></variableExpression>
		</variable>
		<variable name="totalWeight" class="java.lang.Double" calculation="Sum">
			<variableExpression><![CDATA[$F{CARTONWEIGHT}]]></variableExpression>
		</variable>
		<variable name="totalCount" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$F{SHIPCARTONID}]]></variableExpression>
		</variable>
		<variable name="TrackingInfo" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[(($P{module} == null || $V{ShippingItemIDs} == null || $F{HASTRACKING} != true)
    ? ""
    : ((com.evnt.eve.modules.ReportHelperModule) $P{module}).getAllShipItemTrackingInfo("ShipItem", $V{ShippingItemIDs}).replaceAll("    ","\n"))]]></variableExpression>
		</variable>
		<variable name="PriceDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_PRICE")]]></variableExpression>
		</variable>
		<variable name="QtyDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_QTY")]]></variableExpression>
		</variable>
		<variable name="CostDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_COST")]]></variableExpression>
		</variable>
		<variable name="isMultiCurrency" class="java.lang.Boolean">
			<variableExpression><![CDATA[com.evnt.eve.modules.CurrencyModule.isMultiCurrency()]]></variableExpression>
		</variable>
		<variable name="TotalQtyOrdered" class="java.lang.Integer" resetType="Group" resetGroup="Carton" calculation="Sum">
			<variableExpression><![CDATA[$F{SHIPITEMID} != null ? $F{QTYTOFULFILL} : null]]></variableExpression>
		</variable>
		<variable name="TotalQtyShipped" class="java.lang.Integer" resetType="Group" resetGroup="Carton" calculation="Sum">
			<variableExpression><![CDATA[$F{SHIPITEMID} != null ? $F{QTYSHIPPED} : null]]></variableExpression>
		</variable>
		<variable name="TotalQtyRemaining" class="java.lang.Integer" resetType="Group" resetGroup="Carton" calculation="Sum">
			<variableExpression><![CDATA[$F{SHIPITEMID} != null ? $V{QtyRemaining} : null]]></variableExpression>
		</variable>
		<group name="Carton" isStartNewPage="true" isReprintHeaderOnEachPage="true">
			<groupExpression><![CDATA[$F{CARTONID}]]></groupExpression>
		</group>
		<group name="New Column Header">
			<groupExpression><![CDATA[1]]></groupExpression>
		</group>
		<group name="SOLineItem" isReprintHeaderOnEachPage="true">
			<groupExpression><![CDATA[$F{SOLINEITEM}]]></groupExpression>
		</group>
	</subDataset>
