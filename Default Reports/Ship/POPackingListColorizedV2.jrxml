			<parameterDescription><![CDATA[Total Cost]]></parameterDescription>
		</parameter>
		<parameter name="FieldTitle:UnitCost" class="java.lang.String" isForPrompting="false">
			<property name="Tab" value="Field Titles"/>
			<property name="Group" value="Items"/>
			<property name="Sort" value="2"/>
			<parameterDescription><![CDATA[Unit Cost]]></parameterDescription>
		</parameter>
		<parameter name="ShowTotalQty" class="java.lang.Boolean" isForPrompting="false">
			<property name="Group" value="Totals"/>
			<property name="Tooltip" value="Choose to show the sum of the qty ordered column by checking this box"/>
			<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT
    SHIPITEM.ID AS SHIPITEMID,
    POITEM.POLINEITEM AS POLINEITEM,
    PART.NUM AS PARTNUM,
    POITEM.VENDORPARTNUM AS VENDORPARTNUM,
    PART.DESCRIPTION AS PARTDESCRIPTION,
    POITEM.NOTE AS NOTE,
    COALESCE(POITEM.QTYTOFULFILL, 0) AS QTYTOFULFILL,
    COALESCE(POITEM.QTYFULFILLED, 0) AS QTYFULFILLED,
    COALESCE(POITEM.QTYPICKED, 0) AS QTYPICKED,
    UOM.CODE AS UOMCODE,
    COMPANY.NAME AS COMPANYNAME,
    PART.TRACKINGFLAG AS HASTRACKING,
    COALESCE((
            SELECT
                SUM(SHIPITEM.QTYSHIPPED)
            FROM
                SHIPITEM
            WHERE
                SHIPITEM.SHIPID = $P{ShipID}
                AND SHIPITEM.POITEMID = POITEM.ID
        ), 0
    ) AS QTYSHIPPED,
    POITEM.TYPEID,
    POITEM.UNITCOST AS UNITCOST,
    HOMECURRENCY.SYMBOL AS HOMECURRENCYSYMBOL


FROM
    poitem
    INNER JOIN uom ON poitem.uomid = uom.id
    INNER JOIN part ON poitem.partid = part.id
    LEFT OUTER JOIN shipitem ON shipitem.shipID = $P{ShipID} AND shipitem.poItemId = poitem.id
    LEFT OUTER JOIN currency AS homeCurrency ON homeCurrency.homeCurrency = 1
    INNER JOIN company ON company.id = 1

WHERE
    part.typeid IN (10,21,22,30,40,50)
    AND poitem.typeid IN (20,30)
    AND poitem.poid = $P{POID}
    AND shipitem.shipID = $P{ShipID}

ORDER BY poitem.polineitem]]>
		</queryString>
		<field name="SHIPITEMID" class="java.lang.Integer"/>
		<field name="POLINEITEM" class="java.lang.Integer"/>
		<field name="PARTNUM" class="java.lang.String"/>
		<field name="VENDORPARTNUM" class="java.lang.String"/>
		<field name="PARTDESCRIPTION" class="java.lang.String"/>
		<field name="NOTE" class="java.lang.String"/>
		<field name="QTYTOFULFILL" class="java.lang.Double"/>
		<field name="QTYFULFILLED" class="java.lang.Double"/>
		<field name="QTYPICKED" class="java.lang.Double"/>
		<field name="UOMCODE" class="java.lang.String"/>
		<field name="COMPANYNAME" class="java.lang.String"/>
		<field name="HASTRACKING" class="java.lang.Integer"/>
		<field name="QTYSHIPPED" class="java.lang.Double"/>
		<field name="TYPEID" class="java.lang.Integer"/>
		<field name="UNITCOST" class="java.lang.Double"/>
		<field name="HOMECURRENCYSYMBOL" class="java.lang.Integer"/>
		<variable name="PriceDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_PRICE")]]></variableExpression>
		</variable>
		<variable name="QtyDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_QTY")]]></variableExpression>
		</variable>
		<variable name="CostDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_COST")]]></variableExpression>
		</variable>
		<variable name="isMultiCurrency" class="java.lang.Boolean">
			<variableExpression><![CDATA[com.evnt.eve.modules.CurrencyModule.isMultiCurrency()]]></variableExpression>
		</variable>
		<variable name="CountCustParts" class="java.lang.Integer" calculation="Sum">
			<variableExpression><![CDATA[(($F{VENDORPARTNUM} == null) || ($F{VENDORPARTNUM}.length() < 1)) ? new Integer(0) : new Integer(1)]]></variableExpression>
		</variable>
		<variable name="PartInfo" class="java.lang.String">
			<variableExpression><![CDATA[($F{PARTNUM} == null) ? "" :
	(($F{VENDORPARTNUM} == null) || ($F{VENDORPARTNUM}.length() < 1)) ? $F{PARTNUM} + "; " + $F{PARTDESCRIPTION} : $F{VENDORPARTNUM} + " (" + $F{PARTNUM} + "); " + $F{PARTDESCRIPTION}]]></variableExpression>
		</variable>
		<variable name="QtyRemaining" class="java.lang.Double">
			<variableExpression><![CDATA[new Double(
($P{ShipStatus}.trim().equals("30") && $F{TYPEID} != 30)
	? $F{QTYTOFULFILL}.doubleValue() - $F{QTYFULFILLED}.doubleValue()
	: $F{QTYTOFULFILL}.doubleValue() - $F{QTYFULFILLED}.doubleValue() - $F{QTYPICKED}.doubleValue()
)]]></variableExpression>
		</variable>
		<variable name="ShippingItemIDs" class="java.lang.String" resetType="Group" resetGroup="poLineItemGroup">
			<variableExpression><![CDATA[($V{ShippingItemIDs} == null)
	? $F{SHIPITEMID}.toString()
	: $V{ShippingItemIDs} + "," + $F{SHIPITEMID}.toString()]]></variableExpression>
		</variable>
		<variable name="TrackingInfo" class="java.lang.String" resetType="Group" resetGroup="poLineItemGroup">
			<variableExpression><![CDATA[(($P{module} == null || $V{ShippingItemIDs} == null || $F{HASTRACKING} != 1)
    ? ""
    : ((com.evnt.eve.modules.ReportHelperModule) $P{module}).getAllShipItemTrackingInfo("ShipItem", $V{ShippingItemIDs}).replaceAll("    ","\n"))]]></variableExpression>
		</variable>
		<variable name="QtyShipped" class="java.lang.Double" resetType="Group" resetGroup="poLineItemGroup">
			<variableExpression><![CDATA[$F{QTYSHIPPED}]]></variableExpression>
		</variable>
		<variable name="TotalQtyRemaining" class="java.lang.Integer" calculation="Sum">
			<variableExpression><![CDATA[$F{TYPEID} != null ? $V{QtyRemaining} : null]]></variableExpression>
		</variable>
		<variable name="TotalQtyShipped" class="java.lang.Integer" calculation="Sum">
			<variableExpression><![CDATA[$F{TYPEID} != null ? $V{QtyShipped} : null]]></variableExpression>
		</variable>
		<variable name="TotalQtyOrdered" class="java.lang.Integer" calculation="Sum">
			<variableExpression><![CDATA[$F{TYPEID} != null ? $F{QTYTOFULFILL} : null]]></variableExpression>
		</variable>
		<group name="New Column Header" isReprintHeaderOnEachPage="true">
			<groupExpression><![CDATA[1]]></groupExpression>
		</group>
		<group name="poLineItemGroup">
			<groupExpression><![CDATA[$F{POLINEITEM}]]></groupExpression>
		</group>
	</subDataset>
