		<queryString>
			<![CDATA[SELECT    COALESCE($P!{cbGroupBy},"") AS groupby,
          wo.num AS wonum,
	woitem.typeid AS itemtypeid,
	woitem.description AS woitemdescription,
	wo.datefinished,
    	SUM((woitem.qtytarget * COALESCE(uomconversion.multiply,1))/COALESCE(uomconversion.factor,1)) AS qtyneeded,
    	SUM((woitem.qtyused * COALESCE(uomconversion.multiply,1))/COALESCE(uomconversion.factor,1)) AS qtyconsumed,
    	locationgroup.name AS lgname,
	uom.code AS itemcode,
	part.num AS itemnum,
	part.description AS partdescription,
    	company.name AS company,
	moitem.bomid as itmeOnBOM

FROM 	wo
    	INNER JOIN woitem ON wo.id = woitem.woid
    	JOIN moitem on woitem.moitemid = moitem.id
   	INNER JOIN part ON woitem.partid = part.id
    	INNER JOIN uom ON part.uomid = uom.id
    	INNER JOIN locationgroup ON wo.locationgroupid = locationgroup.id
    	LEFT JOIN uomconversion ON (woitem.uomid = uomconversion.fromuomid AND part.uomid = uomconversion.touomid)
    	INNER JOIN company ON company.id = 1

WHERE 	wo.num LIKE $P{woNum}
  AND 	wo.datefinished BETWEEN $P{dateRange1} AND DATE_SUB($P{dateRange2}, INTERVAL 1 SECOND)
  AND 	wo.statusid = 40
  AND 	wo.locationgroupid IN ($P!{locationGroupID})
  AND 	woitem.typeid NOT IN (10,31)
  AND 	part.num LIKE $P{partNum}

GROUP BY 1

ORDER BY 	1]]>
		</queryString>
