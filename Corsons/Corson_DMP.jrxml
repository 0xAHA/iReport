	<parameter name="poNum" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    po.num AS poNum,
    vendor.name AS vendorName,
    part.num AS partNum,
    part.description AS partDescription,
    poItem.qty AS poQty,
    poItem.note AS poLineNote,
    CustomFieldByName(po.customfields, 'Contract #') AS ContractNum,
    CustomFieldByName(po.customfields, 'Grower') AS Grower,
    CustomFieldByName(po.customfields, 'Date') AS ContractDate,
    CustomFieldByName(po.customfields, 'Delivery Start Date') AS DeliveryStartDate,
    CustomFieldByName(po.customfields, 'Delivery End Date') AS DeliveryEndDate,
    CustomFieldByName(poItem.customfields, 'Season') AS Season,
    CustomFieldByName(poItem.customfields, 'Moisture') AS Moisture,
    CustomFieldByName(poItem.customfields, 'KG/HL') AS KGHL,
    CustomFieldByName(poItem.customfields, 'Particle size - 4.75') AS PS475,
    CustomFieldByName(poItem.customfields, 'Particle size - Broken') AS PSBroken,
    CustomFieldByName(poItem.customfields, 'Particle size - Cracked') AS PSCracked,
    CustomFieldByName(poItem.customfields, 'Particle size - Dead') AS PSDead,
    CustomFieldByName(poItem.customfields, 'Afflatoxin') AS Aflatoxin,
    CustomFieldByName(poItem.customfields, 'Infestation') AS Infestation,
    CustomFieldByName(poItem.customfields, 'Sprouted') AS Sprouted,
    CustomFieldByName(poItem.customfields, 'Impurities') AS Impurities,
    CustomFieldByName(poItem.customfields, 'Weed Seeds') AS WeedSeeds,
    CustomFieldByName(poItem.customfields, 'Transport') AS Transport,
    CustomFieldByName(poItem.customfields, 'Truck Code') AS TruckCode,
    CustomFieldByName(poItem.customfields, 'Truck Rego') AS TruckRego,
    CustomFieldByName(poItem.customfields, 'Weight Limit Type') AS WeightLimitType,
    CustomFieldByName(poItem.customfields, 'Permit No') AS PermitNo,
    CustomFieldByName(poItem.customfields, 'Gross Weight 1') AS GrossWeight1,
    CustomFieldByName(poItem.customfields, 'Tare Weight 1') AS TareWeight1,
    CustomFieldByName(poItem.customfields, 'Gross Weight 2') AS GrossWeight2,
    CustomFieldByName(poItem.customfields, 'Tare Weight 2') AS TareWeight2,
    CustomFieldByName(poItem.customfields, 'Total Gross Weight') AS TotalGrossWeight,
    CustomFieldByName(poItem.customfields, 'Total Tare Weight') AS TotalTareWeight,
    CustomFieldByName(poItem.customfields, 'Full Test') AS FullTest,
    CustomFieldByName(poItem.customfields, 'Soy') AS Soy,
    CustomFieldByName(poItem.customfields, 'Gluten') AS Gluten,
    CustomFieldByName(poItem.customfields, 'AFL') AS AFL,
    CustomFieldByName(poItem.customfields, 'Fum') AS Fum,
    receive.dateCreated AS receiveDate,
    receiveItem.qty AS receiveQty,
    location.name AS binLocation,
    CASE WHEN receiveItem.rejected = 1 THEN 'Y' ELSE 'N' END AS isRejected
FROM po
    INNER JOIN poItem ON po.id = poItem.poId
    INNER JOIN part ON poItem.partId = part.id
    INNER JOIN vendor ON po.vendorId = vendor.id
    LEFT JOIN receive ON receive.poId = po.id
    LEFT JOIN receiveItem ON receiveItem.receiveId = receive.id AND receiveItem.poItemId = poItem.id
    LEFT JOIN location ON receiveItem.locationId = location.id
WHERE po.num = $P{poNum}
LIMIT 1]]>
	</queryString>
